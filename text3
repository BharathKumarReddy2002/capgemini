	     $secret_opt[$i] =~ s/`/\\`/g;     # Escape backticks
	     $secret_opt[$i] =~ s/"/\\"/g;     # Escape double quotes
	     $secret_opt[$i] =~ s/\&/\\\&/g;
	     $secret_opt[$i] =~ s/\//\\\//g;
             `$SED -i "/auth[ ].*[ ]$tacplus_module/ s/.*/& secret=$secret_opt[$i]/" "$TACPLUS_PAM"`; #Aricent PR 777846 PR-1846890 End
         }
      }
   
       # set failover options
