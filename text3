sub daemon_get
{
  my $fn = (caller(0))[3]; fen($fn);
  no warnings 'uninitialized';
  my ( $service ) = @_;
  # Only call daemon off if BOTH it is not running AND there is no startup
  # link in /etc/rc3.d
  my $start_link = "$DAEMONS{$service}{ENABLE}";
  if ( ( -l "$start_link" ) ||
       ( `/bin/ps -C $service | grep "$service" | wc -l` !~ /\s*0/ ) ) {
    return 1;
  }
  return 0;
}

sub daemon_read
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $service ) = @_;
  if ( ! -f "$DAEMON_DIR/$service" ) { return $NO_SUCH_SERVICE; }
  if ( ! exists $DAEMONS{$service} ) { return $NO_SUCH_SERVICE; }
  my $state = daemon_get( $service );
  print STDOUT "ST$state\n";
  return $OK;
}

sub daemon_set
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $service, $string) = @_;
  my $current_state = daemon_get( $service );
  my $parse_error = 0;
  if ( $string =~ /ST(\d)/ )      { $state = $1; }
  else { $parse_error = 1; }     # Problem getting state
  # Check for string parsing errors!
  if ( $parse_error == 1 ) { daemon_useage(); }
  if ( ("$service" =~ /usb/) && ($state == 1) ) { daemon_useage(); }
  if ( ! -f "$DAEMON_DIR/$service" ) { return $NO_SUCH_SERVICE; }
  if ( ! exists $DAEMONS{$service} ) { return $NO_SUCH_SERVICE; }
  my $start_link = "$DAEMONS{$service}{ENABLE}";
  my $stop_link = "$DAEMONS{$service}{DISABLE}";
  # For service to be on, need sysv init link & daemon started
  if ( $state == 1 ) {        # Make sure service is enabled.
    if ( -l "$stop_link" ) { system( "/bin/rm", "-f", "$stop_link"); }
    if ( ! -l "$start_link" ) {
      system( "/bin/ln", "-s", "$DAEMON_DIR/$service", "$start_link");
    }
    close (STDIN); open (STDIN, " < /dev/null ");
    if( $current_state ) {
      system( "$DAEMON_DIR/$service", "restart" );
    } else {
      system( "$DAEMON_DIR/$service", "start" );
    }
    close (STDIN); open (STDIN, " < /dev/stdin");
  } else {           # Make sure service is disabled.
    if ( -l "$start_link" ) { system( "/bin/rm", "-f", "$start_link"); }
    if ( ! -l "$stop_link" ) {
      system( "/bin/ln", "-s", "$DAEMON_DIR/$service", "$stop_link");
    }
    system( "$DAEMON_DIR/$service", "stop" );
  }
  FLUSH_ETC();
  return $OK;
}

sub check_user
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $user ) = @_;
  if ($DEBUG) { print "Looking for user $user on the system.\n"; }
  my $rtn_cnt = `$GREP "^$user:" $PASSWD_FILE | wc -l`;
  if ( $rtn_cnt == 0 ) { return $NO_USER; }
  if( `/usr/bin/groups $user` =~ /acorn_priv/ ) {
    if ($DEBUG) { print "Found $user in privilged administrators.\n"; }
    return $PRIV_ADMIN;
  } 
  if( `/usr/bin/groups $user` =~ /acorn_su/ ) {
    if ($DEBUG) { print "Found $user in ctp administrators.\n"; }
    return $ADMIN;
  } 
  if( `/usr/bin/groups $user` =~ /ctp_log/ ) {
    if ($DEBUG) { print "Found $user in auditors.\n"; }
    return $CTP_LOG;
  } 
  if( `/usr/bin/groups $user` =~ /acorn/ ) {
    if ($DEBUG) { print "Found $user in read-only ctp users.\n"; }
    return $CTP_USER;
  } 
  if ($DEBUG) { print "Did not find $user in admins, auditors or users.\n"; }
  $rtn_cnt = `$GREP "^$user:" $PASSWD_FILE | wc -l`;
  if ( $rtn_cnt == 0 ) { return $NO_USER; }
  return $NON_ACORN; # user exists outside of CTP groups -- do not change user
}

