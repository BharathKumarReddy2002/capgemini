##
## Ok, so the PBS bitmask is passed to us as a character string, it's
## stored in modules.conf as a character string, and perl can't deal
## with 64-bit values...
##
## ...so why not just treat it as a character string.
##

sub pbs_cfg_read
{
  my $fn = (caller(0))[3]; fen($fn);
  my $prt = 1;
  my $hdlc_ports = "0";
  my ( $options ) = @_;
  if( defined $options) {
    if( $options =~ /no_prt/ ) { $prt = 0; }
  }
  open(READ, "< $MODULES_CONF") or exit $E_UNKNOWN;
  while (<READ>) {
    if( $_ =~ /HDLC_PORTS=([abcdef\d]+)/ ) {
      $hdlc_ports = $1;
    }
  }
  close(READ);
  if( $prt ) { printf("%s\n", $hdlc_ports); exit $OK; }
  else { return $hdlc_ports; }
}

sub pbs_cfg_cfg
{
  my $fn = (caller(0))[3]; fen($fn);
  my $restart = 1;
  my $quiet = 1;
  my $hdlc_ports = "0";
  my $tmp_file = "/tmp/foo";
  my $max_port = GetNumLocalPorts() - 1;
  my $cfgd_hdlc_ports = pbs_cfg_read( "no_prt" );
  my ( $options, $values ) = @_;
  if( defined $options ) {
    if( $options =~ /menu/ )        { $restart = 0; }
    if( $options =~ /interactive/ ) { $quiet = 0; }
    if( $DEBUG ) { print "Got option $options passed.\n"; }
  }
  if( defined $values ) {
    if( $DEBUG ) { print "Got pbs_bitmask $values passed.\n"; }
    # Look for bad input.
    if( "$values" =~ /[^0-9abcdef]/ ) { pbs_cfg_useage(); }
    $hdlc_ports = $values;
  } elsif( $quiet ) { pbs_cfg_useage(); }

  open(READ, "< $MODULES_CONF") or exit $E_UNKNOWN;
  open(WRITE, "> $tmp_file") or exit $E_UNKNOWN;
  while (<READ>) {
    if( $_ =~ /HDLC_PORTS=/ ) {
      # In case there are more than one entries, remove all and add at end.
      if( $DEBUG ) { print "Found $_."; }
    } else {
      print WRITE "$_";
    }
  }
  printf( WRITE "options nova_new HDLC_PORTS=%s\n", $hdlc_ports);
  close(READ);
  close(WRITE);
  system("/bin/mv", "-f", "$tmp_file", "$MODULES_CONF");
  FLUSH_ETC();
