sub get_route_cfg{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $dev, $rt_num ) = @_;
  my $indx = 0;
  my $rt_file = "$NETSCRIPTS_DIR/route-$dev";
  # Qry /etc/sysconfig/network-scripts/route-$dev for route info
  # ONLY returns ONE route when there are multiple!!
  my $rt_net = "127.0.0.1";      # Default
  my $bits   =  24;        # Default
  my $rt_gw  = "127.0.0.1";      # Default
  my $metric = -1;	# Default
  my $num_rts= 0;       # Default

  if( $DEBUG ) { print "get_route_cfg: Looking for route # $rt_num\n"; }
  if( -f "$rt_file" ) {
    my $ip_match = "$OCTET\.$OCTET\.$OCTET\.$OCTET";
    open( READ, "< $rt_file");
    while(<READ>) {
      if( $_ =~ /^($ip_match)\/(\d+)\s+via\s+($ip_match)/ ) {
        $indx++;
        # NOTE: $OCTET has () in def -> effects match #s, see below.
        if( $DEBUG ) {  print "get_route_cfg: rt #$indx $1/$6 via $7 for $dev\n"; }
        if( $indx == $rt_num ) { 
	  $rt_net = "$1"; $bits = "$6"; $rt_gw  = "$7";
          if( "$_" =~/metric\s+(\d+)/ ) { $metric = $1; }
	}
      }
    }
    close(READ);
    if( $rt_num == 0 ) {   # Return LAST route
      if( "$_" =~/metric\s+(\d+)/ ) { $metric = $1; }
      $rt_net = "$1"; $bits = "$6"; $rt_gw  = "$7";
    }
  }
  if ($DEBUG) { print "get_route_cfg: Got net $rt_net/$bits, gw $rt_gw, metric $metric.\n" }

  return "$rt_net", "$bits", "$rt_gw", $indx, $metric;
}

sub get_route{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $dev ) = @_;
  # Qry routing tables and return route info for device passed
  # ONLY returns ONE route when there are multiple!!
  my $rt_net = `$ROUTE -n | $GREP "$dev" | $GREP "UG" | /usr/bin/awk '{print \$1 }'`;
  my $rt_msk = `$ROUTE -n | $GREP "$dev" | $GREP "UG" | /usr/bin/awk '{print \$3 }'`;
  my $rt_gw  = `$ROUTE -n | $GREP "$dev" | $GREP "UG" | /usr/bin/awk '{print \$2 }'`;
  return "$rt_net";
}

sub non_dflt_rt{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $dev, $ip, $nm ) = @_;
  my $routes = "";
  my $err = 0;
  my $add_rt = "n";
  my $rt_file = "$NETSCRIPTS_DIR/route-$dev";

  if( -f "$rt_file" ) {
    open(READ, "< $rt_file");
    my $line = <READ>;
    if($line) { 
      if( $line !~ /^(\d+)\.(\d+)\.(\d+)\.(\d+)\/(\d+)\s+dev/ ) {
        $add_rt = "y";
      }
    }
    close(READ);
  }
  if( Get_YN("Add route to interface $dev", "$add_rt") ) {
    my ( $net_ip , $bits, $gw, $num_rts, $metric ) = get_route_cfg( "$dev", 1 );
    my $num = Get_Int("How many routes would you like to add to $dev?", 0, 3, $num_rts);
    if( $DEBUG ) { print "Got $num returned\n"; }
    my $indx = 1;
    while( ($indx <= $num) || ($err != 0) ) {
      ( $net_ip , $bits, $gw, $num_rts, $metric ) = get_route_cfg( "$dev", $indx );
      print "\n----- Route #$indx for $dev\n";
      $net_ip = ask_for_ip("network", "$net_ip");
      $bits   = ask_for_nmb("$bits");
      $gw     = ask_for_ip("gateway", "$gw");
      $metric = ask_for_metric($metric);
      $err    = check_net( "$ip", "$gw", "$nm" );
      if( $err ) {
        print "The gateway is not accessable through $dev. Please try again.\n";
      } else {
        my $tmp = "$routes";
	if( $metric == -1 ) { $routes = "$tmp$net_ip/$bits via $gw\n"; }
	else                { $routes = "$tmp$net_ip/$bits via $gw metric $metric\n"; }
        $indx++;
      }
    }
    if ( !$err ) {
      open( WRITE, "> $rt_file");
      print WRITE "$routes";
      close(WRITE);
    }
  } else {
    # Remove any old route info for this interface
    if ( -f "$rt_file" ) { unlink $rt_file; }
  }
  return $err;
}

