sub get_num_eth {
  my $fn = (caller(0))[3]; fen($fn);
  my $num_eth = 1;
  my $num_desc = 0;
  my $eth_file = 0;
  if( -f "$NUM_ETH" ) { $eth_file = $NUM_ETH; }
  elsif( -f "$IF_INFO" ) { $eth_file = $IF_INFO; } 
  else {
    $num_eth = 0;	# Indicate error
    print "\n\n!!! Missing Ethernet info file !!!\n\n";
    exit -1;
  }

  if( $num_eth >= 0 ) {
    if( `/bin/cat $eth_file` =~ /NUM_ETH=(\d+)/ ) { $num_eth = $1; }
    $num_desc = `cat $eth_file | $GREP "_DESC=" | wc -l`;
  }

  if( $num_desc != $num_eth ) {
    print "\n\n!!! Missing descriptions in $eth_file file. Please correct. !!!\n\n";
    $num_eth = 0;	# Indicate error
    exit -1;
  }

  @GLOB_ETH_DEVS_LIST=`grep -o "ETH.*_DESC=" $eth_file | grep -o "[0-9]*"`;
  if( $DEBUG ) { foreach my $dev ( @GLOB_ETH_DEVS_LIST ) {
    chomp $dev;
    print "Eth device eth${dev} has a description\n"; 
  } }

  fex($fn);
  return $num_eth;
}

