#---------------------------------------------------------------------
# This subroutine is meant to modify individual lines in $ifile. Both 
# input and output files are provided. If one needs to make multiple
# changes to a $ifile, they can designate 2 temp files and ping-pong between
# them to get all the changes done. The rules are that any line containing
# $pattern *anywhere* are deleted from the file, and a single line "$prefix
# $pattern $val" is put in the location of the first occurrance. Results
# are written to $ofile. No flash writes are performed.
#---------------------------------------------------------------------
sub set_line_in_file
{
  my $fn = (caller(0))[3]; fen($fn);
  my ($ifile,$ofile,$pattern,$val,$prefix) = @_ ;
  my $first_hit = 0;
  if($DEBUG){print "set_line_in_file: Function Enter\n";}

  if( !defined($pattern) ) {   return $E_UNKNOWN; }
  if( !defined($val) ) {       return $E_UNKNOWN; }
  open( WRITE, "> $ofile" ) or return $NO_SUCH_FILE;
  open( READ,  "< $ifile" ) or return $NO_SUCH_FILE;
  while(<READ>) {
    if( $_ =~ /$pattern/ ) {
      chomp($_);
      if( $DEBUG ) { print "Deleting |$_| from file\n"; }
      if( $first_hit == 0 ) {
	if( defined($prefix) ) { print WRITE "$prefix "; }
	print WRITE "$pattern $val\n";
	$first_hit++;
	if( $DEBUG ) { 
	  print "Adding |";
	  if( defined($prefix) ) { print "$prefix "; }
	  print "$pattern $val";
	  print "| to file\n";
	}
      }
    } else { print WRITE "$_"; }
  }

  close( READ );
  close( WRITE );

  return $OK;
}
