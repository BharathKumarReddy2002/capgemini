sub net_cfg_set
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $opts, $values ) = @_;
  my $firstboot = 0;
  my $protocol = 0;
  open(READ, "< $SYSCFG_CTP") or exit $E_UNKNOWN;
  while (<READ>) {
    if( $_ =~ /CTP_IP_PROTO=(\d+)/ ) {
      $protocol = $1;
    }
  }
  close(READ);

  # Parse & check passed options.
  if( (defined $opts) && ($opts =~ /firstboot/i) ) {
    $firstboot = 1;
    `: > /etc/resolv.conf`;   # Make sure /etc/resolv.conf is empty
    if( -f "/etc/init.d/ctp_setmod" ) {
      system("/etc/init.d/ctp_setmod", "start");
    }
    FLUSH_ETC();
    $protocol = net_cfg_protocol($protocol);
    if($protocol == 1) {
      net_cfg_ip($firstboot, $protocol, "IPV6");
    } elsif($protocol == 2) {
      net_cfg_ip($firstboot, $protocol, "IPV4");
      net_cfg_ip($firstboot, $protocol, "IPV6");
    } else {
      net_cfg_ip($firstboot, $protocol, "IPV4");
    }
    set_sec_lvl_set( 1, "low" );	# Set security level to low at 1st boot
  } elsif ( (defined $opts) && ($opts =~ /protocol/i) ) {
    $protocol = net_cfg_protocol($protocol);
  } elsif ( (defined $opts) && ($opts =~ /ipv4/i) ) {
    net_cfg_ip($firstboot, $protocol, "IPV4");
  } elsif ( (defined $opts) && ($opts =~ /ipv6/i) ) {
    net_cfg_ip($firstboot, $protocol, "IPV6");
  } elsif ( (defined $opts) && ($opts =~ /ivip/i) ) {
    net_cfg_vip();
  } elsif ( (defined $opts) && ($opts =~ /vip/i) ) {
    # Parse values passed.
    my @vals = split /:/, "$values";
    # Did we geta valid # if virtual IPs to configure?
    if( (!defined $vals[0]) || ($vals[0] =~ /\D/) ) { net_cfg_useage(); }
    my $num_vips_to_cfg = $vals[0];
    if ($DEBUG) { print "Asked to configure $num_vips_to_cfg virtual IPs.\n"; }
    # Were we passed enough fields for each virtual IP?
    if( !defined $vals[$num_vips_to_cfg] ) { net_cfg_useage(); }
    # Check that each field holds a valid IP.
    my $vip_num = 1;
    my $parse_error = 0;
    while( $vip_num <= $num_vips_to_cfg ) {
      my $is_ip = 0;
      if( $vals[$vip_num] =~ /^$OCTET\.$OCTET\.$OCTET\.$OCTET$/ ) { $is_ip = 1; }
      if ($DEBUG) { print "Checking VIP #$vip_num. Found is_ip = $is_ip for $vals[$vip_num].\n"; }
      if( !$is_ip ) { net_cfg_useage(); }
      $vip_num++;
    }
    # Now configure the virtual IPs.
    $vip_num =  0;
    while( $vip_num < $MAX_VIP ) {
      if( $vip_num < $num_vips_to_cfg ) {
	my $vip = "$vals[$vip_num+1]";
	if ($DEBUG) { print "Writing ifcfg file for VIP $vip_num with VIP $vip.\n"; }
	set_vip_cfg( $vip_num, "$vip" );
      } else { # Remove all other virtual ips.
	my $ifcfg_file = "$NETSCRIPTS_DIR/ifcfg-lo\:$vip_num";
	if( -f "$ifcfg_file" ) {
	  if ($DEBUG) { print "Removing ifcfg file for VIP $vip_num.\n"; }
	  system("/bin/rm", "-f", "$ifcfg_file");
          FLUSH_ETC();
	}
      }
      $vip_num++;
    }
    # Reboot???? Gui calls this & expects us to reboot!!
    system("/sbin/shutdown", "-r", "now");
  } elsif ( (defined $opts) && ($opts =~ /vlan/i) ) {
    net_cfg_vlan();
  } elsif ( defined $opts ) {
    print "**** Unknown option:$opts. ****\n\n";
    net_cfg_useage();
  }
  fex($fn);
  exit $OK;
}

