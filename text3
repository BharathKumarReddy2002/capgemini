sub ldap_read           # Default port! Only one server!
{
  my $fn = (caller(0))[3]; fen($fn);
  my $sip = "";
  my $names = "";
  my $state = 0;
  my $cnt = 0;
  $cnt = `$GREP "ldap" $NSS_CONF | wc -l`;
  if( $cnt == 3 ) { $state = 1; }   # passwd, shadow & group all must use ldap
  open( READ, "< $LDAP_CONF" ) or die "Can't open $LDAP_CONF!";
  while(<READ>) {
    if ( ! ($_ =~ /^\s*\#/ ) ) { # Skip comments
      if ( $_ =~ /HOST\s+((\d+\.\d+\.\d+\.\d+)|$IPV6ADDFORMAT)/i ) {
        $sip = $1;
      } elsif ( $_ =~ /BASE\s+([\w\=\,]+)/i ) {
        $names = $1;
      }
    }
  }
  close( READ );
  print STDOUT "SIP$sip\:DN$names\:ST$state\n";
  return $OK;
}

sub ldap_set            # Default port! Only one server!
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $string ) = @_;
  my ( $sip, $names, $state ) = "";
  my $parse_error = 0;
  if ( $string =~ /SIP(\d+\.\d+\.\d+\.\d+)/ )  { $sip = $1; }
  elsif ($string =~ /SIP$IPV6ADDFORMAT/ ) { $sip = $1; }
  else { $parse_error = 1; }     # Problem getting server ip
  if ( $string =~ /DN([\w\=\,]+)/ )     { $names = $1; }
  else { $parse_error = 1; }     # Problem getting timeout value
  if ( $string =~ /ST(\d)/ )      { $state = $1; }
  else { $parse_error = 1; }     # Problem getting state
  # Check for string parsing errors!
  if ( $parse_error == 1 ) { ldap_useage(); }
  # /etc/ldap.conf has base not BASE for tag. replace_line is case
  # sensitive!
  replace_line ( "$LDAP_CONF", "host", "HOST $sip");
  replace_line ( "$LDAP_CONF", "base", "BASE $names");
  if ( $state == 1 ) {
    replace_line ( "$NSS_CONF", "passwd", "passwd: files ldap");
    replace_line ( "$NSS_CONF", "shadow", "shadow: files ldap");
    replace_line ( "$NSS_CONF", "group",  "group: files ldap");
  } else {
    replace_line ( "$NSS_CONF", "passwd", "passwd: files");
    replace_line ( "$NSS_CONF", "shadow", "shadow: files");
    replace_line ( "$NSS_CONF", "group",  "group: files");
  }
  FLUSH_ETC();
  system("/etc/init.d/sshd", "restart");
  return $OK;
}

