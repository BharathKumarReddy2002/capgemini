  print "\tRequires a ctpd restart.\n";
  print "\t<protocol> is an integer indicating the protocol to use (dflt 47).\n";
  print "\t<port> is the UDP port number to use (dflt 16).\n";
  print "\t<port6> is the UDP port number to use for ipv6(dflt 32).\n";
  print "Usage: syscfg -r -u ctp_cfg\n";
  print "\tReturns CEP<protocol>:OAMP<port>:OAM6P:<port6>";
  print "\n";
