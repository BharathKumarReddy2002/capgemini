sub ASM_read_cfg
{
  my $fn = (caller(0))[3]; fen($fn);
  my $sl = 60; my ( $ctpd, $aas ) = 0 ; my ( $log, $cmdd ) = ( 1, 1 ) ; my $warn = 90; my $watch = 0;#Defaults
  get_sem ( $ASM_SEM, "ASM_SEM" );
  $ASM_REST_OF_FILE = "";	# initialize container
  open( READ, "< $ASM_CONF") or die "Can't open $ASM_CONF!";
  while (<READ>) {
    if ( $_ =~ s/SLEEP_TIME\s=\s(\d+)\n// ) { $sl = $1; }#
    elsif ( $_ =~ s/CTPD\s=\s(\d+)\n// )       { $ctpd = $1; }
    elsif ( $_ =~ s/AAS\s=\s(\d+)\n// )        { $aas = $1; }
    elsif ( $_ =~ s/LOG\s=\s(\d+)\n// )        { $log = $1; }
    elsif ( $_ =~ s/CMDD\s=\s(\d+)\n// )       { $cmdd = $1; }
    elsif ( $_ =~ s/LOG_WARN_THRESH\s=\s(\d+)\n// )       { $warn = $1; }
    elsif ( $_ =~ s/SYSLOG_WATCH\s=\s(\d+)\n// )       { $watch = $1; }
    else { $ASM_REST_OF_FILE .= $_; }
  }
  close( READ );
  rel_sem ( $ASM_SEM, "ASM_SEM" );
  return ( $sl, $aas, $log, $ctpd, $cmdd, $warn, $watch );
}
sub ASM_read
{
  my $fn = (caller(0))[3]; fen($fn);
  my  ( $request ) = @_;
  if( $request =~ /TEST_(\w+)/ ) {
     my $test_opt = $1;
     if ( $test_opt eq 'CMDD' ) {
         my $string = "$LSOF | $GREP LISTEN | $GREP $LIST_SOCK";
         if ( ` $string | wc -l` == 0  ) {
            print STDOUT "cmd_daemon.pl is NOT listening to port $LIST_SOCK.\n";
            return $NOT_LISTENING;
         } else {
           $rtn = ` $string | $AWK  '{print \$2}' `;
           chop $rtn;
           print STDOUT "$rtn\n";
           return $OK;
         }
     } else {
         print STDOUT "Unknown option TEST_$test_opt for ASM read.\n";
         exit $E_UNKNOWN;
     }
  } else {
     my ( $sl, $aas, $log, $ctpd, $cmdd, $warn, $watch ) = 0;
     ( $sl, $aas, $log, $ctpd, $cmdd, $warn, $watch ) = ASM_read_cfg();
     print STDOUT "SL$sl\:AAS$aas\:LOG$log\:CTPD$ctpd\:CMDD$cmdd\:WARN$warn\:WATCH$watch\n";
     return $OK;
  }
}

sub ASM_set
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $string ) = @_;
  my $got_one = 0;
  my ( $sl, $aas, $log, $ctpd, $warn, $watch ) = 0;
  ( $sl, $aas, $log, $ctpd, $cmdd, $warn, $watch ) = ASM_read_cfg();
  my $tmp = "/tmp/asm.conf";
  $string = "$string ";    # Append a space incase it wasn't initialized
  if ( $string =~ /SL(\d+)/ )  { $sl = $1;   $got_one++;  }
  if ( $string =~ /AAS(\d)/ )  { $aas = $1;  $got_one++;  }
  if ( $string =~ /LOG(\d)/ )  { $log = $1;  $got_one++;  }
  if ( $string =~ /CTPD(\d)/ ) { $ctpd = $1; $got_one++;  }
  if ( $string =~ /CMDD(\d)/ ) { $cmdd = $1; $got_one++;  }
  if ( $string =~ /WARN(\d+)/ ) { $warn = $1; $got_one++;  }
  if ( $string =~ /WATCH(\d)/ ) { $watch = $1; $got_one++;  }
  if ( !$got_one ) { ASM_useage(); }
  get_sem ( $ASM_SEM, "ASM_SEM" );
  open( WRITE, "> $tmp") or die "Can't open $tmp!";
    print WRITE "AAS = $aas\n";
    print WRITE "LOG = $log\n";
    print WRITE "CTPD = $ctpd\n";
    print WRITE "CMDD = $cmdd\n";
    print WRITE "SLEEP_TIME = $sl\n";
    print WRITE "LOG_WARN_THRESH = $warn\n";
    print WRITE "SYSLOG_WATCH = $watch\n";
    print WRITE $ASM_REST_OF_FILE;
  close( WRITE );
  # mv file to ASM.conf
  move("$tmp", "$ASM_CONF");
  if ( $FLASH ) {  DBFLUSH(); }     # Backup config file to flash
  rel_sem ( $ASM_SEM, "ASM_SEM" );
  # If AAS = 0, kill AAS
  if( "$aas" eq "0" ) {
    get_sem ( $AAS_SEM, "AAS_SEM" );
    kill_it( "AcornAutoSwitch" );
    rel_sem ( $AAS_SEM, "AAS_SEM" );
  }
  # If CMDD = 0, kill cmd_daemon
  if( "$cmdd" eq "0" ) { kill_it( "cmd_daemon" ); }
  # HUP AcornSysMon to get it to reread conf file
  hup( "AcornSysMon.pl" );       # ASM does NOT write to config here

  return $OK;
}

