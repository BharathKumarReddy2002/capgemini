sub copy_logs_save
{
  my $fn = (caller(0))[3]; fen($fn);
  my ($logs, $ip_self) = @_;
  if ( $logs < 0 || $logs > 16) {
    print STDOUT "Requested log key not valid.\nExiting . . .\n\n";
    exit $E_NOT_VALID;
  }
   my $is_ip = ( IsIP($ip_self) );
   if ( ! $is_ip ) {
      print STDOUT "The supplied IP address  is not in a valid format.\nExiting . . .\n\n";
      exit $NO_IP_FOUND;
   }
  my $tmp = "/tmp/";
  my $file_name = "";
  my $new_file = "";
  my $ident_dir = "/tmp/ident/";
  my $short_file = "$ip_self"."_logs.tar";
  my $tar_file = "/tmp/$short_file";
  my $tgz_file = "/tmp/$ip_self"."_logs.tgz";
  my $short_ident = "$ip_self"."_ident.tar";
  my $tar_ident = "/tmp/$short_ident";
  my $tgz_ident = "/tmp/$ip_self"."_ident.tgz";
  my $ident_label = "/tmp/label_file";
  my $settings_file = "/tmp/ownership_and_permissions.txt";   #PR 1906832
  my $kernel_file = "/tmp/kernel_release.txt";   #PR 1906832

  # Clear /tmp directory of all archive files
  `rm -f /tmp/*.tgz`;
  # create empty archive, must remove existing file first, create does not deleted existing file
  # Identity files are special case
  if($logs ne "8" && $logs ne "16") {
      if( $DEBUG ) {print STDOUT "Archive file name = $tar_file\n"; }
   `rm -f $tar_file`;
   `tar -cvPf $tar_file -T /dev/null`;
   # tar /var/log/messages*
   if($logs eq "1" || $logs eq "3" || $logs eq "5"  || $logs eq "7"  ) {
      if( $DEBUG ) {print STDOUT "Checking in directory $MSG_ROOT for message logs\n"; }
      foreach  $file ( @MESSAGES_LOG ) {
            if ( -f "$MSG_ROOT"."$file") {
      if( $DEBUG ) {print STDOUT "Copying file name = $file\n"; }
            `tar -rvPC $MSG_ROOT --mode=0644 -f $tar_file $file`;
            }
            next;
      }
   }
   # tar /var/log/auth.log*
   if($logs eq "2" || $logs eq "3" || $logs eq "6"  || $logs eq "7" ) {
      if( $DEBUG ) {print STDOUT "Checking in directory $MSG_ROOT for auth.log logs\n"; }
      foreach  $file ( @SECURE_LOG ) {
            if ( -f "$MSG_ROOT"."$file") {
      if( $DEBUG ) {print STDOUT "Copying file name = $file\n"; }
            `tar -rvPC $MSG_ROOT --mode=0644 -f $tar_file $file`;
            }
            next;
      }
   }
   # tar /backup/messages*
   if($logs eq "4" || $logs eq "5" || $logs eq "6"  || $logs eq "7" ) {
      if( $DEBUG ) {print STDOUT "Checking in directory $BCKUP_ROOT for compressed message logs\n"; }
      my $bckup_base;
      for ( my $i = 0; $i <= 30; $i++ ) {
         $file = "messages".".$i.gz";
         if ( -f "$BCKUP_ROOT"."$file") {
      if( $DEBUG ) {print STDOUT "Copying file name = $file\n"; }
         `tar -rvPC $BCKUP_ROOT --mode=0644 -f $tar_file $file`;
         }
         next;
      }
   }

   if( -f "$tar_file") {
      if( $DEBUG ) {print STDOUT "Compressing $tar_file\n"; }
      `tar -czvPC $tmp --mode=0644 -f $tgz_file $short_file `;
      `rm -f $tar_file`;
      }

   } elsif( $logs eq "8" || $logs eq "16"){
      # Identity files are special case
      # create empty archive, must remove existing file first, create does not deleted existing file
         if( $DEBUG ) {print STDOUT "Archive file name = $tar_ident\n"; }
      system("rm", "-f", "$tar_ident");
      system("tar", "-cvf", "$tar_ident", "-T", "/dev/null");

      # tar system identity files
      if( $DEBUG ) {print STDOUT "Preparing to copy system identity files\n"; }
      foreach  $file ( @IDENTITY_FILES ) {
        if( $DEBUG ) {print STDOUT "Copying file name = $file\n"; }
        # Let tar check if file or directory exists, missing file/dir does not stop process
        # specifically, either only /etc/ssh/ or /usr/local/etc/ will exist . . not both.
        # REMOVE LEADING '/' TO PREVENT ACCIDENTALLY OVERWRITING SYSTEM FILES !!!!!!!!
        if( -f $file || -d $file ) {
           system("tar", "-rvC", "/", "-f", "$tar_ident", "$file");
        }
        next;
      }
   
      #PR 1906832 fix -Start 
      my $date = localtime; 
      `$ECHO "CTP ${ip_self} full backup on $date" > $ident_label`;
      system("tar tvf $tar_ident > $settings_file");
      system("uname -r > $kernel_file");
      #PR 1906832 fix -End

      if( -f "$tar_ident") {
         if( $DEBUG ) {print STDOUT "Compressing $tar_ident\n"; }
         system("tar", "-czvPC", "/tmp", "--mode=0644",  "-f", "$tgz_ident", "$tar_ident", "$ident_label", "$settings_file","$kernel_file"); #PR 1906832
         #need to chown so that gui can overwrite later.
         system("chown", "ctp_cmd:ctp_cmd", "$tgz_ident");
         system("rm", "-f", "$tar_ident");
         system("rm", "-f", "$ident_label");
	 system("rm", "-f", "$settings_file"); #PR 1906832
	 system("rm", "-f", "$kernel_file"); #PR 1906832
      }
   } else {
    print STDOUT "Requested log key not valid.\nExiting . . .\n\n";
    exit $E_NOT_VALID;
   }
    exit $OK;
}

