sub snmptrap_write
{
  my $fn = (caller(0))[3]; fen($fn);
  my ($snmp) = @_ ;
  my ($index);
  my $tmp = "/tmp/foo";
  if($DEBUG){print "snmptrap_write: Function Enter\n";}

  # Flush all the old configs from snmpd.conf file
  open( WRITE, "> $tmp" ) or return $NO_SUCH_FILE;
  open( READ, "< $SNMPDCONF" ) or return $NO_SUCH_FILE;
  while(<READ>) {
    if( ($_ =~ /trapcommunity/) ||
	($_ =~ /trap2sink/) ) {
	chomp($_);
      if( $DEBUG ) { print "Deleting |$_| from file\n"; }
    } else {
      print WRITE "$_";
    }
  }

  # Add new configs to end of snmpd.conf file
  if( $snmp->{state} == 0 ) { print WRITE "#"; }
  if( $DEBUG ) { print "Writing Trap Community $snmp->{comm}\n"; }
  print WRITE "trapcommunity \"$snmp->{comm}\"\n";

  for($index=1;$index<=$MAX_SNMP_USERS;$index++) {
    if( $snmp->{$index}{used} eq "yes" ) {
      if( $DEBUG ) { print "Writing Trapsink IP index # $index\n"; }
      if( $snmp->{state} == 0 ) { print WRITE "#"; }
      print WRITE "trap2sink " . $snmp->{$index}{ip} . "\n";
    }
  }

  close( READ );
  close( WRITE );

  #--- Now copy the tmp file back to snmpdconf
  move $tmp, $SNMPDCONF;
  FLUSH_ETC();

  #--- Notify CTP daemon of trap config changes
  system("$CMD", "node", "cfg", "snmptraps");
  system("/acorn/perl/scripts/trap_clock.pl set 2>/dev/null"); #PR-1846896 
  return $OK;
}

#--------- iptables configuration ------------------------------
