sub get_sem
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $sem, $label ) = @_;
  if ($D_SEM) { log_it( LOG_ERR, "Trying to checkout: $label"); }
  $sem->op(
      0, 0, 0,    # Wait till clear
      0, 1, SEM_UNDO # Take semaphore
      );
  if ($D_SEM) { log_it( LOG_ERR, "Checked out       : $label"); }
}

sub rel_sem
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $sem, $label ) = @_;
  $sem->op(
      0, -1, IPC_NOWAIT # Release semaphore
      );
  if ($D_SEM) { log_it( LOG_ERR, "Released          : $label"); }
}

