  # Check for string parsing errors!
  if ( $parse_error == 1 ) { netlog_useage(); }
  my $cfg_str = "";
  open( WRITE, "> $tmp" ) or die "Can't open $tmp!";
  open( READ, "< $NETLOG_CONF" ) or die "Can't open $NETLOG_CONF!";
  while(<READ>) {
	  #PR 1851876
    if ( $_ =~ /local0/ && $_ =~ /@/  ) {
	 next; 
    }
    if ( $_ =~ /\*\.\*/ && $_ =~ /@/  ) {}
    else { print WRITE "$_"; }
  }    
  if( $state ) {    
   #$facility = "local0";
   #PR 1851876
   $facility = "*";
  }
 #PR 1614305 fix- Start
  if( $sip  =~ /(\d+\.\d+\.\d+\.\d+)/ ) {
	  $cfg_str = "$facility\.\*                     \@$sip\n";
  } 
  else {
	  $cfg_str = "$facility\.\*                     \@\[$sip\]\n";
  }
  print WRITE "$cfg_str";
  if( $secondip ) {
   if( $s1ip  =~ /(\d+\.\d+\.\d+\.\d+)/ ) {
	   $cfg_str = "$facility\.\*                   \@$s1ip\n";
   }  
   else{
	   $cfg_str = "$facility\.\*                   \@\[$s1ip\]\n";
   }
  print WRITE "$cfg_str"; 
  }
 #PR 1614305 fix- End
  system("/bin/mv", "-f", "$tmp", "$NETLOG_CONF");
  FLUSH_ETC();
  system( "$NETLOG_INIT", "restart");
  return $OK;
}

#--------- ssh keys ----- -----------------------------------
#
# routines for ssh key exchange through gui
#
# master host: is the host from which the ssh connection is to be established.
# slave host: is the host that the master connects to.
# self_ip: is the ip address of the host on which this script resides.
#
# Want to configure keys so that root on master can ssh into slave as user ctp_cmd
# without passwords.
#
# To do so requires:
# 1) .ssh directories for root on master & ctp_cmd on slave with 700 permissions
# 2) ssh key pair for root on master (use rsa as default).
# 3) .ssh/known_hosts file with permissions 644 for root on master.
# 4) .ssh/authorized_keys file (permissions 644) for ctp_cmd on slave.
# 5) the public host key from slave in root's known_hosts file on master.
# 6) no conflicting public host key in root's known_hosts file on master.
# 7) root's public key in ctp_cmd's authorized_keys file on slave.
#
# Since the gui can talk to both hosts, it must have the public host key of both.
# - Can get the slave host's public key from apache's know_hosts file.
#
# Procedure -
# 1) Use a set command on the master with M flag, sending the slave host's
#    public host key.
#    -> set command with M flag will:
#       - Check for root's .ssh with proper permissions
#         & set up if necessary.
#       - Check for root's rsa key pair and generate one if they are not found.
#       - Check for root's .ssh/known_hosts with proper permissions
#         & set up if necessary.
#       - Check root's known_hosts file for slave's host key,
#         & add the key if it isn't there,
#         & replace a stale key if one is found.
#       - flush keys to flash storage
#       - return root's public key ...OR..
#         & return unknown failure if any other set above failed.
# 2) gui looks at return from set command on master.
#    -> if return is success, keys are set up and gui's job here is done.
#    -> if return is root's public key, gui sends that to slave host via:
# 3) Use a set command on the slave with S flag, sending root's public key
#    from the master host.
#    -> set command with S flag will:
#       - Check for ctp_cmd's .ssh directory with proper permissions
#         & set up if necessary.
#       - Check for ctp_cmd's .ssh/authorized_keys file with proper permissions
#         & set up if not.
#  - Add root's public key to ctp_cmd's authorized_key file.
#       - flush keys to flash storage
#       - Return success if everything succeeded.
#  - Return unknown failure otherwise.
# On receiving success from the slave, gui should assume that all is well.
# On receiving network or unknown failure from either host, inform gui user.
#
# Read command here returns host key in case we don't want to get it from
# apache's known_host file.

sub sshkey_useage       # Usage is not public info!
{
  my $fn = (caller(0))[3]; fen($fn);
  useage( $E_UNKNOWN );
}

sub sshkey_cfg
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $read, $opts, $values, $ip_self ) = @_;
  if ( $read ) { sshkey_read( "$ip_self" ); }      # only opt is ip_self
  else { sshkey_set(  "$opts", "$values" ); }   # opts contains remote ip
}

# Usage: syscfg -r -u sshkey [ -i ip_self ]
# returns public host key.
# NOTE: host keys must be prepended with ip for use in known_hosts file!
# If ip_self is not provided, then:
# host name must be associated with ip in addtion to  127.0.0.1 in /etc/hosts file
# ip/hostname pair for this host must occur within the top 500 lines in the /etc/hosts file
# script will return first match only
sub sshkey_read            # Only one server!
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $ip_self) = @_;
      my $hkey = "E_UNKNOWN\n";
      my $hostname = hostname();
      my $ip = "none";
      my $get_ip = "127.0.0.1";
      my $is_ip = 0;
  if (($ip_self eq "") || ($ip_self eq "10.0.0.0")) {

      sethostent 1;
      if ( ( ! defined $ip ) || ( $ip =~ /none/)) { # rip through /etc/hosts for our ip
         for ($i=0 ; (($i<500) && ($ip=~/none/)) ; $i++) {   #Need to make sure we look at complete file on a gui server
            my ($name, $aliases, $addrtype, $length, @addrs) = gethostent;
            if ( defined $addrs[0]) {  #Host name may not be in /etc/host file
            my ($a, $b, $c, $d) = unpack('C4', $addrs[0]);
         #print "$hostname, $name $a $b $c $d\n";
            $get_ip = "$a\.$b\.$c\.$d";
            if (( $name eq $hostname ) && ($get_ip ne "127.0.0.1")) { $ip = "$a\.$b\.$c\.$d"; }
            }
         }
      }
      endhostent;
   } else {
      $is_ip = ( ( $ip_self =~ /^$OCTET\.$OCTET\.$OCTET\.$OCTET$/ ) );
      if ( ! $is_ip ) {
         print STDOUT "The supplied IP address for host $hostname is not in a valid format.\n";
         exit $NO_IP_FOUND;
      }
      $ip = $ip_self;
  }
  #print "hostname: $hostname, ip: $ip\n";
  if (( $ip ne "none") && ( $ip ne "10.0.0.0")) {
   open ( READ, "< $HOST_KEY_FILE" ) or $hkey = "E_NO_KEY\n";
   while(<READ>) { chomp(); $hkey = "$ip $_"; }
   close ( READ );
   print STDOUT "\"$hkey\"\n";
   exit $OK;
  } else {
   print STDOUT "Could not locate an ip address for host $hostname.\n";
   exit $NO_IP_FOUND;
  }
}

# Usage: syscfg -s -u sshkey -o <M/S> -v "<key>"
# NOTE: there are spaces in ssh keys, use "" to preserve key as single string!
# NOTE: host keys must be prepended with ip for use in known_hosts file!
sub sshkey_set
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $host, $key) = @_;
  my ( $ssh_dir, $ssh_key_file, $ukey_file ) = "";
  my $ukey = "E_UNKNOWN\n";
  my $local_user = "root";
  if    ( $host eq "M" ) {
    $local_user = "root";
    $ssh_dir = "/root/.ssh";
    $ssh_key_file = "$ssh_dir/known_hosts";
    my $rtn = 0;
    $rtn += check_dir ( "$ssh_dir", "700", "$local_user", "$local_user" );
    $rtn += check_file( "$ssh_key_file", "644", "$local_user", "$local_user" );
    if ( $rtn != 0 ) { exit $NO_SUCH_FILE; }
    #Check for old key, replace if it exists
    my $match = "none"; if ( $key =~ /(\d+\.\d+\.\d+\.\d+)\s+/ ) { $match = $1; }
    #print "Looking for $match in $ssh_key_file\n";
    my $line_found = replace_line( "$ssh_key_file", "$match", "$key" );
    if ( $line_found == 0 ) { `/bin/echo "$key" >> $ssh_key_file`; }
    $ukey_file = "$ssh_dir/$USER_KEY_FILE";
    if ( ! -f "$ukey_file" ) {
      system("$SSH_KEYGEN","-q","-t","rsa","-N","","-f","$ssh_dir/id_rsa");
    }
    open ( READ, "< $ukey_file" ) or $ukey = "E_NO_KEY\n";
    while(<READ>) { chomp(); $ukey = $_; }
    close ( READ );
    print STDOUT "\"$ukey\"\n";
    # flush keys to flash storage
    if ( $FLASH ) { flush( "/root" ); }
    exit $OK;
  } elsif ( $host eq "S" ) {
    $local_user = "ctp_cmd";
    $ssh_dir = "/home/ctp_cmd/.ssh";
    $ssh_key_file = "$ssh_dir/authorized_keys";
    my $rtn = 0;
    $rtn += check_dir ( "$ssh_dir", "700", "$local_user", "$local_user" );
    $rtn += check_file( "$ssh_key_file", "644", "$local_user", "$local_user" );
    if ( $rtn != 0 ) { exit $NO_SUCH_FILE; }
    #Check for old key, replace if it exists
    my $match = "none"; if ( $key =~ /\=\s+(.+\@.+)/ ) { $match = $1; }
    #print "Looking for $match in $ssh_key_file\n";
    my $line_found = replace_line( "$ssh_key_file", "$match", "$key" );
    if ( $line_found == 0 ) { `/bin/echo "$key" >> $ssh_key_file`; }
    # flush keys to flash storage
    if ( $FLASH ) { flush( "/home/ctp_cmd" ); }
    exit $OK;
  } else  { exit "$E_HOST_KEY"; }
}

