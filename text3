sub Radius_read            # Default port! Only one server!
{
  my $fn = (caller(0))[3]; fen($fn);
    my ( $tmpip, $tmpsecret, $tmptimeout ) = ("", "", "");
    my ( $ip, $secret, $timeout, $port, $opt_servers ) = ("", "", "", "", "");
    my ( $state, $retries ) = ( 0, 0  );
    my ( $off_line_failover, $reject_failover ) = ( 0, 0 ); 
    my $cnt = 0;
    my $radius_module = "pam_radius_auth";
    
    open( READ, "< $RADIUS_CONF" ) or die "Can't open $RADIUS_CONF!";
    while(<READ>) {
        if ( ! ($_ =~ /^\s*\#/ ) ) {    # Skip comments
            if ( $_ =~ /^\s*([^\s]*)\s+([\w@!#?^&\{}\[\]%~=\-\,\$'":;<>|\/+*(\)`.,\\]+)\s+([\d]*)/  ) { #Aricent Fix PR-1445364 PR-1846890
                $tmpip = $1; 
                $tmpsecret = $2;
                $tmptimeout = $3;
                # check that IP address is a valid format
                if(  $tmpip =~ /^(\d+\.\d+\.\d+\.\d+)|$IPV6ADDFORMAT$/ ) {
                    if ( $cnt == 0 ) {
                        $ip = $tmpip; 
                        $secret = $tmpsecret;
                        $timeout = $tmptimeout;
                    } elsif ( $cnt <= 9 ) {
                        $opt_servers .= "\:N${cnt}SIP${tmpip}\:N${cnt}SS${tmpsecret}\:N${cnt}TO${tmptimeout}";                    
                    }       
                    $cnt++;
                }    
            }
        }
    }
    close( READ);
    # Destination RADIUS port
    $port = read_radius_port();
    chomp($port);
    # Read options to pam_radius_auth.so in /etc/pam.d/system-auth
    my $line_rad = `$GREP -m 1 'auth[ ].*[ ]$radius_module' $RADIUS_PAM  `;
    chomp($line_rad);
    # Radius is off if pam_radius_auth.so line is commented out in /etc/pam.d/system-auth
    if ( ! ( $line_rad =~ /^\s*[#]/ ) ) {
        $state = 1;
    }
    # Number of retries is 0 by default, if option is present the value can be 0-9
    if ( $line_rad =~ /\sretry=([0-9])/ ) {
        $retries = $1;
    }
    # Failover options
    my $allow_reject_pattern = "authinfo_unavail=bad\\s+default=ignore"; 
    my $disallow_reject_pattern = "ignore=ignore\\s+default=bad";
    if ( $line_rad =~ /$allow_reject_pattern.*localifdown/ ) {         
        $reject_failover = 1;
        $off_line_failover = 1;
    } elsif ( $line_rad =~ /$allow_reject_pattern/ ) {             
        $reject_failover = 1;
        $off_line_failover = 0;
    } elsif ( $line_rad =~ /$disallow_reject_pattern.*localifdown/ ) {         
        $reject_failover = 0;
        $off_line_failover = 1;
    } elsif ( $line_rad =~ /$disallow_reject_pattern/ ) {         
        $reject_failover = 0;
        $off_line_failover = 0;
    } 
    
    print STDOUT "SIP$ip\:SS$secret\:TO$timeout\:ST$state\:RP$port\:RT$retries\:OLF$off_line_failover\:RF${reject_failover}$opt_servers\n";
    return $OK;
}

sub Radius_set             
{
  my $fn = (caller(0))[3]; fen($fn);
    my ( $string ) = @_;
    my ( $sip, $secret, $to, $state, $port, $retries, $off_line_failover, $reject_failover );
    my ( @sip_opt, @secret_opt, @to_opt );
    my $parse_error = 0;
    my $radius_module = "pam_radius_auth";
    my $unix_module = "pam_unix";
    
    if ( $string =~ /SIP(\d+\.\d+\.\d+\.\d+)/ )  { $sip = $1; }
    elsif ($string =~ /SIP$IPV6ADDFORMAT/ ) { $sip = $1; }
    else { $parse_error = 1; }     # Problem getting server ip
    if ( $string =~ /SS([\w@!&#.?^&\{\}\[\]%~=\-\,\$'"|\/<>:;+*(\)`\\]+)\:TO/ ) { $secret = $1;}   # Aricent Fix PR-1445364, PR-1846890
    else { $parse_error = 1; print "Characters single quote (') can be configured as '\\''\ .\n"; } # Problem getting shared secret PR-1846890 
    if ( $string =~ /TO(\d+)/ )     { $to = $1; }
    else { $parse_error = 1; }     # Problem getting timeout value
    if ( $string =~ /ST([01])/ )      { $state = $1; }
    else { $parse_error = 1; }     # Problem getting state
    if ( $string =~ /RP(\d+)/ )      { $port = $1; }
    else { $parse_error = 1; }     # Problem getting port
    if ( $string =~ /RT(\d)/ )      { $retries = $1; }
    else { $parse_error = 1; }     # Problem getting retries
    if ( $string =~ /OLF([01])/ )      { $off_line_failover = $1; }
    else { $parse_error = 1; }     # Problem getting off-line failover
    if ( $string =~ /RF([01])/ )      { $reject_failover = $1; }
    else { $parse_error = 1; }     # Problem getting reject failover
    for ( my $i=1; $i<=9; $i++ ) {        
        if ( $string =~ /N${i}SIP(\d+\.\d+\.\d+\.\d+)/ )  { $sip_opt[$i] = $1; }
        elsif ($string =~ /N${i}SIP$IPV6ADDFORMAT/ ) { $sip_opt[$i] = $1; }
        else { $sip_opt[$i] = ""; }     # no valid entry
        if ( $string =~ /N${i}SS([\w@!&#.?^&\{}\[\]%~=\-\,\$'"|\/<>:;+*(\)`\\]+)\:N${i}/ ) { $secret_opt[$i] = $1;}    # Aricent Fix PR-1445364, PR-1846890
        else { $secret_opt[$i] = "none"; }     # no valid entry        
        if ( $string =~ /N${i}TO(\d+)/ )     { $to_opt[$i] = $1; }
        else { $to_opt[$i] = ""; }     # no valid entry
    }
  
    # Check for string parsing errors!
    if ( $parse_error == 1 ) { Radius_useage(); return $OK; }
    $rtn = ` $GREP -e '^[ ]*[^#].*pam_tacplus\.so' $RADIUS_PAM  | wc -l  `;
    chomp ($rtn);
    # Aricent fix for PR 794392 start
    if( $state == 1 && $rtn >= 1 ) {    # Aricent PR 1173747 fix
        Radius_useage(); return $OK;
    }
    # Aricent fix for PR 794392 end

       # Rewrite server file
       my $cfg_str = "$sip        $secret        $to\n";
       open( WRITE, "> $RADIUS_CONF" ) or die "Can't open $RADIUS_CONF!";
       print WRITE $cfg_str;
       for ( my $i=1; $i<=9; $i++ ) { 
           if ( $sip_opt[$i] ne "" ) {
             print WRITE "$sip_opt[$i]        $secret_opt[$i]        $to_opt[$i]\n";        
          }        
       }
       close(WRITE);
       
       # update system-auth file
       # set state
       manage_comment ( "$RADIUS_PAM", "$radius_module", $state );
       
       # set retries
       `$SED -i "s/ retry=[0-9]// " $RADIUS_PAM`;
       `$SED -i "/$radius_module/ s/.*/& retry=$retries/" $RADIUS_PAM`;
       
       # set failover options
       # replace the entire control field
       my $allow_reject_field = "[success=done new_authtok_reqd=done authinfo_unavail=bad default=ignore]"; 
       my $disallow_reject_field = "[success=done new_authtok_reqd=done ignore=ignore default=bad]";
       if ( $reject_failover == 1 ) {
           `$SED -i "/$radius_module/ s/auth.*$radius_module/auth      $allow_reject_field      $radius_module/"  $RADIUS_PAM`; 
       } elsif ( $reject_failover == 0 ) {
           `$SED -i "/$radius_module/ s/auth.*$radius_module/auth      $disallow_reject_field      $radius_module/"  $RADIUS_PAM`; 
       } # doing nothing if non-valid value
       
       # set $off_line_failover option
       `$SED -i "s/ localifdown// " $RADIUS_PAM`;
       if ( $off_line_failover == 1 ) {
           `$SED -i "/$radius_module/ s/.*/& localifdown/" $RADIUS_PAM`;
       }
       
       # set RADIUS port
       my $acct_port = $port + 1; 
       system("$SED -i '/^radius[[:space:]]/ s/[0-9]\\{1,5\\}/$port/' $SERVICES");
       system("$SED -i '/^radius-acct[[:space:]]/ s/[0-9]\\{1,5\\}/$acct_port/' $SERVICES");  
       
#       # update AllowTemplateAccts in sshd_config
       my $yn = "no"; 
       if( $state == 1 ) {
           $yn = "yes";
       }
#Aricent PR 1401407 fix
       `$SED -i "/AllowTemplateAccts/ cAllowTemplateAccts $yn" $SSHD_CONF`;
       
       # make sure ChallengeResponseAuthentication is set to yes
       `$SED -i "/ChallengeResponseAuthentication/ cChallengeResponseAuthentication yes" $SSHD_CONF`;
       FLUSH_USR_LOCAL(); #Aricent fix for PR 784551
       FLUSH_ETC();
       system("/etc/init.d/sshd", "stop");
       sleep 1;
       system("/etc/init.d/sshd", "start");
    return $OK;
}

