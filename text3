sub manage_comment         # Add ($state=0) or remove ($state=1)
{              # a # to comment out (uncomment) all lines
  my $fn = (caller(0))[3]; fen($fn);
  my ( $file, $match, $state ) = @_;   # containing $match in $file.
  my $tmp = "/tmp/foo";
  copy( $file, $tmp );
  my ( $dev,$ino,$mode,$nlink,$uid,$gid,$rdev,$size,
       $atime,$mtime,$ctime,$blksize,$blocks ) =
       stat( $file ) or die "Could not file $file!";
  open ( READ, "< $file" ) or die "Could not open $file!";
  open ( WRITE, "> $tmp" ) or die "Could not open $tmp!";
  while (<READ>) {
    if ( $_ =~ /$match/ ) {      # Matching line
      #print "Got match!: $_";
      if ( ( $state == 0 ) && ( $_ !~ /^\s*\#/ ) ) {
        print WRITE "\#$_";
        #print "Turn on #!: \#$_";
      } elsif ( ( $state == 1 ) && ( $_ =~ /^\s*\#(.+)/ ) ) {
        print WRITE "$1\n";      # . doesn't match /n!
        #print "Turn off #!: $1\n";
      } else {
        print WRITE "$_";     # Nothing to do but print the line
        #print "Do nothing!: $_";
      }
    } else {
      print WRITE "$_";       # Not a matching line
    }
  }
  close ( READ );
  close ( WRITE );
  # Now copy the tmp file back to $file and set permissions
  chmod $mode, $tmp;
  move $tmp, $file;
}

sub replace_line           # Replace all lines in $file that
{              # contain $match with $newline
  my $fn = (caller(0))[3]; fen($fn);
