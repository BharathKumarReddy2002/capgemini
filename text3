sub tacplus_read            # Default port! Only one server!
{
  my $fn = (caller(0))[3]; fen($fn);
    my ( $tmpip, $tmpsecret, $tmptimeout ) = ("", "", "");
    my ( $ip, $secret, $timeout, $port, $opt_servers ) = ("", "", "", "", "");
    my $state = 0;
    my ( $off_line_failover, $reject_failover ) = ( 0, 0 );
    my $cnt = 0;
    my $server = 0;
    my $secret_key = 0;
    my @secret_arr = ("");
    my @server_arr = ("");
    my $tacplus_module = "pam_tacplus";

    # Destination TACPLUS port
    $port = read_tacplus_port();
    chomp($port);
    # Read options to pam_tacplus.so in /etc/pam.d/system-auth
    my $line_tac = `$GREP -m 1 '$tacplus_module' $TACPLUS_PAM  `;
    chomp($line_tac);
    # TACPLUS is off if pam_tacplus.so line is commented out in /etc/pam.d/system-auth
    if ( ! ( $line_tac =~ /^\s*[#]/ ) ) {
        $state = 1;
    }

    if ( $line_tac =~ /\sserver=($IPV4ADDFORMAT|$IPV6ADDFORMAT)/ ) { $ip = $1; } # server IP
    if ( $line_tac =~ /\ssecret=([\w@!#?^&\{}\[\]%~=\-\,\$'"|\/<>:;.+*(\)`\\]+)/ ) { $secret = $1; } # Secret key #PR-1846890
    if ( $line_tac =~ /\stimeout=(\d+)/ ) { $timeout = $1; } # timeout value

    while( $line_tac =~ /\s+server=($IPV4ADDFORMAT|$IPV6ADDFORMAT)/gi ) {
          $server_arr[$server] = $1;
          $server++;
    }

    while( $line_tac =~  /\s+secret=([\w@!#?^&\{}\[\]%~=\-\,\$'"|\/<>:;.+*(\)`\\]+)/gi ) { #PR-1846890
          $secret_arr[$secret_key] = $1;
          $secret_key++;

    }

    for ( my $i=1; $i<$server; $i++ ) {
      $opt_servers .= "\:N${i}SIP${server_arr[$i]}";
      if ($secret_arr[$i]) {
          $opt_servers .= "\:N${i}SS${secret_arr[$i]}";
      } else {
          $opt_servers .= "\:N${i}SS";
      }
    }
 # Failover options
    my $allow_reject_pattern = "authinfo_unavail=bad\\s+default=ignore";
    my $allow_offline_pattern = "authinfo_unavail=ignore\\s+ignore=ignore\\s+default=bad"; #Aricent PR 777865
    my $allow_offline_reject_pattern = "authinfo_unavail=ignore\\s+default=ignore";
    my $disallow_offline_reject_pattern = "ignore=ignore\\s+default=bad";
    if ( $line_tac =~ /$allow_offline_reject_pattern/ ) {
        $reject_failover = 1;
        $off_line_failover = 1;
    } elsif ( $line_tac =~ /$allow_reject_pattern/ ) {
        $reject_failover = 1;
        $off_line_failover = 0;
    } elsif ( $line_tac =~ /$allow_offline_pattern/ ) {
        $reject_failover = 0;
        $off_line_failover = 1;
    } elsif ( $line_tac =~ /$disallow_offline_reject_pattern/ ) {
        $reject_failover = 0;
        $off_line_failover = 0;
    }

    print STDOUT "SIP$ip\:SS$secret\:TO$timeout\:ST$state\:RP$port\:OLF$off_line_failover\:RF${reject_failover}$opt_servers\n";
    return $OK;
}

sub tacplus_set
{
  my $fn = (caller(0))[3]; fen($fn);
    my ( $string ) = @_;
    my ( $sip, $secret, $to, $state, $port, $off_line_failover, $reject_failover );
