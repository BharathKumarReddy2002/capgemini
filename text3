sub AAS_set_bndl
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $bNum, $string ) = @_;
  my $cp = 20;
  my ( $cbs, $pip, $pcid, $sip, $scid, $st, $rvt ) = AAS_get_dflts();
  my $dflts = 1;
  my $parse_error = 0;
  my $tmp = "/tmp/aas.conf";
  if ( $string =~ /CBS(\d+)/ )   { $cbs = $1; }
  else { $parse_error = 1; }     # Problem getting check_b4_switch
  if ( $string =~ /PIP(\d+\.\d+\.\d+\.\d+)/ ) { 
    if( "$pip" ne "$1" ) { $pip = $1; $dflts = 0; }
  } else { $parse_error = 1; }     # Problem getting primary ip
  if ( $string =~ /PP(\s?\d+)/ ) { $pcid = $1; }
  else { $parse_error = 1; }     # Problem getting primary cid
  if ( $string =~ /SIP(\d+\.\d+\.\d+\.\d+)/ ) { 
    if( "$sip" ne "$1" ) { $sip = $1; $dflts = 0; }
  } else { $parse_error = 1; }     # Problem getting secondary ip
  if ( $string =~ /SP(\s?\d+)/ ) { $scid = $1; }
  else { $parse_error = 1; }     # Problem getting secondary cid
  if ( $string =~ /CP(\d+)/ )    { $cp = $1; }
  else { $parse_error = 1; }     # Problem getting check period
  if ( $string =~ /RVT(\d+)/ )   { $rvt = $1; } # Not all gui's send this!
  if ( $string =~ /ST(\d+)/ )    { $st  = $1; }
  else { $parse_error = 1; }      # Problem getting state
  # Check for string parsing errors!
  if ( $parse_error == 1 ) { AAS_useage(); }
  # Take semaphore while: Reading AAS_CONF, writing $tmp & flushing new
  # config file to flash.
  get_sem ( $AAS_SEM, "AAS_SEM" );
  open( WRITE, "> $tmp") or die "Can't open $tmp!";   # open for appending!
  if( !$dflts ) {
    print WRITE "BNDL_$bNum : CHECK_B4_SWITCH = $cbs\n";
    print WRITE "BNDL_$bNum : PRI_IP = $pip\n";
    print WRITE "BNDL_$bNum : PRI_CID = $pcid\n";
    print WRITE "BNDL_$bNum : SEC_IP = $sip\n";
    print WRITE "BNDL_$bNum : SEC_CID = $scid\n";
    print WRITE "BNDL_$bNum : REVERT = $rvt\n";
    print WRITE "BNDL_$bNum : WATCH = $st\n";
    print WRITE "\n";
  }
  close( WRITE );
  # Scan through AAS.conf, appending all but this port's settings to $tmp
  `$CAT $AAS_CONF | $SED "/BNDL_$bNum /d" >> $tmp`;
  # Replace/add SLEEP_TIME (check period)
  my $lines_replaced = 0;
  $lines_replaced += replace_line( "$tmp", "SLEEP_TIME","SLEEP_TIME = $cp");
  if ( $lines_replaced == 0 ) {     # Didn't find SLEEP_TIME add it!
    `echo "SLEEP_TIME = $cp" >> $tmp`;
  }
  # mv file to AAS.conf
  move( "$tmp", "$AAS_CONF" );
  # MUST check ssh keys for the remote host!
  # Restart AcornAutoSwitch with -a flag, it will clean out all other instances,
  # reload config file, & make sure AcornSysMon will watch it.
  DBFLUSH();	# Backup config file to flash
  rel_sem ( $AAS_SEM, "AAS_SEM" );
  close (STDOUT); open (STDOUT, " > /dev/null ");
  close (STDERR); open (STDERR, " > /dev/null ");
  # Now check if AAS is running already, if so restart it with new cfg file
  if( !system("ps", "-C", "AcornAutoSwitch") ) { system("$AAS", "-a"); }
  close (STDOUT); open (STDOUT, " > /dev/stdout");
  close (STDERR); open (STDERR, " > /dev/stderr");
  return $OK;
}

