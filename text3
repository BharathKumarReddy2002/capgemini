        if ( $string =~ /N${i}SS([\w@!#?^&\{}\[\]%~=\-\,\$'"|\/<>:.;+*(\)`\\]+)/ ) { $secret_opt[$i] = $1; }  # Aricent fix for PR 798137, PR-1846890
        else { $secret_opt[$i] = ""; }     # no valid entry
    }

    # Check for string parsing errors!
    if ( $parse_error == 1 ) { tacplus_useage(); return $OK; }
