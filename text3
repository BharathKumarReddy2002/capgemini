sub snmpdconf_write
{
  my $fn = (caller(0))[3]; fen($fn);
  my ($snmp) = @_ ;
  my ($index);
  my $tmp = "/tmp/foo";
  if($DEBUG){print "snmpdconf_write: Function Enter\n";}


  # Flush all the old configs from snmpd.conf file
  open( WRITE, "> $tmp" ) or return $NO_SUCH_FILE;
  open( READ, "< $SNMPDCONF" ) or return $NO_SUCH_FILE;
  while(<READ>) {
    if( ($_ =~ /rocommunity/) ||
	($_ =~ /rwcommunity/) ||
	($_ =~ /rouser/)      ||
	($_ =~ /createUser/)  ||
	($_ =~ /syslocation/)  ||
	($_ =~ /^pass/)  ||
	($_ =~ /syscontact/) ) {
	chomp($_);
      if( $DEBUG ) { print "Deleting |$_| from file\n"; }
    } else {
      print WRITE "$_";
    }
  }

  # Add new configs to end of snmpd.conf file
  print WRITE "syslocation \"$snmp->{location}\"\n";
  print WRITE "syscontact  \"$snmp->{contact}\"\n";

  for($index=1;$index<=$MAX_SNMP_USERS;$index++) {
    if( $snmp->{$index}{used} eq "yes" ) {
      if( $DEBUG ) { print "Writing SNMPv"; }
      if( $snmp->{$index}{SNMPv} == 2 ) {
	if( $DEBUG ) { print "2 user # $index\n"; }
	print WRITE $snmp->{$index}{rw} . "community";
	if( $snmp->{$index}{IPv} == 6 ) { print WRITE "6 "; }
	else {                             print WRITE "  "; }
	print WRITE $snmp->{$index}{comm} . " ";
	if( $snmp->{ $index}{ip} eq "default") { print WRITE "default\n"; }
	else { print WRITE $snmp->{$index}{ip} . "\n"; }
      } else {		# SNMPv3
	if( $DEBUG ) { print "3 user # $index\n"; }
	print WRITE $snmp->{$index}{rw} . "user ";
	print WRITE $snmp->{$index}{user} . " priv\n";
	print WRITE "createUser " . $snmp->{$index}{user};
	print WRITE " SHA \"" . $snmp->{$index}{pass} . "\" AES ";
        print WRITE $snmp->{$index}{ip} . "\n"; # Aricent PR 1362733 fix
      }
    }
  }
  print WRITE "pass .1.3.6.1.4.1.18841 /acorn/perl/scripts/snmpAcorn.pl\n";

  close( READ );
  close( WRITE );
  # Now copy the tmp file back to snmpdconf
  move $tmp, $SNMPDCONF;
  FLUSH_ETC();
}

