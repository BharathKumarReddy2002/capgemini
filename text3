    else { $parse_error = 1; }     # Problem getting off-line failover
    if ( $string =~ /RF([01])/ )      { $reject_failover = $1; }
    else { $parse_error = 1; }     # Problem getting reject failover
    for ( my $i=1; $i<=9; $i++ ) {
        if ( $string =~ /N${i}SIP(\d+\.\d+\.\d+\.\d+)/ )  { $sip_opt[$i] = $1; }
