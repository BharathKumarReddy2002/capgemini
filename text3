  return $rtn;
}

sub AAS_read
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $request ) = @_;
  my $rtn = $OK;
  my $bNum = 0;
  if ( $request =~ /eth(\d)/ ) {
    my $eth_dev = $request;
    $rtn = AAS_get_eth("$eth_dev", 1);
  } elsif ( $request =~ /ARM/i ) {
    $rtn = AAS_get_ARM();
  } elsif ( $request =~ /TEST($OCTET\.$OCTET\.$OCTET\.$OCTET$)/ ) {
    my $test_ip = $1;
      if( $DEBUG ) {print STDOUT "Testing connection to $test_ip\n"; }
    $rtn = test_ctp_key("$test_ip");
  } elsif ( $request =~ /CP/i ) {
    $rtn = AAS_get_CP();
  } elsif ( $request =~ /(\d+)/ ) {
    $bNum = $1;
    $rtn = AAS_get_bndl(1, $bNum);
  } else {  # default request is bNum 0
    $rtn = AAS_get_bndl(1, $bNum);
  }
  return $rtn;
}

sub AAS_get_eth{
  my $fn = (caller(0))[3]; fen($fn);
  # Finds available ethernets:
  #   How many (from num_eth file)
  #     If hw not there, AVAILABLE=NO
  #     Any that have ifcfg files with ONBOOT=yes, AVAILABLE=NO
  #     Remaining -> look in AAS.conf
  #
  my ( $eth_dev, $force ) = @_;
  my $desc = "Unknown";
  GetAllEth();          # Setup ETH_CONFIG
  if ( $ETH_CONFIG{$eth_dev}{AVAILABLE} == $YES ) {
    get_sem ( $AAS_SEM, "AAS_SEM" );
    my $rtn_str = `$GREP $eth_dev $AAS_CONF`;
    rel_sem ( $AAS_SEM, "AAS_SEM" );
    # Unless configured otherwise, dflt is not to use available ethernets.
    my $use = $NO;
    if ( $rtn_str =~ /$eth_dev\s*:\s*USE\s*=\s*(\d)/ ) { $use = $1; }
    my $dev_num = 0;
    if( "$eth_dev" =~ /eth(\d+)/ ) {
      $dev_num = $1;
      $desc = get_eth_desc("$dev_num");
    }
    print STDOUT "$eth_dev:AVAILABLE$YES:USE$use:$desc\n";
  } else {
    # Device not available, may be in use already!
    # Try to get description.
    if( "$eth_dev" =~ /eth(\d+)/ ) {
      $dev_num = $1;
      $desc = get_eth_desc("$dev_num");
    }
    if( $desc =~ /\w+/ ) { # Print output
      print STDOUT "$eth_dev:AVAILABLE$NO:USE$NO:$desc\n";
    } elsif ( $force ) {
      print STDOUT "$eth_dev:AVAILABLE$NO:USE$NO:$desc\n";
      return $E_NO_SUCH_DEV;
    }
  }
  return $OK;
}

sub test_ctp_key{
  my $fn = (caller(0))[3]; fen($fn);
   # Tests passwordless connection from this user root to remoter user ctp_cmd
    my ( $test_ip ) = @_;
    my @rtn = "";
    my $err = 0;
    my $status = "";
    my $SSH = "/usr/local/bin/ssh";   # OpenSSH_3.9p1!
    if ( ! -f "$SSH") {
      $SSH = "/usr/bin/ssh";            # Early version Default path
    }
    my $remote_user = "ctp_cmd";
    #### We must watch STDERR as well as STDOUT -> pipe STDERR into STDOUT and collect
    ( @rtn ) = `$SSH -x  -o BatchMode=yes -o StrictHostKeyChecking=no $remote_user\@$test_ip whoami 2>&1 `;
    chomp $rtn[$#rtn];
    if ( $rtn[0] =~ /$remote_user/i  ) {  #Keys setup OK! Return no error
       $err = 0; $status = "Keys OK";
    } elsif ( $rtn[0] =~ /No\s+route / ) {
       $err = $E_NO_ROUTE; $status = "No route to Host";
       #Nothing we can do but report the problem!
    } elsif ( $rtn[$#rtn] =~ /No\s+route/ ) {
        $err = $E_NO_ROUTE; $status = "No route to Host";
       #Nothing we can do but report the problem!
    } elsif ( $rtn[0] =~ /@@@@@@@@@@@@@@@@@@@@@@@@@/  ||  $rtn[0] =~ /(yes\/no)\?/  ||  $rtn[0] =~ /s\s+password:/  ||  $rtn[0] =~ /Password:/  ||  $rtn[0] =~ /passphrase/ ) {
       $err = $E_HOST_KEY; $status = "Invalid Authorization Key";
    } elsif ( $rtn[$#rtn] =~ /Permission\s+denied/ ) {
       $err = $E_NOT_VALID; $status = "Permission denied";
    } elsif ( $rtn[$#rtn] =~ /$remote_user/i  ) {  #Keys setup OK! Return no error
       $err = 0; $status = "Keys OK";
    } else {
       $err = 1; $status = $rtn[0];   # Don't know what happened!
    }
     print STDOUT "\n   Key Check for host $test_ip => $status\n\n";
   return( $err);
}

sub AAS_get_dflts {
  my $fn = (caller(0))[3]; fen($fn);
  my ( $cbs, $pip, $pcid, $sip, $scid, $st, $rvt ) = (0, 0, 0, 0, 0, 0, 0, 0, 1);
  get_sem ( $AAS_SEM, "AAS_SEM" );
  open( READ, "< $AAS_CONF") or die "Can't open $AAS_CONF!";
  while (<READ>) {
    if ( $_ =~ /DFLT_S\s\:/ ) {
      if ( $_ =~ /CHECK_B4_SWITCH\s=\s(\d+)/ )       { $cbs  = $1; }
      if ( $_ =~ /PRI_IP\s=\s(\d+\.\d+\.\d+\.\d+)/ ) { $pip  = $1; }
      if ( $_ =~ /PRI_CID\s=\s(\d+)/ )               { $pcid = $1; }
      if ( $_ =~ /SEC_IP\s=\s(\d+\.\d+\.\d+\.\d+)/ ) { $sip  = $1; }
      if ( $_ =~ /SEC_CID\s=\s(\d+)/ )               { $scid = $1; }
      if ( $_ =~ /REVERT\s=\s(\d)/ )                 { $rvt  = $1; }
      if ( $_ =~ /WATCH\s=\s(\d)/ )                  { $st   = $1; }
    }
  }
  close( READ );
  rel_sem ( $AAS_SEM, "AAS_SEM" );
  return ( $cbs, $pip, $pcid, $sip, $scid, $st, $rvt );
}

sub AAS_get_ARM {
  my $fn = (caller(0))[3]; fen($fn);
  my ( $arm, $arm_rvt ) = (0, 0); # Aricent PR 841216 Fix
  get_sem ( $AAS_SEM, "AAS_SEM" );
  open( READ, "< $AAS_CONF") or die "Can't open $AAS_CONF!";
  while (<READ>) {
    # Aricent PR 841216 Fix - Start
    if ( $_ =~ /ARM\s+\=\s+(\d)/ ) { print STDOUT "ARM$1"; }
