#PR 1906832 fix -Start
sub fix_ctp_ident_owner_perms {
    my $ident_tgz_new = `ls -t /tmp/*_ident.tgz | head -1`;
    chomp $ident_tgz_new;
    chdir '/';
    system("tar xvfzp $ident_tgz_new /tmp/ownership_and_permissions.txt");
    open(my $fh, '<', '/tmp/ownership_and_permissions.txt') or die "Cannot open file: $!";
    print "Applying ownership and permissions of Identity files.....\n";

    while (my $line = <$fh>) {
        chomp $line;
	#print "Line: $line\n";
        my @fields = split(/\s+/, $line);
        my $file_w_path = "/" . $fields[5];
        my ($owner, $group) = split(/\//, $fields[1]);
        my $perms = substr($fields[0], -9);
        my $perms_oct = convert_rwx_to_octal($perms);

	print "File: $file_w_path, chown: ${owner}:${group}, chmod: $perms_oct (\"$perms\")\n";
        system("chown ${owner}:${group} $file_w_path");
        system("chmod $perms_oct $file_w_path");
    }
    print "done.\n";
    close($fh);
}

sub convert_rwx_to_octal {
    my ($rwx) = @_;
    my %map = ('r' => 4, 'w' => 2, 'x' => 1, '-' => 0);
    my $octal = '';

    for (my $i = 0; $i < length($rwx); $i += 3) {
        my $triplet = substr($rwx, $i, 3);
        my $value = 0;
        $value += $map{$_} for split('', $triplet);
        $octal .= $value;
    }
    return $octal;
}
