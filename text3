# Aricent fix for PR-739109 start.
# If PMC613 is present then check does it contain mac address with RAMIX OUID "00:30:F7"
# If interface is not having RAMIX OUID then consider mac is corrupted.
# If mac of one interface is corrupted and another seems good then program EEPROM of faulty interface
#    with (good mac -/+ 1) address.
# If both of the mac of PMC613 is corrupted then create a random mac with RAMIX OUID "00:30:F7" and
#    write into the EEPROM of both the interface.
sub chk_eepro_cfg
{
  my $fn = (caller(0))[3]; fen($fn);
  my $rtn = $OK;
  my $ev_cnt;
  my $num_eepro_ifs = `lspci -d 8086:1209 | $WC -l`;
  chomp($num_eepro_ifs);
  my $is_eepro_mod = `lsmod | egrep 'eepro100'| $WC -l`;
  my $i;
  my $tmp = "/acorn/tmp/eepro_temp";
  my $eeprodiag = "/acorn/bin/eepro100-diag";
  my $mac_unique_new="00:00:00";
  my $needs_kis = 0;
  my $ksum = `/bin/uname -r `;
  if( "$ksum" =~ /3.14.39ltsi-WR7.0.0.27_standard/ ) { return $rtn; }
  if ($num_eepro_ifs != 0) {
    if ($is_eepro_mod == 0) {
      `modprobe eepro100`;
    }
  } else {
    return $rtn;
  }
  if ( -f "$tmp") {
    system("rm -rf $tmp");
  }
  system("$eeprodiag -ae -f > $tmp");
  open( INFILE, "<$tmp" ) || die "Can't open !!!\n";
  $ev_cnt = 0;
  if ($DEBUG) {
    printf "--------------------Table-----------------------\n";
  }
  while( <INFILE> ) {
    if(/^IO\s*addr\s*(\w+)\sStation\saddress\s(\w{2}:\w{2}:\w{2}):(\w{2}:\w{2}:\w{2})/) {
      $io_mac{$ev_cnt}{ioaddr} = $1;
      $io_mac{$ev_cnt}{mac_vendor} = $2;
      $io_mac{$ev_cnt}{mac_unique} = $3;
      if ($io_mac{$ev_cnt}{mac_vendor} eq "00:30:F7") {
        $io_mac{$ev_cnt}{mac_valid} = 0;
        if ($DEBUG) {
          printf "Parsed $1, $2, $3,inx $ev_cnt valid 0\n";
        }
      } else {
        $io_mac{$ev_cnt}{mac_valid} = 1;
        if ($DEBUG) {
          printf "Parsed $1, $2, $3,inx $ev_cnt valid 1\n";
        }
      }
      $ev_cnt++;
    }
  }
  if ($DEBUG) {
    printf "------------------------------------------------\n";
  }
  close INFILE;
  for($i=0;$i<$ev_cnt;$i++) {#$i indicates the interface number.
    if ($io_mac{$i}{mac_valid}){
      my $mac_new;
      my $j;
      if ($i % 2) {
        $j = $i - 1;
      } else {
        $j = $i + 1;
      }
      if ( $io_mac{$j}{mac_valid} == 0 ) {#EEPROM of one interface is good.
        my @split_macs = split /:/, $io_mac{$j}{mac_unique};#get the good mac.
        my $k;
        my $hex_val=0;
        for ($k=2;$k>=0;$k--) {
          $hex_val = hex($split_macs[$k]);
          if ( ($i > $j) && ($hex_val != 255)){#EEPROM contents of second interface is corrupted and not FF.
            $split_macs[$k] = sprintf "%x", $hex_val+1;
            $k=0;
          } elsif ( ($i > $j) && ($hex_val == 255)){#EEPROM contents of second interface is corrupted and FF.
            $hex_val=0;
            $split_macs[$k] = sprintf "%x",$hex_val;
          } elsif ( ($i < $j) && ($hex_val != 0)) {#EEPROM contents of first interface is corrupted and not 0.
            $split_macs[$k] = sprintf "%x", $hex_val-1;
            $k=0;
          } elsif ( ($i < $j) && ($hex_val == 0)) {#EEPROM contents of first interface is corrupted and 0.
            $hex_val=255;
            $split_macs[$k] = sprintf "%x",$hex_val;
          }
        }
        $mac_unique_new=join(":",@split_macs);
      } else {
        if ($i % 2) {#random mac is created earlier.
          my $k;
          my $hex_val=0;
          my @split_macs = split /:/,$mac_unique_new;
          for ($k=2;$k>=0;$k--) {
            $hex_val = hex($split_macs[$k]);
            if ( $hex_val != 255){
              $split_macs[$k] = sprintf "%x", $hex_val+1;
              $k=0;
            } elsif ( $hex_val == 255 ){
              $hex_val=0;
              $split_macs[$k] = sprintf "%x",$hex_val;
            }
          }
          $mac_unique_new=join(":",@split_macs);

        } else {
          my $range = 255;
          my $int_var=0;
          my @mac_rand = split /:/,"00:00:00";
          for ($k=0;$k<3;$k++) {
            $int_var = int(rand($range));
            $mac_rand[$k]=sprintf "%x",$int_var;
          }
          $mac_unique_new=join(":",@mac_rand);
        }
      }
      $mac_new = "00:30:F7".":"."$mac_unique_new";
      system("$eeprodiag -E -p $io_mac{$i}{ioaddr} -H $mac_new -w -f");
      system("/bin/touch /tmp/eepro_changed");
    }
  }
  return $rtn;
}

