sub get_eth_cfg {
  my $fn = (caller(0))[3]; fen($fn);
  my ( $eth_dev, $dflt, $firstboot, $protocol) = @_;
  my $ipaddr  = "127.0.0.1";     # Default
  my $netmask = "255.255.255.0"; # Default
  my $gateway = "127.0.0.1";     # Default
  my $mtu     = 1500;         # Default
  my $enable = 1;
  my $ifcfg_file = "$NETSCRIPTS_DIR/ifcfg-$eth_dev";
  my $activate = "n";
  my $tmp_file = "/tmp/eth_cfg";
  my $findIpv6 = 0;
  my $dev_num = 0;
  my $rt_file = "$NETSCRIPTS_DIR/route-$eth_dev";
  my $subnet = "127.0.0.1";
  my $cidr = 8;
  my $seg_status = get_seg_file_param(2,0);

  if ( (-f "$ifcfg_file") && (! $firstboot) ) {
    open( READ, "< $ifcfg_file");
    while(<READ>) {
      if($_ =~ /IPADDR/) { $activate = "y";}
    }
    close (READ);
  }

  if ($DEBUG) { print "Got eth_dev $eth_dev, ";
           print "dlft $dflt, & 1st boot $firstboot\n"; }
  if( ! $firstboot ) {
    my ( $stat, $tmp_ip, $tmp_nm, $tmp_gw, $tmp_mtu , $tmp_en) = get_eth_cfg_from_file( "$eth_dev" );
    if ($DEBUG) { print "Got stat $stat, ip $tmp_ip, nm $tmp_nm.\n"; }
    if( $stat & 0x1) { $ipaddr = $tmp_ip; }
    if( $stat & 0x2) { $netmask = $tmp_nm; }
    if( $stat & 0x4) { if( "$tmp_gw" ne "127.0.0.1" ) { $gateway = $tmp_gw; } }
    if( $stat & 0x8) { if( $tmp_mtu != 1500 ) { $mtu = $tmp_mtu; } }
    if( $stat & 0x10) { 
      if( "$tmp_en" eq "yes" ) { 
	$activate = "y";
	if( ! ($stat & 0x1) ) { $ipaddr = "none"; }	# L2 is enabled w/o IP 
      } else { 
        $activate = "n"; 
      } 
    }
    if( $dflt == 1 ) {
      $gateway = get_cfg_gw();
      if ($DEBUG) { print "Got gw $gateway.\n"; }
    } elsif( $dflt == 2 ) {
      $gateway = get_cfg_mgmt_gw( $eth_dev );
      if ($DEBUG) { print "Got management gw $gateway.\n"; }  
    }
  }
 
  if( $dflt == 1) { 
    if($seg_status == 1) {
      print "\n===== Configuration for $eth_dev (Circuit device):\n"; 
    } else {
      print "\n===== Configuration for $eth_dev (default device):\n"; 
    }
  } elsif ($dflt == 2) { 
    print "\n===== Configuration for $eth_dev (management device):\n";
  } else {
    print "\n===== Configuration for $eth_dev:\n";
  }
  if( ($dflt == 1) || ($dflt == 2) ||
      (Get_YN("Activate IPV4 interface $eth_dev on boot", "$activate")) ) {
    my $err = 0;
    do {
      $err = 0;
      # Ask the user for network details.
      $ipaddr  = ask_for_ip("ip", "$ipaddr");
      if( $ipaddr ne "none" ) {		# "none" is L2 interface only
	$netmask = ask_for_ip("netmask", "$netmask");
	if( $dflt ) {
	  $gateway = ask_for_ip("gateway", "$gateway");
	  if ($DEBUG) { print "Got ip $ipaddr, netmask $netmask & gateway $gateway\n"; }
	  # For default dev, check input parmeters to see if ip & gw are in same net
	  $err = check_net( "$ipaddr", "$gateway", "$netmask" );
	  if($err) { 
	    print "\n\nThe gateway you entered does not appear within same network.\n";
	  }
	}
	$mtu = ask_for_mtu("$mtu");
	# Add a non-default route??
	# Note- AAS ethernet failover only brings up default route on default eth device!
	$err += non_dflt_rt( $eth_dev, $ipaddr, $netmask );
      }
    } while ( $err != 0);
  } else {
    $enable = 0;
  }

  open( WRITE, "> $tmp_file");
  if ( (-f "$ifcfg_file") && (! $firstboot) ) {
    open( READ, "< $ifcfg_file");
    while (<READ>) {
    # keep IPV6 configuration if the protocol allows both IPv4 and IPv6
      if( $_ =~ /ETHTOOL_OPTS/) {
        print WRITE "$_";
      }elsif(($_ =~ /IPV6/) && ($protocol == 2)) {
        $findIpv6 = 1;
        print WRITE "$_";
      }
    }
    close(READ);
  }
  print WRITE "DEVICE=$eth_dev\n";
  print WRITE "BOOTPROTO=static\n";
  if($enable) {
    # Save network details to file
    if( $ipaddr ne "none" ) {		# "none" is L2 interface only
      print WRITE "MTU=$mtu\n";
      print WRITE "IPADDR=$ipaddr\n";
      print WRITE "NETMASK=$netmask\n";
    }
    print WRITE "ONBOOT=yes\n";
    if( $dflt == 1 ) { print WRITE "GATEWAY=$gateway\n"; }
  } else {
    #the interface has no IPv6 configuration then don't activate it on bootup
    if($findIpv6) {
      print WRITE "ONBOOT=yes\n";
    } else {
      print WRITE "ONBOOT=no\n";
    }
  }
  close(WRITE);
  # Save network details to file
  system("mv", "-f", "$tmp_file", "$NETSCRIPTS_DIR/ifcfg-$eth_dev");
  
  if ($dflt == 2) {
    if ( $eth_dev =~ /eth(\d+)$/ ) {
      $dev_num = $1;
    } elsif ( $eth_dev =~ /eth(\d+).(\d+)$/) {
      $dev_num = $1; 
    }
    ($subnet , $cidr) = getSubnetInfo($ipaddr, $netmask);
    open( WRITE, "> $tmp_file");
    if ( -f "$rt_file" ) {
      open( READ, "< $rt_file" ) or die "Can't open the file route-$eth_dev";
      while(<READ>) {
        print WRITE "$_";
      }
      close(READ);
    }
    my $tab_num = $dev_num + 10;
    print WRITE "$subnet/$cidr dev $eth_dev scope link tab $tab_num\n";
    print WRITE "default via $gateway dev $eth_dev tab $tab_num\n";
    close(WRITE);
    system("mv", "-f", "$tmp_file", "$NETSCRIPTS_DIR/route-$eth_dev");
   
    open( WRITE, "> /tmp/rule-eth");
    print WRITE "from $ipaddr/32 tab $tab_num\n";
    print WRITE "to $ipaddr/32 tab $tab_num\n";
    close(WRITE);
  }
  #FLUSH_ETC();		# we will do this at the end of net_cfg_ip()
  fex($fn);
  return "$ipaddr";
}

sub get_eth_ip6_cfg {
  my $fn = (caller(0))[3]; fen($fn);
  my ( $eth_dev, $dflt, $firstboot, $protocol) = @_;
  my $mtu6    = 1500;         # Default
  my $enable = 1;
  my $ip6addr = "::1/128";
  my $ipv6gw = "::1";
  my $ifcfg_file = "$NETSCRIPTS_DIR/ifcfg-$eth_dev";
  my $activate = "n";
  my $tmp_file = "/tmp/foo";
  my $findIpv4 = 0;
  if ( (-f "$ifcfg_file") && (! $firstboot) ) {
    open( READ, "< $ifcfg_file");
    while(<READ>) {
      if($_ =~ /IPV6/) { $activate = "y"; }
    }
    close (READ);
  }
  if ($DEBUG) { print "Got eth_dev $eth_dev, ";
           print "dlft $dflt, & 1st boot $firstboot\n"; }
  if( ! $firstboot ) {
    my($stat6, $tmp_ip6, $tmp_mtu6) = get_ip6_cfg_from_file("$eth_dev");
    if ($DEBUG) { print "Got stat6 $stat6, ip6 $tmp_ip6, mtu6 $tmp_mtu6 .\n"; }
    if( $stat6 >=1 ) {$ip6addr = $tmp_ip6;}
    if( $stat6 >=2 ) {$mtu6 = $tmp_mtu6;}
    if( $dflt ) {
      my ($tmpSuccess, $tmpgw6) = get_ipv6gw();
      if( $tmpSuccess ) {
        $ipv6gw = $tmpgw6;
        if ($DEBUG) { print "Got gw $ipv6gw.\n"; }
      }
    }
  }

  if ($DEBUG) { print "Got ip6 $ip6addr, mtu6 $mtu6 .\n"; }

  if( $dflt ) { print "\n===== IPV6 Configuration for $eth_dev (default device):\n"; }
  else { print "\n===== IPV6 Configuration for $eth_dev:\n"; }
  if( ($dflt) ||
      (Get_YN("Activate IPV6 interface $eth_dev on boot", "$activate")) ) {
    my $err = 0;
    do {
      $err = 0;
      $ip6addr = ask_for_ipv6("ipv6", "$ip6addr");
      if( $dflt ) {
        $ipv6gw = ask_for_ipv6gw("ipv6gw", "$ipv6gw");
        $mtu6 = ask_for_ipv6_mtu("$mtu6");
        # Add a non-default route??
        # Note- AAS ethernet failover only brings up default route on default eth device!
        non_dflt_rt6($eth_dev);
      } else {
        $mtu6 = ask_for_ipv6_mtu("$mtu6");
        # Add a non-default route??
        # Note- AAS ethernet failover only brings up default route on default eth device!
        non_dflt_rt6($eth_dev);
      }
    } while ( $err != 0);
  } else {
    $enable = 0;
  }

  open( WRITE, "> $tmp_file");
  if ( -f "$ifcfg_file") {
    open( READ, "< $ifcfg_file");
    while (<READ>) {
      if( $_ =~ /ETHTOOL_OPTS/) {
        print WRITE "$_";
      } elsif(($_ =~ /IPV6/) ||($_ =~ /ONBOOT/) || ($_ =~ /DEVICE/) || ($_ =~ /BOOTPROTO/)) {
      } elsif ($protocol == 1) {
      } elsif ($_ =~ /IPADDR/) {
        $findIpv4 = 1;
        print WRITE "$_";
      } else {
        print WRITE "$_";
      }
    }
    close(READ);
  }
  print WRITE "DEVICE=$eth_dev\n";
  print WRITE "BOOTPROTO=static\n";
  if($enable) {
    # Save network details to file
    print WRITE "IPV6INIT=yes\n";
    print WRITE "IPV6ADDR=\"$ip6addr\"\n";
    print WRITE "IPV6_MTU=\"$mtu6\"\n";
    print WRITE "ONBOOT=yes\n";
  } else {
    # Save network details to file
    if($findIpv4) {
      print WRITE "ONBOOT=yes\n";
    } else {
      print WRITE "ONBOOT=no\n";
    }
  }
  close(WRITE);
  close(READ);
  system("mv", "-f", "$tmp_file", "$NETSCRIPTS_DIR/ifcfg-$eth_dev");
  FLUSH_ETC();

  return "$ipv6gw";
}

