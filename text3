sub get_cfg_mgmt_gw {
  my $fn = (caller(0))[3]; fen($fn);
  
  my ( $eth_dev ) = @_;
  my $gw_file = "$NETSCRIPTS_DIR/route-$eth_dev";
  my $rule_file = "$NETSCRIPTS_DIR/rule-$eth_dev";
  my $gateway = "127.0.0.1";
  if( -f "$rule_file" ) {
    if ( -f "$gw_file" ) {
      open (READ, "< $gw_file");
      while (<READ>) {
        if( $_ =~ /default via/ ) {
          @gw_string = split / /, $_;
          $gateway = $gw_string[2];
          last;
        }
      }
    }
  }
  return $gateway;
}

