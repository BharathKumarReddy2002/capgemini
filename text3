sub dualImg_cfg_set
{
  my $fn = (caller(0))[3]; fen($fn);
  my $sys_type = "";
  my $ret=0;
  my ( $opts, $values ) = @_;  
  my $i=0,$j=0;
  my $pri=0 ;
  my @words;
  my @images=("None","None");
  my $is_uefi=0;
  my $ctpos_rev=`/acorn/bin/cmd -v | fgrep -i "CTPOS CLI version"`;
  my $ctpos_rel="";
  my $ctpos_ver="";
  my $ctpos_edit="";
  my $is_boot_mnt=0;
  my $uefi_mnt_pnt="/mnt/uefi_mount";

  if( $DEBUG ) { print "DEBUG: enable\n"; }
  open(READ, "< $SYS_FILE") or exit $E_UNKNOWN;
  while (<READ>) {
    if( $_ =~ /SYS_TYPE=/ ) { $sys_type = $_; }
  }
  close(READ);

  system('/acorn/bin/cmd -v | grep "CTPOS CLI version" >  /tmp/.dualImg_cfg');
  open(READ, "< /tmp/.dualImg_cfg") or exit $E_UNKNOWN;
  while (<READ>) {
    if(( $_ =~  /version: \s*/ )) {
      @words = split /version: /, $_;
      $ctpos_rev="${words[1]}";
    }
  }
  @words = split /\./, $ctpos_rev;
  $ctpos_rev=${words[0]};
  chomp(${ctpos_rev});
  if( $ctpos_rev < 9 ) { 
    $is_boot_mnt=1; 
  }
  else { 
    if ( ( $sys_type =~ /bacardi/ )|| ( $sys_type =~ /ppf84/ ) ) {
      $is_boot_mnt=0; 
    }
    else {
      $is_boot_mnt=1;
    }
  }
  close(READ);
  if( $DEBUG ) { print "DEBUG: \$ctpos_rev = ${ctpos_rev}\n"; }
  if( $DEBUG ) { print "DEBUG: \$is_boot_mnt = ${is_boot_mnt}\n"; }

  if ( ! -f "${GRUB_CONF}" ) { ${GRUB_CONF}="/boot/grub/grub.cfg"; }
  if ( ( $sys_type =~ /bacardi/ )|| ( $sys_type =~ /ppf84/ ) ) {
    $is_uefi=1;
    system("mkdir -p ${uefi_mnt_pnt}");
    system("lsblk -o name,label | grep CTP_ROOT > /tmp/.dualImg_cfg");
    open(READ, "< /tmp/.dualImg_cfg") or exit $E_UNKNOWN;
    while (<READ>) {
      if( $_ =~ /sda/ ) { $dev = "/dev/sda"; }
      if( $_ =~ /sdb/ ) { $dev = "/dev/sdb"; }
      if( $_ =~ /nvme/ ) { $dev = "/dev/nvme0n1p"; }
    }
    if( $DEBUG ) { print "DEBUG: \$is_uefi = ${is_uefi}\n"; }
    if( $DEBUG ) { print "DEBUG: \$dev = ${dev}\n"; }
    close(READ);
    if ( ! -e "${dev}2" ) {
      print "!!!${dev}2 does not exist...Exiting!!! \n";
      exit $E_UNKNOWN;
    }
    system("umount ${dev}2 >& /dev/null");
    system("mount ${dev}2 ${uefi_mnt_pnt} >& /dev/null");
    if ( -f "${uefi_mnt_pnt}/EFI/BOOT/grub-startup.cfg" ) {
      $GRUB_CONF="${uefi_mnt_pnt}/EFI/BOOT/grub-startup.cfg";
    }
    else {
      print "!!!UEFI grub conf not found...Exiting!!! \n";
      exit $E_UNKNOWN;
    }
    if( $DEBUG ) { print "DEBUG: \$GRUB_CONF = ${GRUB_CONF}\n"; }
  }
  elsif (( $sys_type =~ /pp833/ ) || ( $sys_type =~ /gluon/ ) || ( $sys_type =~ /pp332/ )) {
    $is_uefi=0;
    if( $DEBUG ) { print "DEBUG: \$is_uefi = ${is_uefi}\n"; }
  }
  else {
      print "!!!Unknown platform...Exiting!!! \n";
      exit $E_UNKNOWN;
  }
  if ( $is_uefi == 1 ) {
    $i1=`/bin/fgrep -i "root=LABEL=CTP_ROOT" ${GRUB_CONF} | wc -l `;
    $i2=`/bin/fgrep -i "root=/dev/sda" ${GRUB_CONF} | wc -l `;
    $i=$i1+$i2;
    open (READ, "< $GRUB_CONF") or exit $E_UNKNOWN;
    while (<READ>) {
      if(( $_ =~  /^menuentry \s*/ )) {
        @words = split /\'/, $_;
        if ( $j == 0 ) { ${images[0]}=${words[1]}; }
        if ( $j == 1 ) { ${images[1]}=${words[1]}; }
        $j++;
      }
    }
    close (READ);
  }
  else {
    open (READ5, "< $GRUB_CONF") or exit $E_UNKNOWN;
    while (<READ5>) {
      if(( $_ =~  /\s*image1\s*/ ) && ($_ =~  /root=LABEL=([\w\.]+)/ )) {
        if ($i == 0) { $pri = 1; }
        $i++;
      }
      elsif(( $_ =~  /\s*image2\s*/ ) && ($_ =~  /root=LABEL=([\w\.]+)/ )) {
        if ($i == 0) { $pri = 2; }
        $i++;
      }
      if(( $_ =~  /^title \s*/ )) {
        @words = split /\(/, $_;
        if ( $j == 0 ) { ${images[0]}=${words[1]}; }
        if ( $j == 1 ) { ${images[1]}=${words[1]}; }
        $j++;
      }  
    }
    close (READ5);
  }
  if ( $is_uefi == 1 ) { 
    chomp(${images[0]});
  }
  else {
    chomp(${images[0]});
    chop(${images[0]});
  }
  if( $DEBUG ) { print "DEBUG: \$i = ${i} (Number of image partitions)\n"; }
  if( $DEBUG ) { print "DEBUG: \$images[0] = ${images[0]}\n"; }
  if( $DEBUG ) { print "DEBUG: \$images[1] = ${images[1]}\n"; }
  if ($i == 0) {
    if( $DEBUG ) { print "DEBUG: Since \$i (number of partitions) is ${i}...\n"; }
      if ( $is_uefi == 1 ) { 
        system("umount ${dev}2 >& /dev/null");
        if ( ! -f "${uefi_mnt_pnt}/EFI/BOOT/grub-startup.cfg" ) { system("rm -fr ${uefi_mnt_pnt}  >& /dev/null"); }
      }
      printf("\n*******************************************************\n");
      printf("*** Primary Boot Image   : ${images[0]}\n");
      printf("*** This system has only single partition\n");
      printf("*** Please create Dual Partition&Image first and then \n");
      printf("*** use this option to select Boot option \n");
      printf("*******************************************************\n");
      exit $E_UNKNOWN;
  }
  elsif ($i == 2) {
    if( $DEBUG ) { print "DEBUG: Since \$i (number of partitions) is ${i}...\n"; }
    if ( $is_uefi == 1 ) { 
      chomp(${images[1]});
    }
    else {
      chomp(${images[1]});
      chop(${images[1]});
    }
    printf(" Primary Boot Image   : ${images[0]}\n");
    printf(" Secondary Boot Image : ${images[1]}\n");
    if( Get_YN("Set Primary Boot to ${images[1]} (y/n)?", "n") ) {
      chdir '/tmp';
      if ( $is_uefi == 1 ) {
        my $cmd="awk '{print >out}; /^[[:space:]]*timeout=/{out=\"grub_conf2\"}' out=grub_conf1 ${GRUB_CONF}";
	if( $DEBUG ) { print "DEBUG:  cmd: |${cmd}|\n"; }
        system($cmd);
        $cmd="awk '{print >out}; /^[[:space:]]*}/{out=\"grub_part2\"}' out=grub_part1 grub_conf2 >& /dev/null";
	if( $DEBUG ) { print "DEBUG:  cmd: |${cmd}|\n"; }
        system($cmd);
      }
      else {
        my $cmd="awk '{print >out}; /^[[:space:]]*serial --unit=/{out=\"grub_conf2\"}' out=grub_conf1 $GRUB_CONF";
	if( $DEBUG ) { print "DEBUG:  cmd: |${cmd}|\n"; }
        system($cmd);
        $cmd="awk '{print >out}; /^[[:space:]]*initrd \\//{out=\"grub_part2\"}' out=grub_part1 grub_conf2";
	if( $DEBUG ) { print "DEBUG:  cmd: |${cmd}|\n"; }
        system($cmd);
      }
      if (( -f "grub_part1" ) && ( -f "grub_part2" ) && ( -f "grub_conf1" )) {
        $cmd="cat grub_conf1 > .grub.conf";
	if( $DEBUG ) { print "DEBUG:  cmd: |${cmd}|\n"; }
        system($cmd);
        $cmd="cat grub_part2 >> .grub.conf";
	if( $DEBUG ) { print "DEBUG:  cmd: |${cmd}|\n"; }
        system($cmd);
        $cmd="cat grub_part1 >> .grub.conf";
	if( $DEBUG ) { print "DEBUG:  cmd: |${cmd}|\n"; }
        system($cmd);
        if ( $is_uefi == 0 ) {
          if ( $is_boot_mnt == 1 ) {
	    if( $DEBUG ) { print "DEBUG:  Remounting Boot partition as writable\n"; }
            $i = system("mount -o remount,rw /boot");
            if ( $i != 0 ) {
              system("rm -f .grub.conf grub_*");
              printf("***** Error Occured, Unable to process grub operation *****\n");
              printf("***** Exiting ...                                     *****\n\n");
              exit $E_UNKNOWN;
            }
          }
	  if( $DEBUG ) { 
	    printf("DEBUG: Saving copies of the current and new grub config\n");
	    my $cmd="cp -f /boot/grub/grub.conf /tmp";		print "DEBUG: cmd: |${cmd}|\n"; system($cmd);
	    $cmd="cp -f /boot/grub/grub.cfg /tmp";		print "DEBUG: cmd: |${cmd}|\n"; system($cmd);
	    $cmd="cp -f .grub.conf /tmp/.grub.conf.tmp";	print "DEBUG: cmd: |${cmd}|\n"; system($cmd);
	  }
          system("cp -f .grub.conf /boot/grub/grub.conf");
          system("cp -f .grub.conf /boot/grub/grub.cfg");
          if ( $sys_type =~ /pp332/ ) {
            system("cp -f /boot/grub/grub.conf /boot/grub/grub.conf-pp332");
          }
          elsif ( ( $sys_type =~ /pp833/ ) || ( $sys_type =~ /gluon/ ) || ( $sys_type =~ /bacardi/ )|| ( $sys_type =~ /ppf84/ )) { #PR 1533696 
            system("cp -f /boot/grub/grub.conf /boot/grub/grub.conf-pp833");
            system("cp -f /boot/grub/grub.conf /boot/grub/grub.conf-pp833_gluon");
            system("cp -f /boot/grub/grub.conf /boot/grub/grub.conf-glue");
          }
          if ( $is_boot_mnt == 1 ) {
	    if( $DEBUG ) { print "DEBUG:  Remounting Boot partition as read-only\n"; }
            system("mount -o remount,ro /boot");
          }
          else {
	    if( $DEBUG ) { print "DEBUG:  Copying Boot config to /flash/root\n"; }
            system("mount -o remount,rw /flash_root");
            system("rsync -a /boot/grub/ /flash_root/boot/grub/");
            system("mount -o remount,ro /flash_root");
          }
        }
        else {
	  if( $DEBUG ) { 
	    printf("DEBUG: Saving copies of the current and new grub config\n");
	    my $cmd="cp -f $GRUB_CONF /tmp";			print "DEBUG: cmd: |${cmd}|\n"; system($cmd);
	    $cmd="cp -f .grub.conf /tmp/.grub.conf.tmp";	print "DEBUG: cmd: |${cmd}|\n"; system($cmd);
	    print "DEBUG: diff cmd is \"diff -C 20 /tmp/.grub.conf.tmp /tmp/grub-startup.cfg\" \n";
	  }
          system("cp -f .grub.conf $GRUB_CONF");
          system("umount ${dev}2 >& /dev/null");
        }
        system("rm -f .grub.conf grub_*");
        printf("*******************************************************\n");
        printf("*** Primary Boot: changed to ${images[1]}\n");
      }
      else {
	if( $DEBUG ) { print "DEBUG: grub_part1 or grub_part2 or grub_conf1 dont exist...\n"; }
        if ( $is_uefi == 1 ) { 
          system("umount ${dev}2 >& /dev/null");
          if ( ! -f "${uefi_mnt_pnt}/EFI/BOOT/grub-startup.cfg" ) { system("rm -fr ${uefi_mnt_pnt}  >& /dev/null"); }
        }
        printf("\n***** Error Occured, Unable to process grub operation *****\n");
        printf("***** Exiting ...                                     *****\n\n");
        exit $E_UNKNOWN;
      }
    } 
    else {
      if( $DEBUG ) { print "DEBUG: Answer was \"no\"...\n"; }
      if ( $is_uefi == 1 ) { 
        system("umount ${dev}2 >& /dev/null");
        if ( ! -f "${uefi_mnt_pnt}/EFI/BOOT/grub-startup.cfg" ) { system("rm -fr ${uefi_mnt_pnt}  >& /dev/null"); }
      }
      printf("\n*******************************************************\n");
      printf("*** Primary Boot: NOT Modified\n");
      printf("*** Returning to Previous Menu\n");
      printf("*******************************************************\n");
      exit $E_UNKNOWN;
    }
  }
  elsif ( $i == 1 ) {
      if( $DEBUG ) { print "DEBUG: Since \$i is ${i}...\n"; }
      if ( $is_uefi == 1 ) { 
        system("umount ${dev}2 >& /dev/null");
        if ( ! -f "${uefi_mnt_pnt}/EFI/BOOT/grub-startup.cfg" ) { system("rm -fr ${uefi_mnt_pnt}  >& /dev/null"); }
      }
      printf("\n*******************************************************\n");
      printf("*** Primary Boot Image   : ${images[0]}\n");
      printf("*** Dual Image Does not Exist\n");
      printf("*** Please create Dual Image first and then \n");
      printf("*** use this option to select Boot option \n");
      printf("*******************************************************\n");
      exit $E_UNKNOWN;
  }
  else { 
      if( $DEBUG ) { print "DEBUG: Since \$i (number of partitions) is ${i}...\n"; }
      if ( $is_uefi == 1 ) { 
        system("umount ${dev}2 >& /dev/null");
        if ( ! -f "${uefi_mnt_pnt}/EFI/BOOT/grub-startup.cfg" ) { system("rm -fr ${uefi_mnt_pnt}  >& /dev/null"); }
      }
      printf("\n*******************************************************\n");
      printf("*** Error in $GRUB_CONF file\n");
      printf("\n*******************************************************\n");
      exit $E_UNKNOWN;
  }
  if ( $is_uefi == 1 ) { 
    system("umount ${dev}2 >& /dev/null");
    if ( ! -f "${uefi_mnt_pnt}/EFI/BOOT/grub-startup.cfg" ) { system("rm -fr ${uefi_mnt_pnt}  >& /dev/null"); }
  }
  exit $OK;
}

sub dualImg_cfg
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $read, $opts, $values ) = @_;
  if ( $read ) { dualImg_cfg_read( $opts, $values ); }
  else { dualImg_cfg_set( $opts, $values ); }
}
