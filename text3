sub snmpdconf_cfg
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $read, $opts, $values ) = @_;
  my ( %snmp );
  my $rtn = $OK;
  if ( $read ) { 
    snmpdconf_read( \%snmp, $opts ); 
    snmpdconf_check( \%snmp, $opts );
    snmpdconf_show( \%snmp, $opts );
  } else {
    if( defined($opts) && ($opts =~ /interactive/) ) { 
      snmpdconf_read( \%snmp, $opts );		# set hash from snmpd.conf
      snmpdconf_check( \%snmp, $opts );
      snmpdconf_set( \%snmp, $opts);		# ask user for config
      snmpdconf_check( \%snmp, $opts );
      snmpdconf_write( \%snmp );		# write to snmpd.conf
      snmpdconf_stop_start( \%snmp );		# start/stop snmpd daemon
    } else {
      snmpdconf_set( \%snmp, $opts, $values );	# set hash from passed string
      snmpdconf_check( \%snmp, $opts );
      snmpdconf_write( \%snmp );		# write to snmpd.conf
      snmpdconf_stop_start( \%snmp );		# start/stop snmpd daemon
    }
  }
  return $rtn;
}

#---------------------------------------------------------------------
sub snmpdconf_read
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $snmp, $opts ) = @_;
  if( $DEBUG ) { print "snmpdconf_read: Function Enter\n"; }
  my $num_cfgd_snmp = 0;
  my ($index, $p_err );
  # Initialize hash to all unused entries
  for($index=1;$index<=$MAX_SNMP_USERS;$index++) { 
    $snmp->{$index}{used} = "no"; }
  $snmp->{location} = "Unset";
  $snmp->{contact} = "Unset";
  $p_err = $OK;

  #----- Get config from file -----
  $index = 1;
  open(  READ, "< $SNMPDCONF" ) or return $NO_SUCH_FILE;
  while (<READ>) {
    # As of version 5.3.0.1, we use rwcommunity to setup v2c access
    # Format: rwcommunity <community name> [<ip>|default]
    # Note: default is equilavent to not specifying a server ip. In these
    # cases requests form ANY ip are serviced.
    if( $_ =~ /^(..)community6\s+(\S+)\s*(\S*)/ ) {
      if($DEBUG){print "snmpdconf_read: found IPv6 comm, USR $index\n"; }
      $snmp->{$index}{used}  = "yes";
      $snmp->{$index}{SNMPv} = 2;
      $snmp->{$index}{rw}    = $1;
      $snmp->{$index}{IPv}   = 6;
      $snmp->{$index}{comm}  = $2;
      $snmp->{$index}{ip}    = $3;
      $index++;
    } 
    elsif( $_ =~ /^(..)community\s+(\S+)\s*(\S*)/ ) {
      $snmp->{$index}{used}  = "yes";
      $snmp->{$index}{SNMPv} = 2;
      $snmp->{$index}{rw}    = $1;
      $snmp->{$index}{IPv}   = 4;
      $snmp->{$index}{comm}  = $2;
      $snmp->{$index}{ip}    = $3;
      $index++;
    } 
    elsif( $_ =~ /^createUser\s+([!-~]+)\s+\w+\s+"([!-~]+)"\s+\w+\s+([!-~]*)/ ) { # Aricent PR 1362733 fix PR-1846890
      $snmp->{$index}{used} = "yes";
      $snmp->{$index}{SNMPv} = 3;
      $snmp->{$index}{user} = $1;
      $snmp->{$index}{pass} = $2;
      # Aricent PR 1362733 fix - Start
      $snmp->{$index}{ip}   = $3;
      if($snmp->{$index}{ip} =~ /(\d+)\.(\d+)\.(\d+)\.(\d+)/) {
        $snmp->{$index}{IPv}   = 4;
      } else {
        $snmp->{$index}{IPv}   = 6;
      }
      # Aricent PR 1362733 fix - End
      $snmp->{$index}{rw} = "ro";	# only do read-only for now
      $index++;
    } 
    elsif( $_ =~ /^syslocation\s+\"(.+)\"/ ) {
      $snmp->{location} = $1;
    } elsif( $_ =~ /^syscontact\s+\"(.+)\"/ ) {
      $snmp->{contact} = $1;
    }
  }
  close ( READ );

  #----- Get daemon state -----
  $snmp->{state} = `$SELF -r -u daemon -o snmpd`; chomp($snmp->{state});
  $snmp->{state} =~ /ST(\d)/; $snmp->{state} = $1;
  if($DEBUG){print "snmpdconf_read: found state: $snmp->{state}\n"; }
  return $p_err;
}

