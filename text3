  else { xinetd_set( $opts, $values ); }
}

sub xinetd_read
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $service ) = @_;
  my $state = 0;
  open( READ, "< $XINETD_DIR/$service" ) or exit $NO_SUCH_SERVICE;
  while(<READ>) {
    if ( $_ =~ /\s*disable/) {      # look to see if service is disabled
      if ( $_ =~ /yes/ ) {    # It's disabled!
        $state = 0;
      } else {
        $state = 1;
      }
    }
  }
  close( READ );
  print STDOUT "ST$state\n";
  exit $OK;
}

sub xinetd_set
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $service, $string) = @_;
  my $parse_error = 0;
  if ( $string =~ /ST(\d)/ )      { $state = $1; }
  else { $parse_error = 1; }     # Problem getting state
  # Check for string parsing errors!
  # Check for valid service
  if ( ! -f "$XINETD_DIR/$service" ) { exit $NO_SUCH_SERVICE; }
  if ( $parse_error == 1 ) { xinetd_useage(); }
  if ( $state == 1 ) {        # Make sure service is enabled.
    replace_line( "$XINETD_DIR/$service","\\s*disable\\s*=\\s*yes","\tdisable = no");
  } else {           # Make sure service is disabled.
    replace_line( "$XINETD_DIR/$service","\\s*disable\\s*=\\s*no","\tdisable = yes");
  }
  FLUSH_ETC();
  # Must HUP xinetd to get it to reread config files
  hup( "xinetd" );
  exit $OK;
}


