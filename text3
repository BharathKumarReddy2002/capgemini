sub copy_logs_restore
{
  my $fn = (caller(0))[3]; fen($fn);
  my ($logs, $ip_self) = @_;
  if ( $logs != 8 && $logs != 16) {
    print STDOUT "Requested log key not valid for restore function.\nExiting . . .\n\n";
    exit $E_NOT_VALID;
  }
   my $is_ip = ( IsIP($ip_self) );
   if ( ! $is_ip ) {
      print STDOUT "The supplied IP address  is not in a valid format.\nExiting . . .\n\n";
      exit $NO_IP_FOUND;
   }
  my $tmp = "/tmp/";
  my $file_name = "";
  my $new_file = "";
  my $short_ident = "$ip_self"."_ident.tar";
  my $tar_ident = "/tmp/$short_ident";
  my $tgz_ident = "/tmp/$ip_self"."_ident.tgz";
  my $ident_label = "/tmp/label_file";
  my $settings_file = "/tmp/ownership_and_permissions.txt";  #PR 1906832
  my $kernel_file = "/tmp/kernel_release.txt";               #PR 1906832
  my $pre6 = $NO;

  #stop ctp daemon
  if( $DEBUG ) {print STDOUT "Stopping AcornSysMon.\n"; }
  system("AcornSysMon.pl", "-m");
  if( $DEBUG ) {print STDOUT "Stopping ctp daemon.\n"; }
  system("/etc/init.d/ctp", "stop");

  #find target tgz file
  if ( ! -f $tgz_ident ) {
    print STDOUT "Required file $tgz_ident not found.\nExiting . . .\n\n";
    exit $NO_SUCH_FILE;
  }

  #uncompress target file
  system ("tar", "-xzvC", "/", "-f", "$tgz_ident");  #PR :1874017
  if ( ! -f "$tar_ident" ) {
    print STDOUT "Required file $tar_ident was not found.\nExiting . . .\n\n";
    exit $NO_SUCH_FILE;
  } else {
    if( `tar tf $tar_ident` =~ /backuplogs/ ) {
      print STDOUT "**** Old identity was pre-6.0.\n";
      $pre6 = $YES;
    }
  }

   # Clean out named directories of old files
   if( $DEBUG ) {print STDOUT "Removing old files from system\n"; }
   foreach  $dir ( @CLEAN_DIRS ) {
      if( $DEBUG ) {print STDOUT "Cleaning directory $dir\n"; }
      system ("rm", "-f", "$dir");
      next;
   }

   # install (untar) the tar_ident file
   if( $DEBUG ) {print STDOUT "Restoring saved identity files.\n"; }
   #PR 1554086 start

   if( $pre6 ) {
     system("tar -xvC / -f $tar_ident --exclude system-auth --exclude init.ipv6-global --exclude network-functions --exclude pam.d --exclude ifup --exclude ifup-aliases --exclude ifup-post --exclude ifup-routes");    #Aricent PR 1304119 fix  # PR 1851876
   } else {
     system("tar -xvC / -f $tar_ident --exclude system-auth --exclude init.ipv6-global --exclude network-functions --exclude pam.d --exclude ifup --exclude ifup-aliases --exclude ifup-post --exclude ifup-routes");    #Aricent PR 1304119 fix # PR 1851876
   }
     
   system("tar -xvC / -f $tar_ident --exclude system-auth --exclude init.ipv6-global --exclude network-functions --exclude pam.d --exclude ifup --exclude ifup-aliases --exclude ifup-post --exclude ifup-routes");    #Aricent PR 1304119 fix # PR 1851876


   fix_ctp_ident_owner_perms(); #PR 1906832


   #PR 1554086 end
   # Next blocks are for restoring from pre-6.0R1 identity files....
   if( $pre6 ) {
     print STDOUT "**** Old identity was pre-6.0. Making system changes for new system.\n";
     fixup_restore_old()
   }

   # Make sure serial console does not get kernel messages (from CTPOS <= 6.0R1)
   no_kern_console_msg();

   # need to kill agetty process that is using /usr/local/etc/banner
   my $pid = `/usr/sbin/lsof -n | grep  /usr/local/etc/banner | egrep -o 'agetty[[:space:]]+[[:digit:]]+[[:space:]]+' | egrep -o '[[:digit:]]+'`;
   chomp $pid;
   if( $DEBUG ) {print STDOUT "pid=$pid\n"; }
   #PR 1554086 start
   if($pid ne ""){
     system ("/bin/kill", "$pid");
   }
   #PR 1554086 end
   # remove tar files
   if( $DEBUG ) {print STDOUT "Cleaning up /tmp directory.\n"; }
      system("rm", "-f", "$tgz_ident");
      system("rm", "-f", "$tar_ident");
      system("rm", "-f", "$ident_label");
      system("rm", "-f", "$settings_file");  #PR 1906832
      system("rm", "-f", "$kernel_file");    #PR 1906832

   # Aricent PR 1428842 fix - Start
   if ( -f $make_conf_file_edits ) {
      system("$make_conf_file_edits");
   }    # Aricent PR 1428842 fix - End

   # Record ID change in /etc/ctp/history
   if( $logs == 16 ) {
     my $hist_file = "/etc/ctp/history";
     if( -f "$hist_file" ) {
       my $date = localtime;
       open(WRITE,">> $hist_file");
       print WRITE "\n$date: Restored ID using $tgz_ident.\n\n";
       close(WRITE);
     }
   }
   
   # Back it all up to flash, no need for slow backup as we are restoring the CTP identity
   FLUSH();

   if( $logs == 16) {
      if( $DEBUG ) {print STDOUT "Rebooting CTP.\n"; }
      system("$SHUTDOWN", "-r", "now");
   }

    exit $OK;
}

