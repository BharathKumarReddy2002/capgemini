    }
    elsif ( ($key_value ne "") && (($key_value =~ /[^!-~]/) || $key_value =~ /[`'"]/) ) { #PR-1846890
        $parse_error = 1;
	print "Invalid key value\n Characters not allowed are backtick (\`), single quote ('), and double quote (\") are not allowed.\n"; #PR-1846890
    }
    elsif ( ($key_value ne "") && (length($key_value) >  31) ) {
       $parse_error = 1;
       print "Invalid key value\nKey value can be only 31 characters long";    # Aricent PR 1122855 fix
    }
