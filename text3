sub getSubnetInfo {
  my $fn = (caller(0))[3]; fen($fn);
  my ($ipaddr, $netmask) = @_;
  my $nbits=0;
  my @maskByteArray  = split /\./, $netmask;
  my $i = 0;
  #Aricent Fix PR 1133380 - start
  my $temp = 0;
  #Aricent Fix PR 1133380 - End
  foreach (@maskByteArray)
  {
    #Aricent Fix PR 1133380 - start
    my @ipByteArray  = split /\./, $ipaddr;
    #Aricent Fix PR 1133380 - End
    if($maskByteArray[$i] == 255) {$nbits+=8;}
    if($maskByteArray[$i] == 254) {$nbits+=7;}
    if($maskByteArray[$i] == 252) {$nbits+=6;}
    if($maskByteArray[$i] == 248) {$nbits+=5;}
    if($maskByteArray[$i] == 240) {$nbits+=4;}
    if($maskByteArray[$i] == 224) {$nbits+=3;}
    if($maskByteArray[$i] == 192) {$nbits+=2;}
    if($maskByteArray[$i] == 128) {$nbits+=1;}
    #Aricent Fix PR 1133380 - start
    $temp = $maskByteArray[$i] & $ipByteArray[$i];
    if($i == 0) {
      $ipaddr= "$temp.$ipByteArray[1].$ipByteArray[2].$ipByteArray[3]";
    }
    if($i == 1) {
      $ipaddr= "$ipByteArray[0].$temp.$ipByteArray[2].$ipByteArray[3]";
    }
    if($i == 2) {
      $ipaddr= "$ipByteArray[0].$ipByteArray[1].$temp.$ipByteArray[3]";
    }
    if($i == 3) {
      $ipaddr= "$ipByteArray[0].$ipByteArray[1].$ipByteArray[2].$temp";
    }
    #Aricent Fix PR 1133380 - End
    $i = $i + 1;
  }
  return ($ipaddr, $nbits);
}


