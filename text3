sub users_set
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $cmd, $args ) = @_;
  my $error = "error";
  my ( $group, $name, $passwd ) = "$error";;
  my $status = 0;

  #--- Parse args for group, user, & passwd
  #print "Got cmd $cmd and args $args \n";
  if ( $args =~ /GRadmin\:?/ ) { $group = " ";  }
  elsif ( $args =~ /GRuser\:?/ ) { $group = "acorn";  }
  else { $group = $error; }      # Didn't get group
  if ( $args =~ /NM([\w\.]+)\:?/ ) { $name = $1;  }
  else { $name = $error; }    # Didn't get username
  if ( $args =~ /PW([^:]+)\:?/ ) { $passwd = $1;  }
  else { $passwd = $error; }     # Didn't get passwd

  if ( $cmd =~ /add/i ) {
    #print "Adding $name to group $group \n";
    #--- Add a user ( must flush new user dir to /altflash)
    if ( $group eq $error ) { users_useage(); }
    if ( $name  eq $error ) { users_useage(); }
    if ( $name eq "root" ) { users_useage(); }
    if ( $name eq "ctp_cmd" ) { users_useage(); }
    if ( $name eq "ctp" ) { users_useage(); }

    $status = system("$ADD_USER $name $group");
    if ( $status != 0 ) {
      print "Got nonzero status when trying to add $name \n";
    }

  } elsif ( $cmd =~ /del/i ) {
    #--- Del a user (must remove dir on /altflash)
    #    Don't allow to delete default acorn users (ctp & ctp_cmd)
    if ( $name eq $error )    { users_useage(); }
    if ( $name eq "root" )    { users_useage(); }
    if ( $name eq "ctp_cmd" ) { users_useage(); }
    if ( $name eq "ctp" )     { users_useage(); }
    $status = system("/usr/sbin/userdel", "-r", "$name");
    system("/usr/sbin/groupdel", "$name");
    FLUSH_ETC();
    FLUSH_HOME();
    if ( $status != 0 ) {
      print "Got nonzero status when trying to remove $name\n";
    }

  } elsif ( $cmd =~ /pass/i ) {
    #--- Change a passed
    if ( $passwd eq $error ) { users_useage(); }
    if ( $name   eq $error ) { users_useage(); }
    if ( $name   eq "root" ) { users_useage(); }
    #$status = `echo $passwd | $PASSWD --stdin $name`;
    $status = `echo "$name:$passwd" | chpasswd`;
    FLUSH_ETC();
    #print "Changed password for user $name to $passwd.\n";
    #if ( $status ne " ") {
    #  print "Got nonzero status when trying to change password for $name: $status\n";
    #}
  } else {
    exit $E_UNKNOWN;
  }
  exit $OK;
}

