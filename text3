sub add_iptables
{
  my $fn = (caller(0))[3]; fen($fn);
    # Adding Rule for IPV6
    my $chk_rule=`$SED -n '/:INPUT/p' $IP6TABLESCONF | head -1 | $AWK '{print \$2}'`;
    chomp($chk_rule);
    my $iptable_flag = 0;
    if( $chk_rule =~ /ACCEPT/ ) {
     `$SED -i '1,/INPUT ACCEPT/s/INPUT ACCEPT/INPUT DROP/' $IP6TABLESCONF`;
      $iptable_flag++;
    }
    # Adding Rule for IPV4
    $chk_rule=`$SED -n '/:INPUT/p' $IPTABLESCONF | head -1 | $AWK '{print \$2}'`;
    chomp($chk_rule);
    if( $chk_rule =~ /ACCEPT/ ) {
     `$SED -i '1,/INPUT ACCEPT/s/INPUT ACCEPT/INPUT DROP/' $IPTABLESCONF`;
      $iptable_flag++;
    }
    if($iptable_flag) {
      #Aricent PR-1059814 Fix Start 
      my $proto = `cat /etc/sysconfig/ctp | grep CTP_PROTOCOL | cut -f2 -d'='`;
      chomp($proto);
      if ( $proto eq "" ) {
       `$SED -i '/address-mask-request/a -A INPUT -p 47 -j ACCEPT' $IPTABLESCONF`;
       } else {
        `$SED -i '/address-mask-request/a -A INPUT -p $proto -j ACCEPT' $IPTABLESCONF`;
      }
      #Aricent PR-1059814 Fix End 
      print "\nIptables rules has been changed. Restarting ctpd..\n";
      system("$CTPD stop > /dev/null 2>&1");
      system("$NETWORK stop > /dev/null 2>&1");     # Aricent PR 1056980 and 1056982 fix
      system("$IP6TABLES restart > /dev/null 2>&1");
      system("$IPTABLES restart > /dev/null 2>&1");
      system("$NETWORK start > /dev/null 2>&1");    # Aricent PR 1056980 and 1056982 fix
      system("$CTPD start > /dev/null 2>&1");
      $iptable_flag = 0;
    }
}
sub clear_iptables
{
  my $fn = (caller(0))[3]; fen($fn);
    # Removing Rule for IPV6
    my $chk_rule=`$SED -n '/:INPUT/p' $IP6TABLESCONF | head -1 | $AWK '{print \$2}'`;
    chomp($chk_rule);
    my $iptable_flag = 0;
    if( $chk_rule =~ /DROP/ ) {
     `$SED -i '1,/INPUT DROP/s/INPUT DROP/INPUT ACCEPT/' $IP6TABLESCONF`;
      $iptable_flag++;
    }
    # Removing Rule for IPV4
    $chk_rule=`$SED -n '/:INPUT/p' $IPTABLESCONF | head -1 | $AWK '{print \$2}'`;
    chomp($chk_rule);
    if( $chk_rule =~ /DROP/ ) {
     `$SED -i '1,/INPUT DROP/s/INPUT DROP/INPUT ACCEPT/' $IPTABLESCONF`;
      $iptable_flag++;
    }

    if($iptable_flag) {
      #Aricent PR-1059814 Fix Start 
      my $proto = `cat /etc/sysconfig/ctp | grep CTP_PROTOCOL | cut -f2 -d'='`;
      chomp($proto);
      if ( $proto eq "" ) {
       `$SED -i '/-A INPUT -p 47 -j ACCEPT/,+d' $IPTABLESCONF`;
