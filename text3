sub ethernet_read
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $opt, $eth_dev ) = @_;
  if ( ! defined $eth_dev ) { $eth_dev = get_dflt_dev(); }# qry running dflt dev

  #strip off vlan id to be only ethernet physical port.
  if($eth_dev =~ /^eth(\d+)\.(\d+)$/) {
    $eth_dev = "eth$1";
  }

  my $num_eth  = get_num_eth();
  my $eth_num = 0;
  my $desc = "";
  if ( ($num_eth > 1) && ( $opt =~ /interactive/i ) ) {
    print "Here is a list of the available ethernet devices and their descriptions:\n";
    my $i=0;
    while ( $i < $num_eth ) {
      if( eth_dev_up("eth$i") ) { $desc = get_eth_desc($i); print "\teth$i: $desc\n"; }
      $i++;
    }
    do {
      print "Please input the device to display the media for: ";
    } while ( !(<STDIN> =~ /eth(\d+)/) || !($1 < $num_eth) );
    $eth_dev = "eth$1";
    $eth_num = $1;
    print "\n";
  }
  $desc = get_eth_desc($eth_num);
  if( $desc =~ /fiber/i ) {
    print "***** This is a $desc interface *****\n";
    exit $OK;
  }
  # Check to see that device is UP
  if( eth_dev_up("$eth_dev") ) {
    my $eth_module = get_eth_module("$eth_dev");
    print ("\n");
    if( "$eth_module" =~ /via|natsemi|e1000|r8169/ ) {
      system("$ETHTOOL", "$eth_dev");
    } else {
      system("$MII_TOOL", "-v", "$eth_dev");
    }
    print ("\n");
  } else {
    print "\nDevice is not UP. Can only query media for devices that are active.\n\n";
    exit $E_UNKNOWN;
  }
  exit $OK;
}

sub ethernet_set
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $opts, $values ) = @_;
  if( $VCTP == 1){
    print "Ethernet media configuration is not supported for vCTP\n";
    exit $OK;
  }
  my $auto   = 1;               # Default autoneg.
  my $speed  = 0;
  my $duplex = 0;
  my $cnt    = 0;
  my $eth_dev = get_cfg_dflt_dev();
  my $eth_num = 0;
  my $num_eth  = get_num_eth();
  if ( ($num_eth > 1) && ( $opts =~ /interactive/i ) ) {
    print "Here is a list of the available ethernet devices and their descriptions:\n";
    my $i=0;
    while ( $i < $num_eth ) {
      if( eth_dev_cfgd("eth$i") ) { my $desc = get_eth_desc($i); print "\teth$i: $desc\n"; }
      $i++;
    }
    do {
      print "Please input the device to configure the media for: ";
    } while ( (!(<STDIN> =~ /eth(\d+)/) || !($1 < $num_eth)) || !eth_dev_up("eth$1") );
    $eth_dev = "eth$1";
    $eth_num = $1;
    print "\n";
  }
  # Check to see that it is not fiber
  if( get_eth_desc($eth_num) =~ /fiber/i ) {
    print "***** Sorry, you cannot configure the media for fiber interfaces *****\n";
    print "*****                   Hit return to continue.                  *****\n";
    my $rtn = <STDIN>;
    exit $OK;
  }
  #strip off vlann id to be only ethernet physical port.
  if($eth_dev =~ /^eth(\d+)\.(\d+)$/) {
    $eth_dev = "eth$1";
  }

  # Grab module used for eth from modules.conf
  my $eth_module = get_eth_module("$eth_dev");
  if ( "$eth_module" eq "none" ) {
    print "Could not determine module used for ethernet!\n";
    return $E_UNKNOWN;
  }
  #--- Parse the values.
  if( (defined $opts) && ($opts =~ /interactive/i) ){
    $auto = Get_YN("Configure $eth_dev ($eth_module) for autonegotiation?", "y");
    if ( $auto == 0 ) {
     # Aricent fix for PR-902243 Start
     if(Get_YN("Configure $eth_dev for 100 Mbps", "y") ) {
        $speed=100;
      } else {
         print "OK, setting speed to 10 Mbps.\n";
         $speed=10;
     }
    # Aricent fix for PR-902243 End 
    }
  } elsif ( defined $values ) {
    if ( $values =~ /auto/i ) { $auto = 1; } else { $auto = 0; }
    #print "Got auto = $auto\n";
    if ( $auto == 0 ) {           # manual??
      if ( $values =~ /full/i ) {
   $duplex = 2;
      } elsif ( $values =~ /half/i ) {
   $duplex = 1;
      }
      if ($values =~ /1000/ ) {
        if( "$eth_module" =~ /e1000/ ) {
     $speed = 1000;
        }
      } elsif ( $values =~ /100/ ) {
   $speed = 100;
      } elsif ( $values =~ /10/ ) {
   $speed = 10;
      }
    #print "Got speed = $speed & duplex = $duplex\n";
    }
    if ( ($auto == 0) && ($speed == 0) && ($duplex == 0) ) {
      ethernet_useage();
    }
  } else {
    ethernet_useage();
  }

  if( $DEBUG ) { print "Got auto = $auto, speed = $speed & duplex = $duplex\n"; }
  if ( "$eth_module" =~ /(sis900|eepro)/ ) {
    my $match = "options\\s*$eth_module";
    # Note, this passes 0's for autoneg.
    my $new_str = "options $eth_module Speed=$speed Duplex=$duplex";
    $cnt = replace_line( "$MODULES_CONF", "$match", "$new_str" );
    #print "Lines replaced = $cnt\n";
    if ( $cnt == 0 ) {    # Must add the line by hand!
      `/bin/echo "$new_str" >> $MODULES_CONF`;
    }
    FLUSH_ETC();
  } elsif ( "$eth_module" =~ /(via|natsemi|e1000|r8169)/ ) {
    #Set media options by adding ETHTOOL_OPTS="" to ifcfg-eth
    if ($DEBUG) { print "Got $eth_module to configure with ETHTOOL_OPTS\n";}
    my $IFCFG_FILE = "$NETSCRIPTS_DIR/ifcfg-$eth_dev";
    my $tmp_file   = "/tmp/foo";
    if( $auto ) {
      `$GREP -v ETHTOOL_OPTS $IFCFG_FILE > $tmp_file`;
    } else {
	# Aricent fix for PR-902243 Start
       `$GREP -v ETHTOOL_OPTS $IFCFG_FILE > $tmp_file`;
       `echo "ETHTOOL_OPTS=\\\"autoneg off speed $speed duplex full\\\"" >> $tmp_file`;
	# Aricent fix for PR-902243 End 
    }
    system("/bin/mv", "-f", "$tmp_file", "$IFCFG_FILE");
    FLUSH_ETC();
  } else {
    # Either tulip or unsupported -> do nothing
  }
  exit $OK;
}

sub get_eth_module
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $eth_dev ) = @_;
  my $eth_module = "none";
  #in case of vlan ....
  my $found = 0;
  my $dev_num = 0;
  my $last_mod = "none";
  my $last_num = 0;
  if( "$eth_dev" =~ /eth(\d)/ ) { $dev_num = $1; }
  open ( READ, "< $MODULES_CONF" ) or exit $NO_SUCH_FILE;
  while( <READ> ) {
    if( !$found ) {      # Returns LAST instance of match!
      if( $_ =~ /^alias\s+eth(\d)\s+(\w+)/ ) {
   if( ($1 < $dev_num) && ($1 >= $last_num) ) {
     $last_num = $1;
     $last_mod = $2;
   }
      }
      if( $_ =~ /^alias\s+$eth_dev\s+(\w+)/ ) {
   $eth_module = $1;
   $found = 1;
      }
    }
  }
  close ( READ );
  if( $eth_module =~ /none/ ) { $eth_module = "$last_mod"; }
  return "$eth_module";
}

