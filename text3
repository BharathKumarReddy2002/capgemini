        print WRITE "$_";
      }
    }
    close(READ);
    close(WRITE);
    system("/bin/mv", "-f", "$tmp_file", "$NETWORKFILE");
  }

#Read the configuration
  open(READ, "< $SYSCFG_CTP") or exit $E_UNKNOWN;
