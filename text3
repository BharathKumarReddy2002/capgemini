sub add_vlan
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $vlan_cnt ) = @_;
  my $vlan_id = 0;
  if($vlan_cnt >= $MAX_VLAN) {
    print "$vlan_cnt VLANS are already configured on the system\n";
    print "deletion of a vlan is required prior to addition of a new vlan \n";
  } else {
    my $num_eth = get_num_eth();
#PR-1855200 Start
    print "\nEthernet interfaces available for VLAN configuration:\n";

    my %configurable_eths;
    foreach my $i (@GLOB_ETH_DEVS_LIST) {
      chomp $i;
      my $desc = get_eth_desc( $i ); 
      my $type = ($desc =~ /Virtual Bridge/i) ? "Virtual Bridge" : "Physical";
      $configurable_eths{$i} = $type;

      printf("  [%2d] eth%-2d  (%s interface)\n", $i, $i, $type);
    }

    my @configurable_ids = sort { $a <=> $b } keys %configurable_eths;

    while (1) {
      $dev_id = Get_Int("Enter the Ethernet device number to add VLAN on from above list of interfaces", 0, 99, 0);
      last if grep { $_ == $dev_id } @configurable_ids;
      print "Invalid choice. Please select a valid device from the list above.\n";
    }
#PR-1855200 End
    my $vlan_id = Get_Int("What is the new VLAN id?", 0, $MAX_VLAN_ID, 0);

    if( -f "$NETSCRIPTS_DIR/ifcfg-eth$dev_id.$vlan_id") {
      print "This VLAN is already added !\n";
    } else {
      system("touch $NETSCRIPTS_DIR/ifcfg-eth$dev_id.$vlan_id ");
      FLUSH_ETC();
    }
  }
}

