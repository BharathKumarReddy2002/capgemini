sub verifyIP
{
  my $fn = (caller(0))[3]; fen($fn);
  my $ip = shift;
  my $rtn = 1;
  my $pattern_v4= '^0*([1-9]?\d|1\d\d|2[0-4]\d|25[0-5])\.0*([1-9]?\d|1\d\d|2[0-4]\d|25[0-5])\.0*([1-9]?\d|1\d\d|2[0-4]\d|25[0-5])\.0*([1-9]?\d|1\d\d|2[0-4]\d|25[0-5])$';
  my $pattern_v6 = '^((([0-9A-Fa-f]{1,4}:){7}[0-9A-Fa-f]{1,4})|(([0-9A-Fa-f]{1,4}:){6}:[0-9A-Fa-f]{1,4})|(([0-9A-Fa-f]{1,4}:){5}:([0-9A-Fa-f]{1,4}:)?[0-9A-Fa-f]{1,4})|(([0-9A-Fa-f]{1,4}:){4}:([0-9A-Fa-f]{1,4}:){0,2}[0-9A-Fa-f]{1,4})|(([0-9A-Fa-f]{1,4}:){3}:([0-9A-Fa-f]{1,4}:){0,3}[0-9A-Fa-f]{1,4})|(([0-9A-Fa-f]{1,4}:){2}:([0-9A-Fa-f]{1,4}:){0,4}[0-9A-Fa-f]{1,4})|(([0-9A-Fa-f]{1,4}:){6}((\b((25[0-5])|(1\d{2})|(2[0-4]\d)|(\d{1,2}))\b)\.){3}(\b((25[0-5])|(1\d{2})|(2[0-4]\d)|(\d{1,2}))\b))|(([0-9A-Fa-f]{1,4}:){0,5}:((\b((25[0-5])|(1\d{2})|(2[0-4]\d)|(\d{1,2}))\b)\.){3}(\b((25[0-5])|(1\d{2})|(2[0-4]\d)|(\d{1,2}))\b))|(::([0-9A-Fa-f]{1,4}:){0,5}((\b((25[0-5])|(1\d{2})|(2[0-4]\d)|(\d{1,2}))\b)\.){3}(\b((25[0-5])|(1\d{2})|(2[0-4]\d)|(\d{1,2}))\b))|([0-9A-Fa-f]{1,4}::([0-9A-Fa-f]{1,4}:){0,5}[0-9A-Fa-f]{1,4})|(::([0-9A-Fa-f]{1,4}:){0,6}[0-9A-Fa-f]{1,4})|(([0-9A-Fa-f]{1,4}:){1,7}:))$';

  $ip = "" unless $ip;
  if ( $ip =~ /$pattern_v4/ ){
     $rtn = 0;
  }
  elsif ( $ip =~ /$pattern_v6/ ){
     $rtn = 0;
  }
  return $rtn;

}
# Aricent PR 1122855 fix - End

sub ntp_set             # Only one server!
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $string ) = @_;
  my $sip = "";
  my $s1ip = "";
  my $state = 0;
  my $key_id = "";
  my $key_value = "";
  my $key_id1 = "";
  my $key_value1 = "";
  my $secondip = 0;
  my $tmp = "/tmp/foo";
  my $parse_error = 0;
  # Aricent PR 1362733 fix - Start
  my $old_sip = `$GREP "server" $NTP_CONF | $GREP -v "#" | $AWK 'NR==1{print \$2}'`;
  my $old_s1ip = `$GREP "server" $NTP_CONF | $GREP -v "#" | $AWK 'NR==2{print \$2}'`;
  my $old_state = 0;
  my $old_ntp_procs=0; $old_ntp_procs += `ps aux | $GREP "ntpd" | $GREP -v "grep" | wc -l | $AWK '{print \$1}'`;
  if ( ( -f $NTP_START ) && ( $old_ntp_procs != 0 ) ) { $old_state = 1; }
  else { $old_state = 0; }
  my $old_key_id = `$CAT $NTP_KEYS | $AWK 'NR==1{print \$1}'`;
  my $old_key_value = `$CAT $NTP_KEYS | $AWK 'NR==1{print \$3}'`;
  my $old_key_id1 = `$CAT $NTP_KEYS | $AWK 'NR==2{print \$1}'`;
  my $old_key_value1 = `$CAT $NTP_KEYS | $AWK 'NR==2{print \$3}'`;
  chomp($old_sip); chomp($old_s1ip); chomp($old_key_id);
  chomp($old_key_value); chomp($old_key_id1); chomp($old_key_value1);
  # Aricent PR 1362733 fix - End
  if ( $string =~ /SIP(\d+\.\d+\.\d+\.\d+|$IPV6ADDFORMAT):KID/ )  { $sip = $1; }
  elsif ($string =~ /SIP($IPV6ADDFORMAT):KID/ ) { $sip = $1; } # Aricent PR 1362866 fix
  else { $parse_error = 1; print "SIP problem\n"; }   # Problem getting receiver ip
  if ( $string =~ /KID(.*?):SS(.*?):ST/ )  { $key_id = $1; $key_value = $2; }
  if ( $string =~ /ST(0|1)/ )      { $state = $1;}
  else { $parse_error = 1; print "ST problem\n"; } # Problem getting state
  # Aricent PR 1122857 fix - Start
  if ( $string =~ /\:S1IP(.*?):K1ID/ )  { $s1ip = $1; }    # Aricent PR 1142788 fix
  if ( $string =~ /K1ID(.*?):SS1(.*)/ ) { $key_id1 = $1; $key_value1 = $2;  }
  # Aricent PR 1122857 fix - End

  if ( ($sip ne "") && ($parse_error == 0) ){ 
    # Aricent PR 1122855 fix - Satrt
    if ( verifyIP($sip) == 1 ) {
      $parse_error = 1;
      print "Invalid IP address\n";
    }
    elsif ( ($key_id eq "") && ($key_value ne "") ) {
      $parse_error = 1;
      print "Please enter key ID\n";
    }
    # Aricent PR 1122855 fix - End
    elsif ( ($key_id ne "") && ($key_value eq "") ) {
      $parse_error = 1;
      print "Please enter key value\n";    #Aricent PR 1124693 fix
    }
    elsif ( ($key_id ne "") && ($key_id =~ /\D+/) ) {
        $parse_error = 1;
