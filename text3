sub get_eth_cfg_from_file {
  my $fn = (caller(0))[3]; fen($fn);
  my ( $eth_dev ) = @_;
  my $success = 0;
  my $ip = "127.0.0.1";       # Default
  my $nm = "255.255.255.0";      # Default
  my $gw = "127.0.0.1";       # Default
  my $en = "no";       # Default
  my $mtu = 1500;       # Default
  my $ifcfg_file = "$NETSCRIPTS_DIR/ifcfg-$eth_dev";
  if ( -f "$ifcfg_file" ) {
    open( READ, "< $ifcfg_file" );
      while (<READ>) {
        if( $_ =~ /IPADDR=($OCTET\.$OCTET\.$OCTET\.$OCTET)/ )	{ $ip = $1;  $success |= 0x1; }
        if( $_ =~ /NETMASK=($OCTET\.$OCTET\.$OCTET\.$OCTET)/ )	{ $nm = $1;  $success |= 0x2; }
        if( $_ =~ /GATEWAY=($OCTET\.$OCTET\.$OCTET\.$OCTET)/ )	{ $gw = $1;  $success |= 0x4; }
        if( $_ =~ /MTU=(\d+)/ )					{ $mtu = $1; $success |= 0x8; }
        if( $_ =~ /ONBOOT=(\w+)/ )				{ $en = $1;  $success |= 0x10; }
      }
    close(READ);
  }
  fex($fn);
  return $success, "$ip", "$nm", "$gw", "$mtu" , "$en";
}

