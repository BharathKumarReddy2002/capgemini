sub get_active_dflt_eth_params {
  my $fn = (caller(0))[3]; fen($fn);
  my ( $ipaddr, $netmask ) = ( "0.0.0.0", "0.0.0.0" );
  my $gateway = get_gw();
  my $eth_dev = get_dflt_dev();
  if ( $eth_dev =~ /(eth(\d+))/ ) {
    my $dev_num = $1;
    my $rtn = `$IFCONFIG $1 | grep addr`;
    ($ipaddr, $netmask ) = get_ip_nm( $dev_num );
  } else {
    # dflt gw not attached to an ethernet device!!
  }
  return "$eth_dev", "$ipaddr", "$netmask", "$gateway";
}

sub eth_dev_read {
  my $fn = (caller(0))[3]; fen($fn);
  my ( $cmd ) = @_;
  my ( $eth_dev, $ipaddr, $netmask, $gateway ) = get_active_dflt_eth_params();
  if ( $cmd =~ /all/i ) {
    print "$eth_dev:IPADDR$ipaddr:NETMASK$netmask:GATEWAY$gateway\n";
  } elsif ( $cmd =~ /eth/i )    {
    print "$eth_dev\n";
  } elsif ( $cmd =~ /ipaddr/i ) {
    print "$ipaddr\n";
  } elsif ( $cmd =~ /netmask/i )   {
    print "$netmask\n";
  } elsif ( $cmd =~ /gateway/i )   {
    print "$gateway\n";
  } else {
    if( $eth_dev =~ /eth(\d+)/ ) { print "$1\n"; }
    else { print "0\n"; exit $E_NO_DEV; }
  }
  exit $OK;
}

sub eth_dev_set
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $opts, $values ) = @_;
  my ( $cur_dev, $ipaddr, $netmask, $gateway ) = get_active_dflt_eth_params();
  if( $cur_dev =~ /eth(\d+)/ ) {
    my $old_dev_num = $1;  # default to eth0!!
    if ($DEBUG) { print "Got cur_dev $cur_dev\n"; }
    if( defined($values) ) {
      my $new_dev_num = 0;    # default to eth0!!
      my $new_dev = "$values";
      if( $new_dev =~ /eth(\d+)/ ) { $new_dev_num = $1; }
      if( $new_dev eq $cur_dev ) {
   if( $DEBUG ) { print "Already using $cur_dev, nothing to do...\n"; }
   exit $OK;
      } else {
   my $dev_exists = system("$IFCONFIG $new_dev > /dev/null");
   if( $DEBUG ) { print "Got dev_exists $dev_exists\n"; }
   if( $dev_exists == 0 ) {   # It's there!!
     if ($DEBUG) { print "OK, lets set up eth$new_dev_num.\n"; }
     # Tell ctpd to switch devices in nid structure.
     # log_it(LOG_ERR, "About to issue $CMD node cfg www_nid for old $old_dev_num & new $new_dev_num");
     if( system("$CMD", "-n", "node", "cfg", "www_nid", "OldDevNum", "$old_dev_num", "NewDevNum", "$new_dev_num") ){
       log_it(LOG_ERR, "cmd node cfg www_nid returned 1 for old $$old_dev_num & new $new_dev_num tyr again.");
       sleep 5;
       if( system("$CMD", "-n", "node", "cfg", "www_nid", "OldDevNum", "$old_dev_num", "NewDevNum", "$new_dev_num") ){
         log_it(LOG_ERR, "cmd node cfg www_nid failed twice");
         exit $E_UNKNOWN;
       }
     }
     # Aricent Fix for PR 860455 Start
     bndl_state_change("$cur_dev", "0"); #Going to disable the bundle's created on the given eth
     sleep 1;
     # Aricent Fix for PR 860455 End
     my $broadcast=`$IFCONFIG $cur_dev | $GREP Bcast | $AWK '{print \$3}' | cut -d":" -f2`; #Fix PR-874076
     # Take down old device.
     system("$IFCONFIG", "$cur_dev", "down");
     if( -f "$IFDOWN_LOCAL") { system("$IFDOWN_LOCAL", "$cur_dev"); }
     if ($DEBUG) { print "\t$cur_dev down.\n"; }
          # Bring up new device. Must add address and netmask & defaulot route!
     system("$IFCONFIG", "$new_dev", "$ipaddr", "broadcast", "$broadcast", "netmask", "$netmask", "up"); # Fix PR-874076
     if ($DEBUG) { print "\t$new_dev up with ip $ipaddr & netmask $netmask.\n"; }
     system("$ROUTE", "add", "default", "gw", "$gateway", "$new_dev");
     if ($DEBUG) {print "\tDefault gw ($gateway) added.\n"; }
     #Aricent PR 1080510 Fix - Start
     my $eth_dflt=$cur_dev;
     my @eth_array = `$GREP -n "ONBOOT=yes" $NETSCRIPTS_DIR/ifcfg-eth* | $AWK -F":" '{print \$1}' | $FGREP -v "\." | $AWK -F"-" '{print \$3}'`;
     foreach my $eth_if (@eth_array) {
       chomp($eth_if);
       $eth_AAS = `$SYSCFG -r -u AAS -o $eth_if`;
       chomp($eth_AAS);
       if ( $eth_AAS =~ /AVAILABLE1/ ) {
         $eth_dflt=$eth_if;
         last;
       }
     }
     if( -f "$NETSCRIPTS_DIR/route-$eth_dflt") {
       open (READ, "< $NETSCRIPTS_DIR/route-$eth_dflt");
       while (<READ>) {
         system("/sbin/ip route add $_");
       }
       close(READ);
     }
     #Aricent PR 1080510 Fix - End
     if( -f "$IFUP_LOCAL") { system("$IFUP_LOCAL", "$new_dev","$ipaddr"); } #Aricent PR 736115
     # Aricent Fix for PR 860455 Start
     sleep 1;
     SwitchVlanConfig($cur_dev, $new_dev, $eth_dflt);  #Aricent PR 971882 and 1080510 Fix
     bndl_state_change("$cur_dev", "1"); #Going to activate the bundle's created on the given eth
     # Aricent Fix for PR 860455 End 
   } else {
     if( $DEBUG ) { print "Device $new_dev does not seem to exist.\n"; }
     exit $E_NO_DEV;
   }
      }
    } else {
      if( $DEBUG ) { print "Did not find device number passed to me!\n"; }
      eth_dev_useage();
    }
  } else { # Didn't find current device
    exit $E_NO_DEV;
  }
  exit $OK;
}

#Aricent PR 971882 fix - start
sub SwitchVlanConfig {
  my $fn = (caller(0))[3]; fen($fn);
  my ($cur_dev, $next_dev, $dflt_dev) = @_;   #Aricent PR 1080510 Fix
  my $vlan_id;
  my $ret;
  my $switch_flag;
  my $ipaddr;
  my $netmask;
  my $broadcast;
  my $vlan_mtu;         #Aricent PR 1101373 Fix
  my $command_str;
  my $tmpdev_file = "/tmp/eth_vlan";
  open (WRITE, "> $tmpdev_file");
  system("$IFCONFIG -a | $GREP $cur_dev | $AWK '{print \$1}' > $tmpdev_file");
  close (WRITE);
  open (READ, "< $tmpdev_file");
  while (<READ>) {
    if( $_ =~ /$cur_dev.(\d+)$/) {
      $vlan_id = $1;
      $switch_flag = 0;
      $ipaddr = 0;
      $netmask = 0;
      $broadcast = 0;
      $vlan_mtu = 1500;       #Aricent PR 1101373 Fix
      # Add VLAN interface to next device if it is not already present
      if( system("$IFCONFIG $next_dev.$vlan_id > /dev/null") ) {
        $ret = system("/usr/sbin/vconfig add $next_dev $vlan_id > /dev/null");
        if ($ret == 0) {
          $switch_flag = 1;
        }
        else {
          log_it(LOG_ERR, "Could not create vlan interface $next_dev.$vlan_id");
        }
      }
      else {
        $switch_flag = 1;
      }
      if ( $switch_flag == 1 ) {
        my $old_dev_num;
        my $new_dev_num;
        if( $cur_dev =~ /eth(\d+)/ ) {
          $old_dev_num = $1;
        }
        if( $next_dev =~ /eth(\d+)/ ) {
          $new_dev_num = $1;
        }
        $command_str = `$CMD -n node cfg www_nid vlan $vlan_id OldDevNum $old_dev_num NewDevNum $new_dev_num`;
        if ( $? ) {
          log_it(LOG_ERR, "cmd node cfg www_nid failed for old $old_dev_num.$vlan_id & new $new_dev_num.$vlan_id. Try again");
          $command_str = `$CMD -n node cfg www_nid vlan $vlan_id OldDevNum $old_dev_num NewDevNum $new_dev_num`;
          if ( $? ) {
            log_it(LOG_ERR, "cmd node cfg www_nid failed twice");
            exit $E_UNKNOWN;
          }
        }
        if( -f "$IFDOWN_LOCAL") {
          system("$IFDOWN_LOCAL", "$cur_dev.$vlan_id");
        }
        $ipaddr = `$IFCONFIG $cur_dev.$vlan_id | $GREP "inet addr" | $AWK '{print \$2}' | cut -d":" -f2`;
        $netmask = `$IFCONFIG $cur_dev.$vlan_id | $GREP Mask | $AWK '{print \$4}' | cut -d":" -f2`;
        $broadcast = `$IFCONFIG $cur_dev.$vlan_id | $GREP Bcast | $AWK '{print \$3}' | cut -d":" -f2`;
        $vlan_mtu = `$IFCONFIG $cur_dev.$vlan_id | $GREP MTU | $AWK -F"MTU:" '{print \$2}' | $AWK '{print \$1}'`;  #Aricent PR 1101373 Fix
        chomp($broadcast);
        chomp($ipaddr);
        chomp($netmask);
        #Aricent PR 1101373 Fix - Start
        chomp($vlan_mtu);
        if ( $ipaddr && $netmask && $broadcast && $vlan_mtu ) {
          $ret = system("$IFCONFIG", "$next_dev.$vlan_id", "$ipaddr", "broadcast", "$broadcast", "netmask", "$netmask", "mtu", "$vlan_mtu", "up");
          #Aricent PR 1101373 Fix - End
          #Aricent PR 1080510 Fix - Start
          if( -f "$NETSCRIPTS_DIR/route-$dflt_dev.$vlan_id") {
            open (READFILE, "< $NETSCRIPTS_DIR/route-$dflt_dev.$vlan_id");
            while (<READFILE>) {
              system("/sbin/ip route add $_");
            }
            close(READFILE);
          }
          #Aricent PR 1080510 Fix - End
          if( -f "$IFUP_LOCAL") {
            system("$IFUP_LOCAL", "$next_dev.$vlan_id","$ipaddr");
          }
        }
      }
    }
  }
  close (READ);
  system("/bin/rm -f $tmpdev_file");
}
