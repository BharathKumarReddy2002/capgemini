sub AAS_get_bndl{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $force, $bNum ) = @_;
  my ( $cbs, $pip, $pcid, $sip, $scid, $st, $rvt ) = AAS_get_dflts();
  my $cp = 10;          # Default check period.
  my $dflts = 1;
  get_sem ( $AAS_SEM, "AAS_SEM" );
  open( READ, "< $AAS_CONF") or die "Can't open $AAS_CONF!";
  while (<READ>) {
    if ( $_ =~ /SLEEP_TIME\s=\s(\d+)/ ) { $cp = $1; }
    if ( $_ =~ /BNDL_$bNum\s\:/ ) {
      if ( $_ =~ /CHECK_B4_SWITCH\s=\s(\d+)/ ) { $cbs = $1; }
      if ( $_ =~ /PRI_IP\s=\s(\d+\.\d+\.\d+\.\d+)/ ) {
	if( "$pip" ne "$1" ) { $pip = $1; $dflts = 0; }
      }
      if ( $_ =~ /PRI_PORT\s=\s(\d+)/ ) { $pcid = $1; }
      if ( $_ =~ /PRI_CID\s=\s(\d+)/ )  { $pcid = $1; }
      if ( $_ =~ /SEC_IP\s=\s(\d+\.\d+\.\d+\.\d+)/ ) { 
	if( "$sip" ne "$1" ) { $sip = $1; $dflts = 0; }
      }
      if ( $_ =~ /SEC_PORT\s=\s(\d+)/ ) { $scid = $1; }
      if ( $_ =~ /SEC_CID\s=\s(\d+)/ )  { $scid = $1; }
      if ( $_ =~ /REVERT\s=\s(\d+)/ )   { $rvt = $1;  }
      if ( $_ =~ /WATCH\s=\s(\d)/ )     { $st = $1;   }
    }
  }
  close( READ );
  rel_sem ( $AAS_SEM, "AAS_SEM" );
  if( $force || !$dflts ) {
    print STDOUT "BNDL$bNum$DELIM";
    print STDOUT "CBS$cbs$DELIM";
    print STDOUT "PIP$pip$DELIM";
    print STDOUT "PP$pcid$DELIM";
    print STDOUT "SIP$sip$DELIM";
    print STDOUT "SP$scid$DELIM";
    print STDOUT "CP$cp$DELIM";
    print STDOUT "ST$st$DELIM";
    print STDOUT "RVT$rvt";
    print STDOUT "\n";
  }
  return $OK;
}

sub AAS_set
{
  if( $DEBUG ) {print STDOUT "AAS_set: Function enter.\n"; }
  my ( $request, $string ) = @_;
  my $rtn = $OK;
  my $bNum = 0;
  if ( $request =~ /eth(\d)/ ) {
    my $eth_dev = $request;
    $rtn = AAS_set_eth($eth_dev, $string);
  } elsif ( $request =~ /ARM/i ) {
    $rtn = AAS_set_ARM($string);
  } elsif ( $request =~ /CP/i ) {
    $rtn = AAS_set_CP($string);
  } elsif ( $request =~ /(\d+)/ ) {
    $bNum = $1;
    $rtn = AAS_set_bndl($bNum, $string);
  } elsif ( $request =~ /set_dflt/ ) {
    # Set all bundles to default settings.
    # To do this, just remove all but DFLT_S parameters
    get_sem ( $AAS_SEM, "AAS_SEM" );
    my $tmp = "/tmp/aas.conf";
    `$ECHO "# Bundle config structure with default values:" > $tmp`;
    `$GREP DFLT_S $AAS_CONF >> $tmp`;
    `$ECHO "" >> $tmp`;
    `$ECHO "SLEEP_TIME = 20" >> $tmp`;
    `$ECHO "" >> $tmp`;
    `$ECHO "eth0 : USE = 1" >> $tmp`;
    move( "$tmp", "$AAS_CONF" ); DBFLUSH();
    rel_sem ( $AAS_SEM, "AAS_SEM" );
  } else {  # default request is bNum 0
    $rtn = AAS_set_bndl($bNum, $string);
  }
  return $rtn;
}

sub AAS_set_eth
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $eth_dev, $string ) = @_;
  if( $DEBUG ) { print"AAS_set: Got eth_dev $eth_dev, string $string\n"; }
  if ( $eth_dev !~ /eth\d/ ) {
    return $E_UNKNOWN;
  }
  GetAllEth();    # Setup ETH_CONFIG
  if ( $ETH_CONFIG{$eth_dev}{AVAILABLE} == $YES ) {
    # Only do config if device is available.
    if ( $string =~ /USE(0|1)/ ) {
      my $new_line = "$eth_dev \: USE = $1";
      my $lines_replaced = 0;
      get_sem ( $AAS_SEM, "AAS_SEM" );
      $lines_replaced += replace_line( "$AAS_CONF", "$eth_dev","$new_line");
      if ( $lines_replaced == 0 ) { # Didn't find eth_dev, add it!
	`echo "$new_line" >> $AAS_CONF`;
      }
      rel_sem ( $AAS_SEM, "AAS_SEM" );
    } else {
      AAS_useage();
    }
# Now check if AAS is running already, if so restart it with new cfg file
    close (STDOUT); open (STDOUT, " > /dev/null ");
    close (STDERR); open (STDERR, " > /dev/null ");
    if( !system("ps", "-C", "AcornAutoSwitch") ) { system("$AAS", "-a"); }
    close (STDOUT); open (STDOUT, " > /dev/stdout");
    close (STDERR); open (STDERR, " > /dev/stderr");
  }
  return $OK;
}

