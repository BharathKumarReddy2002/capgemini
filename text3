  my ( $read, $opts, $values ) = @_;
  if ( $read ) { iptables_read( ); }
  else { iptables_set( $opts, $values ); }
}

sub iptables_read
{
  my $fn = (caller(0))[3]; fen($fn);
  exit $OK;
}

sub iptables_set
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $cmd, $string ) = @_;
  my $parse_error = 0;
  my $OP = "none"; my $Op  = 0;
  my $NP = "none"; my $Np  = 0;
  my $foo = "/tmp/foo";
  if ($cmd =~ /clr/) {ctp_clr_iptables(); exit $OK;}
  if ( ($cmd =~ /add/i) || ($cmd =~ /replace/i) ) {
    #print "Looking through \"$string\" for NP & Np\n";
    #Look for protocol & port for new rule
    if ( $string =~ /NP(\w+)/ )     { $NP = $1; }
    else { $parse_error += 1; print "NP problem\n"; } # Problem getting readonly community name
    if ( $string =~ /Np(\d+)/ )     { $Np = $1; }
    else { $parse_error += 1; print "Np problem\n"; } # Problem getting readonly community name
  }
  if ( ($cmd =~ /del/i) || ($cmd =~ /replace/i) ) {
    #print "Looking through \"$string\" for OP & Op\n";
    #Look for protocol & port for old rule
    if ( $string =~ /OP(\w+)/ )     { $OP = $1; }
    else { $parse_error += 1; print "OP problem\n"; } # Problem getting readonly community name
    if ( $string =~ /Op(\d+)/ )     { $Op = $1; }
    else { $parse_error += 1; print "Op problem\n"; } # Problem getting readonly community name
  }
  if ( $parse_error != 0) { iptables_useage(); }
  my $rtn = `sed s/'p $OP -m $OP --dport $Op'/'p $NP -m $NP --dport $Np'/ $IPTABLESCONF > $foo`;
  #print "Got rtn $rtn\n";
  system("$CP", "$foo", "$IPTABLESCONF");
  system("$IPTABLES", "restart");
  FLUSH_ETC();
  exit $OK;
}

