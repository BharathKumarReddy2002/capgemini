sub iptables_useage
{
  my $fn = (caller(0))[3]; fen($fn);
  print "\n";
  print "Usage: syscfg -s -u iptables -o [add|del|replace|clr] -v OP<oPo>:Op<op>:NP<nP>:Np<np>\n";
  print "  Options: \n";
  print "          add: Add a rule using <nP> & <np>.\n";
  print "          del: Delete a rule using <oP> & <op>.\n";
  print "          replace: Replace a rule using <oP>, <op>, <nP> & <np>.\n";
  print "          clr: clear iptables rules added by management port and ctp_allow.\n";
  print "  Where:\n";
  print "          <oP> is the protocol of an existing rule eg upd or tcp.\n";
  print "          <op> is the port number of an existing rule (eg 16).\n";
  print "          <nP> is the protocol for the new rule eg upd or tcp.\n";
  print "          <np> is the port number for the new rule (eg 16).\n";
  print "Usage: syscfg -r -u iptables \n";
  print "  Does nothing!\n";
  print "\n";
  exit $E_UNKNOWN;
}

