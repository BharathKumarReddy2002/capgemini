    if ($separation) {
      print "$dflt_dev is the circuit device.\n";
      print "$dflt_mgmt_dev is the management device.\n";
    } else {
      print "$dflt_dev is the default device.\n"; 
    }
  }
  #Aricent Fix PR 1133380 - End
  # Get hostname & write to /etc/hosts & /etc/sysconfig/network

  if ( ! $ON_GUI ) {
    if(($ipprot eq "IPV4") || ($protocol == 1)) {
      $hostname = ask_for_hostname("$hostname");
    }
  }

  # Now configure/enable/disable interfaces
  my $i = 0;
  my $both_dev_cfgd = 0;
  my $check_subnet = 0;
  foreach $i ( @GLOB_ETH_DEVS_LIST ) {
    chomp $i;
    if( "eth$i" eq "$dflt_dev" ) {
      if($ipprot eq "IPV4") {
        ($dflt_ip) = get_eth_cfg( "eth$i", 1, $firstboot, $protocol );
        $both_dev_cfgd++;
      } else {
	($ipv6gw) = get_eth_ip6_cfg( "eth$i", 1, $firstboot, $protocol );
      }
    } elsif ($firstboot==0) {
      if ($separation == 1 && ($dflt_mgmt_dev eq "eth$i")) {
        $dev_type = 2;
        $both_dev_cfgd++;
      } else {
        $dev_type = 0;
      }
      if($ipprot eq "IPV4") {
        get_eth_cfg( "eth$i", $dev_type, $firstboot, $protocol );
      } else {
        get_eth_ip6_cfg( "eth$i", $dev_type, $firstboot, $protocol );
      }
    } else {
      # Put ONBOOT=no into ifcfg file
      my $ifcfg_file = "$NETSCRIPTS_DIR/ifcfg-eth$i";
      open( WRITE, "> $ifcfg_file ");
      print WRITE "DEVICE=eth$i\n";
      print WRITE "ONBOOT=no\n";
      close(WRITE);
    }
    if(($separation == 1) && ($both_dev_cfgd == 2)) {
      $check_subnet = check_SubnetOverlap();
      if($check_subnet != 0) { 
        $i = $i - 1;
        print("\nSubnet of eth$i Overlaps, please re-insert correct IP of eth$i\n");
        $both_dev_cfgd = 1;
      }
    }
    $dev_type = 0;
    #FLUSH_ETC();		# we will do this at the end of net_cfg_ip()
  }

  $dev_type = 0;
  if($vlan_cnt) {
    print "\n$ipprot configuration for VLAN interfaces : \n\n";
    open (WRITE, "> $tmpdev_file");
    system("ls $NETSCRIPTS_DIR/ifcfg-eth*.* > $tmpdev_file");
    close (WRITE);
    open (READETH, "< $tmpdev_file");
    while (<READETH>) {
      if( $_ =~ /ifcfg-eth(\d+)\.(\d+)$/) {
        if ("eth$1.$2" eq "$dflt_dev") {
          if($ipprot eq "IPV4") {
            ($dflt_ip) = get_eth_cfg( "eth$1.$2", 1, $firstboot, $protocol );
            $both_dev_cfgd++;
          } else {
            ($ipv6gw) = get_eth_ip6_cfg( "eth$1.$2", 1, $firstboot, $protocol );
          }
        } elsif ($firstboot==0) {
          if ($separation == 1 && ($dflt_mgmt_dev eq "eth$1.$2")) {
            $dev_type = 2;
            $both_dev_cfgd++;
	  } else {
	    $dev_type = 0;
	  }
          if($ipprot eq "IPV4") {
       	    get_eth_cfg( "eth$1.$2", $dev_type, $firstboot, $protocol );
          } else {
            get_eth_ip6_cfg( "eth$1.$2", $dev_type, $firstboot, $protocol );
          }
        }
        #Aricent Fix PR 1133380 - Start
        if(($separation == 1) && ($both_dev_cfgd == 2)) {
          $check_subnet = check_SubnetOverlap();
          if($check_subnet != 0) { 
            print("\nSubnet of eth$1.$2 Overlaps, please re-insert correct IP of eth$1.$2\n");
            close(READETH);
            open (READETH, "< $tmpdev_file");
          }
        }
        $dev_type = 0;
        #Aricent Fix PR 1133380 - End
      }
    }
    close(READETH);
    system ("/bin/rm -f $tmpdev_file");
  }

  if ( ! $ON_GUI ) {
   if(($ipprot eq "IPV4") || ($protocol == 1)) {
      open( WRITE, "> $HOSTS_FILE");
      print WRITE "127.0.0.1 localhost.localdomain localhost\n";
      print WRITE "$dflt_ip  $hostname\n";
      close(WRITE);
      system ("echo $hostname \> $HOSTNAME_FILE"); # PR 1851876
   }
  } 
  open(READ, "< $NETWORKFILE") or exit $E_UNKNOWN;
  open(WRITE, "> $tmp_file") or exit $E_UNKNOWN;
  print WRITE "NETWORKING=yes\n";
  if(($ipprot eq "IPV6") && ($protocol == 2)) {
    while (<READ>) {
      if( $_ =~ /HOSTNAME/) {
        print WRITE "$_";
      }
    }
    close(READ);
    open(READ, "< $NETWORKFILE") or exit $E_UNKNOWN;
  } else {
    print WRITE "HOSTNAME=$hostname\n";
  }
  if( ! $ON_GUI ) { print WRITE "VLAN=yes\n"; }
  print WRITE "NETWORKING_IPV6=yes\n";
  print WRITE "IPV6FORWARDING=yes\n";
  print WRITE "IPV6_AUTOCONF=no\n";
  if($ipprot eq "IPV4") {
    while (<READ>) {
      if( $_ =~ /IPV6_DEFAULT/) {
        print WRITE "$_";
      }
    }
  } else {
    print WRITE "NETWORKING_IPV6=yes\n";
    print WRITE "IPV6FORWARDING=yes\n";
    print WRITE "IPV6_DEFAULTGW=\"$ipv6gw\"\n";
    print WRITE "IPV6_DEFAULTDEV=$dflt_dev\n";
  }
  close(READ);
  close(WRITE);
  system("/bin/mv", "-f", "$tmp_file", "$NETWORKFILE");
  FLUSH_ETC();
  print "\n\n";

  fex($fn);
  return;
}


#--------- eth_dev ------------------------------------------
#   Manages the active ethernet device for which the default gw is
#   attached.
sub eth_dev_useage
{
  my $fn = (caller(0))[3]; fen($fn);
  print "\n";
  print "Usage: syscfg -s -u eth_dev -v <dev>\n";
  print "  <dev> = new ethernet device to use. eg eth1\n";
  print "Usage: syscfg -r [-o <opt>] -u eth_dev \n";
  print "  When no option is specified, returns the active dflt eth device #, eg 1 -> eth1.\n";
  print "  When <opt> is:\n";
  print "           all      returns <eth#>:IPADDR<ip address>:NETMASK<netmask>GATEWAY<gateway>\n";
  print "           eth      returns <eth#>\n";
  print "           ipaddr   returns <ip address>\n";
  print "           netmask  returns <netmask>\n";
  print "           gateway  returns <gateway>\n";
  print "NOTE: In case of multiple active devices, the details associated with the \n";
  print "      device associated with the default network gateway is returned.\n";
  print "NOTE: If AAS ehternet failover has switched the default device from what \n";
  print "      is configured at bootup, the details of the currently running ethernet\n";
  print "      device are returned.\n";
  print "\n";
  exit $E_UNKNOWN;
}

sub eth_dev_cfg
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $read, $opts, $values ) = @_;
  if ( $read ) { eth_dev_read( $opts ); }
  else { eth_dev_set( $opts, $values ); }
}

sub get_dflt_dev {
  my $fn = (caller(0))[3]; fen($fn);
  # This next line (AND AcornAutoSwitch) assumes gateway is reachable
  # through default eth device.
  my $eth_dev = `$IP route show | $GREP "default" | $AWK '{print \$5 }'`;
  chomp($eth_dev);
  return "$eth_dev";
}

sub get_cfg_dflt_dev {
  my $fn = (caller(0))[3]; fen($fn);
  # This next line (AND AcornAutoSwitch) assumes gateway is reachable
  # through default eth device.
  my $found = 0;
  my $tmp_file = "/tmp/fii";
  my $eth_dev = "";
  if( `ls $NETSCRIPTS_DIR/* | grep ifcfg-eth | wc -l` > 0) {
    if( (system("$GREP -H GATEWAY $NETSCRIPTS_DIR/ifcfg-eth* > $tmp_file") == 0) ) {
      $found = 1;
      open (READ, "< $tmp_file");
      while (<READ>) {
        if( $_ =~ /ifcfg-eth(\S+)\:/) {
          $eth_dev = "eth$1";
        }
      }
      close (READ);
      system (" rm -f $tmp_file ");
      if($DEBUG) { print "Found cfg'd dflt eth: $eth_dev\n"; }
    }
  }
  if ($found == 0) { $eth_dev = "eth0"; }
  if($DEBUG) { print "Configured dflt eth is $eth_dev\n"; }
  fex($fn);
  return $eth_dev;
}

sub get_cfg_ipv6_dflt_dev {
  my $fn = (caller(0))[3]; fen($fn);
  # This next line (AND AcornAutoSwitch) assumes gateway is reachable
  # through default eth device.
  my $default_dev = "eth0";
  if ( -f "$NETWORKFILE" ) {
    open (READ, "<$NETWORKFILE");
      while (<READ>) {
        if ($_ =~ /IPV6_DEFAULTDEV=(\S+)/ ) { $default_dev = $1; }
      }
    close (READ);
  }
  return "$default_dev";
}

sub get_cfg_dflt_mgmt_dev {
  my $fn = (caller(0))[3]; fen($fn);
  # This function assumes that "rule-ethX" file exists for the default management device ethX 
  my $dflt_mgmt_dev = "eth0";
  my $found = 0;
  if( `ls $NETSCRIPTS_DIR/* | $GREP rule-eth | wc -l` == 1 ) {
    $dflt_mgmt_dev = `ls $NETSCRIPTS_DIR/* | $GREP rule-eth | $AWK -F"-" '{print \$3}'`;
    $found = 1;
  }
  if($DEBUG) { print "Configured dflt management eth is $dflt_mgmt_dev\n"; }
  chomp ($dflt_mgmt_dev);
  return $dflt_mgmt_dev;
}
sub get_seg_file_param
{
  my $fn = (caller(0))[3]; fen($fn);
   #Aricent Fix PR 1133380 - Start
   my ( $dev_flag, $ctp_file) = @_; # dev_flag (0- ckt dev, 1- mgmt dev, 2- status) ctp_file(0- ctp_tmp file, 1- ctp file)
   #Aricent Fix PR 1133380 - End
   my $mgmt_dev = -1;
   my $ckt_dev = -1;
   my $status = -1;
   my $found = -1;
   my $seg_file = "/etc/sysconfig/ctp";
   if($ctp_file == 0) { 
     if( -f "/tmp/ctp_tmp" ) { $seg_file = "/tmp/ctp_tmp"; }
   }
   open( READ, "< $seg_file");
   while (my $line = <READ>) {
     chomp($line);
     my ($splt1,$splt2) = (split /=/, $line)[0, 1];
     $splt1 //= '';  #Assign an empty string if $splt1 is undefined PR-1733446
     if ($splt1 eq "mgmt_dev") {$mgmt_dev = $splt2;$found = 0;}
     if ($splt1 eq "ckt_dev") {$ckt_dev = $splt2;$found = 0;}
     if ($splt1 eq "status") {$status = $splt2;$found = 0;}
   }
   close(READ);
   fex($fn);
   if ($found != 0) {
     return "$found";
   }
   if($dev_flag == 1)  	{return "$mgmt_dev";}
   if($dev_flag == 0)  	{return "$ckt_dev";}
   if($dev_flag == 2)  	{return "$status";}
}

sub get_ip_nm {
  my $fn = (caller(0))[3]; fen($fn);
  my ( $eth_dev ) = @_;
  if ($DEBUG) { print "Passed eth_dev $eth_dev\n"; }
  my $rtn = `$IFCONFIG $eth_dev | $GREP addr`;
  my ($ipaddr, $netmask ) = ( $rtn =~ /addr:(\d+.\d+.\d+.\d+)\s+\S+\s+Mask:(\d+.\d+.\d+.\d+)/ ) ;
  return "$ipaddr", "$netmask";
}

sub get_gw {
