  if ($DEBUG) { print "GetAllEth: Got dflt_dev $dflt_dev, dflt_num $dflt_eth_num.\n"; }
  $ETH_CONFIG{$dflt_dev}{USE} = $YES;
  $ETH_CONFIG{$dflt_dev}{AVAILABLE} = $YES;
  close (STDERR); open (STDERR, " > /dev/null ");
  while ($dev_num < $MAX_ETH_DEV_NUM) {
    if ( $dev_num != $dflt_eth_num ) {
      my $eth_dev = "eth$dev_num";
      $ETH_CONFIG{$eth_dev}{AVAILABLE} = $NO;   # Default to NO!
   if ($dev_num < $max_eth ) {
     if ($DEBUG) { print "\tChecking for eth$dev_num.\n"; }
     my $rtn_stat = system("$IFCONFIG eth$dev_num > /dev/null");
     if ($VDEBUG) { print "\tGot rtn_stat=$rtn_stat from ifconfig eth$dev_num\n"; }
     if( $rtn_stat == 0 ) {
            # device exists! Is it already in use???
       my $running = `$IFCONFIG eth$dev_num | $GREP "RUNNING" | $WC -l`;
       chomp($running);
       if ( $running == 0 ) { $ETH_CONFIG{$eth_dev}{AVAILABLE} = $YES; }
   }
      }
    }
    $dev_num++;
  }
  close (STDERR); open (STDERR, " > /dev/stderr ");
}

