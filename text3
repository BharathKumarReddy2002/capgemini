sub net_cfg_read
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $cmd, $runtime ) = @_;
  my $dflt_dev = "eth0";
  my $tmpeth_file = "/tmp/eth";
  my $dflt_dev_ipv6 = "eth0";
  my $gateway  = get_gw();
  my $num_eth  = get_num_eth();
  my $protocol = 0;
  open(READ, "< $SYSCFG_CTP") or exit $E_UNKNOWN;
  while (<READ>) {
    if( $_ =~ /CTP_IP_PROTO=(\d+)/ ) {
      $protocol = $1;
    }
  }
  close(READ);
  if($protocol != 1) {$dflt_dev = get_cfg_dflt_dev();}
  if($protocol != 0) {$dflt_dev_ipv6 = get_cfg_ipv6_dflt_dev();}
  if( $cmd eq "" ) { $cmd = "dflt"; }
  if ($DEBUG) { print "net_cfg_read: Got dflt_dev $dflt_dev, gateway $gateway, num_eth $num_eth, opts $cmd\n"; }
  if ( $cmd =~ /all/i ) {
    #Aricent Fix PR 1133380 - Start
    # get seg status. If 0- Segregation between management and circuit traffic: Off
    # if 1 - Segregation between management and circuit traffic: On
    if( ! $ON_GUI ) {
        my $seg_status = get_seg_file_param(2,0);
        if($seg_status == 1) {
           print "Segregation between management and circuit traffic: ON\n";
        }
        else {
           print "Segregation between management and circuit traffic: OFF\n";
        }
    }
    #Aricent Fix PR 1133380 - End
    my $hostname = hostname();
    print "\nHostname: $hostname\n";
    if( $ON_GUI ) {
      print "\nDomain: ";
      getDomainFromHosts("$hostname");
    }
    my $i = 0;

    print "\nProtocols supported:   ";
    if($protocol == 1) {
      print "IPV6 ONLY\n\n";
    } elsif($protocol == 2) {
      print "IPV4 & IPV6 \n\n";
    } else {
      print "IPV4 ONLY\n\n";
    }

    open(WRITE, "> $tmpeth_file") or exit $E_UNKNOWN;
    if( `ls $NETSCRIPTS_DIR/* | grep ifcfg-eth | wc -l` > 0) {
      system("ls $NETSCRIPTS_DIR/ifcfg-eth* > $tmpeth_file");
    }
    close(WRITE);
    open(READETH, "< $tmpeth_file") or exit $E_UNKNOWN;
    while (<READETH>) {
      if( $_ =~ /ifcfg-(\S+)$/ ) {
        my $dev = $1;
        if($protocol != 1) {
          net_prt_cfg_ipv4($dev, $dflt_dev);
        }
        if($protocol != 0) {
          net_prt_cfg_ipv6($dev, $dflt_dev_ipv6);
        }
      }
    }
    close(READETH);
    print "\n";
    system("rm -f $tmpeth_file");
    get_cfg_vip();
  } elsif ( $cmd =~ /dflt/i ) {
    if($protocol != 1) {
      net_prt_cfg_ipv4($dflt_dev, $dflt_dev);
    }
    if($protocol != 0) {
      net_prt_cfg_ipv6($dflt_dev_ipv6, $dflt_dev_ipv6);
    }
  } elsif( $cmd =~ /protocol/i ) {
    my $ip_prot = 0;
    open(READ, "< $SYSCFG_CTP") or exit $E_UNKNOWN;
    while (<READ>) {
      if( $_ =~ /CTP_IP_PROTO=(\d+)/ ) {
        $ip_prot = $1;
      }
    }
    print "$ip_prot\n";
  } elsif ( $cmd =~ /vip/i ) {
    get_cfg_vip();
    print "\n";
  } else {
    if($protocol != 1) {
      net_prt_cfg_ipv4($cmd, $dflt_dev);
    }
    if($protocol != 0) {
      net_prt_cfg_ipv6($cmd, $dflt_dev_ipv6);
    }
    print "\n";
  }
  exit $OK;
}

