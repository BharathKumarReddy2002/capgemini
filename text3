sub kill_it
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $process_name ) = @_;
  # OLD: my @processes = `ps ax --cols 200 | fgrep $process_name | fgrep -v grep `;
  my @processes = `ps -C $process_name`;
  foreach my $process (@processes) {
    $process =~ /(\d{1,6})/ or next;
    if ( $1 != $$ ) {                  # If not self! Kill it
      my $p = $1;
      if( "$process_name" =~ /AutoSwitch/ ) { system("kill", "-TERM", "$p"); }
      else                                  { system("kill", "-9", "$p"); }
    }
  }
}

sub hup
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $process_name ) = @_;
  # OLD: my @processes = `ps ax --cols 200 | fgrep $process_name | fgrep -v grep `;
  my @processes = `ps -C $process_name`;
  foreach my $process (@processes) {
    $process =~ /(\d{1,6})/ or next;
    if ( $1 != $$ ) {                  # If not self! HUP it
      system("kill", "-HUP", "$1");
    }
  }
}

