    # Aricent fix for PR 794392 start
    if( $state == 1 && $rtn == 1 ) {
        tacplus_useage(); return $OK;
    }
    # Aricent fix for PR 794392 end

      # update system-auth file
      # set state
      manage_comment ( "$TACPLUS_PAM", "$tacplus_module", $state );
      manage_comment ( "$TACPLUS_PAM_ACCOUNT", "$tacplus_module", $state );  #Aricent PR 1401407 fix
      # set timeout
      `$SED -i "s/ timeout=[0-9]*// " $TACPLUS_PAM`;
      `$SED -i "/$tacplus_module/ s/.*/& timeout=$to/" $TACPLUS_PAM`;
      # setting server Ips and secret keys
      my $line_tac = `$GREP -m 1 'auth[ ].*[ ]$tacplus_module' $TACPLUS_PAM  `;
       while( $line_tac =~  /\s+server=($IPV4ADDFORMAT|$IPV6ADDFORMAT)/gi ) {
      `$SED  -i "s/ server=[^[:space:]]*//" $TACPLUS_PAM`;
      }
       while( $line_tac =~  /\s+secret=([\w@!#?^&\{}\[\]%~=\-\,\$'"|\/<>:.;+*(\)`\\]+)/gi ) {  # Aricent fix for PR 798137, PR-1846890
      `$SED  -i "s/ secret=[^[:space:]]*//" $TACPLUS_PAM`;
      }
  
      `$SED -i "/auth[ ].*[ ]$tacplus_module/ s/.*/& server=$sip/" $TACPLUS_PAM`;
      for ( my $i=1; $i<=9; $i++ ) {
         if ( $sip_opt[$i] ne "" ) {
            `$SED -i "/auth[ ].*[ ]$tacplus_module/ s/.*/& server=$sip_opt[$i]/" $TACPLUS_PAM`; #Aricent PR 777846
         }
      }
      $secret =~ s/([\&\$\\\/"`])/\\$1/g;  # Escape &, $, \, /, ", and ` for Perl safety PR-1846890
      #PR-1846890 Start
