  $ifcfg_file = "$NETSCRIPTS_DIR/ifcfg-$mgmt_dev";
  if ( -f "$ifcfg_file" ) {
    open( READ, "< $ifcfg_file" );
      while (<READ>) {
        if( $_ =~ /IPADDR=(\d+\.\d+\.\d+\.\d+)/ )  { $net2 = $1;}
        if( $_ =~ /NETMASK=(\d+\.\d+\.\d+\.\d+)/ ) { $mask2 = $1; }
      }
    close(READ);
  }

  $net1  = packip4($net1);
  $mask1 = packip4($mask1);
  $net2  = packip4($net2);
  $mask2 = packip4($mask2);
  my $first1 = $net1 & $mask1;
  my $last1  = $net1 | ((~$mask1) & 0xffffffff);
  my $first2 = $net2 & $mask2;
  my $last2  = $net2 | ((~$mask2) & 0xffffffff);
  if((($first2 < $first1) && ($last2 < $first1)) || (($first2 > $last1) && ($last2 > $last1)))
  {
    $overlap = 0;
  }
  return $overlap;
}

sub packip4   { return unpack('N', (pack 'C4', split(/\./, shift))); }

