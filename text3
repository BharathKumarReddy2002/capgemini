  if ( ($s1ip ne "") && ($parse_error == 0) ){
    $secondip ++;    # Aricent PR 1142788 fix
    if ( $sip eq $s1ip ) {
      $parse_error = 1;
      print "IP address should be unique\n";
    }
    # Aricent PR 1122855 fix - Start
    elsif ( verifyIP($s1ip) == 1 ) {
