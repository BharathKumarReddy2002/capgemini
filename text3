sub check_file          # Check if a file exists with given
{              # permissions & ownership,
  my $fn = (caller(0))[3]; fen($fn);
  my ( $file, $mode, $owner,$grp ) = @_;# create/chmod/chown if not.
  my $status = 0;
  my ( $dev,$ino,$mode_f,$nlink,$uid,$gid,$rdev,$size,
       $atime,$mtime,$ctime,$blksize,$blocks ) =
       stat( $file ) or $status = 1;
  if ( $status == 1) {
    $status = 0;
    $status += system( "/bin/touch", "$file" );
    $status += system( "/bin/chmod", "$mode", "$file" );
    $status += system( "/bin/chown", "$owner:$grp", "$file" );
    return $status;
  }
  if ( $mode != $mode_f) { $status += system( "/bin/chmod", "$mode", "$file" ); }
  my $found_owner = getpwuid($uid);
  my $found_grp   = getgrgid($gid);
  if ( ( $owner ne $found_owner ) || ( $grp ne $found_grp ) ) {
    $status += system( "/bin/chown", "$owner:$grp", "$file" );
  }
  return $status;
}

