sub bndl_state_change
{
  my $fn = (caller(0))[3]; fen($fn);
  ( $cur_dev, $activate ) = @_;
  my $bn; #bundle no.
  if( !$activate) {
        for( $bn=0; $bn< $CTP_MAX_BNDLS ; $bn++) { #run loop upto $count times
	my $bndlid =` $CMD bndl $bn qry all | grep "Bundle" | $AWK '{ print \$3}' | tail -1 `; # fetching bndlid 
	my $rem_ip =` $CMD bndl $bn qry all | grep "Remote Addr" | $AWK '{ print \$3}'`; #fetchin remote ip of bundle
	my $state  =` $CMD bndl $bn qry all | grep "Run*" | grep "State" | awk '{ print \$3}'`; #fetching runtime state of bundle

        chomp($rem_ip);
        chomp($state);
        chomp($bndlid);

        if (( $state ne "DISABLD" ) && ( $state ne "" ) && ( $rem_ip ne "" )) { # if bndlid and state is DISABLD then not a bndlid
         if ($bndlid=~ /^[+-]?\d+$/) { #checking string is number or digit; extra protection 
	   my $ip_count;
           my @ip_array;
           my $ipaddress;
	   my $total_dest_ip = ` $ROUTE -C | $GREP $cur_dev | $WC -l `; #total destination on ethX
           for($ip_count=1; $ip_count <= $total_dest_ip; $ip_count++) {
             $ipaddress=` $ROUTE -C | grep $cur_dev | $AWK '{print \$2}' |head -n $ip_count | tail -1`; #fetching ip one by one
             if(!grep(/$ipaddress/, @ip_array )){ 
               push(@ip_array, $ipaddress);  #storing only unique ip based on above if condition
             }
            }
            if (grep(/$rem_ip/, @ip_array )) { #if remote ip found in ip_array then do further processing
              my $loop_to_net =` $CMD bndl $bndlid qry all | $GREP "Serial Loop" | cut -d":" -f 2 `; #loop_to_net enable or not
	      my $bndl_type   =` $CMD bndl $bndlid qry all | grep "type" | $AWK ' {print \$5}' | head -n 1`; #bndl_type is CTP/SAToP/CESoPSN/VCOMP
              chomp($bndl_type);
              chomp($loop_to_net);
              $loop_to_net =~ s/\s//g;
              if( ( "$bndl_type" eq "CESoPSN" ) && ( "$loop_to_net" eq "ToNET" ) ) { #if CESoPSN and loop ToNET then store bndlid for cesopsn
                 ` $ECHO "$bndlid" >> /tmp/cesopsn.txt `;
               }
                system("$CMD","bndl", "$bndlid", "disable");
                ` $ECHO "$bndlid" >> /tmp/bndl_id.txt`;
              }
           }
        }
     }
  } else {
     my $total_bndl =` $CAT /tmp/bndl_id.txt | $WC -l `; #fetching total bundle 
     $bn=1;
     while ( $bn <= $total_bndl ) {
        my $bndl_id =` $CAT /tmp/bndl_id.txt | head -n $bn | tail -1 `;
        chomp($bndl_id);
        system("$CMD", "bndl", "$bndl_id", "activate");
        $bn++;
     }
     # loop to net logic enable
     $bn=1;
     if ( -f "/tmp/cesopsn.txt" ) { # if loop to net CESoPSN  bundle's available then enable "loop to net"
        my $total_cesopsn_bndls=` $CAT /tmp/cesopsn.txt | $WC -l `;
        while( $bn <= $total_cesopsn_bndls ) {
           $bndl_id=` $CAT /tmp/cesopsn.txt | head -n $bn | tail -1 `;
           chomp($bndl_id);
           my $port_type =` $CMD bndl $bndl_id qry all | $GREP "Port" | head -n 1 | $AWK '{ print \$3}'`;
           chomp($port_type);
           system("$CMD", "port", "$port_type", "runtime", "ser_loop", "ToNet");
           $bn++;
        }
        #Removing temporary file
        system("/bin/rm", "-f", "/tmp/cesopsn.txt");
     }
     #Removing temporary file
     system("/bin/rm", "-f", "/tmp/bndl_id.txt");
  }
}
