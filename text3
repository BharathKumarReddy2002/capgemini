sub snmpdconf_set
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $snmp, $opts, $string ) = @_;
  # Aricent PR 1255040 fix - Start
  my ($engine_id);
  my $tmp = `$GREP "engineID" $SNMPDCONF | $WC -l`;
  my (@choices);
  my ($sel);
  # Aricent PR 1255040 fix - End
  if( $DEBUG ) { print "snmpdconf_set: Function Enter\n"; }

  #=========== Interactive ============
  if( defined($opts) && ($opts =~ /interactive/) ) { 
    my $rtn = "";
    my $cnt = 0;	# index of last configured element

    print "\nCurrent SNMP Location string is \"$snmp->{location}\".\n";
    $snmp->{location} = 
      ask_for_string("Location String (<cr> to keep)", $snmp->{location});
    print "\nCurrent SNMP Contact string is \"$snmp->{contact}\".\n";
    $snmp->{contact} = 
      ask_for_string("Contact String (<cr> to keep)", $snmp->{contact});
  # Aricent PR 1255040 fix - Start
    if ( $tmp =~ /0/ ) {
      print "\nDo you want to add SNMPv3 engine id?\n";
    } else {
      $engine_id = `$GREP "engineID" $SNMPDCONF | $AWK '{print \$2}'`;
      chomp($engine_id);
      print "\nThe configured SNMPv3 engine ID is $engine_id";
      print "\nDo you want to edit this SNMPv3 engine id?\n";
    }
    @choices = ('Yes','No');
    $sel = ask_for_choice(\@choices,$#choices);
    if( $sel =~ /Yes/ ) {
      $engine_id = ask_for_string("the SNMPv3 engine id");
   # Aricent PR 1323213 fix - Start
    if ( $engine_id !~ /^[\w\.]+$/ ) {
    print "Only alphanumerics or \"_\" or \".\" allowed in engineId!!\n";
    exit(-1);
    }
    # Aricent PR 1323213 fix - End
      if ( $tmp =~ /0/ ) {
        `echo "engineID $engine_id" >> $SNMPDCONF`;
      } else {
        `$SED -i '/^[ ]*engineID/ cengineID $engine_id' $SNMPDCONF`;
      }
     `echo "engineID $engine_id" > /etc/eng_id_key`; # Aricent PR 1362872 fix
      $snmp_usm = 1;
      if( ! $ON_GUI )  { system ("/etc/init.d/local", "logflush"); } #Aricent PR 1401407 fix
      FLUSH_ETC();
    }
    # Aricent PR 1255040 fix - End
    while ($rtn !~ /^quit/) {
      # Find out how many SNMP users there are by displaying them.
      $cnt = snmpdconf_show( $snmp, $opts );
      print "\nHow do you want to change SNMP users (add/del/quit) ? (<cr> to show): ";
      chop ( $rtn = <STDIN> );
      if ( $rtn =~ /add/ ) {
	snmpdconf_set_add($snmp, $cnt);
	snmpdconf_check($snmp, $opts);
      } elsif ( $rtn =~ /del/ ) {
	if($cnt == 0) { print "Sorry, but there are no SNMP users configured\n" }
	else { snmpdconf_set_del($snmp, $cnt); }
      }
      print "\n\n";
    }
    if( $cnt ) { $snmp->{state} = 1; }	# users exist, so enable daemon
    else       { $snmp->{state} = 0; }
  } 
  #=========== Non-Interactive (from string) ============
  else {
    my $index;
    my $p_err = 0;
# Initialize hash to all unused entries
    for($index=1;$index<=$MAX_SNMP_USERS;$index++) { 
      $snmp->{$index}{used} = "no"; }
    $snmp->{location} = "Unset";
    $snmp->{contact} = "Unset";
    $index = 1;

    while( ($string ne ":") && ($p_err == 0) ) {
      if($DEBUG){print STDOUT "---> String to parse: \"$string\"\n";}
      #--- LO token
      if( $string =~ s/^:LO,([^:]+):/:/ )  { 
	$snmp->{location} = $1;
	if($DEBUG){print STDOUT "---> location: \"$1\"\n";}
      }
      #--- CO token
      elsif( $string =~ s/^:CO,([^:]+):/:/ )  { 
	$snmp->{contact} = $1;
	if($DEBUG){print STDOUT "---> contact: \"$1\"\n";}
      }
      #--- ST token
      elsif( $string =~ s/^:ST(\d+):/:/ )      { $snmp->{state} = $1; }
      #--- USR token
      elsif( $string =~ /^:USR,(r[ow]),([23]),/ ) { 
	if( $string =~ s/^:USR,(r[ow]),2,([^,]+),([^,]+),([^,]+),:/:/ ) { 
	  if( $DEBUG ) { print "Found SNMPv2 user # $index\n"; }
	  $snmp->{$index}{used}  = "yes";
	  $snmp->{$index}{rw}    = $1;
	  $snmp->{$index}{SNMPv} = 2;
	  $snmp->{$index}{IPv}   = $2;
	  $snmp->{$index}{comm}  = $3;
	  $snmp->{$index}{ip}    = $4;
	  # This is the place to do some checking...
	  # (IP format or password strength)
	  if( $DEBUG ) { 
	    print "Parsed from string:\n";
	    print "used  : $snmp->{$index}{used}\n";
	    print "rw    : $snmp->{$index}{rw}\n";
	    print "SNMPv : $snmp->{$index}{SNMPv}\n";
	    print "IPv   : $snmp->{$index}{IPv}\n";
	    print "comm  : $snmp->{$index}{comm}\n";
	    print "ip    : $snmp->{$index}{ip}\n";
	  }
	  $index++;
	}
	elsif( $string =~ s/^:USR,(r[ow]),3,([^,]+),([^,]+),([^,]+),([^,]+),:/:/ ) {     # Aricent PR 1362733 fix 
	  if( $DEBUG ) { print "Found SNMPv3 user # $index\n"; }
	  $snmp->{$index}{used}  = "yes";
	  $snmp->{$index}{rw}    = $1;
	  $snmp->{$index}{SNMPv} = 3;
	  $snmp->{$index}{user}  = $2;
	  $snmp->{$index}{pass}  = $3;
          # Aricent PR 1362733 fix - Start
          $snmp->{$index}{IPv}   = $4;
          $snmp->{$index}{ip}    = $5;
          # Aricent PR 1362733 fix - End
	  if( $DEBUG ) { 
	    print "Parsed from string:\n";
	    print "used  : $snmp->{$index}{used}\n";
	    print "rw    : $snmp->{$index}{rw}\n";
	    print "SNMPv : $snmp->{$index}{SNMPv}\n";
	    print "user  : $snmp->{$index}{user}\n";
	    print "pass  : $snmp->{$index}{pass}\n";
            print "ip    : $snmp->{$index}{ip}\n";    # Aricent PR 1362733 fix
	  }
	  $index++;
	} else { $p_err++; print "Couldn't parse USR token\n"; }
      }
      # Aricent PR 1255040 fix - Start
      #--- SNMPv3 Engine ID Token
      elsif( $string =~ s/^:SNMPv3_EID,([^:]+):/:/ )  {
        $engine_id = $1;
       # Aricent PR 1323213 fix - Start
        if ( $engine_id !~ /^[\w\.]+$/ ) {
                print "Only alphanumerics or \"_\" or \".\" allowed in engineId!!\n";
                exit(-1);
           }
        # Aricent PR 1323213 fix - End
        if ( $tmp =~ /0/ ) {
          `echo "engineID $engine_id" >> $SNMPDCONF`;
        } else {
          `$SED -i '/^[ ]*engineID/ cengineID $engine_id' $SNMPDCONF`;
        }
        $snmp_usm = 1;
      }
      # Aricent PR 1255040 fix - End
      #--- default token
      else { $p_err++; print "rw or SNMPv fields not right\n"; }
    }
    #if ( $p_err ) { snmpdconf_useage(); }
    if ( $p_err ) { exit(-1); }
  }
}

