sub netlog_cfg
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $read, $opts, $values ) = @_;
  my $rtn = $OK;
  if ( $read ) { $rtn = netlog_read(); }  # No options or values allowed
  else { $rtn = netlog_set( $values ); }  # No options allowed
  return $rtn;
}

sub netlog_read            # starting with 5.3 Two servers allowed
{
  my $fn = (caller(0))[3]; fen($fn);
  my $sip = "10.0.0.1";        # Default for none.
  my $s1ip = "";        # Default for none.
  my $secondip = 0;
  my $state = 0;
  open( READ, "< $NETLOG_CONF" ) or die "Can't open $NETLOG_CONF!";

  while(<READ>) {
	  #if ( $_ =~ /local0/ && $_ =~ /\@(.+)/  ) {      # network logging line requires @ sign
      if ( $_ =~ /@@/){
	  	next;
      }
      if (( $_ =~ /\*\.*/ || $_ =~ /local0/ ) && $_ =~ /\@(.+)/  ) {      # network logging line requu
      if( $secondip ) { $s1ip = $1 }
      else { $sip = $1; $secondip++; }
      if ( $_ =~ /^\s*\#/ ) {    # It's commented out!
        $state = 0;
      } else {
        $state = 1;
      }
    }
  }

  close( READ );
  print STDOUT "SIP$sip:ST$state:S1IP$s1ip\n";
  return $OK;
}

