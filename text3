       my $allow_reject_field = "[success=done new_authtok_reqd=done authinfo_unavail=bad default=ignore]";
       my $allow_offline_field = "[success=done new_authtok_reqd=done authinfo_unavail=ignore ignore=ignore default=bad]";
       my $allow_offline_reject_field = "[success=done new_authtok_reqd=done authinfo_unavail=ignore default=ignore]";
       my $disallow_offline_reject_field = "[success=done new_authtok_reqd=done ignore=ignore default=bad]";
       if ( ( $reject_failover == 1 ) && ( $off_line_failover == 0 ) ) {
           `$SED -i "/$tacplus_module/ s/auth.*$tacplus_module/auth      $allow_reject_field      $tacplus_module/"  $TACPLUS_PAM`;
       } elsif ( ( $reject_failover == 0 ) && ( $off_line_failover == 1 ) ) {
           `$SED -i "/$tacplus_module/ s/auth.*$tacplus_module/auth      $allow_offline_field      $tacplus_module/"  $TACPLUS_PAM`;
       } elsif ( ( $reject_failover == 1 ) && ( $off_line_failover == 1 ) ) {
           `$SED -i "/$tacplus_module/ s/auth.*$tacplus_module/auth      $allow_offline_reject_field      $tacplus_module/"  $TACPLUS_PAM`;
       } elsif ( ( $reject_failover == 0 ) && ( $off_line_failover == 0 ) ) {
           `$SED -i "/$tacplus_module/ s/auth.*$tacplus_module/auth      $disallow_offline_reject_field      $tacplus_module/"  $TACPLUS_PAM`;
       }# doing nothing if non-valid value
   
       # set TACPLUS port
       system("$SED -i '/^tacacs[[:space:]]/ s/[0-9]\\{1,5\\}/$port/' $SERVICES");
#       # update AllowTemplateAccts in sshd_config
       my $yn = "no";
       if( $state == 1 ) {
           $yn = "yes";
       }
#Aricent PR 1401407 fix
       `$SED -i "/AllowTemplateAccts/ cAllowTemplateAccts $yn" $SSHD_CONF`;
   
       FLUSH_USR_LOCAL(); #Aricent fix for PR 784551
       FLUSH_ETC();
       system("/etc/init.d/sshd", "stop"); # Aricent PR 777842
       sleep 1;
       system("/etc/init.d/sshd", "start");
    return $OK;
}

