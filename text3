sub change_user_perms {
  my $fn = (caller(0))[3]; fen($fn);
  my ($sec_lvl) = @_;
    open(READ,"< /etc/passwd");
    while(<READ>) {
      if( ("$_" =~ /([\w\.]+):x:(\d+):(\d+)/) ) {
        my $user = $1;
        my $uid = $2;
        my $gid = $3;
        my $path = "/home/$user";
        if( $uid >= 500 ) {
          my $user_type = check_user("$user");
           if($DEBUG) { printf("User $user, uid $uid, type $user_type.\n"); }
           if( $user_type ne $NON_ACORN and $user_type ne $NO_USER ) {
            my $dir_owner = `ls -lrt "/home" | grep " $user " | awk '{print \$3}'`;
            my $dir_permission = `stat -c '%a' $path`;
            chomp($dir_owner);
            chomp($dir_permission);
            my $dir_group_owner = `ls -lrt "/home" | grep " $user " | awk '{print \$4}'`;
            chomp($dir_group_owner);
            if ("$sec_lvl" =~ /^low/ or "$sec_lvl" =~ /^very-low/){
              my $output1 = `grep -m 1 "^$user:" "$USER_PERMS_BACKUP"`;
              if ($output1 =~ /\S+:\.\S+:(\d+):\S+:\S+:\S+/){
                $pre_dir_permission = $1;
                if ($pre_dir_permission ne $dir_permission){
                  system("/bin/chmod", "$pre_dir_permission", "$path");
                }
              }
            }elsif ("$sec_lvl" =~ /^high/){
              if ($dir_permission > '750'){
                system("/bin/chmod", "750", "$path");
              }
            }
            my @ls_out = `ls -al $path`;
            foreach my $file(@ls_out){
              if( $file =~ /[-d]\S+\s+\S+\s+(\S+)\s+(\S+)\s+\S+\s+\S+\s+\S+\s+\S+\s+(\.[a-zA-Z]\S+)/ ) {
                $file_name = $3;
                $file_owner = $1;
                $group_owner = $2;
                
                if ("$sec_lvl" =~ /^low/ or "$sec_lvl" =~ /^very-low/){
                  my $output1 = `grep -m 1 "^$user:$file_name:" "$USER_PERMS_BACKUP"`;
                  if($output1 =~ /\S+:\S+:\S+:\S+:(\S+):\S+:(\S+)/){
                    $pre_file_owner = $1;
                    $pre_group_owner = $2;
                    $file_path = "$path/$file_name";
                    if($file_owner ne $pre_file_owner){
                      system("/bin/chown", "$pre_file_owner", "$file_path");
                    }
                    if ($group_owner ne $pre_group_owner){
                      system("/bin/chgrp", "$pre_group_owner", "$file_path");
                    }
                  }
                } elsif ("$sec_lvl" =~ /^high/){
                   if ( !( -f $USER_PERMS_BACKUP)){
                     system("/bin/touch $USER_PERMS_BACKUP");
                   }
                   open(WRITETO, ">> $USER_PERMS_BACKUP");
                   print WRITETO "$user:$file_name:$dir_permission:$dir_owner:$file_owner:$dir_group_owner:$group_owner\n";
                   close(WRITETO);
                   $file_path = "$path/$file_name";
                   if($dir_owner ne $file_owner and $file_owner ne "root") {
                     system("/bin/chown", "$dir_owner", "$file_path");
                   }
                   if($dir_group_owner ne $group_owner){
                     system("/bin/chgrp", "$dir_group_owner", "$file_path");
                   }
                }
              }
            }
          }
        }
      }
    }
   if ("$sec_lvl" =~ /^low/ or "$sec_lvl" =~ /^very-low/){
     unlink($USER_PERMS_BACKUP) or die "can't delete file : $USER_PERMS_BACKUP";
   }
   close(READ);
}
