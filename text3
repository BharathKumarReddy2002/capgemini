sub log_user_read
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $options ) = @_;
  if( ! ($options =~ /(\w+):(\d+)/) ) { log_user_useage(); } # Exits
  my $prog_name = $1;
  my $pid = $2;
  my $user = $ENV{LOGNAME};
  my $sudoer = $ENV{SUDO_USER};
  my $sudo_cmd = $ENV{SUDO_COMMAND};
  my $remote = $ENV{REMOTEHOST};
  my $log_msg = "";
  my $log_opt = 0;   # No options!
  if( defined $sudoer ) { $user = $sudoer; }
  if( defined $remote ) {
    $log_msg = "\[$pid\] Program enter by user $user logged in from $remote.\n";
  } else {
    $log_msg = "\[$pid\] Program enter by user $user logged in locally.\n";
  }
  openlog $prog_name, $log_opt, $LOG_FAC;
  if ($DEBUG) { print "$log_msg\n"; }
  syslog $LOG_LVL, "$log_msg";
  closelog;
  exit $OK;
}


