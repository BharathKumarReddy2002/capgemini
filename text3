sub ctp_allow_read
{
  my $fn = (caller(0))[3]; fen($fn);
  my $ipaddr = "";
  my $interact = 0;
  my $numip = 0;
  my ( $options ) = @_;
  if( defined $options ) {
    if( $options =~ /interactive/ ) {
      $interact = 1;
      print "Following ip addresses are allowed: \n";
    }
  }
  open(READ, "< $IPTABLESCONF") or exit $E_UNKNOWN;
  while (<READ>) {
    if( $_ =~ /22/ ) {
      my $str = $_;
        # We need to be able to support either empty | default | ip for server
      if( $str =~ /($OCTET\.$OCTET\.$OCTET\.$OCTET)/ ) {
        $ipaddr = $1;
        if( $interact == 1) {
          print "\t\t\t\t\t$ipaddr \n";
          $numip ++;
        } else { print "$ipaddr,"; }
      } 
    }
  }
  if( ($numip == 0) && ($interact == 1)) { print "\t\t\t\t\tAll\n"; }
  print "\n";
  close(READ);
  exit $OK;
}

sub ctp_allow_cfg
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( @cfgIp ) = ();
  my $numip = 0;
  my $net_ip = "127.0.0.1";
  my $tmp_file = "/tmp/foo";
  my ( $options, $values ) = @_;
  my $restart = 0;
  my $cfgedall = 0;
  
  #---- Configure CTP access to use passwords and PAM for ssh
  if ( (defined $options) && ( $options =~ /usepass/ )) {
    set_line_in_file($SSHD_CONF,"/tmp/foo","PasswordAuthentication","yes");
    set_line_in_file("/tmp/foo","/tmp/foo1","UsePAM","yes");
    move "/tmp/foo1", $SSHD_CONF; 
    FLUSH_USR_LOCAL();
    system("/etc/init.d/sshd", "restart");
  }
  #---- Configure CTP access only use keys for ssh
  elsif ( (defined $options) && ( $options =~ /nopass/ )) {
    set_line_in_file($SSHD_CONF,"/tmp/foo","PasswordAuthentication","no");
    set_line_in_file("/tmp/foo","/tmp/foo1","UsePAM","no");
    move "/tmp/foo1", $SSHD_CONF; 
    FLUSH_USR_LOCAL();
    system("/etc/init.d/sshd", "restart");
  }
  #---- Configure CTP access from a fixed set of IP addresses
  else {
    if ( (defined $options) && ( $options =~ /interactive/ )) {
      my $tmpip = 0;
      my $allowedip = Get_Int("How many ip addresses are allowed to access CTP?(0 allow all)", 0, 10, $numip);
      $numip = $allowedip;
      while ( $tmpip < $numip ) { 
	$cfgIp[$tmpip] = ask_for_ip("allowed ip", "$net_ip");
	$tmpip ++;
      }
    } elsif( (defined $values) && ($values =~ /\,/ ) ) {
      @cfgIp = split(/,/, $values);
      $numip = $#cfgIp + 1;
      $restart ++;
    } else {
      ctp_allow_useage();
      exit $E_UNKNOWN;
    }
    
    open(READ, "< $IPTABLESCONF") or exit $E_UNKNOWN;
    open(WRITE, "> $tmp_file") or exit $E_UNKNOWN;
    
    while (<READ>) {
      if( $_ =~ /22/ ) {
	if( $numip ) {
	  while ( $numip ) {
	    $numip--;
	    print WRITE "-A $IPTABLESLABEL -m state --state NEW -m tcp -p tcp --dport 22 -s $cfgIp[$numip] -j ACCEPT\n";
	  }
	} elsif( $cfgedall == 0 ) {
	  print WRITE "-A $IPTABLESLABEL -m state --state NEW -m tcp -p tcp --dport 22 -j ACCEPT\n";
	}
	$cfgedall = 1; 
      } else {
	print WRITE "$_";
      }
    }
    close(READ);
    close(WRITE);
    if ( ! $ON_GUI ) {
        system("/bin/mv", "-f", "$tmp_file", "$IPTABLESCONF");
	FLUSH_ETC();
        if( $restart ) {
        system("$CTPD", "stop");
        system("$IPTABLES", "restart");
        system("$CTPD", "start");
        }
    } else {
        print "\n";
        system("/usr/sbin/iptables-restore < $tmp_file");
        print "\n";
        system("/etc/init.d/iptables", "save");
        print "\n";
        system("$NTP_INIT stop >&  /dev/null ");
        system("$NTP_INIT", "start");
        system("$SSH_INIT", "restart", ">>", "/dev/null");
        print "\n";        
    }
  }
  exit $OK  
}

