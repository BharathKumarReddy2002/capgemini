        my $secret = $1;

        # Remove patterns related to ":TO..:ST.."
        $secret =~ s/:TO\d+:ST[01]:RP\d+:OLF[01]:RF[01].*//;
	$secret =~ s/\\/\\\\/g;   # Escape backslashes
	$secret =~ s/`/\\`/g;     # Escape backticks
	$secret =~ s/"/\\"/g;     # Escape double quotes
       # Ensure sed handles all special characters safely
       `$SED -i "/auth[ ].*[ ]$tacplus_module/ s/.*/& secret=$secret/" "$TACPLUS_PAM"`;
     } #PR-1846890 End

   
      for ( my $i=1; $i<=9; $i++ ) {
         if ( $secret_opt[$i] ne "" ) {
	     #PR-1846890 start
	     $secret_opt[$i] =~ s/\\/\\\\/g;   # Escape backslashes
