sub net_prt_cfg_ipv4
{
  my $fn = (caller(0))[3]; fen($fn);
  my ($dev, $dflt_dev) = @_;
  my ( $stat, $ipaddr, $netmask, $gw, $mtu, $en ) = get_eth_cfg_from_file( $dev ); #PR-1780615
  my $desc = "";
  my $ctp_file = 1;
  my $mgmt_dev;
  my $ckt_dev;
  my $seg_status = get_seg_file_param(2,$ctp_file);

  if ( $seg_status == 1 ) {
    $mgmt_dev = get_seg_file_param(1,$ctp_file);
    $ckt_dev = get_seg_file_param(0,$ctp_file);
  }
  if ($dev =~ /^eth(\d+)$/) { 
    $desc = get_eth_desc($1); 
  } 
  if ($dev =~ /^eth(\d+)\.(\d+)$/) { 
    $desc = "VLAN ID $2 on ethernet port $1"; 
  } 
  if ( "$dev" eq "$dflt_dev" ) {
    if($stat < 3) {
      if( ($seg_status == 1) && ($ckt_dev eq $dev) ) {
        print"\nIPv4 Circuit network device seems not configured. \n";
      } else {
        print"\nDefault IPv4 network device seems not configured. \n";
      }
      return;
    }
    if( ($seg_status == 1) && ($ckt_dev eq $dev) ) {
      print "\nCircuit network device ($dev: $desc) IPV4 parameters:\n";
    } else {
      print "\nDefault network device ($dev: $desc) IPV4 parameters:\n";
    }
  } elsif ( $stat >= 2 && $en eq "yes" ) { #PR-1780615
    if( ($seg_status == 1) && ($mgmt_dev eq $dev) ) {
      print "\nManagement network device ($dev: $desc) IPV4 parameters:\n";
    } else {
      print "\nNetwork device ($dev: $desc) IPV4 parameters:\n";
    }
  } else {
    return;
  }
  print "\tipaddress:  $ipaddr\n";
  print "\tnetmask:    $netmask\n";
  if ( "$dev" eq "$dflt_dev" ) {
    print "\tdefault gw: $gw\n";
  }
  if( ($seg_status == 1) && ($mgmt_dev eq $dev) ) {
    my $mgmt_route="/etc/sysconfig/network-scripts/route-$mgmt_dev";
    open(ROUTE_READ, "< $mgmt_route");
    while(<ROUTE_READ>) {
      if ( $_ =~ /default via ($OCTET\.$OCTET\.$OCTET\.$OCTET)/) {
        print "\tdefault gw: $1\n";
      }
    }
    close(ROUTE_READ);
  }
  print "\tmtu:        $mtu bytes\n";
  if ( $stat >= 1) {
    prt_route_cfg("$dev");
  }
}

