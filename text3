sub snmpdconf_show
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $snmp, $opts ) = @_;
  my $num_cfgd_snmp = 0;
  my $index;
  my $engine_id = `$GREP "engineID" $SNMPDCONF | $WC -l`;    # Aricent PR 1255040 fix
  if($DEBUG){print "snmpdconf_show: Function Enter\n";}

  #=========== Interactive ============
  if( (defined $opts) && ($opts =~ /interactive/i) ){
    print STDOUT "  Location: \"$snmp->{location}\"\n";
    # Aricent PR 1255040 fix - Start
    print STDOUT "  Contact:  \"$snmp->{contact}\"\n";
    if ( $engine_id =~ /1/ ) {
	    $engine_id = `$GREP "engineID" $SNMPDCONF | $AWK '{print \$2}'`;
	    chomp($engine_id);
	    print STDOUT "  SNMPv3 Engine ID: \"$engine_id\"\n\n";
    }
    # Aricent PR 1255040 fix - End

    for($index=1;$index<=$MAX_SNMP_USERS;$index++) { 
      if( $snmp->{$index}{used} eq "yes" ) {
	$num_cfgd_snmp++;
	print STDOUT "  $num_cfgd_snmp) ";
	print STDOUT "Type: SNMPv" . $snmp->{$index}{SNMPv} . " ";
	print STDOUT "Access: " . $snmp->{$index}{rw} . " ";
	if( $snmp->{$index}{SNMPv} == 2 ) {
	  print STDOUT "Comm: \"" . $snmp->{$index}{comm} . "\" ";
	  print STDOUT "IPv" . $snmp->{$index}{IPv} . " ";
	  print STDOUT "IP: " . $snmp->{$index}{ip} . " ";
	} else {
	  print STDOUT "User: \"" . $snmp->{$index}{user} . "\" ";
	  print STDOUT "Pass: \"" . $snmp->{$index}{pass} . "\" ";
          # Aricent PR 1362733 fix - Start
          print STDOUT "IPv" . $snmp->{$index}{IPv} . " ";
          print STDOUT "IP: " . $snmp->{$index}{ip} . " ";
          # Aricent PR 1362733 fix - End
	}
	print STDOUT "\n";
      }
    }
    if($num_cfgd_snmp) {
      if( $DEBUG ) { print "Found $num_cfgd_snmp SNMP users\n"; }
    } else {
      print "\nNo SNMP users are configured on the system :\n\n";
    }
  } 
  #=========== Non-Interactive (single string) ============
  else {
    print STDOUT ":ST$snmp->{state}:";
    print STDOUT "LO,$snmp->{location}:";
    print STDOUT "CO,$snmp->{contact}:";
    for($index=1;$index<=$MAX_SNMP_USERS;$index++) { 
      if( $snmp->{$index}{used} eq "yes" ) {
	print STDOUT "USR,";
	print STDOUT $snmp->{$index}{rw}     . ",";
	print STDOUT $snmp->{$index}{SNMPv}  . ",";
	if( $snmp->{$index}{SNMPv} == 2 ) {
	  print STDOUT $snmp->{$index}{IPv}  . ",";
	  print STDOUT $snmp->{$index}{comm} . ",";
	  print STDOUT $snmp->{$index}{ip}   . ",";
	} else {
	  print STDOUT $snmp->{$index}{user} . ",";
	  print STDOUT $snmp->{$index}{pass} . ",";
          # Aricent PR 1362733 fix - Start
          print STDOUT $snmp->{$index}{IPv}  . ",";
          print STDOUT $snmp->{$index}{ip}  . ",";
          # Aricent PR 1362733 fix - End
	}
	print STDOUT ":";
      }
    }
 # Aricent PR 1255040 fix - Start
    if ( $engine_id =~ /1/ ) {
      $engine_id = `$GREP "engineID" $SNMPDCONF | $AWK '{print \$2}'`;
      chomp($engine_id);
      print STDOUT "SNMPv3_EID,$engine_id:";
    # Aricent PR 1362733 fix - Start
    } else {
      print STDOUT "SNMPv3_EID,_:";
    # Aricent PR 1362733 fix - End
    }
    # Aricent PR 1255040 fix - End
    print STDOUT "\n";
  }
  return $num_cfgd_snmp;
}

