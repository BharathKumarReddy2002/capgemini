sub snmpdconf_set_del
{
  my $fn = (caller(0))[3]; fen($fn);
  my ($snmp, $num_cfgd_snmp) = @_;
  my $index = 0;
  if($DEBUG){print "snmpdconf_set_del: Function Enter\n";}
  my $del_num = Get_Int("Which SNMP user will be deleted?", 1, $num_cfgd_snmp, $num_cfgd_snmp);
  while( $del_num ) {
    $index++;
    if( $snmp->{$index}{used} eq "yes" ) { $del_num--; }
  }
  $snmp->{$index}{used} = "no";	# delete entry
}

