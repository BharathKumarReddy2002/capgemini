#---------------------------------------------------------------------
sub snmptrap_cfg
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $read, $opts, $values ) = @_;
  my ( %snmp );
  my $rtn = $OK;
  if ( $read ) { 
    $rtn = snmptrap_read( \%snmp, $opts );
    $rtn = snmptrap_show( \%snmp, $opts );
  } else { 
    if( defined($opts) && ($opts =~ /interactive/) ) { 
      snmptrap_read( \%snmp, $opts );		# set hash from snmpd.conf
      snmptrap_set(\%snmp, $opts);		# ask user for changes
      snmptrap_write( \%snmp );			# write to snmpd.conf
    } else {
      snmptrap_set( \%snmp, $opts, $values );	# set hash from string
      snmptrap_write( \%snmp );			# write to snmpd.conf
    }
  }
  return $rtn;
}

#---------------------------------------------------------------------
sub snmptrap_show
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $snmp, $opts ) = @_;
  my $num_cfgd_snmp = 0;
  my ($index, $sink_target, $user_target);    # Aricent PR 1362733 fix
  if($DEBUG){print "snmptrap_show: Function Enter\n";}

  #=========== Interactive ============
  if( (defined $opts) && ($opts =~ /interactive/i) ){
    print STDOUT "  Trap Community: \"$snmp->{comm}\"\n\n";
    for($index=1;$index<=$MAX_SNMP_USERS;$index++) { 
      if( $snmp->{$index}{used} eq "yes" ) {
	$num_cfgd_snmp++;
	print STDOUT "  $num_cfgd_snmp) ";
	print STDOUT "IPv" . $snmp->{$index}{IPv} . " ";
	print STDOUT "IP: " . $snmp->{$index}{ip} . " ";
	print STDOUT "\n";
      }
    }
    if($num_cfgd_snmp) {
      if( $DEBUG ) { print "Found $num_cfgd_snmp Trap Hosts\n"; }
    } else {
      print "\nNo Trap Hosts are configured on the system :\n\n";
    }
  } 
  #=========== Extract specific trap host IP ============
  elsif( (defined $opts) && ($opts =~ /sink(\d+)/i) ) {
    if( $snmp->{state} == 1 ) {
      $sink_target = $1;
      for($index=1;$index<=$MAX_SNMP_USERS;$index++) { 
	if( $snmp->{$index}{used} eq "yes" ) {
	  if( $sink_target == 1 ) {
	    print STDOUT $snmp->{$index}{ip} . "\n";
	  }
	  $sink_target--;
	}
      }
      # Indicate there are no more trap hosts
      if( $sink_target >= 1) { print STDOUT "none\n"; }
    } else { print STDOUT "none\n"; }
  } 
  # Aricent PR 1362733 fix - Start
  elsif( (defined $opts) && ($opts =~ /user(\d+)/i) ) {
    if( $snmp->{state} == 1 ) {
      $user_target = $1;
      for($index=1;$index<=$MAX_SNMP_USERS;$index++) {
        if( $user_target == 1 ) {
          print STDOUT $snmp->{$index}{user} . " " . $snmp->{$index}{pass} . "\n";
        }
        $user_target--;
      }
      # Indicate there are no more trap hosts
      if( $user_target >= 1) { print STDOUT "none none\n"; }
    } else { print STDOUT "none none\n"; }
  }
  # Aricent PR 1362733 fix - End
  #=========== Just return count of TrapHosts ============
  elsif( (defined $opts) && ($opts =~ /justcnt/i) ) {
    for($index=1;$index<=$MAX_SNMP_USERS;$index++) { 
      if( $snmp->{$index}{used} eq "yes" ) { $num_cfgd_snmp++; }
    }
  } 
  #=========== Non-Interactive (single string) ============
  else {
    print STDOUT ":ST$snmp->{state}:";
    print STDOUT "TR$snmp->{comm}:";
    for($index=1;$index<=$MAX_SNMP_USERS;$index++) { 
      if( $snmp->{$index}{used} eq "yes" ) {
	print STDOUT "IP,";
	print STDOUT $snmp->{$index}{ip};
	print STDOUT ",:";
      }
    }
    print STDOUT "\n";
  }
  return $num_cfgd_snmp;
}

#---------------------------------------------------------------------
sub snmptrap_read
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $snmp, $opts ) = @_;
  my $num_cfgd_snmp = 0;
  my $commented_out = 0;
  my $index;
  my $user_index = 1;    # Aricent PR 1362733 fix
  # Initialize hash to all unused entries
  for($index=1;$index<=$MAX_SNMP_USERS;$index++) { 
    # Aricent PR 1362733 fix - Start
    $snmp->{$index}{used} = "no";
    $snmp->{$index}{user} = "none";
    $snmp->{$index}{pass} = "none";
    # Aricent PR 1362733 fix - End
  }
  $snmp->{comm} = "none";
  $snmp->{state} = 0;		# assume disabled for now

  #----- Get config from file -----
  $index = 1;
  open(  READ, "< $SNMPDCONF" ) or return $NO_SUCH_FILE;
  while (<READ>) {
    # As of version 5.3.0.1, we use rwcommunity to setup v2c access
    # Format: rwcommunity <community name> [<ip>|default]
    # Note: default is equilavent to not specifying a server ip. In these
    # cases requests form ANY ip are serviced.
    #--- trap community (enabled)
    if( $_ =~ /^(#?)trapcommunity\s+\"(\S+)\"\s*$/ ) {
      if( $1 eq "#" ) { $commented_out++ };
      $snmp->{comm} = $2;
      if($DEBUG){print "snmptrap_read: found trap comm $2\n"; }
    } 
    #--- trap2sink
    elsif( $_ =~ /^(#?)trap2sink\s+(\S+)\s*$/ ) {
      $snmp->{$index}{ip}    = $2;
      if( $snmp->{$index}{ip} =~ /($IPV4ADDFORMAT)/ ) {
	$snmp->{$index}{ip}	= $1;
	$snmp->{$index}{IPv}	= 4;
	$snmp->{$index}{used} = "yes";
	if($DEBUG){print "snmptrap_read: found IPv4 trap sink $1\n"; }
	$index++;
      }
      elsif( $snmp->{$index}{ip} =~ /($IPV6ADDFORMAT)/ ) {
	$snmp->{$index}{ip}	= $1;
	$snmp->{$index}{IPv}	= 6;
	$snmp->{$index}{used} = "yes";
	if($DEBUG){print "snmptrap_read: found IPv6 trap sink $1\n"; }
	$index++;
      }
      else {
        print "Problem parsing trap2sink IP address in snmpd.conf\n";
	return $NO_IP_FOUND;
      }
    }
    # Aricent PR 1362733 fix - Start
    elsif( $_ =~ /^(#?)createUser\s+(\S+)\s*SHA\s*\"(\S+)\"\s*AES/ ) {
      $snmp->{$user_index}{user} = $2;
      $snmp->{$user_index}{pass} = $3;
      $user_index++;
    }
    # Aricent PR 1362733 fix - End 
  }
  close ( READ );

  if($DEBUG){print "snmptrap_read: index $index\n"; }
  if($DEBUG){print "snmptrap_read: commented_out $commented_out\n"; }

  if( ($snmp->{comm} eq "none") || 
      ($index == 1) ||
      ($commented_out > 0) ) { 
    $snmp->{state} = 0; 
  } else { $snmp->{state} = 1; }

  return $OK;
}

#---------------------------------------------------------------------
sub snmptrap_set
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $snmp, $opts, $string ) = @_;
  if( $DEBUG ) { print "snmptrap_set: Function Enter\n"; }

  #=========== Interactive ============
  if( defined($opts) && ($opts =~ /interactive/) ) { 
    my $rtn = "";
    my $cnt = 0;	# index of last configured element

    print "\nCurrent SNMP trap community is \"$snmp->{comm}\".\n";
    print "Trap Community String (<cr> to keep, \"none\" to disable)\n";
    $snmp->{comm} = 
      ask_for_string("a value", $snmp->{comm});

    if( $snmp->{comm} !~ /^[\!\#\@A-Za-z0-9_\-\?^&\{}\[\]%~=\$|\/<>;.+*(\)\\]+$/ ) { #PR-1846890
      print "\nComm string may have character set from 0x21(!) to 0x7e(~), characters backtick (\`), single quote ('),comma(,),colon(:) and double quote (\") are not allowed. \n"; #PR-1846890
      $snmp->{comm} = "none";
    }

    while ($rtn !~ /^quit/) {
      # Find out how many trap hosts there are by displaying them.
      $cnt = snmptrap_show( $snmp, $opts );
      print "\nHow do you want to change trap hosts (add/del/quit) ? (<cr> to show): ";
      chop ( $rtn = <STDIN> );
      if ( $rtn =~ /add/ ) {
	snmptrap_set_add($snmp, $cnt);
      } elsif ( $rtn =~ /del/ ) {
	if($cnt == 0) { print "Sorry, but there are no trap hosts configured\n" }
	else { snmptrap_set_del($snmp, $cnt); }
      }
      print "\n\n";
    }
    $cnt = snmptrap_show( $snmp, "justcnt" );	# just to get the traphost count

    #--- Figure out if traps are enabled
    if(($snmp->{comm} ne "none") && ($cnt != 0)) { 
      $snmp->{state} = 1; 
    } else { $snmp->{state} = 0; }

  } 
  #=========== Non-Interactive (from string) ============
  else {
    my $index;
    my $p_err = 0;
    my $state = 0;
    # Initialize hash to all unused entries
    for($index=1;$index<=$MAX_SNMP_USERS;$index++) { 
      $snmp->{$index}{used} = "no"; }
    $snmp->{comm} = "none";
    $snmp->{state} = 0;

    $index = 1;	# reset loop count
    while( ($string ne ":") && ($p_err == 0) ) {
      if($DEBUG){print STDOUT "---> String to parse: \"$string\"\n";}
      #--- TR token
      if( $string =~ s/^:TR([^:]+):/:/ )  { 
	$snmp->{comm} = $1;
	if($DEBUG){print "Parsed community string: $snmp->{comm}\n"; }
      }
      #--- ST token
      elsif( $string =~ s/^:ST(\d+):/:/ ) { 
	$state = $1; 
	if($DEBUG){print "Parsed state: $state\n"; }
      }
      #--- IP token
      elsif( $string =~ s/^:IP,([^,]+),:/:/ )  { 
	$snmp->{$index}{ip}    = $1;
	if( $snmp->{$index}{ip} =~ /($IPV4ADDFORMAT)/ ) {
	  $snmp->{$index}{ip}	= $1;
	  $snmp->{$index}{IPv}	= 4;
	  $snmp->{$index}{used} = "yes";
	  if($DEBUG){print "Parsed IPv4: $snmp->{$index}{ip}\n"; }
	  $index++;
	}
	elsif( $snmp->{$index}{ip} =~ /($IPV6ADDFORMAT)/ ) {
	  $snmp->{$index}{ip}	= $1;
	  $snmp->{$index}{IPv}	= 6;
	  $snmp->{$index}{used} = "yes";
	  if($DEBUG){print "Parsed IPv6: $snmp->{$index}{ip}\n"; }
	  $index++;
	} 
	else { $p_err = 1; print "Couldn't parse IP token\n"; }
      } 
      #--- default
      else { $p_err = 1; print "Couldn't parse token\n"; }
    }
    if ( $p_err == 1 ) { snmptrap_useage(); }

    if($DEBUG){print "snmptrap_set: index $index\n"; }
    if($DEBUG){print "snmptrap_set: state $state\n"; }

    #--- Figure out if traps are enabled
    if( ($snmp->{comm} ne "none") && 
	($index != 1) && 
	($state == 1) ) { 
      $snmp->{state} = 1; 
    } else { $snmp->{state} = 0; }
  }
}

#---------------------------------------------------------------------
sub snmptrap_set_del
{
  my $fn = (caller(0))[3]; fen($fn);
  my ($snmp, $num_cfgd_snmp) = @_;
  my $index = 0;
  if($DEBUG){print "snmptrap_set_del: Function Enter\n";}
  my $del_num = Get_Int("Which trap host will be deleted?", 
      1, $num_cfgd_snmp, $num_cfgd_snmp);
  while( $del_num ) {
    $index++;
    if( $snmp->{$index}{used} eq "yes" ) { $del_num--; }
  }
  $snmp->{$index}{used} = "no";	# delete entry
}

#---------------------------------------------------------------------
sub snmptrap_set_add
{
  my $fn = (caller(0))[3]; fen($fn);
  my ($snmp, $num_cfgd_snmp) = @_ ;
  my (@choices);
  my $index = 1;
  my $found_mt_idx = 0;
  my ($sel);
  if($DEBUG){print "snmptrap_set_add: Function Enter\n";}
  if($num_cfgd_snmp >= $MAX_SNMP_USERS) {
    print "$num_cfgd_snmp trap hosts are already configured on the system\n";
    print "deletion of a trap host is required prior to addition of a new one \n";
  } else {
    $num_cfgd_snmp++;
    # find the available slot in the snmp hash
    while( ($index<=$MAX_SNMP_USERS) && ($found_mt_idx==0) ) {
      if( $snmp->{$index}{used} eq "yes" ) { $index++; }
      else { $found_mt_idx++; }
    }
    if($DEBUG){print "Free hash index: $index\n"; }
    $snmp->{$index}{used} = "yes";
    #----
    @choices = ('IPv4','IPv6');
    $sel = ask_for_choice(\@choices,$#choices);
    $sel =~ /IPv(\d+)/;
    $snmp->{$index}{IPv} = $1;
    if($DEBUG){print "IPv: $snmp->{$index}{IPv}\n"; }

    if( $snmp->{$index}{IPv} == 4 ) {
      $sel = ask_for_ip("trap host (IPv4)");
      $snmp->{$index}{ip} = $sel;
    } else {
      $sel = ask_for_ipv6_add("trap host (IPv6)");
      $snmp->{$index}{ip} = $sel;
    }
  }
}

