sub ctp_cfg
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $read, $opts, $values ) = @_;
  if ( $read ) { ctp_cfg_read( $opts ); }
  else { ctp_cfg_cfg( $opts, $values); }
}

sub ctp_cfg_read
{
  my $fn = (caller(0))[3]; fen($fn);
  my $protocol = 47;
  my $port     = 16;
  my $port6    = 32;
  my ( $options ) = @_;
  open(READ, "< $SYSCFG_CTP") or exit $E_UNKNOWN;
  while (<READ>) {
    if( $_ =~ /CTP_PROTOCOL=(\d+)/ ) { $protocol = $1; }
    if( $_ =~ /CTP_PORT=(\d+)/ )     { $port     = $1; }
    if( $_ =~ /CTP_PORT_V6=(\d+)/ )     { $port6 = $1; }
  }
  close(READ);
  if( defined $options) {
    if( $options =~ /no_prt/ ) {
      return $protocol, $port, $port6;
    } elsif ( $options =~ /protocol/i ) {
      print "$protocol \n";
    } elsif ( $options =~ /port/i ) {
      print "$port \n";
    } elsif ( $options =~ /port6/i ) {
      print "$port6 \n";
    } else {
      print "CEP$protocol:OAMP$port:OAM6P$port6\n";
    }
    exit $OK;
  }
}

sub ctp_cfg_cfg
{
  my $fn = (caller(0))[3]; fen($fn);
  my $restart = 1;
  my $found_one = 0;
  my $found_cep = 0;
  my $found_oam = 0;
  my $found_oam6 = 0;
  my ( $protocol, $port, $port6 ) = ctp_cfg_read("no_prt");
  my $tmp_file = "/tmp/foo";
  my ( $options, $values ) = @_;
  if( defined $options ) {
    if( $options =~ /menu/ )        { $restart = 0; }
    if( $DEBUG ) { print "Got option $options passed.\n"; }
  }
  if( defined $values ) {
    if( $DEBUG ) { print "Got values $values passed.\n"; }
    if ( $values =~ /CEP(\d+)/ )  { $protocol = $1; $found_one++; }
    if ( $values =~ /OAMP(\d+)/ ) { $port     = $1; $found_one++; }
    if ( $values =~ /OAM6P(\d+)/ ){ $port6   = $1; $found_one++; }
  }
  if( $found_one == 0 ) { ctp_cfg_useage(); }
  open(READ, "< $SYSCFG_CTP") or exit $E_UNKNOWN;
  open(WRITE, "> $tmp_file") or exit $E_UNKNOWN;
  while (<READ>) {
    if( $_ =~ /CTP_PROTOCOL=(\d+)/ ) {
      if( $protocol != 47) { print WRITE "CTP_PROTOCOL=$protocol\n"; }
      $found_cep = 1;
    } elsif( $_ =~ /CTP_PORT=(\d+)/ ) {
      if( $port != 16 ) { print WRITE "CTP_PORT=$port\n"; }
      $found_oam = 1;
    } elsif( $_ =~ /CTP_PORT_V6=(\d+)/ ) {
      if( $port6 != 32 ) { print WRITE "CTP_PORT_V6=$port6\n"; }
      $found_oam6 = 1;
    } else {
      print WRITE "$_";
    }
  }
  if( (!$found_cep) && ($protocol != 47) ) { print WRITE "CTP_PROTOCOL=$protocol\n"; }
  if( (!$found_oam) && ($port     != 16) ) { print WRITE "CTP_PORT=$port\n"; }
  if( (!$found_oam6) && ($port6   != 32) ) { print WRITE "CTP_PORT_V6=$port6\n"; }
  close(READ);
  close(WRITE);
  system("/bin/mv", "-f", "$tmp_file", "$SYSCFG_CTP");
  FLUSH_ETC();
  if( $restart ) {
    system("$CTPD", "stop");
    system("$NETWORK", "restart");
    system("$CTPD", "start");
  }
  exit $OK
}

