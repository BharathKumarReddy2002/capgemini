sub ntp_read            # Only one server!
{
  my $fn = (caller(0))[3]; fen($fn);
  my $sip = "10.0.0.1";        # Default for none.
  my $s1ip = "";
  my ($key, $key_value, $key1, $key_value1) = ("") x 4;
  my $state = 0;
  my $secondip = 0;
  open( READ, "< $NTP_CONF" ) or die "Can't open $NTP_CONF!";
  while(<READ>) {
    if ( $_ =~ /^\s*server\s+(\d+\.\d+\.\d+\.\d+|$IPV6ADDFORMAT)/ ) {      # Skip comments
      if ( $1 ne "127.127.1.0" ) { 
        if( $secondip == 0 ) { $sip = $1; $secondip ++;}
        else { $s1ip = $1; }
      }  
    }
  }
  close( READ );

  $secondip = 0;
  open( READ1, "< $NTP_KEYS" ) or die "Can't open $NTP_KEYS!";
  while(<READ1>) {
    if ( $_ =~ /^(\d+)\s+SHA1\s+([!-~]+)/ ) { # Aricent PR 1124693,1857570, 1846890
      if( $secondip == 0 ) { $key=$1; $key_value=$2; $secondip ++;}
      else { $key1=$1; $key_value1=$2; }
    }
    elsif ( $_ =~ /^\s$/  ) {    # Aricent PR 1142788 fix
      if( $secondip == 0 ) { $key=""; $key_value=""; $secondip ++;}
      else { $key1=""; $key_value1=""; }
    }
  }
  close( READ1 );
  
  # State is ONLY on if ntpd is running AND startup exisits in /etc/init.d
  my $ntp_procs=0; $ntp_procs += `ps aux | $GREP "ntpd" | $GREP -v "grep" | wc -l`;
  if ( ( -f $NTP_START ) && ( $ntp_procs != 0 ) ) { $state = 1; }
  else { $state = 0; }
  #print STDOUT "SIP$sip\:ST$state\:S1IP$s1ip\n";
  print STDOUT "SIP$sip\:KID$key\:SS$key_value\:ST$state\:S1IP$s1ip\:K1ID$key1\:SS1$key_value1\n";
  return $OK;
}

