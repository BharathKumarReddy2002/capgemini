sub GetNumLocalPorts{
  my $fn = (caller(0))[3]; fen($fn);
  my $ctpd_running = 0;
  my $num_ports = 4;    # Default to 4 ports (ctp1004)
  $ctpd_running = `/bin/ps aux | $GREP "/acorn/bin/ctpd" | /usr/bin/wc -l`;
  if ( $ctpd_running == 0 ) { return 0; }
  if ( ! -f "$CMD" ) { return 0; }
  my $cmd = "$CMD node qry www_ver";
  my $rtn_str = `$cmd`;
  if( "$rtn_str" =~ /unusable/i ) {
    $SYS_UNUSABLE = $YES;
    $num_ports = 56;
    # Wrong fpga, look for cards present.
    log_it( LOG_ERR, "System unusable, please check card fpga versions.");
    my $card = 0 ;
    while($card <= 8) {
      if( "$rtn_str" =~ /$card\s+(Yes|No)/ ) {
	my $card_present = ($1 =~ /Yes/) ?  $YES : $NO;
	my $p = 0;
	while( $p< 8  ) {
	  my $port = 8*$card + $p;
	  my $port_key = "PORT_$port";
	  $p++;
	}
      }
      $card++;
    }
  } else {
    if(($?>>8)&0xff) { print "cmd failed: $cmd\n"; exit $E_PROG_ERR; }
    #print "Got return: $rtn_str.\n";
    my @values = split /;/, $rtn_str;
    if ( defined $values[10] ) {
      my @cfg_values = split /:/, $values[10];
      if( defined $cfg_values[0] ) {
	my $port_str = $cfg_values[0];
	my $len_2_match  = 14; #56 ports max
	  my $port_str_len = 0;
	while ( ($len_2_match >= 0) && ($port_str_len == 0) ) {
	  if( $port_str =~ /[\dF]{$len_2_match}/ ) { $port_str_len = $len_2_match; }
	  $len_2_match--;
	}
	if ($VDEBUG) { print "\tPort string is $port_str\n"; }
	if ($VDEBUG) { print "\tPort string length is $port_str_len\n"; }

	if( $port_str_len == 1 ) {
          # 4 port cards only support 4, 2, 1 or 0 ports
	  if( $port_str eq "F" ) { $num_ports = 4; }
	  elsif ( $port_str == "3" ) { $num_ports = 2; }
	  elsif ( $port_str == "1" ) { $num_ports = 1; }
	  else { $num_ports = 0; }
	} elsif( $port_str_len == 3 ) {
          # 12 port only support 12 ports!
	  $num_ports = 12;
	} elsif( $port_str_len == 6 )  {
          # 24 port
	  $num_ports = 24;
	} elsif( $port_str_len == 14 ) {
          # 56 port
	  $num_ports = 56;
	}
      }
    }
  }
  return $num_ports;
}

