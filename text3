    if ( $_ =~ /PRIMARY_ROUTE\s+\=\s+eth(\d+):(\d+\.\d+\.\d+\.\d+)\/(\d+)/ ) { print STDOUT ":PRIMARY_ROUTEeth$1:$2\/$3"; }
    if ( $_ =~ /FORCE_SWITCH\s+\=\s+(\d)/ ) { print STDOUT ":FORCE_SWITCH$1"; }  # Aricent PR 846653 fix
    # Aricent PR 841216 Fix - End
  }
  close( READ );
  rel_sem ( $AAS_SEM, "AAS_SEM" );
  print STDOUT "\n";
  return $OK;
}

