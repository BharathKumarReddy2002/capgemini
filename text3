    elsif ($string =~ /SIP$IPV6ADDFORMAT/ ) { $sip = $1; }
    else { $parse_error = 1; }     # Problem getting server ip
    if ( $string =~ /SS([\w@!#?^&\{}\[\]%~=\-\,\$"'|\/<>:;.+*(\)`\\]+)/ ) { $secret = $1; } # Aricent fix for PR 798137, PR-1846890
    if ( $string =~ /TO(\d+)/ )     { $to = $1; }
