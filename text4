int ctp_wait_for_handle(int Card,int pNum)
{
  int cnt = 0;
  int status = SUCCESS;
  FUNC_PRT(ctp_wait_for_handle, PF_VSIG, -1);

  while( HANDLE_LOCK(Card,pNum) != 0 ) {
    usleep(10000);
    cnt++;
    if( cnt >= 50 ) {
      status = FAILURE;
      PRTP(MIN,Timout waiting for free port resource handle);
      break;
    }
  }
  HANDLE_LOCK(Card,pNum) = 1;
  return(status);
}

void ctp_release_handle(Card,pNum)
{
  FUNC_PRT(ctp_release_handle, PF_VSIG, -1);

  HANDLE_LOCK(Card,pNum) = 0;
}

int  ctp_vb_cmd(int Card, int pNum, u32 cmd)
{
  int status = SUCCESS;
  int log = 0;
  FUNC_PRT(ctp_vb_cmd, PF_VSIG, -1);

#ifdef DBG_VB_CMD
  log = 1;
#endif

  //--- Check for allowed card command
  switch(CARDTYPE(Card)){
    case EMCARD:
      if( !(cmd & CTP_VB_CMD_EM_MASK) ) {
	if( !(cmd & CTP_VB_CMD_EM) ) PRTC(MIN,Got command for non-E&M card)
	else                         PRTC(MIN,Unsupported E&M command);
	status = FAILURE;
      }
      break;
    case FXSCRD:
      if( !(cmd & CTP_VB_CMD_FXS_MASK) ) {
	if( !(cmd & CTP_VB_CMD_FXS) ) PRTC(MIN,Got command for non-FXS card)
	else                          PRTC(MIN,Unsupported FXS command);
	status = FAILURE;
      }
      break;
    case FXOCRD:
      if( !(cmd & CTP_VB_CMD_FXO_MASK) ) {
	if( !(cmd & CTP_VB_CMD_FXO) ) PRTC(MIN,Got command for non-FXO card)
	else                          PRTC(MIN,Unsupported FXO command);
	status = FAILURE;
      }
      break;
    default:
      PRT(MIN,ctp_vb_cmd: Unsupported card type);
      status = FAILURE;
      break;
  }

  if( status == SUCCESS) status = ctp_wait_for_handle(Card,pNum);

  if( status == SUCCESS) {
    VBHANDLE hRes = (VBHANDLE)pVcSigs->Card[Card].hRes[pNum];
    switch(cmd) {
      case CTP_VB_CMD_EM_PTT_SENSE:
	if( audPttSense(hRes, 1) != VB_OK) PRTP(MIN,Problem enabling M-lead indications);
	if(log) PRTP(MIN,audPttSense 1 called);
	break;
      case CTP_VB_CMD_EM_PTT_SENSE_OFF:
	if( audPttSense(hRes, 0) != VB_OK) PRTP(MIN,Problem disabling M-lead indications);
	if(log) PRTP(MIN,audPttSense 0 called);
	break;
      case CTP_VB_CMD_EM_OFF_HOOK:
	if( audControl(hRes, 1, AUDCTL_ELEAD) != VB_OK) PRTP(MIN,Problem taking E-lead off hook);
	if(log) PRTP(MIN,audControl 1 called);
	break;
      case CTP_VB_CMD_EM_ON_HOOK:
	if( audControl(hRes, 0, AUDCTL_ELEAD) != VB_OK) PRTP(MIN,Problem putting E-lead on hook);
	if(log) PRTP(MIN,audControl 0 called);
	break;
      case CTP_VB_CMD_FXS_HOOK_SENSE:
	if( ncoHooksense(hRes, 1) != VB_OK) PRTP(MIN,Problem enabling hook sense indications);
	if(log) PRTP(MIN,ncoHooksense 1 called);
	break;
      case CTP_VB_CMD_FXS_HOOK_SENSE_OFF:
	if( ncoHooksense(hRes, 0) != VB_OK) PRTP(MIN,Problem disabling hook sense indications);
	if(log) PRTP(MIN,ncoHooksense 0 called);
	break;
      case CTP_VB_CMD_FXS_RING_SENSE:
	if( ncoRingGroundSense(hRes, 1) != VB_OK) PRTP(MIN,Problem enabling ring ground sense indications)
	else                                      PRTP(GEN,**** Enabled ring ground sense indications);
	if(log) PRTP(MIN,ncoRingGroundSense called);
	break;
      case CTP_VB_CMD_FXS_RESET:
	if( ncoReset(hRes) != VB_OK) PRTP(MIN,Problem resetting fxs port);
	if(log) PRTP(MIN,ncoReset called);
	break;
      case CTP_VB_CMD_FXS_RING_OFF:
	if( ncoRingControl(hRes, 0, RC_STANDARD) != VB_OK) PRTP(MIN,Problem turning off ring on fxs port);
	if(log) PRTP(MIN,ncoRingControl 0 called);
	break;
      case CTP_VB_CMD_FXS_RING_ON:
	if( ncoRingControl(hRes, 1, RC_STANDARD) != VB_OK) PRTP(MIN,Problem turning on ring on fxs port);
	if(log) PRTP(MIN,ncoRingControl 1 called);
	break;
      case CTP_VB_CMD_FXS_GND_TIP:
	if( ncoGroundTip(hRes) != VB_OK) PRTP(MIN,Problem grounding tip on fxs port);
	if(log) PRTP(MIN,ncoGroundTip called);
	break;
      case CTP_VB_CMD_FXS_LOOP_START:
	if( ncoLoopStart(hRes) != VB_OK) PRTP(MIN,Problem setting fxs port to loop start);
	if(log) PRTP(MIN,ncoLoopStart called);
	break;
      case CTP_VB_CMD_FXS_GND_START:
	if( ncoGroundStart(hRes) != VB_OK) PRTP(MIN,Problem setting fxs port to ground start);
	if(log) PRTP(MIN,ncoGroundStart called);
	break;
      case CTP_VB_CMD_FXO_RING_SENSE:
	if( lineHalfRingSenseOn(hRes) != VB_OK) PRTP(MIN,Problem enabling ring sense indications)
	else                                    PRTP(GEN,**** Enabled ring sense indications);
	if(log) PRTP(MIN,lineHalfRingSenseOn called);
	lineWriteCodecRegister(hRes,23,8);	// Decrease ring sense hystereis
	break;
      case CTP_VB_CMD_FXO_RING_SENSE_OFF:
	if( lineHalfRingSenseOff(hRes) != VB_OK) PRTP(MIN,Problem disabling ring sense indications);
	if(log) PRTP(MIN,lineHalfRingSenseOff called);
	break;
      case CTP_VB_CMD_FXO_TIP_SENSE:
	if( lineTipGroundSense(hRes) != VB_OK) PRTP(MIN,Problem enabling tip ground sense indications)
	else                                   PRTP(GEN,**** Enabled tip ground sense indications);
	if(log) PRTP(MIN,lineTipGroundSense called);
	break;
      case CTP_VB_CMD_FXO_RESET:
	if( lineReset(hRes) != VB_OK) PRTP(MIN,Problem resetting fxo port);
	if(log) PRTP(MIN,lineReset called);
	break;
      case CTP_VB_CMD_FXO_OFF_HOOK:
	if( lineOffhook(hRes) != VB_OK) PRTP(MIN,Problem taking fxo port off hook)
	else { if(GROUND_START(Card,pNum)) RING_GROUND(Card,pNum) = 2; }
	if(log) PRTP(MIN,lineOffhook called);
	OFF_HOOK(Card,pNum) = 1;
	break;
      case CTP_VB_CMD_FXO_ON_HOOK:
	if( lineOnhook(hRes) != VB_OK) PRTP(MIN,Problem putting fxo port on hook)
	else { if(GROUND_START(Card,pNum)) RING_GROUND(Card,pNum) = 0; }
	if(log) PRTP(MIN,lineOnhook called);
	OFF_HOOK(Card,pNum) = 0;
	break;
      case CTP_VB_CMD_FXO_GND_RING:
	if( lineGroundRing(hRes) != VB_OK) PRTP(MIN,Problem grounding ring on fxo port)
	else RING_GROUND(Card,pNum) = 1;
	if(log) PRTP(MIN,lineGroundRing called);
	break;
      case CTP_VB_CMD_FXO_UNGND_RING:
	if( lineRemoveGroundRing(hRes) != VB_OK) PRTP(MIN,Problem ungrounding ring on fxo port)
	else RING_GROUND(Card,pNum) = 0;
	if(log) PRTP(MIN,lineRemoveGroundRing called);
	break;
      case CTP_VB_CMD_FXO_LOOP_START:
	if( lineLoopStart(hRes) != VB_OK) PRTP(MIN,Problem setting fxo port to loop start);
	if(log) PRTP(MIN,lineLoopStart called);
	OFF_HOOK(Card,pNum) = 0;
	break;
      case CTP_VB_CMD_FXO_GND_START:
	if( lineGroundStart(hRes) != VB_OK) PRTP(MIN,Problem setting fxo port to ground start)
	else RING_GROUND(Card,pNum) = 0;
	if(log) PRTP(MIN,lineGroundStart called);
	OFF_HOOK(Card,pNum) = 0;
	break;
      default:
	break;
    }
    ctp_release_handle(Card,pNum);
  } else {
    PRTVP(MIN,Could not run cmd,cmd);
  }

  return(status);
}

int ctp_set_vb_sig_sense(int Card) 
{
  int pNum;
  FUNC_PRT(ctp_set_vb_sig_sense, PF_VSIG, 0);
  //--- Check for card type
  if( VOICE(Card) ) {
    switch(CARDTYPE(Card)) {
      case(EMCARD):
	  //--- Enable indications for each port
	for (pNum = 0; pNum < pSysInfo->Card[Card].PortsOnCard; pNum++) {
	  ctp_vb_cmd(Card, pNum, CTP_VB_CMD_EM_PTT_SENSE);
	}
	PRTC(MIN,Watching M-Lead signaling on card);
	break;
      case(FXSCRD):
	  //--- Enable indications for each port
	for (pNum = 0; pNum < pSysInfo->Card[Card].PortsOnCard; pNum++) {
	  ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RESET);
	  usleep(2000);
	  ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_HOOK_SENSE);
	}
	PRTC(MIN,Watching hooksense on card);
	break;
      case(FXOCRD):
	//--- Enable indications for each port
	for (pNum = 0; pNum < pSysInfo->Card[Card].PortsOnCard; pNum++) {
	  ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_RESET);
	  usleep(2000);
	  ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_RING_SENSE);
	}
	PRTC(MIN,Watching for ring indication on card);
	break;
      default:
	break;
    }
  }  
}
void ctp_proc_vb_msg(int * param )
{
  int Card;
  int pNum, nQueueResult, temp;
  vbIndAudPttSenseType vbMsg;	// This is biggest that we handle, see vbdefs.h & other h files
  vbMsgAddrType addr;
  CTP_Q_MSG		TMsg;
  int 	pid = (int) getpid();
#ifdef VCTP
  int c_idx;
#endif
  FUNC_PRT(ctp_proc_vb_msg, PF_VSIG, pNum);


  //--- set static fields in OAM message ---
  TMsg.mtype			= 4;			// reserved and fixed
  TMsg.CtpMsg.MsgType		= CTPMSGTYPE_SIG_CHANGE;

  PRTDV(GEN,ctp_proc_vb_msg: Using VB message queue address, hMsgQ);

  for( Card=0; Card<CTP_MAX_CARDS; Card++) ctp_set_vb_sig_sense(Card);	

  while (1)
  {
    int SkipMessage;
    nQueueResult = vbQueueGet(hMsgQ, sizeof(vbIndAudPttSenseType), (UINT_32*)&vbMsg, &addr);

    if (nQueueResult <= 0) continue;

    pNum = addr.device;
    Card = ctp_unmap_vb_slot( addr.board );

    TMsg.CtpMsg.DestTaskQid	= Ctp.Task[CTP_TASK].Qid;	// PR 1417135
    TMsg.CtpMsg.OrigTask = Card;			// Send card here
    TMsg.CtpMsg.SubType  = pNum;			// Send pNum here
    TMsg.CtpMsg.Ident    = 0;			// Send Chan here!
    SkipMessage = 0;

    switch (vbMsg.icode)
    {
      case VBAUD_PTT_SENSE:	//--- E&M only
	{
	  vbIndAudPttSenseType *audInd = (vbIndAudPttSenseType *)&vbMsg;

	  TMsg.CtpMsg.Status   = audInd->state ? 0xf : 0x0;
	  if( audInd->state ) { PRTP(EVE,M LEAD is now OFFHOOK); }
	  else                { PRTP(EVE,M LEAD is now ONHOOK);  }
	}
	break;
      case VBNCO_HOOKSENSE:	//--- FXS
	{
	  vbIndNcoHookType *ncoInd = (vbIndNcoHookType *)&vbMsg;
	  int State = ncoInd->status;

	  PRTDVP(DBG,Got HOOKSENSE with state, State);
	  if( State == 1 )      {
	    PRTP(EVE,Got ONHOOK indication);
	    TMsg.CtpMsg.Status = CTP_VP_EVENT_ONHOOK;
	  } else if( State == 2 ) {
	    PRTP(EVE,Got ring ground indication);
	    TMsg.CtpMsg.Status = CTP_VP_EVENT_RING_GND;
	  } else                  {
	    PRTP(EVE,Got OFFHOOK indication);
	    TMsg.CtpMsg.Status = CTP_VP_EVENT_OFFHOOK;
	  }
	}
	break;
      case VBLIN_RING:		//--- FXO (AC ring) & FXS (ring ground)
      case VBLIN_HOOKPATTERN:	//--- FXO (tip ground)
	{
	  vbIndLinRingType *linInd = (vbIndLinRingType *)&vbMsg;
	  int State = linInd->state;
	  int RingId = linInd->ringId;

	  PRTDVP(DBG,Got RING/HOOKPATTERN with state, State);
	  if( State == 1 ) {
#if 0
	    { 	// DEBUG CODE
	      struct timeval	time_now;
	      char		PrtStr[80];
	      gettimeofday (&time_now, NULL);
	      while (time_now.tv_usec < 0)        { time_now.tv_usec += 1000000; time_now.tv_sec--; }
	      while (time_now.tv_usec >= 1000000) { time_now.tv_usec -= 1000000; time_now.tv_sec++; }
	      sprintf(PrtStr,"at %d.%d with ringId %d",
		  time_now.tv_sec, time_now.tv_usec, RingId);
	      PRTSP(TMP,Got RING indication, PrtStr );
	    }	// DEBUG CODE
#endif
	    if( RingId != 1 ) {
	      PRTDVP(EVE,Got RING indication,RingId);
	    }
	    TMsg.CtpMsg.Status = CTP_VP_EVENT_RING;
	    switch (RingId) {
	      case 1: SkipMessage++; break;
	      case 11: RING_ON(Card,pNum) = 1; SND_RING_CH(Card,pNum) = 1; break;
	      case 10: RING_ON(Card,pNum) = 0; SND_RING_CH(Card,pNum) = 1; break;
	      default: SkipMessage++; break;
	    }
	  } else if( State == 2 ) {
	    TIP_GROUND(Card,pNum) = 1;
	    PRTP(EVE,Got tip ground indication);
	    ctp_vb_cmd(Card,pNum,CTP_VB_CMD_FXO_RING_SENSE_OFF);
	    ctp_vb_cmd(Card,pNum,CTP_VB_CMD_FXO_UNGND_RING);
	    if( ((VC_SIGS_OUT(Card,pNum,0) >> 2) & 0x3) != 0x1) {
	      ctp_vb_cmd(Card,pNum,CTP_VB_CMD_FXO_OFF_HOOK);
	    }
	    TMsg.CtpMsg.Status = CTP_VP_EVENT_TIP_GND;
	  } else {
	    TIP_GROUND(Card,pNum) = 0;
	    PRTP(EVE,Got tip open indication);
	    if(RING_GROUND(Card,pNum) == 2) {
	      PRTP(GEN,Attached FXS going on-hook);
	    } else {
	      PRTP(GEN,Attached FXS responding to our on-hook);
	    }
	    TMsg.CtpMsg.Status = CTP_VP_EVENT_TIP_OPEN;
	  }
	}
	break;
      default:
	PRTDVP(MIN,Got unsupported VB message, vbMsg.icode);
	break;
    }
    //--- Send the message!
    if( !SkipMessage ) { ctp_send_msg( &TMsg ); }
  }
}

void ctp_vb_port_qry_sigs( int Card, int pNum){
  VBHANDLE hRes;
  int status;
  FUNC_PRT(ctp_vb_port_qry_sigs, PF_VSIG, pNum);

  status = ctp_wait_for_handle(Card,pNum);
  if( status == SUCCESS) {
    switch( CARDTYPE(Card)) {
      case EMCARD:
	{
	  int bndld = util_port_is_bndld(&Db.Card[Card].Port[pNum]);
	  hRes = pVcSigs->Card[Card].hRes[pNum];
	  if(  hRes != VBBAD_HANDLE ) {
	    UINT_32 MLeadState;
	    UINT_16 ELeadState;
	    audGetStatus(hRes, &ELeadState, &MLeadState, VB_NULL);	// Qry again

	    if( ELeadState ) { PRTP(GEN,ELeadState is OFFHOOK); }
	    else             { PRTP(GEN,ELeadState is ONHOOK); }
	    if( MLeadState ) { PRTP(GEN,MLeadState is OFFHOOK); }
	    else             { PRTP(GEN,MLeadState is ONHOOK); }
	    if(!bndld) VC_SIGS(Card,pNum,0) = (ELeadState ? 0xf0 : 0x00) |
	                                      (MLeadState ? 0x0f : 0x00);

	  }
	}
	break;
      case FXSCRD:
	{
	  hRes = pVcSigs->Card[Card].hRes[pNum];
	  if(  hRes != VBBAD_HANDLE ) {
	    UINT_32 hookStates;
	    UINT_32 ringGround = 0;
	    int State, Ring;
	    int loopStart = GROUND_START(Card,pNum) ? 0 : 1;

	    PRTP(DBG,Calling ncoGetStatus);
	    ncoGetStatus(hRes, &hookStates);	// Qry again
	    State = (hookStates & (0x1<<pNum)) ? 1 : 0;

	    if( loopStart ) {
	      if( State ) { PRTP(MIN,Port OffHook); }
	      else        { PRTP(MIN,Port OnHook); }
	    } else {
	      int isigs = VC_SIGS(Card,pNum,0);
	      PRTP(DBG,Calling ncoGetGroundStartStatus);
	      ncoGetGroundStartStatus(hRes, &ringGround);
	      Ring = (ringGround & (0x1<<pNum)) ? 1 : 0;
	      if( State ) {
		PRTVP(MIN,Ground start port OffHook with sigs, isigs);
		if( Ring )  {
		  PRTP(MIN,Ring ground event detected);
		} else {
		  PRTP(MIN,Ring ground event not detected);
		}
	      } else {
		PRTVP(MIN,Ground start port OnHook with sigs, isigs);
		if( Ring )  {
		  PRTP(MIN,Ring ground event detected);
		} else {
		  PRTP(MIN,Ring ground event not detected);
		}
	      }

	    }

	  }
	}
	break;
      case FXOCRD:
	{
	  hRes = pVcSigs->Card[Card].hRes[pNum];
	  if(  hRes != VBBAD_HANDLE ) {
	    UINT_16 State;
	    UINT_16 Ring;
	    int state, ring;
	    int loopStart = GROUND_START(Card,pNum) ? 0 : 1;

	    PRTP(DBG,Calling lineGetStatus);
	    lineGetStatus(hRes, &State, &Ring, VB_NULL);	// Qry again

	    state = (int) (State & 0xff);
	    ring  = (int) Ring;

	    PRTVP(DBG,Port state, state);

	    if( loopStart) {
	      int bndld = util_port_is_bndld(&Db.Card[Card].Port[pNum]);
	      if( state == 2 ) {
		PRTP(MIN,Loop start port is off-hook);
		if(!bndld) VC_SIGS(Card,pNum,0) = 0xff;
	      } else if( state == 1 ) {
		PRTP(MIN,Loop start port is ringing);
		if(!bndld) VC_SIGS(Card,pNum,0) = 0x00;	// Should not be needed but sppeds up manufacturing test!
	      } else {
		PRTP(MIN,Loop start port is idle);
		if(!bndld) VC_SIGS(Card,pNum,0) = 0x55;
	      }
	    } else {
	      int isigs = VC_SIGS(Card,pNum,0);
	      if( state == 3 ) {
		PRTVP(MIN,Ground start port is idle with sigs, isigs);
	      } else if( state == 2 ) {
		int tip_gnd = TIP_GROUND(Card,pNum);
		PRTVP(MIN,Ground start port is off-hook with sigs, isigs);
		PRTDVP(DBG,Tip gnd,tip_gnd);
	      } else {
		int ring_gnd = RING_GROUND(Card,pNum);
		PRTVP(MIN,Ground start port has sigs, isigs);
		PRTDVP(DBG,Ring gnd,ring_gnd);
	      }
	    }

	  }
	}
	break;
      default:
	PRTP(MIN,Do not know how to qry voice port sigs);
	break;
    }
    ctp_release_handle(Card,pNum);
  }
}

