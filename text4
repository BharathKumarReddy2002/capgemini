//--------------------------------------------------------------------------
int ctp_proc_msg_ses_id( CTP_Q_MSG * pMsg )
{
/**** PR1401392-Fix ****/
  CTP_Q_MSG *	pTMsg     = (CTP_Q_MSG *)malloc(sizeof(CTP_Q_MSG));
  CTP_Q_MSG *   pFlushMsg = (CTP_Q_MSG *)malloc(sizeof(CTP_Q_MSG));
/**** PR1401392-End ****/
  int			 i, Session_id, status;
  FUNC_PRT(ctp_proc_msg_ses_id, PF_IPC, -1);

#ifdef DBG_MSG_QUEUE
  PRT(EVE,CTP processing msg session id request);
#endif

  //util_prt_msg(pMsg);

/**** PR1401392-Fix ****/
  ctp_copy_msg_hdr( pMsg, pTMsg );	// build header of response message

  switch(pMsg->CtpMsg.MsgType) {
    //----------------
    case CTPMSGTYPE_GET_SESSION_ID:
      // Start Searching for available session ID at 4.
      // 1 is reserved for session ID requests
      // 2 is reserved for the CTP timer daemon
      // 3 is reserved for the CTP network daemon
      for(i=4;i<CTP_MAX_SESSIONS;i++) {
	if( Session[i] == INACTIVE_H ) {
	  Session[i] = ACTIVE_H;
	  break;
	}
      }
      if( i >= CTP_MAX_SESSIONS ) {
	PRT(MIN,Maximum menu sessions active);
/**** PR1401392-Fix ****/
	pTMsg->CtpMsg.Status = FAILURE;
      } else {
/**** PR1401392-Fix ****/
	pTMsg->CtpMsg.msg.SesId.SesId = i;
	PRTDV(DBG,Activated Menu Session,i);
      }
      break;
    //----------------
    case CTPMSGTYPE_RELEASE_SESSION_ID:
    // release session id don't expect return message
      Session_id = pMsg->CtpMsg.msg.SesId.SesId;
      if( Session[Session_id] == ACTIVE_H ) {
	PRTDV(DBG,Deactivated Menu Session,Session_id);
	Session[Session_id] = INACTIVE_H;
      } else {
	PRTDV(MIN,Menu session already inactive,Session_id);
/**** PR1401392-Fix ****/
	pTMsg->CtpMsg.Status = FAILURE;
      }

/*** PR-1669469 Fix ***/
      memcpy(&Tmp_Ctp_Q_Msg, pFlushMsg, sizeof(CTP_Q_MSG));

      // Clear the message for the session
      do
      {
/**** PR1401392-Fix ****/
        status = msgrcv(pMsg->CtpMsg.OrigTaskQid,
                    &Tmp_Ctp_Q_Msg,
                    sizeof(CTP_Q_MSG),
                    Session_id,
                    IPC_NOWAIT);
/**** PR1401392-End ****/
      } while (status > 0);

/**** PR1401392-Fix ****/
      status = pTMsg->CtpMsg.Status;
      goto MSG_SES_ID_EXIT;
/**** PR1401392-End ****/
      break;

    default:
      PRTV(MIN,Unexpected message type,pMsg->CtpMsg.MsgType);
/**** PR1401392-Fix ****/
      status = FAILURE;
      goto MSG_SES_ID_EXIT;
/**** PR1401392-End ****/
      break;
  }

/*** PR-1669469 Fix ***/
  memcpy(&Tmp_Ctp_Q_Msg, pTMsg, sizeof(CTP_Q_MSG));

/**** PR1401392-Fix ****/
  ctp_send_msg( &Tmp_Ctp_Q_Msg );		// Send response back
  status = Tmp_Ctp_Q_Msg.CtpMsg.Status;
MSG_SES_ID_EXIT:
  if (pTMsg) free(pTMsg);
  if (pFlushMsg) free(pFlushMsg);
  return(status);
/**** PR1401392-End ****/
}

