void ctp_timer_proc_t1card(int Card, int pNum)
{
  u32 status, Prevt1State, changed_status;
  char	PrtBuf[80];
  CTP_PORT_CNTRS *pPortCnt = &Ctp.Card[Card].Cntr[pNum];    // Aricent PR 1273976
  CTP_PORT_STATE  *pPortSt = &Ctp.Card[Card].Port[pNum];
  FUNC_PRT(ctp_timer_proc_t1card, PF_PST, -1);
  Prevt1State = pPortSt->t1State;
  // check t1 alarms
  if(Ctp.Card[Card].Port[pNum].Diagnostics) status = 0;
  else {
    if( IS_ABRG(Card) ) { status = 0; } // PR 1565597 - Audio Bridge Never has LOF/LOS/AIS
    else { status = ctp_get_t1_state(Card, pNum); }
  }
  if((status != pPortSt->t1State) && (Db.Card[Card].Port[pNum].DcardCfg1 & T1E1_MSK_FRAME)
     &&(ctp_bndl_type_wp(Card, pNum))) {
    ctp_set_t1e1_alarm(Card, pNum, status, pPortSt->t1State);
  }
  /* The following block is to loop tx clk back to rx in case of LOS on the port
     The purpose is to avoid using the DALLAS internal generated clock for real
     passing traffic.
     So in case of LOS, we are using local loopback on T1 port while preserve the
     LOS since local loopback is behind the LOS detection block. Once LOS is cleared
     the loopback is restored to previous value.
  */
  if((status & T1_ALARM_LOS) != (pPortSt->t1State & T1_ALARM_LOS)) {
    pPortSt->t1State=status;
      fpga_clr_fcfg();
      if(status & T1_ALARM_LOS) { /* enter into LOS */
        fpga_set_rx_scc_clk(pNum, CTP_CLK_SEL_DDS);
	PRTP(GEN,Setting Dallas Clock fix during LOS);
      } else fpga_set_rx_scc_clk(pNum, CTP_CLK_SEL_TT);
      fpga_send_fcfg(pPortSt->SccNum);
  } else pPortSt->t1State=status;
  if(status & T1_ALARM_LOS) Ctp.Card[Card].t1LosPortBitMap |= 1<<pNum;
  if(status & T1_ALARM_LOF) Ctp.Card[Card].t1LofPortBitMap |= 1<<pNum;
  // PR 1164105 - generate LOS/AIS exit entry syslog messages
  changed_status = Prevt1State ^ status;
  if( changed_status & ( T1_ALARM_LOS | T1_ALARM_AIS ) ) {
    int los_new_state = (status & T1_ALARM_LOS) ? 1 : 0;
    int ais_new_state = (status & T1_ALARM_AIS) ? 1 : 0;
    if( changed_status & T1_ALARM_LOS ) { 
      sprintf(PrtBuf,"T1/E1 LOS state changed to %d\n",los_new_state);
      PRTSP(EVE,,PrtBuf); 
      R_PRTSP(EVE,,PrtBuf);
    }
    if( changed_status & T1_ALARM_AIS ) { 
      sprintf(PrtBuf,"T1/E1 AIS state change to %d\n",ais_new_state);
      PRTSP(EVE,,PrtBuf); 
      R_PRTSP(EVE,,PrtBuf);
    }
  }
  //Aricent PR 1273976  fix start
  if( changed_status & T1_ALARM_LOF){
    int lof_new_state = (status & T1_ALARM_LOF)? 1 : 0;
    sprintf(PrtBuf,"T1/E1 LOF state changed to %d\n",lof_new_state);
    PRTSP(EVE,,PrtBuf);
    R_PRTSP(EVE,,PrtBuf);
    if(((status & T1_ALARM_LOF)== 1) && (Prevt1State & T1_ALARM_LOF)== 0) {
      CTP_PORT_DBASE *pDbP = &Db.Card[Card].Port[pNum];
      int bNum = util_get_next_bNum(pDbP, -1);
      int bType = Db.Bndl[bNum].Type;
      if (bType == CTP_BNDL_TYPE_VC) {
        Ctp.Bndl_cnt[bNum].Bndl.vc_cntrs.vc_bndl.LOFOccurCnt +=1;
      } else Ctp.Bndl_cnt[bNum].Bndl.ctp.LOFOccurCnt +=1;
    }
  }
  //Aricent PR 1273976  fix end

  return;
}

void ctp_timer_proc_wp_bert(int Card, int pNum)
{
  /* following part is only for winpath bndl */
  CTP_PORT_STATE  *pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_CNTRS  *pPortCnt = &Ctp.Card[Card].Cntr[pNum];

  if(pPortSt->RxBert != CTP_RX_BERT_OFF) {
    u32 BertSyncLoss, BertErrCnt, BertSync;
    ctp_get_t1_stats(Card, pNum, &pPortCnt->t1Stats);
    BertSyncLoss = pPortCnt->t1Stats.BertStatus & 0x2;
    BertErrCnt = pPortCnt->t1Stats.bitErrorCount;
    if(((pPortCnt->t1Stats.BertStatus & (~0x40)) == 0) &&
      (pPortCnt->t1Stats.bitCount!= 0)) BertSync = 1;
    else BertSync = 0;
    pPortCnt->BertRunSec++;
    pPortCnt->BertSync = BertSync;
    if( BertSyncLoss ) pPortCnt->BertSyncLossCnt++;
    if( BertSync ) {
      pPortCnt->BertSyncSec++;
      pPortCnt->BertErrCnt += BertErrCnt;	// Only cnt errs when in sync
    }
    if( BertSyncLoss || !BertSync || BertErrCnt ) pPortCnt->BertErrSec++;
  }
  return;
}

