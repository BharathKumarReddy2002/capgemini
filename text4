  //--------------------------------------------
  if((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) 
    Ctp.Node[1].SkipPllRoutines = YES;
#ifdef TARGET
#ifndef VCTP
  for(Card=0;Card<pSysInfo->CardsPerCpu;Card++) {
#else
  for(c_idx = 0; c_idx<pSysInfo->CardsPerCpu; c_idx++) {
    Card = cardIndx[c_idx];
#endif
    if(SCC_CARD(Card)) {
      if( (Ctp.Node[Card].DiagsUsingFreqCntr == NO) &&
	  (Ctp.Node[Card].SkipPllRoutines == NO) ) {
	if( (Card != 0) ||				
	    (pNRefs->State == CTP_NETREF_STATE_DIS) ||	// Either NetRef disabled _or_
	    (pNRefs->Type  == CTP_NETREF_TYPE_SRC)  ) {	// NetRef master.
	  ctp_proc_ref_check(Card);
	  ctp_proc_pll(Card);
	} else {
	  PRTC(GN3,NetRef enabled skipping node refs);
	}
      }
    }
  }
#endif // TARGET
   //if(pNRef)ctp_free_nrefs_info();  //PR-1874138
   // PR-1874138 start
  if (__old_pNRefs && __old_pNRefs != (CTP_NREFS_STATE*)-1 &&
      __old_pNRefs != pNRefs) {
      if (shmdt(__old_pNRefs) == -1) {
          PRT(MIN,shmdt old pNRefs failed);
      }
  }
// PR-1874138 end



#ifdef DBG_PROC_MSG_TIMER
  gettimeofday (&t_end, NULL);
  while (t_end.tv_usec < 0)
  {
    t_end.tv_usec += 1000000;
    t_end.tv_sec--;
  }
  while (t_end.tv_usec >= 1000000)
  {
    t_end.tv_usec -= 1000000;
    t_end.tv_sec++;
  }
  diff_msec = (int)((t_end.tv_usec - t_start.tv_usec) / 1000);
  while ( diff_msec < 0 ) { diff_msec += 1000; }
  if( diff_msec > 50 ) {
    PRTDV(MIN,proc_msg_timer processing time, diff_msec);
  }
#endif	//DBG_PROC_MSG_TIMER

  return(SUCCESS);
}

//--------------------------------------------------------------------------
// This routine processes the adaptive clocking buffer storage
// Things still to do:
//   - Initialize group array when we turn on adaptive clocking.
//--------------------------------------------------------------------------
void ctp_proc_adap_bufmon( int bNum )
{
  char			 PrtBuf[80];
  int			 i, Index, TempInt;
  u32			 last;
  int			 MaxBuffDiff;
  u16			 AdapReqBufIoctls;
  int 	Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
  int   pNum = util_bndl_src_pNum(0, &Db.Bndl[bNum]);
  CTP_PORT_STATE	*pPortSt    = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  CTP_BNDL_CNTRS	*pBndlCnt   = &Ctp.Bndl_cnt[bNum];
  struct acrndrv_buffer_stats ebuf = pBndlCnt->Bndl.ctp.Current.Buffer;
  struct acrndrv_buffer_stats prebuf = pBndlCnt->Bndl.ctp.Previous.Buffer;
  CTP_ADAP_GROUP	*pGrp,*pPrevGrp;
  int			 PrevIdx,Idx;
  FUNC_PRT(ctp_proc_adap_bufmon, PF_ADAP, bNum);
  // Note: For CESoPSN bundle type only CTP150 CESoPSN and adaptive master
  //       Bundle should call this function.
  //--- Get a sorted data every 1 sec (CTP_SCRUB_PERIOD) from acron_drv
  //    using ioctl.
  //--- acorn_drv takes a buffer measurement on _nearly_ every packet
  //    (those where the counter didn't give a good measurement are
  //    skipped).  The driver sorts through the buffer measurements, saving
  //    the largest, next largest, next next largest, smallest, positions
  //    of these, total number of buffer measurements and sum of the buffer
  //    measurements (for determining the average buffer level).
  //    The largest, next largest ... are distinct values (ie different).
  //    the number of luckest packets is also saved. Note- only the
  //    position of the _first_ occurance of each of these values is saved.
  //--- We call each buffer measurement by the driver a "sample".
  //--- The ioctl that gets the data processed by the driver also clears
  //    the data for the next sample group-> required in order that
  //    processed data represents the max, min, etc buffer measurement
  //    since the last ioclt.
  //--- Data from this ioctl goes to long bufmon & adap bufmon.
  //--- User configures the number of ioctls (seconds) required to produce
  //    a "group". The key here is that the user must take responsibility
  //    for choosing this time interval so that there are enough lucky
  //    packets to do a good calculation.
  //--- A "group" then consists of samples from one or more ioctls. The
  //    data saved for a group includes: top 3 distinct luck packet buffer
  //    measurements & their locations. Total number of samples processed
  //    in this group, a restart flag & valid flag.
  //--- A "calculation" is done on a group. Need at least two valid groups
  //    to calculate a slope, one to calculate a buffer error.
  //--- Slope & buffer error determine the "state" and dds value for each
  //    each state.  Actual dds can get clamped for (1) each change, and
  //    (2) total change.
  //
  // TODO This will have to be modified if the number of adaptive states changes
  if( pPortSt->AdapState == CTP_ADAP_STATE_MAINTAIN ) {
    AdapReqBufIoctls  = pPortIntSt->AdapReqMntnSeconds;	// CTP_SCRUB_PERIOD = 1Sec!
    //PRTDV(OFF,Maintain state required buffs,AdapReqBufIoctls);
  } else {
    AdapReqBufIoctls  = pPortIntSt->AdapReqAggrSeconds;	// CTP_SCRUB_PERIOD = 1Sec!
    //PRTDV(OFF,Agressive state required buffs,AdapReqBufIoctls);
  }

  //--- We got an ioctl set of data to analyze / increase ioctl counter
  Index = pPortIntSt->AdapGroupIndex % CTP_MAX_ADAP_GROUPS;
  pGrp = (CTP_ADAP_GROUP *)&pPortIntSt->AdapGroups[Index];
  pGrp->NumIoctls++;

  //--- We just got the latest ioctl of buffer fill measurements from
  //    the driver. If this is the first ioctl we initialize the adaptive
  //    group paramenters, else we merge in what we just got.
  if( pGrp->NumIoctls == 1 ) {
    //===================================================================
    // First pass, samples come already sorted, load up 3 "luckest" packets.
    //===================================================================
    pGrp->Hi[2]		= ebuf.NNLargest;
    pGrp->HiIdx[2]	= ebuf.NNLargestPktNum;
    pGrp->Hi[1]		= ebuf.NLargest;
    pGrp->HiIdx[1]	= ebuf.NLargestPktNum;
    pGrp->Hi[0]		= ebuf.Largest;
    pGrp->HiIdx[0]	= ebuf.LargestPktNum;
    pGrp->Num		= ebuf.Samples;
    if( ebuf.restart_cnt > prebuf.restart_cnt ) {
      pPortIntSt->AdapRestarts = 1;	// Binary - if ANY restarts happened, don't use.
    } else {
      pPortIntSt->AdapRestarts = 0;
    }
  } else {
    //===================================================================
    // Not 1st pass, merge samples into what we already have
    //===================================================================
    if ( ebuf.Largest > pGrp->Hi[0] ) { // New lucky packet
      pGrp->Hi[2] 	= pGrp->Hi[1];
      pGrp->HiIdx[2] 	= pGrp->HiIdx[1];
      pGrp->Hi[1] 	= pGrp->Hi[0];
      pGrp->HiIdx[1] 	= pGrp->HiIdx[0];
      pGrp->Hi[0] 	= ebuf.Largest;
      pGrp->HiIdx[0] 	= ebuf.LargestPktNum + pGrp->Num;
      if ( ebuf.NLargest > pGrp->Hi[1] ) { // New next luckiest pkt
	pGrp->Hi[2]       = pGrp->Hi[1];
	pGrp->HiIdx[2]    = pGrp->HiIdx[1];
	pGrp->Hi[1]       = ebuf.NLargest;
	pGrp->HiIdx[1]    = ebuf.NLargestPktNum + pGrp->Num;
        if (ebuf.NNLargest > pGrp->Hi[2]) {
	  pGrp->Hi[2]       = ebuf.NNLargest;
	  pGrp->HiIdx[2]    = ebuf.NNLargestPktNum + pGrp->Num;
        }
      } else if (ebuf.NLargest > pGrp->Hi[2]) {
	pGrp->Hi[2]       = ebuf.NLargest;
	pGrp->HiIdx[2]    = ebuf.NLargestPktNum + pGrp->Num;
      }
    } else if ( ebuf.Largest > pGrp->Hi[1] ) {
      pGrp->Hi[2]       = pGrp->Hi[1];
      pGrp->HiIdx[2]    = pGrp->HiIdx[1];
      pGrp->Hi[1]       = ebuf.Largest;
      pGrp->HiIdx[1]    = ebuf.LargestPktNum + pGrp->Num;
      if (ebuf.NLargest > pGrp->Hi[2]) {
	  pGrp->Hi[2]       = ebuf.NLargest;
	  pGrp->HiIdx[2]    = ebuf.NLargestPktNum + pGrp->Num;
      }
    } else if ( ebuf.Largest > pGrp->Hi[2] ) {
      pGrp->Hi[2]       = ebuf.Largest;
      pGrp->HiIdx[2]    = ebuf.LargestPktNum + pGrp->Num;
    }
    pGrp->Num += ebuf.Samples;
    TempInt = pGrp->Num;
    PRTDVP(GN3,Accumulated buffer samples for this calc,TempInt);
    if( ebuf.restart_cnt > prebuf.restart_cnt ) {
      pPortIntSt->AdapRestarts++;
    }
  }

  if( pGrp->NumIoctls >= AdapReqBufIoctls ) {
    // We have enough data for a group.
    // Finish processing group info & set index for next group.

    //We get some buffer measurements that are clearly out of line.
    //They differ from the rest by more than 60,000.
    //In order NOT to use these in our calculations we take the
    //Luckest packet from the previous group and check to see
    //if timing measurements are more than 60,000 larger
    //We also look to see these changes are one-time or persistant.
    //NOTE- this is a real hack and may come back to bite us
    //in a network where REAL timing variations may be 60,000 (4mS) or
    //larger and we have few lucky packets!
    PrevIdx = (Idx + CTP_MAX_ADAP_GROUPS - 1) % CTP_MAX_ADAP_GROUPS;
    pPrevGrp = (CTP_ADAP_GROUP *)&pPortIntSt->AdapGroups[PrevIdx];
    if( pPrevGrp->Valid == 1 ) {
      last = pPrevGrp->Highest;
    } else {                //use 3rd luckest.
      last = pGrp->Hi[2];
    }
    //The trigger for the state change from maintain -> aggressive is
    //determined by the difference between the average buffer position
    //(for the group) and the buffer set point. If a single point is
    //enough to trigger the change, we remove it.  This assumes that
    //pPortIntSt->AdapMaxBufError has been set correctly for the network.
    //CTP_MAX_ADAP_TRACKED is the number of lucky packets used for average.
    MaxBuffDiff = CTP_MAX_ADAP_TRACKED * pPortIntSt->AdapMaxBufError;
    if( ( (int)(pGrp->Hi[0] - last) > MaxBuffDiff ) &&
      ( (int)(pGrp->Hi[1] - last) < MaxBuffDiff ) ) {	// Hi[0] BAD!!
      // toss packet timing info and log
      sprintf(PrtBuf,"Got buffer measurements: %d, %d, %d, %d\n",
            (int)pGrp->Hi[0],(int)pGrp->Hi[1],(int)pGrp->Hi[2],(int)last);
      PRTSP(EVE,,PrtBuf);
      pGrp->Hi[0]    = pGrp->Hi[1];
      pGrp->HiIdx[0] = pGrp->HiIdx[1];
      pGrp->Hi[1]    = pGrp->Hi[2];
      pGrp->HiIdx[1] = pGrp->HiIdx[2];
    }
  } else {
    //===================================================================
    // Not 1st pass, merge samples into what we already have
    //===================================================================
    if ( ebuf.Largest > pGrp->Hi[0] ) { // New lucky packet
      pGrp->Hi[2] 	= pGrp->Hi[1];
      pGrp->HiIdx[2] 	= pGrp->HiIdx[1];
      pGrp->Hi[1] 	= pGrp->Hi[0];
      pGrp->HiIdx[1] 	= pGrp->HiIdx[0];
      pGrp->Hi[0] 	= ebuf.Largest;
      pGrp->HiIdx[0] 	= ebuf.LargestPktNum + pGrp->Num;
      if ( ebuf.NLargest > pGrp->Hi[1] ) { // New next luckiest pkt
	pGrp->Hi[2]       = pGrp->Hi[1];
	pGrp->HiIdx[2]    = pGrp->HiIdx[1];
	pGrp->Hi[1]       = ebuf.NLargest;
	pGrp->HiIdx[1]    = ebuf.NLargestPktNum + pGrp->Num;
        if (ebuf.NNLargest > pGrp->Hi[2]) {
	  pGrp->Hi[2]       = ebuf.NNLargest;
	  pGrp->HiIdx[2]    = ebuf.NNLargestPktNum + pGrp->Num;
        }
      } else if (ebuf.NLargest > pGrp->Hi[2]) {
	pGrp->Hi[2]       = ebuf.NLargest;
	pGrp->HiIdx[2]    = ebuf.NLargestPktNum + pGrp->Num;
      }
    } else if ( ebuf.Largest > pGrp->Hi[1] ) {
      pGrp->Hi[2]       = pGrp->Hi[1];
      pGrp->HiIdx[2]    = pGrp->HiIdx[1];
      pGrp->Hi[1]       = ebuf.Largest;
      pGrp->HiIdx[1]    = ebuf.LargestPktNum + pGrp->Num;
      if (ebuf.NLargest > pGrp->Hi[2]) {
	  pGrp->Hi[2]       = ebuf.NLargest;
	  pGrp->HiIdx[2]    = ebuf.NLargestPktNum + pGrp->Num;
      }
    } else if ( ebuf.Largest > pGrp->Hi[2] ) {
      pGrp->Hi[2]       = ebuf.Largest;
      pGrp->HiIdx[2]    = ebuf.LargestPktNum + pGrp->Num;
    }
    if( ebuf.restart_cnt > prebuf.restart_cnt ) {
      pPortIntSt->AdapRestarts++;
    }
  }

  if( pGrp->NumIoctls >= AdapReqBufIoctls ) {
    // We have enough data for a group.
    // Finish processing group info & set index for next group.

    //We get some buffer measurements that are clearly out of line.
    //They differ from the rest by more than 60,000.
    //In order NOT to use these in our calculations we take the
    //Luckest packet from the previous group and check to see
    //if timing measurements are more than 60,000 larger
    //We also look to see these changes are one-time or persistant.
    //NOTE- this is a real hack and may come back to bite us
    //in a network where REAL timing variations may be 60,000 (4mS) or
    //larger and we have few lucky packets!
    PrevIdx = (Idx + CTP_MAX_ADAP_GROUPS - 1) % CTP_MAX_ADAP_GROUPS;
    pPrevGrp = (CTP_ADAP_GROUP *)&pPortIntSt->AdapGroups[PrevIdx];
    if( pPrevGrp->Valid == 1 ) {
      last = pPrevGrp->Highest;
    } else {                //use 3rd luckest.
      last = pGrp->Hi[2];
    }
    //The trigger for the state change from maintain -> aggressive is
    //determined by the difference between the average buffer position
    //(for the group) and the buffer set point. If a single point is
    //enough to trigger the change, we remove it.  This assumes that
    //pPortIntSt->AdapMaxBufError has been set correctly for the network.
    //CTP_MAX_ADAP_TRACKED is the number of lucky packets used for average.
    MaxBuffDiff = CTP_MAX_ADAP_TRACKED * pPortIntSt->AdapMaxBufError;
    if( ( (int)(pGrp->Hi[0] - last) > MaxBuffDiff ) &&
      ( (int)(pGrp->Hi[1] - last) < MaxBuffDiff ) ) {	// Hi[0] BAD!!
      // toss packet timing info and log
      sprintf(PrtBuf,"Got buffer measurements: %d, %d, %d, %d\n",
            (int)pGrp->Hi[0],(int)pGrp->Hi[1],(int)pGrp->Hi[2],(int)last);
      PRTSP(EVE,,PrtBuf);
      pGrp->Hi[0]    = pGrp->Hi[1];
      pGrp->HiIdx[0] = pGrp->HiIdx[1];
      pGrp->Hi[1]    = pGrp->Hi[2];
      pGrp->HiIdx[1] = pGrp->HiIdx[2];
    }

    if( pPortIntSt->AdapRestarts == 0 ) {
      pGrp->Valid    = 1;		// Set Valid group flag
    } else {
      pGrp->Valid    = 0;		// Set Valid group flag
    }
    //--- Set Valid flag = 1 if restarts = 0
    pGrp->Valid = (pPortIntSt->AdapRestarts == 0) ? 1 : 0 ;

    pPortIntSt->AdapAllGroups++;		// Bump stored group count

    // Don't allow the number of groups to exceed array bounds
    if( pPortIntSt->AdapAllGroups > CTP_MAX_ADAP_GROUPS ) {
      pPortIntSt->AdapAllGroups = CTP_MAX_ADAP_GROUPS;
    }

    //--- AdapCurGroupIndex is the index we use to get the group to
    //    calculate the slope & buffer error.
    pPortIntSt->AdapCurGroupIndex = pPortIntSt->AdapGroupIndex;
    //--- AdapGroupIndex is the index we use to when we gather stastics
    //    at the group level.
    //    We had enough ioctls for our group. Next time through we start
    //    group so bump the index by 1.
    pPortIntSt->AdapGroupIndex = (Index + 1) % CTP_MAX_ADAP_GROUPS;

    //--- This is the number of seconds it took to gather a data group.
    pPortIntSt->AdapCalcSec = pGrp->NumIoctls * CTP_SCRUB_PERIOD;

    //--- These are used by ctpd_adap_set_dds function
    if ( (double)pGrp->Num != 0) {
      pPortIntSt->AdapSecPerSample = (double)pPortIntSt->AdapCalcSec / (double)pGrp->Num;
    } else {
      pPortIntSt->AdapSecPerSample = (double)pPortIntSt->AdapCalcSec;
      PRT(EVE,pGrp->Num was zero);
    }
    if ( (double)pPortIntSt->AdapCalcSec != 0) {
      pPortIntSt->AdapSamplePerSec = (double)pGrp->Num / (double)pPortIntSt->AdapCalcSec;
    } else {
      pPortIntSt->AdapSamplePerSec = (double)pGrp->Num;
      PRT(EVE,pPortIntSt->AdapCalcSec was zero);
    }


    //--- Now we reset the NumIoctls value to 0 so next time we use this
    //    group array index, we know to start fresh.
    pGrp->NumIoctls = 0;

    //PRTDV(OFF,Groups,pPortIntSt->AdapAllGroups);
    //PRTDV(OFF,Saving Groups stats to Index,Index);
    PRTU16P(GN2,Total buffer samples for this calc,pGrp->Num);
    for(i=0;i<CTP_MAX_ADAP_TRACKED;i++) {
      sprintf(PrtBuf,"Hi[%d]=%4d at Idx %4d\n",i,(int)pGrp->Hi[i],pGrp->HiIdx[i]);
      PRTSP(GN1,,PrtBuf);
    }
  }
}

//--------------------------------------------------------------------------
// This routine processes the adaptive clocking state machine.
// Things still to do:
// - Add additional states: aggressive-maintance & long term maintance
//--------------------------------------------------------------------------
void ctp_proc_adap_state( int Card, int pNum )
{
  CTP_PORT_STATE	*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  CTP_PORT_DBASE	*pDbP = &Db.Card[Card].Port[pNum];
  double		 Slope;
  int			 BufferError;
  int			 i;
  char			 PrtBuf[100];
  FUNC_PRT(ctp_proc_adap_state, PF_ADAP, pNum);

  if( (pDbP->dds_src == CTP_DDS_SRC_ADAPTIVE) ||
      (pDbP->dds_src == CTP_DDS_SRC_AUTOBAUD) ) {
    switch( pPortSt->AdapState ) {
      //------------------------------------------------------------------
      case CTP_ADAP_STATE_WAIT:
	pPortIntSt->AdapStateCnt--;
	//PRTDV(OFF,AdapStateCnt,pPortIntSt->AdapStateCnt);
	if( pPortIntSt->AdapStateCnt <= 0 ) {
	  //--- Set the index for the group to use
          pPortIntSt->AdapGroupIndex = 0;
	  // Clear out Adaptive sample array
	  for(i=0;i<CTP_MAX_ADAP_GROUPS;i++) {
	    pPortIntSt->AdapGroups[i].Valid = 0;
	    //--- Set the NumIoctls to zero
	    pPortIntSt->AdapGroups[i].NumIoctls = 0;
	  }
	  pPortSt->AdapState = CTP_ADAP_STATE_AGGRESSIVE;
	  pPortIntSt->AdapAggrAdjustCnt = 0;	// reset DDS adjust counter
	  sprintf(PrtBuf,"- State changing to AGGRESSIVE\n");
	  PRTSP(EVE,,PrtBuf);
	}
	break;
      //------------------------------------------------------------------
      case CTP_ADAP_STATE_AGGRESSIVE:
	//--- Aggressive calc requires two groups to calculate slope
	if( pPortIntSt->AdapAllGroups >= 1 ) {
	  if( pPortIntSt->AdapRestarts == 0 ) {
	    if( ctp_adap_calc_slope(Card, pNum) == SUCCESS ) {
	      int AdapAggrAdjustCnt;
	      pPortIntSt->AdapConsecRestarts = 0;

	      // Create absolute values of interesting numbers
	      if( pPortIntSt->AdapSlope < 0 )	Slope = 0 - pPortIntSt->AdapSlope;
	      else			Slope = pPortIntSt->AdapSlope;

	      // Now decide on state change
	      if( Slope < (double)pPortIntSt->AdapMntnSlope ) {
		pPortSt->AdapState = CTP_ADAP_STATE_MAINTAIN;
	        sprintf(PrtBuf,"++++++++++ State changing to MAINTAIN ++++++++++ \n");
	        PRTSP(EVE,,PrtBuf);
		pPortIntSt->AdapBufSetPoint = pPortIntSt->AdapCurBufPos;
	        sprintf(PrtBuf,"----- Buffer Set Point %.2f msec\n",
		     pPortIntSt->AdapBufSetPoint/((double)CTP_OSC_FREQ));
	        PRTSP(EVE,,PrtBuf);
		//PRTDV(OFF,Current DDS value,pPortSt->AdapDdsValue);
	      }

	      // We want to adjust the DDS after the state change decision is
	      // made since the current state dictates the DDS adjust method.
	      ctp_adap_set_dds( Card, pNum, pPortSt->AdapState );

	      // We need to let the system settle a bit after making
	      // aggressive DDS adjustments to allow the slope calculations
	      // to be accurate again. Empirical data indicates that 2
	      // calc periods need to be skipped before slopes are accurate
	      // again (I personally thought 1 would have been enough...)
	      if( pPortIntSt->AdapAggrAdjustCnt == 0 ) pPortIntSt->AdapAggrAdjustCnt = 1;	// Skips one calc!
	      else				       pPortIntSt->AdapAggrAdjustCnt--;
	      AdapAggrAdjustCnt = pPortIntSt->AdapAggrAdjustCnt;
	      PRTDVP(FNC,AdapAggrAdjustCnt now, AdapAggrAdjustCnt);

	    } else {
	      sprintf(PrtBuf,"----- Slope cannot be calculated yet so do nothing \n");
	      PRTSP(GEN,,PrtBuf);
	    }
	  } else {
	        sprintf(PrtBuf,"----- Restart happened so do nothing \n");
	        PRTSP(GEN,,PrtBuf);
		pPortIntSt->AdapConsecRestarts++;
		if( pPortIntSt->AdapConsecRestarts >= 3 ) {
		  ctp_adap_set_dds( Card, pNum, pPortSt->AdapState );
		}
	  }

	  pPortIntSt->AdapAllGroups = 0;		// reset storage
	  pPortIntSt->AdapRestarts = 0;		// reset flag
	}
	break;
      //------------------------------------------------------------------
      case CTP_ADAP_STATE_MAINTAIN:
	if( pPortIntSt->AdapAllGroups >= 1 ) {		// If we have a group...

	  //--- Need slope in case the state changes to aggressive.
	  if( ctp_adap_calc_slope(Card, pNum) == SUCCESS ) {
	    pPortIntSt->AdapConsecRestarts = 0;
	  }

	  if( pPortIntSt->AdapRestarts == 0 ) {
	    if( pPortIntSt->AdapResetBufSetPoint == 1 ) {
	      // Previous "calc" period had a restart, so set the buffer
	      // again and reset the flag.
	      pPortIntSt->AdapBufSetPoint = pPortIntSt->AdapAvgBufPos;
	      sprintf(PrtBuf,"----- Resetting Buffer Set Point %.2f msec\n",
		  pPortIntSt->AdapBufSetPoint/((double)CTP_OSC_FREQ));
	      PRTSP(EVE,,PrtBuf);
	      pPortIntSt->AdapResetBufSetPoint = 0;
	    } else {
	      // Create absolute values of interesting numbers
	      //--- BufferError is in msec
	      BufferError = (pPortIntSt->AdapBufSetPoint - pPortIntSt->AdapAvgBufPos);
	      if( BufferError < 0 ) BufferError = 0 - BufferError;

	      // Now decide on state change
	      // Buffer measured in ticks of 32MHz clk
	      // AdapMaxBufError is in usec
	      if( (double)BufferError/((double)CTP_OSC_FREQ/1024.0) > (double)pPortIntSt->AdapMaxBufError ) {
		pPortSt->AdapState = CTP_ADAP_STATE_AGGRESSIVE;
		pPortIntSt->AdapAggrAdjustCnt = 0;	// reset DDS adjust counter
	        sprintf(PrtBuf,"++++++++++ State changing to AGRESSIVE ++++++++++ \n");
	        PRTSP(EVE,,PrtBuf);
	        sprintf(PrtBuf,"BufferError = %.2f, MaxBufError %.2f\n",
		    (double)BufferError/((double)CTP_OSC_FREQ/1024.0), (double)pPortIntSt->AdapMaxBufError);
	        PRTSP(EVE,,PrtBuf);
	      }

	      // We want to adjust the DDS after the state change decision is
	      // made since the current state dictates the DDS adjust method.
	      ctp_adap_set_dds( Card, pNum, pPortSt->AdapState );
	    }
	  } else {
	    // If a restart has happened during this "calc" period, we do
	    // not want to adjust the DDS at the moment. However, we will
	    // want to reset the buffer set point on the next pass.
	    sprintf(PrtBuf,"Restart happened so do nothing during this period \n");
	    PRTSP(GEN,,PrtBuf);
	    pPortIntSt->AdapResetBufSetPoint = 1;
	    pPortIntSt->AdapConsecRestarts++;
	    if( pPortIntSt->AdapConsecRestarts >= 3 ) {
	      ctp_adap_set_dds( Card, pNum, pPortSt->AdapState );
	    }
	  }

	  pPortIntSt->AdapAllGroups = 0;		// reset storage
	  pPortIntSt->AdapRestarts = 0;		// reset flag
	}
	break;
      //------------------------------------------------------------------
      default:
	PRTV(MAJ,Invalid state ,pPortSt->AdapState);
	pPortSt->AdapState = CTP_ADAP_STATE_WAIT;
	pPortIntSt->AdapStateCnt = CTP_ADAP_WAIT;
	break;
    }
  }
}

//--------------------------------------------------------------------------
// This routine will take X Groups and perform correlation operations.
// A regression line is drawn through the data points. The important output
// here is slope, which will tell us not only the direction of the buffer
// fill trend (emptying or filling), but also the magnitude. Also a Pearson
// correlation calculation is done to see how well these points "fit the
// line". This correlation is a quality metric to determine whether or not to
// "trust" the calculated line slope. Also, this routine calculates the
// average Y (buffer fill) value. This average is useful in maintenance
// mode when the slope is close to 0 and we are trying to drive the buffer
// fill to a fixed fill value. The idea is to send any data gathered to
// this routine, and any potentially useful calculations are performed on
// it. What is actually done with the data is the responsibility of higher
// layers.
//--------------------------------------------------------------------------
int ctp_adap_calc_slope( int Card, int pNum )
{
  CTP_PORT_STATE	*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  CTP_ADAP_GROUP	*pPrevGrp,*pGrp;
  int			 PrevIdx, Idx, delta_x, delta_y;
  double		 slope;
  char			 PrtBuf[100];
  FUNC_PRT(ctp_adap_calc_slope, PF_ADAP, pNum);

  Idx = pPortIntSt->AdapCurGroupIndex;
  pGrp = (CTP_ADAP_GROUP *)&pPortIntSt->AdapGroups[Idx];

  //--- We calculate the spope use only two values, the luckest packet from
  //    the last group and the luckest packet from this group.
  PrevIdx = (Idx + CTP_MAX_ADAP_GROUPS - 1) % CTP_MAX_ADAP_GROUPS;
  pPrevGrp = (CTP_ADAP_GROUP *)&pPortIntSt->AdapGroups[PrevIdx];
  if( (pGrp->Valid == 1) && (pPrevGrp->Valid == 1) ) {
    //--- We are using the _first_ occurence of the luckest packet in each
    //    group to get the slope!
    //--- We assume that the number of packets per second & samples per
    //    group are the same for both groups (ie ~constant).

    //--- This the buffer level difference, in 32MHz ticks, between our two lucky packets
    delta_y = (int)(pGrp->Hi[0] - pPrevGrp->Hi[0]);

    sprintf(PrtBuf,"- delta_y (%d) = %d - %d in 32MHz ticks\n",
	delta_y, (int)pGrp->Hi[0], (int)pPrevGrp->Hi[0]);
    PRTSP(FNC,,PrtBuf);
    //sprintf(PrtBuf,"-  Hi[1] , Hi[2] = %d , %d in 32MHz ticks\n",
    //	pGrp->Hi[1], pPrevGrp->Hi[2]);
    //PRTSP(GEN,,PrtBuf);

    //--- This the number of packets between our two lucky packets
    delta_x = (int)(pPrevGrp->Num - pPrevGrp->HiIdx[0] + pGrp->HiIdx[0]);
    if ( 20*delta_x < pGrp->Num) {
      sprintf(PrtBuf,"- delta_x = %d, Number of samples = %d \n",
	  delta_x, pGrp->Num);
      PRTSP(FNC,,PrtBuf);
    }

    sprintf(PrtBuf,"- delta_x (%d) = %d + %d, with %d samples in %d seconds \n",
	delta_x, (pPrevGrp->Num - pPrevGrp->HiIdx[0]), pGrp->HiIdx[0], pGrp->Num, pPortIntSt->AdapCalcSec);
    PRTSP(FNC,,PrtBuf);

    //--- Want the slope in ppm, note, a tick of 32MHz clk ~ 30.5 nSec
    if ( (double)delta_x != 0 ) {
      slope = (double)delta_y/(double)delta_x;
    } else { PRT(EVE,delta_x was zero); return(FAILURE); }
    //sprintf(PrtBuf,"- slope = %.2f ticks per packet\n", slope );
    //PRTSP(FNC,,PrtBuf);
    slope /= (double)(CTP_OSC_FREQ/1000);			// 32 MHz clk, convert Numerator to usec
    //sprintf(PrtBuf,"- slope = %.4f ticks per usec\n", slope );
    //PRTSP(FNC,,PrtBuf);
    if ( ( (double)pGrp->Num != 0 ) && ( (double)pPortIntSt->AdapCalcSec != 0 ) ) {
      slope /= (double)pPortIntSt->AdapCalcSec / (double)pGrp->Num;	// Convert denominator to seconds!
    } else { PRT(EVE,pPortIntSt->AdapCalcSec or pPortIntSt->AdapCalcSec was zero); return(FAILURE); }
    //sprintf(PrtBuf,"- slope = %.4f ppm\n", slope );
    //PRTSP(FNC,,PrtBuf);

  } else {
    sprintf(PrtBuf,"- Waiting for two consectutive valid groups to calculate slope\n");
    PRTSP(GEN,,PrtBuf);
    return(FAILURE);
  }

  pPortIntSt->AdapSlope = slope;
  if (pPortSt->AdapState == CTP_ADAP_STATE_AGGRESSIVE) {
    sprintf(PrtBuf,"- slope = %.4f ppm\n", pPortIntSt->AdapSlope );
    PRTSP(GEN,,PrtBuf);
  }

  //--- Use the 3rd luckest buffer value for AdapCurBufPos
  pPortIntSt->AdapCurBufPos = (double)(pGrp->Hi[2]);
  //--- Use 3 luckest buffer vlaues from this group to
  //    set average buffer position.
  pPortIntSt->AdapAvgBufPos = (double)((pGrp->Hi[0] + pGrp->Hi[1] + pGrp->Hi[2])/3) ;

  return(SUCCESS);
}

//--------------------------------------------------------------------------
// full = 0, For CTP 2000/150 Card 0, only set the fixed frequency value.
// full = 1, For CTP 2000/150 Card 0, Init H/W for fixed freq output, and set freq value
// full = 2, For CTP 150      Card 1, only set the fixed frequency value.
// full = 3, For CTP 150      Card 1, Init H/W for fixed freq output, and set freq value
//--------------------------------------------------------------------------
void ctp_set_pll_fixed( u16 pll_val, int full)
{
  int Card = 0;		// Default Manage vcxo on card 0.
  int PllVal = (int)pll_val;
  FUNC_PRT(ctp_set_dds_fixed, PF_REF, -1);

    fpga_clr_fcfg();
    fpga_set_ref_fixed((u32)pll_val);
    if( full&1 ) { // if full == 1 or == 3
      fpga_set_ref_fixed_period(CTP_PHDET_GEN_SPAN);
      fpga_set_ref_sel(CTP_REF_FIXED);		// Set PLL to use fixed value
      fpga_set_ref_bypass(ACTIVE_H);
      fpga_disable_phdet(ACTIVE_H);
    }
    // steal full variable for programming card 1 vcxo
#ifdef VCTP
    if(full & 2) Card = cardIndx[1];	// if full == 2 or 3
#else
    if(full & 2) Card = 1;	// if full == 2 or 3
#endif
    PRTVC(GN1, set_pll_fixed value, PllVal);
    fpga_send_fcfg(pSysInfo->Card[Card].BaseSccNum);
}
//--------------------------------------------------------------------------
// This routine will sets the DDS to an adjusted value based on the
// information stored in the "adap" portion of the internal port state.
// The routine accepts the current adaptive state of the port so that it
// can use the appropriate data for adjusting the clock. In the agressive
// state, the goal is to adjust the DDS so that the next calculated slope
// will be 0. In the maintenance state we are trying to drive the average
// buffer level to a constant (saved) value.
//--------------------------------------------------------------------------
void ctp_adap_set_dds( int Card, int pNum, int state )
{
  CTP_PORT_STATE	*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  CTP_PORT_DBASE	*pDbP = &Db.Card[Card].Port[pNum];
  double		 max_dds_adj, max_dds_off, max_pll_adj;
  double		 eff_desired_slope;
  double		 dds_adjust_aggr, dds_adjust_mntn;
  double		 pll_adjust_aggr, pll_adjust_mntn;
  double		 PpmPerPll = ((double)Ctp.Node[0].VcxoPpmRange)/((double)CTP_PHDET_SPAN);
  u32			 dds_adjust_abs, new_dds_val;
  u16			 pll_adjust_abs, new_pll_val;
  int			 BufferError, dds_adjust, dds_adjust_actual;
  int			 pll_adjust, pll_adjust_actual;
  char			 PrtBuf[120];
  FUNC_PRT(ctp_adap_set_dds, PF_ADAP, pNum);

  // Based on the acquired data, now calculate DDS adjustment values.
  BufferError = pPortIntSt->AdapBufSetPoint - pPortIntSt->AdapAvgBufPos;
  pPortSt->AdapError = BufferError;
  //PRTDV(OFF,Buffer Error,BufferError);

  //--- Want to hit buffer set point in AdapDecay calculation periods
  //    If current slope were zero => Effective slope we want in ppm
  //    Current slope is taken into account below!
  eff_desired_slope  = (double)(BufferError>>5) /
    ((double)pPortIntSt->AdapDecay * (double)pPortIntSt->AdapReqMntnSeconds);
  sprintf(PrtBuf, "E= %dus, AdapDecay= %d, eff_desired_slope= %.4f ppm\n",
      (int)(BufferError>>5), pPortIntSt->AdapDecay, eff_desired_slope);
  PRTSP(FNC,,PrtBuf);

  dds_adjust_mntn = ((double)pPortSt->AdapDdsValue * eff_desired_slope / 1000000.0);
  if( PpmPerPll == 0 ) PpmPerPll = 80.0/((double)CTP_PHDET_SPAN);	// Cover our buts!
  pll_adjust_mntn = eff_desired_slope / PpmPerPll;


  //--- Slope is in ppm!!
  dds_adjust_aggr = ((double)pPortSt->AdapDdsValue * (double)pPortIntSt->AdapSlope / 1000000.0);
  pll_adjust_aggr = pPortIntSt->AdapSlope / PpmPerPll;

  if(pPortSt->NetRefAdapBndl) {
    sprintf(PrtBuf, "pll %d(%d), ppm range %d, ppm/pll %f.\n",
	pNRefs->AdapPllValue, Ctp.Node[0].Calibration, Ctp.Node[0].VcxoPpmRange, PpmPerPll);
    PRTSP(DBG,,PrtBuf);
    //--- Update NetRef state to that of port state!
    switch(state){
      case CTP_ADAP_STATE_AGGRESSIVE:
	if( pNRefs->State != CTP_NETREF_STATE_AGGR ) {
	  if       ( pNRefs->State == CTP_NETREF_STATE_WAIT ) {
	    PRT(MIN,NetRef state transition: wait -> aggressive);
	  } else if( pNRefs->State == CTP_NETREF_STATE_MNTN ) {
	    PRT(MIN,NetRef state transition: maintain -> aggressive);
	  } else {
	    PRTDV(MIN,NetRef state transition to aggressive from, pNRefs->State);
	  }
	  ctp_set_led(PLL_LED_RED, 0);
	  pNRefs->State = CTP_NETREF_STATE_AGGR;
	}
	sprintf(PrtBuf, "adap slope %.2f adjust_aggr %.2f\n",
	    pPortIntSt->AdapSlope, pll_adjust_aggr);
	PRTSP(FNC,,PrtBuf);
	break;
      case CTP_ADAP_STATE_MAINTAIN:
	if( pNRefs->State != CTP_NETREF_STATE_MNTN ) {
	  if( pNRefs->State == CTP_NETREF_STATE_AGGR ) {
	    PRT(MIN,NetRef state transition: aggressive -> maintain);
	  } else {
	    PRTDV(MIN,NetRef state transition to maintain from, pNRefs->State);
	  }
	  ctp_set_led(PLL_LED_GREEN, 0);
	  pNRefs->State = CTP_NETREF_STATE_MNTN;
	}
	sprintf(PrtBuf, "desired slope (ppm) %.2f adjust_mntn %.2f, adap slope %.2f adjust_aggr %.2f\n",
	    eff_desired_slope, pll_adjust_mntn, pPortIntSt->AdapSlope, pll_adjust_aggr);
	PRTSP(GEN,,PrtBuf);
	break;
      case CTP_ADAP_STATE_WAIT:
      default:
	pNRefs->State = CTP_NETREF_STATE_WAIT;
	pNRefs->last_ppm_adj  = 0.0;
	break;
    }
    sprintf(PrtBuf,
	"dds_adjust_mntn %.2f, pll_adjust_mntn %.2f, dds_adjust_aggr %.2f, pll_adjust_aggr %.2f.\n",
	dds_adjust_mntn, pll_adjust_mntn, dds_adjust_aggr, pll_adjust_aggr);
    PRTSP(FNC,,PrtBuf);
  }
  //--------------------------------------
  if( state == CTP_ADAP_STATE_WAIT ) {
    // Frankly, I am not sure why the DDS should get changed at all when in
    // this state. This is supposed to be a waiting state until we go to
    // AGRESSIVE, where intelligent clock adjustments are made based on the
    // calculated slope. We should do nothing here.
  }
  //--------------------------------------
  else if( state == CTP_ADAP_STATE_AGGRESSIVE ) {
    if( pPortIntSt->AdapAggrAdjustCnt == 0 ) {
      dds_adjust	= (u32)dds_adjust_aggr;
      dds_adjust_actual	= (u32)dds_adjust_aggr;
      pll_adjust	= (int)pll_adjust_aggr;
      pll_adjust_actual	= (int)pll_adjust_aggr;
    } else {
      dds_adjust	= 0;
      dds_adjust_actual	= 0;
      pll_adjust	= 0;
      pll_adjust_actual	= 0;
    }

    //PRTDV(OFF,Calced DDS adjusted by,dds_adjust_actual);
    //PRTFVP(MIN,Aggr calced PLL adj,pll_adjust_aggr);
    //PRTDVP(MIN,Aggr calced PLL adj act,pll_adjust_actual);
  }
  //--------------------------------------
  else if( state == CTP_ADAP_STATE_MAINTAIN ) {
    dds_adjust = (u32)dds_adjust_aggr - (u32)dds_adjust_mntn;
    pll_adjust = (int)(pll_adjust_aggr - pll_adjust_mntn);
    //PRTDV(OFF,Calced DDS adjusted by,dds_adjust);
    //PRTDVC(GN3,Calced PLL mntn adj,pll_adjust);

    // Find magnitude of DDS adjustment
    if( dds_adjust > 0 )	{ dds_adjust_abs = dds_adjust; }
    else if( dds_adjust < 0 )	{ dds_adjust_abs = 0 - dds_adjust; }
    else			{ dds_adjust_abs = 0; }
    // Find magnitude of PLL adjustment
    if( pll_adjust > 0 )	{ pll_adjust_abs = pll_adjust; }
    else if( pll_adjust < 0 )	{ pll_adjust_abs = 0 - pll_adjust; }
    else			{ pll_adjust_abs = 0; }


    //--- Set max_dds_adj	- the max dds change we allow per calc.
    max_dds_adj = ((double)pPortIntSt->AdapMaxPpbAdj *
	(double)pPortSt->AdapDdsValue / 1000000000.0);
    max_pll_adj = (double)pPortIntSt->AdapMaxPpbAdj /( PpmPerPll * 1000.0);


    // Clip value if greater than max
    if( dds_adjust_abs > max_dds_adj ) {
      if( dds_adjust > 0 )	{ dds_adjust_actual = max_dds_adj; }
      else if( dds_adjust < 0 )	{ dds_adjust_actual = 0 - max_dds_adj; }
      else			{ dds_adjust_actual = 0; }
    } else {
      dds_adjust_actual = dds_adjust;
    }
    // Clip value if greater than max 
    if( pll_adjust_abs > max_pll_adj ) {
      if(pPortSt->NetRefAdapBndl) {
	PRTFVP(GN2,max_pll_adj, max_pll_adj);
	PRTDVP(GN2,Before PLL capped by max pll adj it was,pll_adjust);
      }
      if( pll_adjust > 0 )	{ pll_adjust_actual = max_pll_adj; }
      else if( pll_adjust < 0 )	{ pll_adjust_actual = 0 - max_pll_adj; }
      else			{ pll_adjust_actual = 0; }
    } else {
      pll_adjust_actual = pll_adjust;
    }
    if(pPortSt->NetRefAdapBndl) {
      PRTDVP(GN2,mntn PLL adjust is now, pll_adjust_actual);
    }
#if 1
    // want to try an experiment here. DDS adjustments are reduced
    // significantly when the Error is small. This should help avoid
    // "bobbling" when the adaptive is "locked". The +1 and -1 make sure
    // that we do not truncate the adjustment and make no change.
    // TODO: Make buffer error threshold configurable
    if(pPortSt->NetRefAdapBndl) {
      sprintf(PrtBuf, "BufferError %d, pll_adjust %d pll_adjust_actual %d\n", BufferError, pll_adjust, pll_adjust_actual);
      PRTSP(FNC,Before limits,PrtBuf);
    }

    // 400 -> 12 uSec which really doesn't make much sense as without a
    // slope correction (aggressive adjustment), & using standard adaptive 
    // settings, correction for this buffer level is < 1!
    if( (BufferError < 400) && (BufferError > -400) ) {
      if( dds_adjust_actual < 0 ) {
	dds_adjust_actual = (dds_adjust_actual / 10) - 1;
      } else if( dds_adjust_actual > 0 ) {
	dds_adjust_actual = (dds_adjust_actual / 10) + 1;
      } else {
	dds_adjust_actual = 0;
      }

    }

    if( pPortSt->NetRefAdapBndl &&
	(BufferError < 4000) && (BufferError > -4000) &&
	(pll_adjust_aggr < 10) && (pll_adjust_aggr > -10) ) {
      PRTDVP(GN2,Before PLL capped by BufferError was,pll_adjust_actual);
      if( pll_adjust_actual < -20 ) {
	pll_adjust_actual = (pll_adjust_actual / 2);
      } else if( pll_adjust_actual < 0 ) {
	pll_adjust_actual = -1;	
      } else if( pll_adjust_actual > 20 ) {
	pll_adjust_actual = (pll_adjust_actual / 2);
      } else if( pll_adjust_actual > 0 ) {
	pll_adjust_actual = +1;
      } else {
	pll_adjust_actual = 0;
      }
    }

#endif

    // Don't set it to 0. At least do *something*. This avoids the long
    // breathing effect that Ray and SI have seen. Bug #360.
    if( dds_adjust_actual == 0 ) {
      if( dds_adjust < 0 )	dds_adjust_actual = -1;
      else			dds_adjust_actual = 1;
    }

    if( pll_adjust_actual == 0 ) {
      if( pll_adjust < 0 )	pll_adjust_actual = -1;
      else			pll_adjust_actual = 1;
    }

  }

  new_dds_val = pPortSt->AdapDdsValue + dds_adjust_actual;
  if(pPortSt->NetRefAdapBndl){
    PRTDVP(GN2,pll_adjust_actual,pll_adjust_actual);
    //--- Limit Pll to 0 <-> 4095
    if( (int)pNRefs->AdapPllValue + pll_adjust_actual  < 0 ) {
      new_pll_val = 0;
      PRTP(EVE,Pll at rail: 0);
    } else if( (int)pNRefs->AdapPllValue + pll_adjust_actual  > 4095 ) {
      new_pll_val = 4095;
      PRTP(EVE,Pll at rail: 4095);
    } else {
      new_pll_val = (int)pNRefs->AdapPllValue + pll_adjust_actual;
    }
  }
  // This is an added safeguard... When the DDS over/underflow rate is
  // faster than either the aggr or maintain calc frequency, the
  // possibility exists that adaptive cannot recover. This is a
  // "watchdog".
  if( pPortIntSt->AdapConsecRestarts >= 3 ) {
    if(pPortSt->NetRefAdapBndl) PRTP(MIN,Too many consec restarts - reset to nominal PLL)
    else                        PRTP(MIN,Too many consec restarts - reset to nominal DDS);
    new_dds_val = pPortIntSt->AdapDdsNominal;
    new_pll_val = pPortIntSt->AdapPllNominal;
    pPortSt->AdapState = CTP_ADAP_STATE_WAIT;
    pPortIntSt->AdapStateCnt = CTP_ADAP_WAIT;
  }

  // Here we check to make sure that the actual DDS value programmed is no
  // more than AdapMaxPpmOffset from the nominal center value. This max
  // 200 ppm. 100 accounts for the possible inaccuracy for the
  // system TCVCXO. The other 100 ppm is how far off center frequency the
  // remote port is allowed to be. Nominal would be the measured frequency
  // from the remote end if in autobaud mode. 100 ppm is the accuracy of a
  // cheesy can oscillator.

  //--- Set max_dds_off	- the max dds offset, or change from nominal value
  max_dds_off = ((double)pPortIntSt->AdapMaxPpmOffset *
      (double)pPortSt->AdapDdsValue / 1000000.0);

  if( (new_dds_val > (pPortIntSt->AdapDdsNominal + max_dds_off)) ) {
    sprintf(PrtBuf,"DDS adjustment beyond upper bound\n");
    PRTSP(EVE,,PrtBuf);
    new_dds_val = pPortIntSt->AdapDdsNominal + max_dds_off;
  }
  else if( (new_dds_val < (pPortIntSt->AdapDdsNominal - max_dds_off)) ) {
    sprintf(PrtBuf,"DDS adjustment beyond lower bound\n");
    PRTSP(EVE,,PrtBuf);
    new_dds_val = pPortIntSt->AdapDdsNominal - max_dds_off;
  }

  if(pPortSt->NetRefAdapBndl) {
    int pll_change = new_pll_val - pNRefs->AdapPllValue;
    pNRefs->last_ppm_adj  = (double)pll_change * PpmPerPll;
    pNRefs->AdapPllValue = new_pll_val;
    ctp_set_pll_fixed( new_pll_val, 0);
    sprintf(PrtBuf,"pll adj act %d, new pll %d, ppm adj %.3f",pll_change, new_pll_val, pNRefs->last_ppm_adj);
    PRTSP(GEN,,PrtBuf);
  } else {
    fpga_clr_fcfg();
    fpga_set_dds_freq( Card, pNum, new_dds_val );
    // Aricent PR 1198066 Fix - Start
    if(IS_SER(Card)) {
      if( pDbP->dds_src == CTP_DDS_SRC_AUTOBAUD ) {
        fpga_set_dds_div(pNum, (u32)0);
      } else {
        fpga_set_dds_div(pNum, pDbP->dds_div );
      }
    }
    // Aricent PR 1198066 Fix - End
    fpga_send_fcfg(pPortSt->SccNum);

    pPortSt->AdapDdsValue = new_dds_val;		// Save new DDS value

    //PRTDV(OFF,Actual DDS adjusted by,dds_adjust_actual);
    sprintf(PrtBuf, "%s: E= %dus, Da/m= %.0f/%.0f, dds_adj= %d/%d, dds_offset= %d\n",
	( state == CTP_ADAP_STATE_MAINTAIN ) ? "MNTN" : "AGGR",
	(int)(BufferError>>5), dds_adjust_aggr, dds_adjust_mntn, (int)dds_adjust,
	(int)dds_adjust_actual, (int)(new_dds_val - pPortIntSt->AdapDdsNominal) );
    PRTSP(GEN,,PrtBuf);
  }
}

//--------------------------------------------------------------------------
// This routine checks for overflow & underflow conditions.  If either is
// detected, it increments the under/overflow counter and forces a restart.
//--------------------------------------------------------------------------
int ctp_proc_over_underflow( int bNum )
{
  int Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
  int pNum = util_bndl_src_pNum(0, &Db.Bndl[bNum]);
  CtpBndlState			*pBndlSt    = &Ctp.Bndl[bNum].Bndl.ctp;
  CTP_BNDL_DBASE		*pDbB 	= &Db.Bndl[bNum];
  CTP_PORT_STATE		*pPortSt = &Ctp.Card[Card].Port[pNum];
  struct acrndrv_buffer_stats	*pBuff = &Ctp.Bndl_cnt[bNum].Bndl.ctp.Current.Buffer;
  struct acrndrv_runtime_cntrs	*pCntr = &Ctp.Bndl_cnt[bNum].Bndl.ctp.Current.Counters;
  struct acrndrv_runtime_cfg     nrc;
  char				 SccBuf[40],PrtBuf[150];
  u32				 prev_largest;
  int                            num;// Aricent PR 1356307 fix
  FUNC_PRT(ctp_proc_over_underflow, PF_PST, bNum);

  //--- At slow speeds we may have 1 packet every few seconds.
  //    In order to ensure we have enough packets to evaluate whether or
  //    not there was an under or overflow, we accumilate the luckest two
  //    packet buffer levels in the internal state. Once we have
  //    accumilated at least CTP_REQ_BUF_SAMPLES (30), we look for under
  //    and overflows, and reset the NumBufSamples to start again.
  // Aricent PR-947222 Start
 if( Db.Bndl[bNum].Type == CTP_BNDL_TYPE_WP){
  sprintf(SccBuf,"cbc%d",pDbB->Bndl.wp_bndl.cbc_num);
 } 
 // Aricent PR-947222 Start
 else  sprintf(SccBuf,"scc%d",pPortSt->SccNum);
  
  if( pBndlSt->NumBufSamples == 0 ) {
    pBndlSt->LastBufMax = pBndlSt->BufMax1;
    pBndlSt->BufMax1 	= pBuff->Largest;
    pBndlSt->BufMax2 	= pBuff->NLargest;
    pBndlSt->NumBufSamples 	= pBuff->Samples;
  } else {
    //--- Sort them in
    if( pBuff->Largest > pBndlSt->BufMax1 ) {
      pBndlSt->BufMax2 = pBndlSt->BufMax1;
      pBndlSt->BufMax1 = pBuff->Largest;
      if( pBuff->NLargest > pBndlSt->BufMax2 ) {
	pBndlSt->BufMax2 = pBuff->NLargest;
      }
    }
    else if ( pBuff->Largest > pBndlSt->BufMax2 ) {
      pBndlSt->BufMax2 = pBuff->Largest;
    }
    pBndlSt->NumBufSamples 	+= pBuff->Samples;
  }
  //
  //--- Do we have enough samples to process under & overflows?
  if( pBndlSt->NumBufSamples >= CTP_REQ_BUF_SAMPLES ) {
    PRTDVP(FNC,Samples to be processed, pBndlSt->NumBufSamples);
    pBndlSt->NumBufSamples = 0;		// Reset for next time through
    //--- Did both largest & next largest samples go over the max threshold?
    if( (pBndlSt->BufMax1 > pDbB->MaxDel) &&
	(pBndlSt->BufMax2 > pDbB->MaxDel) ) {
      pCntr->overflow_cnt++;
      //-- Force a restart
      ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
#ifndef DISABLE_UNDER_OFLOWS
      nrc.restart = YES;
#endif
      nrc.starve_flag = NO;
      ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      sprintf(PrtBuf,"Overflow: Largest %d Next Largest %d MaxDel %d ticks\n",
	  (int)pBndlSt->BufMax1, (int)pBndlSt->BufMax2, (int)pDbB->MaxDel);
      R_PRTSP(EVE,,PrtBuf);
      // Aricent PR 1356307 fix - Start
      num = trap_number("TRAP_PT_OFLOW");
      if (trap_bitmap & (1 << (num - 1))){
	trap_bNum = bNum; //PR-1878575
        ctp_send_trap(Card, pNum,TRAP_PT_OFLOW,pCntr->overflow_cnt);
      }
      // Aricent PR 1356307 fix - End
      return (1);
    }
    //--- Check for underflow
    prev_largest = (pBndlSt->LastBufMax == 0) ?
      pBndlSt->BufMax1 : pBndlSt->LastBufMax;
    if (((prev_largest+pBndlSt->BufMax1) < 2* pDbB->MinDel ) &&
	(pBndlSt->BufMax1 != 0 )) {
      pCntr->underflow_cnt++;
      //-- Force a restart
      ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
#ifndef DISABLE_UNDER_OFLOWS
      nrc.restart = YES;
#endif
      nrc.starve_flag = NO;
      ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      sprintf(PrtBuf,"Underflow: Largest %d (%d) MinDel %d ticks\n",
	  (int)pBndlSt->BufMax1, prev_largest, (int)pDbB->MinDel);
      R_PRTSP(EVE,,PrtBuf);
      // Aricent PR 1356307 fix - Start
      num = trap_number("TRAP_PT_UFLOW");
      if (trap_bitmap & (1 << (num - 1))){
	trap_bNum = bNum; //PR-1878575
        ctp_send_trap(Card, pNum,TRAP_PT_UFLOW,pCntr->underflow_cnt);
      }
      // Aricent PR 1356307 fix - End
      //--- Zero this so we don't reuse it next time
      pBndlSt->BufMax1 = 0;
      return (1);
    }
  }
  return (0);
}

//--------------------------------------------------------------------------
// This routine checks for SCC sync on this port. If it is not in sync, a
// crypto resync pulse is generated on DSR (unbalanced) and CTS (balanced).
//--------------------------------------------------------------------------
int ctp_proc_hdlc_crypto( int Card, int pNum )
{
  struct acrndrv_runtime_cntrs	*pCurr = &Ctp.Card[Card].Cntr[pNum].Current.Counters;
  CTP_PORT_INT_STATE		*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  CTP_PORT_DBASE    		*pDbP = &Db.Card[Card].Port[pNum];
  char msg[80];
  int insync;

  FUNC_PRT(ctp_proc_hdlc_crypto, PF_MISC, pNum);

  /*
   * Check to see if the port is "down" -- for some not-too-useful definition of "down".
   *
   * Since scc_sync might indicate the port is up even when the crypto is out of sync
   * and spewing random bits at us, a more reliable method is to use the HDLC-layer
   * keepalive mechanisms (appropriate to the l2 protocol in use)
   */

  if (pCurr->scc_sync == 0) {
    insync = 0;
  } else {
    int mode = utl_get_port_mode(Card,pNum);
    if( mode == PORT_MODE_CKTEM ) {
      insync = 1;
    } else {
      switch (pDbP->pkt_info.Encap) {
	case CTP_ENCAP_CHDLC:
	  insync = pPortIntSt->hdlcstatus.cisco.up;
	  break;
	case CTP_ENCAP_PPP:
	  insync = (pPortIntSt->hdlcstatus.ppp.lcp == LCP_STATE_OPENED);
	  break;
	case CTP_ENCAP_FRAME_RELAY:
	  insync = pPortIntSt->hdlcstatus.fr.reliable;
	  break;
	default:
	  insync = 1;    // If this happens, something's broken that crypto resync can't fix...
      }
    }
  }

#ifdef DBG_CRYPTO
  sprintf(msg, "crypto: sync: %d  state: %d count: %d", 
      insync, pPortIntSt->HdlcCryptoState,pPortIntSt->HdlcCryptoCounter);
  PRTSP(MIN,,msg);
#endif

  pPortIntSt->HdlcCryptoCounter--;

  switch( pPortIntSt->HdlcCryptoState ) {
    //------------------
    // This is the initial state, where we set up the signals, state and counters
    case CRYPTO_STATE_INIT: 
      pPortIntSt->HdlcCryptoState = CRYPTO_STATE_SYNC;
      pPortIntSt->HdlcCryptoCounter = CRYPTO_WAIT_TIME(pDbP->CryptoResync1);
      ctp_set_single_sig_out( Card, pNum, CTP_SIG_OUT_DSR, CRYPTO_DSR_NORM(pDbP->CryptoResync2) ? 1 : 0);
      ctp_set_single_sig_out( Card, pNum, CTP_SIG_OUT_CTS, CRYPTO_CTS_NORM(pDbP->CryptoResync2) ? 1 : 0);
      PRTP(EVE,crypto states: INIT->SYNC - Init sigs and cntrs);
      break;
    //------------------
    case CRYPTO_STATE_SYNC:
      if( insync ) {
        pPortIntSt->HdlcCryptoCounter = CRYPTO_WAIT_TIME(pDbP->CryptoResync1);
      } else {
	if (pPortIntSt->HdlcCryptoCounter == 0) {
	  pPortIntSt->HdlcCryptoState = CRYPTO_STATE_NOSYNC_PULSE;
	  pPortIntSt->HdlcCryptoCounter = CRYPTO_PULSE_TIME(pDbP->CryptoResync2);
	  ctp_set_single_sig_out( Card, pNum, CTP_SIG_OUT_DSR, CRYPTO_DSR_PULSE(pDbP->CryptoResync2) ? 1 : 0);
	  ctp_set_single_sig_out( Card, pNum, CTP_SIG_OUT_CTS, CRYPTO_CTS_PULSE(pDbP->CryptoResync2) ? 1 : 0);
	  PRTP(EVE,crypto states: SYNC->NOSYNC_PULSE - pulse sigs);
	}
      }
      break;
    //------------------
    case CRYPTO_STATE_NOSYNC_PULSE:
      if (pPortIntSt->HdlcCryptoCounter == 0) {
	  pPortIntSt->HdlcCryptoState = CRYPTO_STATE_NOSYNC_WAIT;
	  pPortIntSt->HdlcCryptoCounter = CRYPTO_PERIOD(pDbP->CryptoResync1) - CRYPTO_PULSE_TIME(pDbP->CryptoResync2);
	  ctp_set_single_sig_out( Card, pNum, CTP_SIG_OUT_DSR, CRYPTO_DSR_NORM(pDbP->CryptoResync2) ? 1 : 0);
	  ctp_set_single_sig_out( Card, pNum, CTP_SIG_OUT_CTS, CRYPTO_CTS_NORM(pDbP->CryptoResync2) ? 1 : 0);
	  PRTP(EVE,crypto states: NOSYNC_PULSE->NOSYNC_WAIT - unpulse sigs);
      }
      break;
    //------------------
    case CRYPTO_STATE_NOSYNC_WAIT:
      if (pPortIntSt->HdlcCryptoCounter == 0) {
	if( insync ) {
	  pPortIntSt->HdlcCryptoState = CRYPTO_STATE_SYNC;
	  pPortIntSt->HdlcCryptoCounter = CRYPTO_WAIT_TIME(pDbP->CryptoResync1);
	  ctp_set_single_sig_out( Card, pNum, CTP_SIG_OUT_DSR, CRYPTO_DSR_NORM(pDbP->CryptoResync2) ? 1 : 0);
	  ctp_set_single_sig_out( Card, pNum, CTP_SIG_OUT_CTS, CRYPTO_CTS_NORM(pDbP->CryptoResync2) ? 1 : 0);
	  PRTP(EVE,crypto states: NOSYNC_WAIT->SYNC);
	} else {
	  pPortIntSt->HdlcCryptoState = CRYPTO_STATE_NOSYNC_PULSE;
	  pPortIntSt->HdlcCryptoCounter = CRYPTO_PULSE_TIME(pDbP->CryptoResync2);
	  ctp_set_single_sig_out( Card, pNum, CTP_SIG_OUT_DSR, CRYPTO_DSR_PULSE(pDbP->CryptoResync2) ? 1 : 0);
	  ctp_set_single_sig_out( Card, pNum, CTP_SIG_OUT_CTS, CRYPTO_CTS_PULSE(pDbP->CryptoResync2) ? 1 : 0);
	  PRTP(EVE,crypto states: NOSYNC_WAIT->NOSYNC_PULSE - pulse sigs);
	}
      }
      break;
    default: 
      pPortIntSt->HdlcCryptoState = CRYPTO_STATE_INIT;
      PRTP(EVE,crypto states: INVALID->INIT - clean up);
      break;
  }

  return (0);
}

//--------------------------------------------------------------------------
// This routine checks for a problem with the Tx DMA. The symptom is that
// there are no packets pulled from the RING by the SCC/DMA even though
// packets are arriving and clocks are good. If the condition is detected,
// it is corrected by a restart.
//--------------------------------------------------------------------------
int ctp_proc_stalled_tx( int bNum )
{
  int Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
  int pNum = util_bndl_src_pNum(0, &Db.Bndl[bNum]);
  CTP_PORT_STATE		*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_BNDL_STATE		*pBndlSt = &Ctp.Bndl[bNum];
  struct acrndrv_runtime_cntrs	*pCurr = &Ctp.Bndl_cnt[bNum].Bndl.ctp.Current.Counters;
  struct acrndrv_runtime_cntrs	*pPrev = &Ctp.Bndl_cnt[bNum].Bndl.ctp.Previous.Counters;
  struct acrndrv_runtime_cfg     nrc;
  char				 SccBuf[40];
  int				 Thresh;
  int                            bndlState=0;
  FUNC_PRT(ctp_proc_stalled_tx, PF_PST, bNum);
  //PR772696 - Aricent Fix Start
  if((Db.Bndl[bNum].Type == CTP_BNDL_TYPE_CTP) || (Db.Bndl[bNum].Type == CTP_BNDL_TYPE_SO)) 
     bndlState = pPortSt->State;
  else if(Db.Bndl[bNum].Type == CTP_BNDL_TYPE_WP)
     bndlState = pBndlSt->State;
  //PR772696 - Aricent Fix End
  if( bndlState == CTP_PORT_STATE_RUNNING ) {
    if( (pCurr->tx_intr_count == pPrev->tx_intr_count) || (pCurr->tx_pkts == pPrev->tx_pkts) ) { //PR772696 - Aricent Fix
      pBndlSt->Bndl.ctp.SecsWithNoTxPkts++;
    } else {
      pBndlSt->Bndl.ctp.SecsWithNoTxPkts = 0;		// clear count
    }
    if( pBndlSt->Bndl.ctp.SecsWithNoTxPkts >= CTP_STALL_THRESH ) {
      sprintf(SccBuf,"scc%d",pPortSt->SccNum);
      //--- If Nova system, look for dma in bad mood.
      if( (pSysInfo->SysType == SYS_TYPE_CTP_2000) ||
	  ((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) ) {
	struct acrndrv_command        ncmd;
	ncmd.CmdType = SCC_CMD_TEST_READ_REG;
	ncmd.CmdObj  = NOVA_CARD_FIFO_STAT_RD;
	ncmd.CmdObj2 = 0;
	ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
	if( (ncmd.CmdObj2 == 0x04000000) || (ncmd.CmdObj2 == 0xffffffff)) { //PR772696 - Aricent Fix
	  //--- double check dma state
	  ncmd.CmdObj2 = 0;
	  ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
	  if( (ncmd.CmdObj2 == 0x04000000) || (ncmd.CmdObj2 == 0xffffffff)) { //PR772696 - Aricent Fix
	    PRTP(FAT,Found card with FPGA corrupted or dma state stuck in get_next_fd ... Kicking watchdog...);
	    // Rotate logs twice to get messages onto flash.
	    acorn_system("/usr/sbin/logrotate -f /etc/logrotate.conf");
	    acorn_system("/usr/sbin/logrotate -f /etc/logrotate.conf");
	    sleep(10);	// 10 sec
	    ctp_kick_wdog();
	  }
	}
      }
      pBndlSt->Bndl.ctp.SecsWithNoTxPkts = 0;		// clear count
      Thresh = CTP_STALL_THRESH;
#if 1	// Set to 0 if we don't want to try to fix the problem
      ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      nrc.restart = YES;
      nrc.starve_flag = NO;
      ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      PRTDVP(MIN,Restarting port... Stalled secs for Tx:,Thresh);
#else
      PRTDVP(MIN,Stalled secs for Tx:,Thresh);
#endif
    }
  }
  return (0);
}


//--------------------------------------------------------------------------
// This routine processes PBS port monitoring this is called every second
//--------------------------------------------------------------------------
int ctp_proc_pbs_mon( int Card, int pNum )
{
  char				 SccBuf[40],PrtBuf[150], CmdStr[150];
  struct acrndrv_buf_stats	 ebuf;
  u32				 status;
  CTP_PORT_STATE		*pPortSt     = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE		*pPortIntSt  = &Ctp.Card[Card].PortInt[pNum];
  CTP_PORT_CNTRS		*pPortCnt    = &Ctp.Card[Card].Cntr[pNum];
  int 				 Port = Card*pSysInfo->Card[Card].PortsOnCard + pNum;     // Still port centric
  FUNC_PRT(ctp_proc_pbs_mon, PF_PSTAT, pNum);

  //--- copy current stats to previous stats
  bcopy(  &pPortCnt->Current, &pPortCnt->Previous,
      sizeof(struct acrndrv_runtime_stats) );

  //--- get new stats
  // Still need to check as to whether ioctl was able to access buffer
  // stats within the driver or if it couldn't b/c users flag was lit.
  sprintf(SccBuf,"scc%d", pPortSt->SccNum);
  pPortCnt->Current.Counters.rx_tokens_per_sec = pSysInfo->pps_per_port;
  status = ioc_priv(SccBuf, SCC_GET_RUNTIME_CNTRS, &pPortCnt->Current.Counters);
  if( PBS(Card,pNum) ) {
    if ( status == SUCCESS ) {
      // Calculate clock status for HDLC link
      if( (Db.Card[Card].Port[pNum].rx_sel == CTP_CLK_SEL_TT) ||
	  (Db.Card[Card].Port[pNum].tx_sel == CTP_CLK_SEL_TT) ) {
	int Freq = pPortSt->LocMeasFreq;
	int Acc  = pPortSt->LocMeasFreqAcc;
	double TtFreq = (double)Freq/((double)Acc*500);
	if( TtFreq < CTP_MIN_PBS_TT_FREQ ) {
	  PRTFVP(GEN,TT in use and too low,TtFreq);
	  pPortIntSt->hdlcstatus.tt_in_use_and_bad = 1;
	} else {
	  PRTFVP(GN3,TT in use and OK,TtFreq);
	  pPortIntSt->hdlcstatus.tt_in_use_and_bad = 0;
	}
      } else {
	PRTP(GN3,TT not in use);
	pPortIntSt->hdlcstatus.tt_in_use_and_bad = 0;	// TT not used
      }
      // tt_in_use_and_bad was included in the hdlcstatus stucture so that
      // it could be passed to the driver. The driver doesn't use it
      // anymore, but I left it in the struct. Luckily, it does not get
      // overwritten during this next IOCTL call, so we can still use it.
      status = ioc_priv(SccBuf, SCC_GET_HDLC_STATUS, &pPortIntSt->hdlcstatus);
      ctp_proc_hdlc_crypto(Card, pNum);

      // Handle egress congestion when packets can't go out (when port is
      // configured with Tx clock = TT and TT is not there. This is unique
      // to the L2 bridging function, since it does not go through the
      // stack "normally". So we need to make sure that we detect this
      // condition and handle it properly, so that we do not gum up the
      // egress network queues.
      {
	int tt_bad = pPortIntSt->hdlcstatus.tt_in_use_and_bad;
	int send_tx_pkts = pPortIntSt->hdlcstatus.RcvNrzPkts;

	if( tt_bad ) {
	  if( send_tx_pkts ) {
	    int	status;
	    PRTP(MIN,HDLC TT clock too slow);
	    // This function call does much more (clocks, etc..), which is
	    // inportant. Just ifconfig down/up the network device will
	    // wipe out the clock configuration
	    ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	    status = ctp_cfg_port(Card, pNum, CTP_PORT_CMD_UP);
	    if( status) {
	      PRTP(MAJ,Problem with driver UP);
	      ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	    }
	  }
	  // This will cause Tx packets to get dropped as they arrive at
	  // the device driver.
	  ctp_cfg_port( Card, pNum, CTP_PORT_CMD_BLOCK_TX_PKTS );

	} else {
	  if( !send_tx_pkts ) { PRTP(MIN,HDLC TT good or not needed - UNBLK); }
	  ctp_cfg_port( Card, pNum, CTP_PORT_CMD_UNBLOCK_TX_PKTS );
	}
      }
    } else { return (1); }
  }  
  return 0;  
}    
//--------------------------------------------------------------------------
// This routine processes ALL buffer monitoring.
// It is run once per timer tick (default - second)
// It is the main routine that gathers data from the scc interface
// It processes the long term buffer statistics
// It processes adaptive statistics & state.
//--------------------------------------------------------------------------
int ctp_proc_buff_mon( int bNum )
{
  char				 SccBuf[40],PrtBuf[150], CmdStr[150];
  struct acrndrv_buf_stats	 ebuf;
  u32				 status;
  int 	Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
  int 	pNum = util_bndl_src_pNum(0, &Db.Bndl[bNum]);
  int   bType = Db.Bndl[bNum].Type;
  CTP_PORT_STATE		*pPortSt     = &Ctp.Card[Card].Port[pNum];
  CTP_BNDL_STATE		*pBndlSt     = &Ctp.Bndl[bNum];
  CTP_PORT_INT_STATE		*pPortIntSt  = &Ctp.Card[Card].PortInt[pNum];
  CtpBndlCntrs			*pBndlCnt    = &Ctp.Bndl_cnt[bNum].Bndl.ctp;
  CTP_PORT_CNTRS		*pPortCnt    = &Ctp.Card[Card].Cntr[pNum];
  int                            num;// Aricent PR 1356307 fix
  FUNC_PRT(ctp_proc_buff_mon, PF_PSTAT, bNum);

  //--- copy current stats to previous stats
  bcopy(  &pBndlCnt->Current, &pBndlCnt->Previous,
      sizeof(struct acrndrv_runtime_stats) );

  //--- get new stats
  // Still need to check as to whether ioctl was able to access buffer
  // stats within the driver or if it couldn't b/c users flag was lit.
  // Aricent PR-947222 Start
  if( bType == CTP_BNDL_TYPE_WP ){
   sprintf(SccBuf,"cbc%d",Db.Bndl[bNum].Bndl.wp_bndl.cbc_num);
  }
  // Aricent PR-947222 End 
  else sprintf(SccBuf,"scc%d", pPortSt->SccNum);
  pBndlCnt->Current.Counters.rx_tokens_per_sec = pSysInfo->pps_per_port;
  status = ioc_priv(SccBuf, SCC_GET_RUNTIME_CNTRS, &pBndlCnt->Current.Counters);
  //Start: - Aricent PR 611514 - SAToP unidirectional ports not supported in menu and CTPView
  if( !PBS(Card,pNum) ) {
  //End: - Aricent PR 611514 - SAToP unidirectional ports not supported in menu and CTPView
    PRT(DBG,CTP processing circuit emulation port);
    status += ioc_priv(SccBuf, SCC_QRY_RST_BUF_STATS, &ebuf);
   //Aricent PR 1407824 start
#ifndef WRL
    if( status == SUCCESS ) {
#else
    if( status == SUCCESS && (ebuf.Samples != 0) ) {
#endif
   //Aricent PR 1407824 end
      int strv_cnt = pBndlCnt->Current.Counters.starve_cnt -
	pBndlSt->Bndl.ctp.last_starve_cnt;
      u32 missing_cnt, late_cnt, trapSent = 0;	
      //--- Look to see if we had any starvations since last time through....
      if( strv_cnt > 0 ) {
	sprintf(PrtBuf,"Had %d starvation(s).\n", strv_cnt );
	R_PRTSP(EVE,,PrtBuf);
	// Aricent PR 1356307 fix - Start
        num = trap_number("TRAP_PT_STARVE");
         if (trap_bitmap & (1 << (num - 1))){
	   trap_bNum = bNum; //PR-1878575
           ctp_send_trap(Card, pNum,TRAP_PT_STARVE,pBndlCnt->Current.Counters.starve_cnt);
         }
        // Aricent PR 1356307 fix - End
	trapSent++;
      }
      pBndlSt->Bndl.ctp.last_starve_cnt = pBndlCnt->Current.Counters.starve_cnt;
      //--- Convert buffer levels to ticks of 32MHz clk & save in Current
  sprintf(PrtBuf,"Bundle %d Smallest %d Largest %d Avg %d cntr ticks\n", bNum,
      ebuf.Smallest, ebuf.Largest, ebuf.Avg);
  PRTS(GEN,,PrtBuf);

  // This is useful for under/overflow debugging
#if 0
  {
    int exp_cnts_per_pkt = 
      pPortIntSt->CntrRatio * pBndlCnt->Current.Counters.tx_pkt_size * 8;
    PRTDV(TMP,Expected Free counter cnts per pkt, exp_cnts_per_pkt );
  }
#endif
      
      ctp_proc_curstats(ebuf, bNum);
      if(!trapSent) {
        if(pBndlSt->Bndl.ctp.MissPktsForTrap) {
	  missing_cnt = pBndlCnt->Current.Buffer.missing_pkts - 
	    pBndlCnt->Previous.Buffer.missing_pkts;
	  if(missing_cnt >= pBndlSt->Bndl.ctp.MissPktsForTrap ) {
            sprintf(PrtBuf,"Had %d missing packet(s).\n", missing_cnt );
	    R_PRTSP(EVE,,PrtBuf);
	    // Aricent PR 1356307 fix - Start
            num = trap_number("TRAP_PT_MISSING");
            if (trap_bitmap & (1 << (num - 1))){
              ctp_send_trap(Card, pNum,TRAP_PT_MISSING,missing_cnt);
            }
            // Aricent PR 1356307 fix - End
	    trapSent++;
	  }
        }
      }	
      if(!trapSent) {
        if(pBndlSt->Bndl.ctp.LatePktsForTrap) {
	  late_cnt = pBndlCnt->Current.Buffer.late_pkts - 
	    pBndlCnt->Previous.Buffer.late_pkts;
	  if(late_cnt >= pBndlSt->Bndl.ctp.LatePktsForTrap ) {
            sprintf(PrtBuf,"Had %d late packet(s).\n", late_cnt );
	    R_PRTSP(EVE,,PrtBuf);
	    // Aricent PR 1356307 fix - Start
            num = trap_number("TRAP_PT_LATE");
            if (trap_bitmap & (1 << (num - 1))){
              ctp_send_trap(Card, pNum,TRAP_PT_LATE,late_cnt);
            }
            // Aricent PR 1356307 fix - End
	    trapSent++;
	  }
        }
      }	
      //--- Look for overflow / underflow conditions
      if ( ctp_proc_over_underflow( bNum ) ) { return (1); }      
      //--- Always process stats for long_bufmon
      // Aricent PR 1378149 fix - Start
#ifdef RUNNING_BNDL_STATS
      if((bType == CTP_BNDL_TYPE_WP && pBndlSt->State == CTP_PORT_STATE_RUNNING) ||
        ((bType == CTP_BNDL_TYPE_CTP || bType == CTP_BNDL_TYPE_SO) && 
        pPortSt->State == CTP_PORT_STATE_RUNNING)) {
#endif
        ctp_proc_long_bufmon( bNum );
        //--- Is adaptive turned on?? If so, process stats for adapt_bufmon
        if( (Db.Card[Card].Port[pNum].dds_src == CTP_DDS_SRC_ADAPTIVE) ||
	  (Db.Card[Card].Port[pNum].dds_src == CTP_DDS_SRC_AUTOBAUD) ) {
          if((bType == CTP_BNDL_TYPE_CTP) ||
	   (bType == CTP_BNDL_TYPE_SO) ||
	   ((bType == CTP_BNDL_TYPE_WP) && (Db.Bndl[bNum].Bndl.wp_bndl.adpMaster || 
            IS_SER(Card)))) {  // Aricent PR 880784 fix
	    // 	   
	    ctp_proc_adap_bufmon(bNum);
	    if(!VOICE(Card)) //Aricent PR-947222
	      ctp_proc_adap_state(Card, pNum);
	  }  
        }
#ifdef RUNNING_BNDL_STATS
      }
#endif
      // Aricent PR 1378149 fix - End
      ctp_proc_stalled_tx( bNum );
#ifndef WRL
    } else { PRTB(MIN, Failed to reset);return (1); }
#else
    // Aricent PR 1399028 Start
    } else if (ebuf.Samples != 0) { 
      PRTB(MIN, Failed to reset);
      return (1); 
    } else {
      ctp_proc_curstats(ebuf, bNum);
    }
    // Aricent PR 1399028 End
#endif

    // Process crypto resync output based on remote port T1 flags (if enabled)
    {
      u32	CardCrypto, pNumCrypto, EnableCrypto, FracFlags;
      u16	port_t1e1_crypto = Db.Card[Card].Port[pNum].port_t1e1_crypto;
      int	port_t1e1_lof_ib;	// T1E1 LOF Interface-Bound
      struct acrndrv_runtime_cntrs	*pCurr = &Ctp.Card[Card].Cntr[pNum].Current.Counters;
      getMaskVal(&port_t1e1_crypto,16,0x8000,&EnableCrypto);
      if( EnableCrypto ) {
	getMaskVal(&port_t1e1_crypto,16,0x00ff,&pNumCrypto);
	getMaskVal(&port_t1e1_crypto,16,0x7f00,&CardCrypto);
	FracFlags = Ctp.Card[CardCrypto].PortInt[pNumCrypto].FracFlags;
	port_t1e1_lof_ib = FracFlags & CTP_FT1_FLAG_LOF_IB;
#ifdef DBG_CRYPTO
  //char				 SccBuf[40],PrtBuf[150], CmdStr[150];
	PRTP(MIN,Processing remote T1E1 port resync status);
	sprintf(PrtBuf,"te-%d/%d FracFlags: 0x%x\n",CardCrypto,pNumCrypto,FracFlags);
	PRTSP(MIN,,PrtBuf);
#endif
	if(port_t1e1_lof_ib) {	
	  pCurr->scc_sync = 0;
#ifdef DBG_CRYPTO
	  PRTP(MIN,circuit emulation port crypto resync status bad);
#endif
	} else { 			
	  pCurr->scc_sync = 1;
#ifdef DBG_CRYPTO
	  PRTP(MIN,circuit emulation port crypto resync status good);
#endif
	}
	ctp_proc_hdlc_crypto(Card, pNum);
      }
    }
  }
  return (0);
}

//--------------------------------------------------------------------------
// This routine converts the buffer stats from cntr ticks (units used by
// acorn_drv) to ticks of 32MHz clk.
//--------------------------------------------------------------------------
int ctp_proc_curstats( struct acrndrv_buf_stats BuffStats, int bNum )
{
  u32 	temp;
  struct acrndrv_buffer_stats	*CurrentBuf = &Ctp.Bndl_cnt[bNum].Bndl.ctp.Current.Buffer;
  int Card = util_bndl_src_card(0,&Db.Bndl[bNum]);
  int pNum = util_bndl_src_pNum(0,&Db.Bndl[bNum]);
  char	PrtBuf[140];
  FUNC_PRT(ctp_proc_curstats, PF_PSTAT, bNum);

  //--- Convert buffer levels of interest to 32MHz ticks, include offset
  temp = (u32)(BuffStats.Smallest + BuffStats.ActualStartDel);
  CurrentBuf->Smallest = cntr_to_ticks(temp, Card, pNum);
  CurrentBuf->SmallestPktNum = BuffStats.SmallestPktNum;

  temp = (u32)(BuffStats.Largest + BuffStats.ActualStartDel);
  CurrentBuf->Largest = cntr_to_ticks(temp, Card, pNum);
  CurrentBuf->LargestPktNum = BuffStats.LargestPktNum;
  CurrentBuf->LargestNum = BuffStats.LargestNum;

  temp = (u32)(BuffStats.NLargest + BuffStats.ActualStartDel);
  CurrentBuf->NLargest = cntr_to_ticks(temp, Card, pNum);
  CurrentBuf->NLargestPktNum = BuffStats.NLargestPktNum;

  temp = (u32)(BuffStats.NNLargest + BuffStats.ActualStartDel);
  CurrentBuf->NNLargest = cntr_to_ticks(temp, Card, pNum);
  CurrentBuf->NNLargestPktNum = BuffStats.NNLargestPktNum;

  temp = (u32)(BuffStats.Avg + BuffStats.ActualStartDel);
  CurrentBuf->Avg = cntr_to_ticks(temp, Card, pNum);

#if 0	// It was decided that starvations were a better one than this
  if( BuffStats.restart_cnt > CurrentBuf->restart_cnt ) {
    ctp_send_trap(Card, pNum,TRAP_PT_RSTRT,BuffStats.restart_cnt);
  }
#endif

  CurrentBuf->Samples = BuffStats.Samples;
  CurrentBuf->late_pkts = BuffStats.late_pkts;
  CurrentBuf->missing_pkts = BuffStats.missing_pkts;
  CurrentBuf->restart_cnt = BuffStats.restart_cnt;
  CurrentBuf->restart_flag = BuffStats.restart_flag;
  //sprintf(PrtBuf,"Port %d Smallest %d Largest %d Avg %d ticks\n", Port,
  //    Ctp.Card[Card].Cntr[pNum].Current.Buffer.Smallest,
  //    Ctp.Card[Card].Cntr[pNum].Current.Buffer.Largest,
  //    Ctp.Card[Card].Cntr[pNum].Current.Buffer.Avg);
  //PRTS(EVE,,PrtBuf);

  CurrentBuf->LastTxBb = BuffStats.LastTxBb;
  CurrentBuf->LastDirtyTxBb = BuffStats.LastDirtyTxBb;
  CurrentBuf->BufJif	    = BuffStats.BufJif;
  CurrentBuf->RemPktSize    = BuffStats.RemPktSize;

  return(0);
}

//--------------------------------------------------------------------------
// This routine processes the background long term buffer monitoring
// functions of the serial driver.
//--------------------------------------------------------------------------
void ctp_proc_bndl_buf( int bNum )
{
  char				 Buf[40], YBuf[40];
  FILE				*pBufFile;
  u32				 status, temp;
  struct tm			*pTimeStruct;
  struct stat			 FileStat, YFileStat;
  char                   	 CmdStr[80];
  time_t			 CTime, Time;
  int				 Hour, Min, Sec, SecsToday, EpochSec, EpochDay;
  char				 TodayPingPongChar;
  char				 YesterdayPingPongChar;
  int				 FlagAddDateStamp = 0;
  CTP_BNDL_STATE		*pBndlSt  = &Ctp.Bndl[bNum];
  struct statvfs 		 buffer;
  int            		 rtn_stat;
  FUNC_PRT(ctp_proc_bndl_buf, PF_PSTAT, bNum);
  
  pBndlSt->BufStatsExecCntr--;
  if( pBndlSt->BufStatsExecCntr <= 0 ) {
    //----- Reload Execution counter
    pBndlSt->BufStatsExecCntr = CTP_STATS_PER;
    PRTDVB(GN2,Reload exec counter,pBndlSt->BufStatsExecCntr);
    //----- Get Current Date/Time
    Time = time(NULL);
    pTimeStruct = localtime((time_t *)&Time);
    Hour = pTimeStruct->tm_hour;
    Min = pTimeStruct->tm_min;
    Sec = pTimeStruct->tm_sec;
    SecsToday = Sec + (Min * 60) + (Hour * 3600);
    EpochSec = Time - SecsToday;
    EpochDay = EpochSec/(24 * 3600);
#ifdef DBG_NET_STATS
    PRTDVB(OFF,Hour,Hour);
    PRTDVB(OFF,Min,Min);
    PRTDVB(OFF,Sec,Sec);
    PRTDVB(OFF,SecsToday,SecsToday);
    PRTDVB(OFF,EpochSec,EpochSec);
    PRTDVB(OFF,EpochDay,EpochDay);
#endif
    if( EpochDay & 1 )	{
      TodayPingPongChar = 'b';
      YesterdayPingPongChar = 'a';
    } else {
      TodayPingPongChar = 'a';
      YesterdayPingPongChar = 'b';
    }
    //--- If after 18:00 UTC, look for yesterdays data file and remove if
    //    it is there.
    if( Hour >= 18 ) {
      //--- Get yesterdays file name ---
      sprintf(YBuf,"%s/%s%d%c",CTP_DIR,CTP_BUF_STATS_FILE,bNum,
	  YesterdayPingPongChar);
      if( stat(YBuf, &YFileStat) != -1 ) {
	sprintf(CmdStr,"/bin/rm -f %s", YBuf);
	PRTSB(DBG,CMD-,CmdStr);
	acorn_system(CmdStr);
	PRTB(DBG,Yesterdays data file removed);
      } else {
	PRTB(DBG,Yesterdays data file missing);
      }
    }

    //--- Get File and Scc names ---
    sprintf(Buf,"%s/%s%d%c",CTP_DIR,CTP_BUF_STATS_FILE,bNum,
	pBndlSt->BufStatsPingPongChar);
    pBufFile = (FILE *)pBndlSt->pBufStatsFile;	// Get file pointer

    //============================================================
    //If starting up, no file is open, so do it now. If no file exists, we
    //should create one. However, if there is an existing file, we should
    //check it's creation date, if created today append to it, otherwise wipe it
    //out and start a new file.
    //============================================================
    if( pBufFile == NULL) {
      //----- Save new ping pong value
      pBndlSt->BufStatsPingPongChar = TodayPingPongChar;
      //----- Create buf stats file name string
      sprintf(Buf,"%s/%s%d%c",CTP_DIR,CTP_BUF_STATS_FILE,bNum,
	  pBndlSt->BufStatsPingPongChar);

      if( stat(Buf, &FileStat) != -1) {
	PRTB(GEN,Got file stat);
      } else {
	PRTB(GEN,Problem getting file stat);
      }
      CTime = FileStat.st_mtime;
#ifdef DBG_NET_STATS
      sprintf(PrtBuf,"Port %d LongBufMon: File last modified %d sec / %d min / %d hours ago SecsToday %d\n",
	  Port, (int)(Time - CTime), (int)((Time-CTime)/60),
	  (int)((Time-CTime)/3600), SecsToday);
      PRTSB(EVE,,PrtBuf);
#endif
      pBufFile = fopen(Buf,"r");
      //----- Check for existing file. If exists, append to it
      if( pBufFile != NULL ) {	// File exists
	//--- Get creation time
        #ifdef WRL
	fstat((unsigned long)pBufFile, &FileStat);
        #else
	fstat((int)pBufFile, &FileStat);
        #endif
	CTime = FileStat.st_mtime;
#ifdef DBG_NET_STATS
	sprintf(PrtBuf,"LongBufMon: File last modified %d sec / %d min / %d hours ago SecsToday %d\n",
	    (int)(Time - CTime), (int)((Time-CTime)/60),
	    (int)((Time-CTime)/3600), SecsToday);
	PRTSB(EVE,,PrtBuf);
#endif
	if( (Time - CTime ) <  SecsToday ) {
	  //----- Now, open it for appending
	  if( fclose(pBufFile) == 0 ) {
	    pBufFile = fopen(Buf,"a");
	    if( pBufFile != NULL ) {
	      PRTSB(GEN,Reopening stats file,Buf);
	      pBndlSt->pBufStatsFile = (FILE *)pBufFile;
	      FlagAddDateStamp = 1;	//TODO: Figure out when this can be left out.
	    } else { PRTB(MIN,Error reopening stats file); }
	  } else { PRTB(MIN,Error closing stats file); }
	}
	//----- File exists, but is old, create new one
	else {
	  //----- Now, open it for appending
	  if( fclose(pBufFile) == 0 ) {
	    pBufFile = fopen(Buf,"w");
	    if( pBufFile != NULL ) {
	      PRTSB(EVE,Created stats file,Buf);
	      pBndlSt->pBufStatsFile = (FILE *)pBufFile;
	      FlagAddDateStamp = 1;
	    } else { PRTB(MIN,Error opening stats file); }
	  } else { PRTB(MIN,Error closing stats file); }
	}
      }
      //----- File Doesn't exist, so create new one
      else {
	pBufFile = fopen(Buf,"w");
	if( pBufFile != NULL ) {
	  PRTSB(EVE,Created stats file,Buf);
	  pBndlSt->pBufStatsFile = (FILE *)pBufFile;
	  FlagAddDateStamp = 1;
	} else { PRTB(MIN,Error opening stats file); }
      }
    }
    //============================================================
    // File is already open
    //============================================================
    else {
      //----- Should we ping pong to a new one?
      if( pBndlSt->BufStatsPingPongChar != TodayPingPongChar ) {
	pBndlSt->BufStatsPingPongChar = TodayPingPongChar;
	//PRTCP(OFF,Ponging to,pBndlSt->BufStatsPingPongChar);
	//----- Create new file name string
	sprintf(Buf,"%s/%s%d%c",CTP_DIR,CTP_BUF_STATS_FILE,bNum,
	    pBndlSt->BufStatsPingPongChar);
	//----- Close Old file
	if( fclose(pBufFile) != 0 ) { PRTB(MIN,Error closing capture file); }
	//----- Open New file
	pBufFile = fopen(Buf,"w");
	if( pBufFile != NULL ) {
	  PRTSB(EVE,Created stats file,Buf);
	  pBndlSt->pBufStatsFile = (FILE *)pBufFile;
	  FlagAddDateStamp = 1;
	} else { PRTB(MIN,Error opening stats file); }
      }
    }
    
    //============================================================
    // Check to see if there is still room to write to filesystem
    //============================================================
    if( pSysInfo->LongBufCntr == 0 ) {
      rtn_stat = statvfs(Buf, &buffer);
      if( (pSysInfo->LongBuffEnable) &&
	  (buffer.f_bfree < CTP_REQ_FREE_BLOCKS) ) {
	//----- Not enought free space available in /acorn/log
	pSysInfo->LongBuffEnable=0;	// Turn OFF write enable
	PRTDVB(MIN,Disabling long_bufmon writes- blocks free, buffer.f_bfree);
      } else if( (!pSysInfo->LongBuffEnable) &&
	  (buffer.f_bfree > 4*CTP_REQ_FREE_BLOCKS) ) {
	pSysInfo->LongBuffEnable=1;
	PRTDVB(MIN,Enabling long_bufmon writes- blocks free, buffer.f_bfree);
      }
      pSysInfo->LongBufCntr++;
    } else if ( pSysInfo->LongBufCntr >= CTP_LONG_BUF_PERIOD )  {
        //----- Process next time through
	pSysInfo->LongBufCntr = 0;
    } else {
	pSysInfo->LongBufCntr++;
    }

    //============================================================
    // If we have an open file to write to - Save stats sample to file
    //============================================================
    if( (pBufFile != NULL) && (pSysInfo->LongBuffEnable) ) {
        //----- File is open, there is anough room, so add to it
        ces_buf_stats tx_buf;
        const u32 tmpzero=0;
	//----- If flag is set, Add Date/Format header to file. There is an open file.
	if( FlagAddDateStamp ) {
	  //PRTP(OFF,Adding Date Stamp);
	  temp = CTP_BUF_FORMAT;
	  status = fwrite((u32 *)&temp,4,1,pBufFile);
	  temp = CTP_BUF_STATS_VERSION;
	  status += fwrite((u32 *)&temp,4,1,pBufFile);
	  temp = CTP_BUF_DATESTAMP;
	  status += fwrite((u32 *)&temp,4,1,pBufFile);
	  temp =	(   pTimeStruct->tm_mday & 0xff) |
	    ( ( ( pTimeStruct->tm_mon+1) << 8 ) & 0xff00 ) |
	    ( ( ( pTimeStruct->tm_year+1900) << 16 ) & 0xffff0000);
	  status += fwrite((u32 *)&temp,4,1,pBufFile);
	  if( status != 4) { PRTB(MIN,Error writing header to buf_stats file); }
	}

	//----- put Time stamp in file
	temp = CTP_BUF_STAT_SAMPLE;	// timestamp/stats data code
	status = fwrite((u32 *)&temp,4,1,pBufFile);
	if( status != 1) { PRTB(MIN,Error writing TS code to file); }
	temp =	(   pTimeStruct->tm_sec & 0xff) |
	  ( ( pTimeStruct->tm_min << 8 ) & 0xff00 ) |
	  ( ( pTimeStruct->tm_hour << 16 ) & 0xff0000 );
	status = fwrite((u32 *)&temp,4,1,pBufFile);
	if( status != 1) { PRTB(MIN,Error writing TS to file); }
	switch(pBndlSt->Type) 
	{
          case CTP_BNDL_TYPE_WP:
	    winFlowBufsGet(bNum, &tx_buf);
	    break;
          case CTP_BNDL_TYPE_VC:
            ctp_get_dsp_buffer_stats(bNum, &tx_buf);
            break;
          default:
	    PRTB(MIN,Not supported Bundle type!);
            break;
	}

	bcopy(&tx_buf,&Ctp.Bndl_cnt[bNum].Bndl.ces.buffer_last_min,sizeof(ces_buf_stats)); //copying 1 min buffer in Buffer_last_min
	if(tx_buf.num_samples > 0) tx_buf.total_buff /= tx_buf.num_samples;
	tx_buf.min_buff *= pBndlSt->TicksPerPkt;
	tx_buf.max_buff *= pBndlSt->TicksPerPkt;
	tx_buf.total_buff *= pBndlSt->TicksPerPkt;
	//----- Add Smallest/Largest/Avg/NumSamples/late/missing/restarts/...
        
	status = fwrite((u32 *)&tx_buf.min_buff,4,1,pBufFile);
	status += fwrite((u32 *)&tx_buf.max_buff,4,1,pBufFile);
	status += fwrite((u32 *)&tx_buf.total_buff,4,1,pBufFile);
	status += fwrite((u32 *)&tx_buf.num_samples,4,1,pBufFile);
	status += fwrite((u32 *)&tx_buf.late_pkts,4,1,pBufFile);
	status += fwrite((u32 *)&tx_buf.missing_pkts,4,1,pBufFile);
	
	// waste of space here
	status += fwrite((u32 *)&tmpzero,4,1,pBufFile);
	//----- Add next & nextnext largest distinct buff measurement (version 3)
	status += fwrite((u32 *)&tmpzero,4,1,pBufFile);
	status += fwrite((u32 *)&tmpzero,4,1,pBufFile);
	//----- Max/Min/Sum/Num network delays (in usec) (version 4)
	status += fwrite((u32 *)&tmpzero,4,1,pBufFile);
	status += fwrite((u32 *)&tmpzero,4,1,pBufFile);
	status += fwrite((u32 *)&tmpzero,4,1,pBufFile);
	status += fwrite((u32 *)&tmpzero,2,1,pBufFile);
	//----- Number of Out Of Sequence Packets (version 4)
	status += fwrite((u32 *)&tmpzero,2,1,pBufFile);
	
	//----- add Remote IP address (version 4)
	if(pBndlSt->RemAdCid.Node.Type == CTP_IPV6) { //PR 1544672 fix start
          temp = CTP_IPV6;
          status += fwrite((u32 *)&temp,4,1,pBufFile);
          status += fwrite((struct in6_addr *)&pBndlSt->RemAdCid.Node.v6,16,1,pBufFile);
        }else {
          temp = CTP_IPV4;
          status += fwrite((u32 *)&temp,4,1,pBufFile);
	  status += fwrite((u32 *)&pBndlSt->RemAdCid.Node.v4,4,1,pBufFile);
        }
	if( status != 16) { //PR 1544672 fix end
	  PRTDVB(MIN,Error writing buf stats to file,status);
	} 
	else 
	{
          sprintf(CmdStr, "%x, %x, %x, %x, %x, %x\n", tx_buf.min_buff, 
            tx_buf.max_buff, tx_buf.total_buff, tx_buf.num_samples,tx_buf.late_pkts,
            tx_buf.missing_pkts);
          PRTSB(GEN, , CmdStr);
	}
    }
  }
}
//--------------------------------------------------------------------------
// This routine processes the background long term buffer monitoring
// functions of the serial driver.
//--------------------------------------------------------------------------
void ctp_proc_long_bufmon( int bNum )
{
  char				 Buf[40], YBuf[40];
  int	Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
  int	pNum = util_bndl_src_pNum(0, &Db.Bndl[bNum]);
  FILE				*pBufFile;
  u32				 status, temp;
  struct tm			*pTimeStruct;
  struct stat			 FileStat, YFileStat;
  char                   	 CmdStr[80];
  time_t			 CTime, Time;
  int				 Hour, Min, Sec, SecsToday, EpochSec, EpochDay;
  char				 TodayPingPongChar;
  char				 YesterdayPingPongChar;
  int				 FlagAddDateStamp = 0;
  //char				 PrtBuf[150];
  CTP_PORT_INT_STATE		*pPortIntSt  = &Ctp.Card[Card].PortInt[pNum];
  CtpBndlCntrs			*pBndlCnt    = &Ctp.Bndl_cnt[bNum].Bndl.ctp;
  struct acrndrv_buffer_stats	*CurrentBuf  = &pBndlCnt->Current.Buffer;
  struct acrndrv_buffer_stats	*PreviousBuf = &pBndlCnt->Previous.Buffer;
  struct acrndrv_buffer_stats	*LongBuf     = &pBndlCnt->LongBufMon.Buffer;
  CTP_BNDL_STATE		*pBndlSt     = &Ctp.Bndl[bNum];
  CTP_BNDL_DBASE		*pDbB 	     = &Db.Bndl[bNum];
  double			 long_part, curr_part;
  u32				 total_samples;
  struct statvfs 		 buffer;
  int            		 rtn_stat;
  FUNC_PRT(ctp_proc_long_bufmon, PF_PSTAT, bNum);

  //--- Copy runtime counters
  bcopy(  &pBndlCnt->Current.Counters,
      &pBndlCnt->LongBufMon.Counters,
      sizeof(struct acrndrv_runtime_cntrs) );

  if( ( pBndlSt->BufStatsExecCntr == CTP_STATS_PER ) ) {
    //--- First time through, copy long_bufmon runtime stats to LastLong
    bcopy(  &pBndlCnt->LongBufMon,
	&pBndlCnt->LastLong,
	sizeof(struct acrndrv_runtime_stats) );

    //--- First time through, initialize long bufmon stats
    LongBuf->Largest		= CurrentBuf->Largest;
    LongBuf->NLargest		= CurrentBuf->NLargest;
    LongBuf->NNLargest		= CurrentBuf->NNLargest;
    LongBuf->Smallest		= CurrentBuf->Smallest;
    LongBuf->Samples 		= CurrentBuf->Samples;
    LongBuf->Avg		= CurrentBuf->Avg;
#ifdef DBG_NET_STATS
    sprintf(PrtBuf, "Port %d first time through LongBufMon: avg = %5.1f ms, samples %d\n",
      Port, LongBuf->Avg, LongBuf->Samples);
    PRTSP(EVE,,PrtBuf);
#endif
    //--- Always update these with what has accumilated since last update
    LongBuf->late_pkts	  = CurrentBuf->late_pkts - PreviousBuf->late_pkts;
    LongBuf->missing_pkts = CurrentBuf->missing_pkts -PreviousBuf->missing_pkts;
    LongBuf->restart_cnt  = CurrentBuf->restart_cnt - PreviousBuf->restart_cnt;
  } else {
    //--- Sort latest buffer stats with existing long bufmon stats
    if ( CurrentBuf->Largest > LongBuf->Largest) {
      //-- Rotate old values down.
      LongBuf->NNLargest 	= LongBuf->NLargest;
      LongBuf->NLargest 	= LongBuf->Largest;
      LongBuf->Largest  	= CurrentBuf->Largest;
      if ( CurrentBuf->NLargest > LongBuf->NLargest) {
        LongBuf->NNLargest 	= LongBuf->NLargest;
        LongBuf->NLargest  	= CurrentBuf->NLargest;
        if ( CurrentBuf->NNLargest > LongBuf->NNLargest) {
          LongBuf->NNLargest  	= CurrentBuf->NNLargest;
        }
      } else if ( CurrentBuf->NLargest > LongBuf->NNLargest) {
        LongBuf->NNLargest  	= CurrentBuf->NLargest;
      }
    } else if ( CurrentBuf->Largest > LongBuf->NLargest) {
      LongBuf->NNLargest 	= LongBuf->NLargest;
      LongBuf->NLargest  	= CurrentBuf->Largest;
      if ( CurrentBuf->NLargest > LongBuf->NNLargest) {
        LongBuf->NNLargest  	= CurrentBuf->NLargest;
      }
    } else if ( CurrentBuf->Largest > LongBuf->NNLargest) {
      LongBuf->NNLargest  	= CurrentBuf->Largest;
    }
    if ( CurrentBuf->Smallest < LongBuf->Smallest ) {
      LongBuf->Smallest 	= CurrentBuf->Smallest;
    }
    //--- Update the average buffer level
#ifdef DBG_NET_STATS
    sprintf(PrtBuf,"Port %d LongBufMon: old/new samples: %d/%d\n",
	Port, LongBuf->Samples, CurrentBuf->Samples);
    PRTSP(EVE,,PrtBuf);
    sprintf(PrtBuf,"Port %d LongBufMon: old/new avg: %5.1f/%5.1f\n",
	Port, (double)(LongBuf->Avg/CTP_OSC_FREQ),
	(double)(CurrentBuf->Avg/CTP_OSC_FREQ));
    PRTSP(EVE,,PrtBuf);
#endif
    total_samples = LongBuf->Samples + CurrentBuf->Samples;
#ifdef DBG_NET_STATS
    sprintf(PrtBuf, "Port %d LongBufMon: total_samples  %d\n", Port, total_samples);
    PRTSP(EVE,,PrtBuf);
#endif
    if( total_samples != 0 ) {
      long_part = ((double)LongBuf->Samples/(double)total_samples);
#ifdef DBG_NET_STATS
      sprintf(PrtBuf,"Port %d LongBufMon: long fraction %5.1f\n",
      Port, long_part);
      PRTSP(EVE,,PrtBuf);
#endif
      long_part *= (double)LongBuf->Avg;
      curr_part = ((double)CurrentBuf->Samples/(double)total_samples);
#ifdef DBG_NET_STATS
      sprintf(PrtBuf,"Port %d LongBufMon: curr fraction %5.1f\n",
      Port, curr_part);
      PRTSP(EVE,,PrtBuf);
#endif
      curr_part *= (double)CurrentBuf->Avg;
#ifdef DBG_NET_STATS
      sprintf(PrtBuf,"Port %d LongBufMon: long/curr parts %5.1f/%5.1f\n",
	  Port, (double)(long_part/CTP_OSC_FREQ),
	  (double)(long_part/CTP_OSC_FREQ));
      PRTSP(EVE,,PrtBuf);
#endif
      LongBuf->Avg = (u32)(long_part + curr_part);
    }
    //--- Always update these with what has accumilated since last update
    LongBuf->Samples 	  += CurrentBuf->Samples;
#ifdef DBG_NET_STATS
    sprintf(PrtBuf,"Port %d LongBufMon: avg = %5.1f ms, samples %d\n",
	Port, (double)(LongBuf->Avg/CTP_OSC_FREQ), LongBuf->Samples);
    PRTSP(EVE,,PrtBuf);
#endif
    LongBuf->late_pkts	  += CurrentBuf->late_pkts - PreviousBuf->late_pkts;
    LongBuf->missing_pkts += CurrentBuf->missing_pkts-PreviousBuf->missing_pkts;
    LongBuf->restart_cnt  += CurrentBuf->restart_cnt - PreviousBuf->restart_cnt;
  }

  pBndlSt->BufStatsExecCntr--;
  PRTDVB(GN2,Execution counter,pBndlSt->BufStatsExecCntr);
  if( pBndlSt->BufStatsExecCntr <= 0 ) {
    int Port = Card*pSysInfo->Card[Card].PortsOnCard + pNum;     //TODO Still port-centric
    //----- Reload Execution counter
    pBndlSt->BufStatsExecCntr = CTP_STATS_PER;
    PRTDVB(GN2,Reload exec counter,pBndlSt->BufStatsExecCntr);
    //----- Get Current Date/Time
    Time = time(NULL);
    pTimeStruct = localtime((time_t *)&Time);
    Hour = pTimeStruct->tm_hour;
    Min = pTimeStruct->tm_min;
    Sec = pTimeStruct->tm_sec;
    SecsToday = Sec + (Min * 60) + (Hour * 3600);
    EpochSec = Time - SecsToday;
    EpochDay = EpochSec/(24 * 3600);
#ifdef DBG_NET_STATS
    PRTDVB(OFF,Hour,Hour);
    PRTDVB(OFF,Min,Min);
    PRTDVB(OFF,Sec,Sec);
    PRTDVB(OFF,SecsToday,SecsToday);
    PRTDVB(OFF,EpochSec,EpochSec);
    PRTDVB(OFF,EpochDay,EpochDay);
#endif
    if( EpochDay & 1 )	{
      TodayPingPongChar = 'b';
      YesterdayPingPongChar = 'a';
    } else {
      TodayPingPongChar = 'a';
      YesterdayPingPongChar = 'b';
    }
    //--- If after 18:00 UTC, look for yesterdays data file and remove if
    //    it is there.
    if( Hour >= 18 ) {
      //--- Get yesterdays file name ---
      sprintf(YBuf,"%s/%s%d%c",CTP_DIR,CTP_BUF_STATS_FILE,bNum,
	  YesterdayPingPongChar);
      if( stat(YBuf, &YFileStat) != -1 ) {
	sprintf(CmdStr,"/bin/rm -f %s", YBuf);
	PRTSB(DBG,CMD-,CmdStr);
	acorn_system(CmdStr);
	PRTB(DBG,Yesterdays data file removed);
      } else {
	PRTB(DBG,Yesterdays data file missing);
      }
    }

    //--- Get File and Scc names ---
    sprintf(Buf,"%s/%s%d%c",CTP_DIR,CTP_BUF_STATS_FILE,bNum,
	pBndlSt->BufStatsPingPongChar);
    pBufFile = (FILE *)pBndlSt->pBufStatsFile;	// Get file pointer

    //============================================================
    //If starting up, no file is open, so do it now. If no file exists, we
    //should create one. However, if there is an existing file, we should
    //check it's creation date, if created today append to it, otherwise wipe it
    //out and start a new file.
    //============================================================
    if( pBufFile == NULL) {
      //----- Save new ping pong value
      pBndlSt->BufStatsPingPongChar = TodayPingPongChar;
      //----- Create buf stats file name string
      sprintf(Buf,"%s/%s%d%c",CTP_DIR,CTP_BUF_STATS_FILE,bNum,
	  pBndlSt->BufStatsPingPongChar);

      if( stat(Buf, &FileStat) != -1) {
	PRTB(GEN,Got file stat);
      } else {
	PRTB(GEN,Problem getting file stat);
      }
      CTime = FileStat.st_mtime;
#ifdef DBG_NET_STATS
      sprintf(PrtBuf,"LongBufMon: File last modified %d sec / %d min / %d hours ago SecsToday %d\n",
	  (int)(Time - CTime), (int)((Time-CTime)/60),
	  (int)((Time-CTime)/3600), SecsToday);
      PRTSB(EVE,,PrtBuf);
#endif
      pBufFile = fopen(Buf,"r");
      //----- Check for existing file. If exists, append to it
      if( pBufFile != NULL ) {	// File exists
	//--- Get creation time
        #ifdef WRL
	fstat((unsigned long)pBufFile, &FileStat);
        #else
	fstat((int)pBufFile, &FileStat);
        #endif
	CTime = FileStat.st_mtime;
#ifdef DBG_NET_STATS
	sprintf(PrtBuf,"Port %d LongBufMon: File last modified %d sec / %d min / %d hours ago SecsToday %d\n",
	    Port, (int)(Time - CTime), (int)((Time-CTime)/60),
	    (int)((Time-CTime)/3600), SecsToday);
	PRTSB(EVE,,PrtBuf);
#endif
	if( (Time - CTime ) <  SecsToday ) {
	  //----- Now, open it for appending
	  if( fclose(pBufFile) == 0 ) {
	    pBufFile = fopen(Buf,"a");
	    if( pBufFile != NULL ) {
	      PRTSB(EVE,Reopening stats file,Buf);
	      pBndlSt->pBufStatsFile = (FILE *)pBufFile;
	      FlagAddDateStamp = 1;	//TODO: Figure out when this can be left out.
	    } else { PRTB(MIN,Error reopening stats file); }
	  } else { PRTB(MIN,Error closing stats file); }
	}
	//----- File exists, but is old, create new one
	else {
	  //----- Now, open it for appending
	  if( fclose(pBufFile) == 0 ) {
	    pBufFile = fopen(Buf,"w");
	    if( pBufFile != NULL ) {
	      PRTSB(EVE,Created stats file,Buf);
	      pBndlSt->pBufStatsFile = (FILE *)pBufFile;
	      FlagAddDateStamp = 1;
	      chmod(Buf, 0777);  // Set file permissions to 777 - PR 1866138, 1864004, 1886826 fix
	    } else { PRTB(MIN,Error opening stats file); }
	  } else { PRTB(MIN,Error closing stats file); }
	}
      }
      //----- File Doesn't exist, so create new one
      else {
	pBufFile = fopen(Buf,"w");
	if( pBufFile != NULL ) {
	  PRTSB(EVE,Created stats file,Buf);
	  pBndlSt->pBufStatsFile = (FILE *)pBufFile;
	  FlagAddDateStamp = 1;
	  chmod(Buf, 0777);  // Set file permissions to 777 - PR 1866138, 1864004, 1886826 fix
	} else { PRTB(MIN,Error opening stats file); }
      }
    }
    //============================================================
    // File is already open
    //============================================================
    else {
      //----- Should we ping pong to a new one?
      if( pBndlSt->BufStatsPingPongChar != TodayPingPongChar ) {
	pBndlSt->BufStatsPingPongChar = TodayPingPongChar;
	//PRTCP(OFF,Ponging to,pBndlSt->BufStatsPingPongChar);
	//----- Create new file name string
	sprintf(Buf,"%s/%s%d%c",CTP_DIR,CTP_BUF_STATS_FILE,bNum,
	    pBndlSt->BufStatsPingPongChar);
	//----- Close Old file
	if( fclose(pBufFile) != 0 ) { PRTB(MIN,Error closing capture file); }
	//----- Open New file
	pBufFile = fopen(Buf,"w");
	if( pBufFile != NULL ) {
	  PRTSB(EVE,Created stats file,Buf);
	  pBndlSt->pBufStatsFile = (FILE *)pBufFile;
	  FlagAddDateStamp = 1;
	  chmod(Buf, 0777);  // Set file permissions to 777 - PR 1866138, 1864004, 1886826 fix
	} else { PRTB(MIN,Error opening stats file); }
      }
    }


    //============================================================
    // Check to see if there is still room to write to filesystem
    //============================================================
    if( pSysInfo->LongBufCntr == 0 ) {
      // Aricent PR 1343796 fix - Start
#ifdef WRL
      rtn_stat = getfreememory();
      if( (pSysInfo->LongBuffEnable) &&
	  (rtn_stat < CTP_REQ_FREE_BLOCKS) ) {
#else
      rtn_stat = statvfs(Buf, &buffer);
      if( (pSysInfo->LongBuffEnable) &&
	  (buffer.f_bfree < CTP_REQ_FREE_BLOCKS) ) {
#endif
	// Aricent PR 1343796 fix - End
	//----- Not enought free space available in /acorn/log
	pSysInfo->LongBuffEnable=0;	// Turn OFF write enable
	PRTDVB(MIN,Disabling long_bufmon writes- blocks free, buffer.f_bfree);
      } else if( (!pSysInfo->LongBuffEnable) &&
	  (buffer.f_bfree > 4*CTP_REQ_FREE_BLOCKS) ) {
	pSysInfo->LongBuffEnable=1;
	PRTDVB(MIN,Enabling long_bufmon writes- blocks free, buffer.f_bfree);
      }
      pSysInfo->LongBufCntr++;
    } else if ( pSysInfo->LongBufCntr >= CTP_LONG_BUF_PERIOD )  {
        //----- Process next time through
	pSysInfo->LongBufCntr = 0;
    } else {
	pSysInfo->LongBufCntr++;
    }

    //============================================================
    // If we have an open file to write to - Save stats sample to file
    //============================================================
    if( (pBufFile != NULL) && (pSysInfo->LongBuffEnable) ) {
        //----- File is open, there is anough room, so add to it

	//----- If flag is set, Add Date/Format header to file. There is an open file.
	if( FlagAddDateStamp ) {
	  //PRTP(OFF,Adding Date Stamp);
	  temp = CTP_BUF_FORMAT;
	  status = fwrite((u32 *)&temp,4,1,pBufFile);
	  temp = CTP_BUF_STATS_VERSION;
	  status += fwrite((u32 *)&temp,4,1,pBufFile);
	  temp = CTP_BUF_DATESTAMP;
	  status += fwrite((u32 *)&temp,4,1,pBufFile);
	  temp =	(   pTimeStruct->tm_mday & 0xff) |
	    ( ( ( pTimeStruct->tm_mon+1) << 8 ) & 0xff00 ) |
	    ( ( ( pTimeStruct->tm_year+1900) << 16 ) & 0xffff0000);
	  status += fwrite((u32 *)&temp,4,1,pBufFile);
	  if( status != 4) { PRTP(MIN,Error writing header to buf_stats file); }
	}

	//----- put Time stamp in file
	temp = CTP_BUF_STAT_SAMPLE;	// timestamp/stats data code
	status = fwrite((u32 *)&temp,4,1,pBufFile);
	if( status != 1) { PRTP(MIN,Error writing TS code to file); }
	temp =	(   pTimeStruct->tm_sec & 0xff) |
	  ( ( pTimeStruct->tm_min << 8 ) & 0xff00 ) |
	  ( ( pTimeStruct->tm_hour << 16 ) & 0xff0000 );
	status = fwrite((u32 *)&temp,4,1,pBufFile);
	if( status != 1) { PRTP(MIN,Error writing TS to file); }
	//----- Add Smallest/Largest/Avg/NumSamples/late/missing/restarts/...
	status = fwrite((u32 *)&LongBuf->Smallest,4,1,pBufFile);
	status += fwrite((u32 *)&LongBuf->Largest,4,1,pBufFile);
	status += fwrite((u32 *)&LongBuf->Avg,4,1,pBufFile);
	status += fwrite((u32 *)&LongBuf->Samples,4,1,pBufFile);
	status += fwrite((u32 *)&LongBuf->late_pkts,4,1,pBufFile);
	status += fwrite((u32 *)&LongBuf->missing_pkts,4,1,pBufFile);
	status += fwrite((u32 *)&LongBuf->restart_cnt,4,1,pBufFile);
	//----- Add next & nextnext largest distinct buff measurement (version 3)
	status += fwrite((u32 *)&LongBuf->NLargest,4,1,pBufFile);
	status += fwrite((u32 *)&LongBuf->NNLargest,4,1,pBufFile);
	//----- Max/Min/Sum/Num network delays (in usec) (version 4)
	status += fwrite((u32 *)&pPortIntSt->NetDelays.MaxNetDelay,
	    4,1,pBufFile);
	status += fwrite((u32 *)&pPortIntSt->NetDelays.MinNetDelay,
	    4,1,pBufFile);
	status += fwrite((u32 *)&pPortIntSt->NetDelays.SumNetDelay,
	    4,1,pBufFile);
	status += fwrite((u32 *)&pPortIntSt->NetDelays.Num,2,1,pBufFile);
	//----- Number of Out Of Sequence Packets (version 4)
	status += fwrite((u32 *)&pPortIntSt->NetDelays.OOSP,2,1,pBufFile);
	//----- add Remote IP address (version 4)
	if(pDbB->RemAdCid.Node.Type == CTP_IPV6) { //PR 1544672 fix start
          //----- IP type (1 for IPV6)
          temp = CTP_IPV6;    // CAP PR 1716742 fix
          status += fwrite((u32 *)&temp,4,1,pBufFile);
          status += fwrite((struct in6_addr *)&pDbB->RemAdCid.Node.v6,16,1,pBufFile);
        } else {
          //---- IP type (0 for IPV4)
          temp = CTP_IPV4;    // CAP PR 1716742 fix
          status += fwrite((u32 *)&temp,4,1,pBufFile);
	  status += fwrite((u32 *)&pDbB->RemAdCid.Node.v4,4,1,pBufFile);
        }
	if( status != 16) { //PR 1544672 fix end
	  PRTDVB(MIN,Error writing buf stats to file,status);
	} else {
#if 0
	  sprintf(PrtBuf,"Port %d, Wrote net stats: %d %d %d %d",
	    Port, pPortIntSt->NetDelays.MaxNetDelay,
            pPortIntSt->NetDelays.MinNetDelay,
            pPortIntSt->NetDelays.SumNetDelay,
            pPortIntSt->NetDelays.Num);
	  PRTSB(GEN,,PrtBuf);
#endif
#if 0
	  //--- Dump out stats from last minute.....
	  {
	    char PrtBuf[150];
	    double pdv = ((double)(LongBuf->Largest - LongBuf->Smallest))/(double)CTP_OSC_FREQ;
	    sprintf(PrtBuf, "Last LongBufMon: max pdv = %5.3f ms, samples %d\n", pdv, LongBuf->Samples);
	    PRTSP(TMP,,PrtBuf);
	  }
#endif

	  // Now lets clear out the network delay stats
	  pPortIntSt->NetDelays.MaxNetDelay = 0;
	  pPortIntSt->NetDelays.MinNetDelay = 0;
	  pPortIntSt->NetDelays.SumNetDelay = 0;
	  pPortIntSt->NetDelays.Num         = 0;
	  pPortIntSt->NetDelays.OOSP        = 0;
        }
    }
  }
}

//--------------------------------------------------------------------------
// This routine scans the list of configured references and updates the
// structure with the data.
//--------------------------------------------------------------------------
void ctp_proc_ref_check( int Card )
{
  u8		OldRef, NewRef, SelRef;
  u32		Bad, Acc, Freq, Phdet;
  int		GoodRefMeasure = 0;
  int		i, RefFreqIndex, PhdetMeasIndex, Port;
  u32	        Data;
  double	FreqMeas, FreqCfg, FreqDiff, Ppm;
  double	Span = (double)CTP_PHDET_SPAN;
  double	Range = (double)Ctp.Node[Card].VcxoPpmRange;
  double	PpmPer = Range/Span;
  //short		PpmPerShort = (short)(PpmPer * 100000);
  double	VcxoPosPpmSwing, VcxoNegPpmSwing;
  s32		VcxoPosFreqSwing, VcxoNegFreqSwing;
  CTP_PORT_INT_STATE    *pPortIntSt;
  CTP_PORT_DBASE	*pDbP;
  int                    num;// Aricent PR 1356307 fix
  FUNC_PRT(ctp_proc_ref_check, PF_REF, -1);

  Ctp.Node[Card].RefExecCntr--;
  //PRTDVC(OFF,RefExecCntr,Ctp.Node[Card].RefExecCntr);
  if( Ctp.Node[Card].RefExecCntr <= 0 ) {
    PRTDVC(GN3,+++++++++++++++++++++++++++++++++++++++++++ Card, Card);
    Ctp.Node[Card].RefExecCntr = CTP_REF_CHECK_PERIOD;	// reset period counter

    //--- Get reference accuracy check information from FPGA ---
    OldRef = Ctp.Node[Card].RefBeingChecked;
    SelRef = (u8)Ctp.Node[Card].RefInUse;
    //PRTDVC(OFF,Current Reference,OldRef);
    // Here we loop through all the possible reference and find a good 
    // measurement then break out the loop and continue the processing.
    for(i=0;i<CTP_MAX_REFS_PER_NODE;i++) {		     // check all 5
      NewRef = (OldRef + 1 + i) % CTP_MAX_REFS_PER_NODE;     // set to next ref
      //PRTDVC(OFF,new Reference,NewRef);
      // We do not measure references which are not configured for a valid
      // reference source (port or ext).
      if( (Db.Node[Card].ref[NewRef].Port < CTP_MAX_REFS_PER_NODE) ) {
	int TmpInt = (int)NewRef;
	PRTDVC(GN3,Starting measurement on new Reference,TmpInt);
	TmpInt = (int)Db.Node[Card].ref[NewRef].Port;
	PRTDVC(GN3,new Reference clock from input source,TmpInt);
	// Start measurement on new reference
	// Get frequency measurement of old reference
	PRTC(GN3,FPGA: Read Reference Freq from FPGA);
	fpga_clr_fcfg();
	RefFreqIndex = fpga_get_fcfg_cycle();
	fpga_get_port_freq(0xfe);	// 0xfe is special code for node
	PhdetMeasIndex = fpga_get_fcfg_cycle();
	fpga_get_phdet_meas();
	fpga_set_ref_freq_sel(Db.Node[Card].ref[NewRef].Port);
	fpga_restart_ref_freq();
	fpga_send_fcfg(pSysInfo->Card[Card].BaseSccNum);

	Ctp.Node[Card].RefBeingChecked = NewRef;
	fpga_get_port_freq_val(RefFreqIndex,&Freq,&Acc); // chk returned vals
	if( Acc & 0x100 )	Bad = 1;
	else			Bad = 0;
	Acc &= 0xff;		// remove bad bit
	PRTDVC(GN3,Reference Bad val,Bad);
	PRTDVC(GN3,Reference Acc val,Acc);
	PRTDVC(GN3,Reference Freq val,Freq);
#ifndef XMC    
	fpga_get_phdet_meas_val(PhdetMeasIndex, &Phdet);
	// Check if we are operating in a valid VXCO region. The
	// reference may have pulled us slowly to the edges of the
	// frequency range of the VCXO. The checks below will see if this
	// is true and, if so, disqualifies the reference.
	if( ( Phdet < CTP_PHDET_GUARD_BAND ) ||
	    ( Phdet > (CTP_PHDET_SPAN - CTP_PHDET_GUARD_BAND) ) ) {
	  PRTDVC(EVE,VCXO operating outside valid range. PHDET,Phdet);
	  Ctp.Node[Card].VcxoGuardBandViol = YES;
	  // If the VCXO is running outside the normal range, and we are
	  // tracking a reference, this must mean that the reference went
	  // bad. So we should disqualify the reference here.
	  if( SelRef < CTP_MAX_REFS_PER_NODE ) {
	    Ctp.Node[Card].ref[SelRef].valid = NO;	// Disqualify reference
	    Ctp.Node[Card].ref[SelRef].freq_cnt = 0;	// Disqualify reference
	    Ctp.Node[Card].phdet_cnt = 0;	// Out of range, reset holdover
	    PRTDVC(MIN,reference disqualified - VCXO not tracking,SelRef);
	  }
	} else {
#else // XMC
	{
#ifdef NOT_NOW
	  // This bracket is non functional to the code, but balances the
	  // brackets so that the vi C-code functions work properly (eg "%")
	}
#endif
#endif // XMC
	  // If we got here, we measured the VCXO as operating in a valid
	  // region (i.e. not railed at top or bottom )
	  Ctp.Node[Card].VcxoGuardBandViol = NO;
	  //PRTC(DBG,---------------------------------);
#ifndef XMC
	  PRTDVC(GN3,Good Phdet measurement,Phdet);
#endif
	  GoodRefMeasure++;	// good vcxo clk

	  //===== process LOS on T1 interface =====
	  // This has been added since pulling a T1 reference cable is not
	  // enough to declare it bad. This is because the T1 DCARD
	  // generates a 1544 TT clock even when there is no T1 signal on
	  // the cable. This extra piece of code also qualifies a T1
	  // reference with the LOS condition reported by the LIU.
	  // Only process LOS on port reference (not external ref)
	  Port = Db.Node[Card].ref[OldRef].Port;
	  /* set pPortIntSt pointer*/
	  if( Port < (CTP_MAX_REFS_PER_NODE-1)) {
            pPortIntSt = &Ctp.Card[0].PortInt[Port];	// Used below with GoodRefMeasure!!
	  } else pPortIntSt = &Ctp.Card[0].PortInt[CTP_MAX_REFS_PER_NODE-1];
	  
	  if(Port < (CTP_MAX_REFS_PER_NODE-1)) {
            int pNum = Port;
            int Card = 0;
	    pDbP = &Db.Card[Card].Port[pNum];
	    if(IS_T1E1(Card)) {
	      if(pDbP->State != CTP_DBSTATE_UP) {
	        pPortIntSt->T1RefLOS = 1;
	      } else {
	        pPortIntSt->T1RefLOS = (Ctp.Card[Card].Port[pNum].t1State & T1_ALARM_LOS)? 1:0;
	      }
	    } else if( (pDbP->if_mode == IF_MODE_DCARD) &&
	        (pDbP->DcardType == DCARD_T1E1) &&
	        (Dcard.Card[Card].Info[pNum].Present == YES) ) {
	      dcard_t1_get_liu_reg(Card,pNum,0x2a,&Data);
	      pPortIntSt->T1RefLOS = Data & 0x01;
	    } else
	      pPortIntSt->T1RefLOS = 0;

	  } else if( IS_T1E1(Card) && ((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) ){
	    pPortIntSt->T1RefLOS = (ctp_get_ex_ref_los_state( Card ) & T1_ALARM_LOS) ? 1 : 0;
	    PRTDVC(GN2,Ext Ref los indication, pPortIntSt->T1RefLOS);
	  } else {
	    /* external reference not T1E1 on Gluon or Not gluon */      
	    pPortIntSt->T1RefLOS = 0;
	  }
	  if(pPortIntSt->T1RefLOS) {
	    if( Ctp.Node[Card].ref[OldRef].valid == YES ) {
	      PRTU8C(MIN,reference disqualified - LOS , OldRef);
	      // Aricent PR 1356307 fix - Start
              num = trap_number("TRAP_REF_VLD_CHG");
              if (trap_bitmap & (1 << (num - 1))){
                ctp_send_trap(0,OldRef,TRAP_REF_VLD_CHG,0);
              }
              // Aricent PR 1356307 fix - End
	    }
	    Ctp.Node[Card].ref[OldRef].freq_cnt = 0;
	    Ctp.Node[Card].ref[OldRef].valid = NO;
	  }

	  if(SelRef < CTP_MAX_REFS_PER_NODE) {
#ifdef XMC
	    Ctp.Node[Card].phdet_cnt = -1;	// This easily disables holdover for XMC
#endif
	    int TmpInt = (int)Ctp.Node[Card].phdet_cnt;
	    // If we have gotten here, it means that we are using a valid
	    // reference. Here we process holdover samples on the Selected
	    // Reference. If the counter has been reset, a new holdover
	    // sample is store for subsequent comparison.
	    PRTDVC(GN3,phdet_cnt is,TmpInt);
	    if( Ctp.Node[Card].phdet_cnt == 0 ) {
	      int TmpInt = (int)SelRef;
	      Ctp.Node[Card].phdet = Phdet;	// Save first value
	      PRTDVC(GEN,Holdover first value saved for reference,TmpInt);
	      PRTDVC(GEN,Holdover first value saved,Phdet);
	    }
	    // If ref-in-use phdet value is the "same", increment holdover cntr
	    // The criteria is that newer Phdet samples are within +/-4 or
	    // the same as the original saved sample.
	    if( ( (Ctp.Node[Card].phdet > Phdet ) &&
		  (Ctp.Node[Card].phdet - Phdet) <= 4 ) ||
		( (Ctp.Node[Card].phdet < Phdet ) &&
		  (Phdet - Ctp.Node[Card].phdet) <= 4 ) ||
		(Ctp.Node[Card].phdet == Phdet ) ) {
	      int TmpInt;
	      Ctp.Node[Card].phdet_cnt++;
	      TmpInt = (int)Ctp.Node[Card].phdet_cnt;
	      PRTDVC(GN3,Holdover count,TmpInt);
	      // If counter has reached max cnt, save holdover value
	      if( Ctp.Node[Card].phdet_cnt == CTP_MAX_HOLDOVER_CNT ) {
		int TmpInt = (int)Ctp.Node[Card].phdet;
		Ctp.Node[Card].phdet_hold_valid = YES;
		Ctp.Node[Card].phdet_hold = Ctp.Node[Card].phdet;
		PRTDVC(GEN,Reference Holdover value saved,TmpInt);
	      }
	      if( Ctp.Node[Card].phdet_cnt > CTP_MAX_HOLDOVER_CNT ) {
		Ctp.Node[Card].phdet_cnt = CTP_MAX_HOLDOVER_CNT;
	      }
	      // Otherwise, reset counter (new sample saved next time around)
	      // Since the holdover value has changed, we clear the flag so
	      // that indicates that we have a valid holdover value
	    } else {
	      //Ctp.Node[Card].phdet_hold_valid = NO;
	      Ctp.Node[Card].phdet_cnt = 0;
	      //PRTC(GEN,Holdover value change - resetting counter);
	      //PRTDVC(GEN,This was the Saved Value,Ctp.Node[Card].phdet);
	      //PRTDVC(GEN,This was the Current Value, Phdet);
	    }
	  }
	}
	//--- Calculate the range to which the PLL will lock
	//PRTFVC(OFF,PpmPer,PpmPer);
	//PRTDVC(OFF,PpmPerShort,PpmPerShort);
  	VcxoPosFreqSwing = CTP_PHDET_SPAN - CTP_PHDET_GUARD_BAND - Phdet;
#ifdef XMC
  	VcxoPosPpmSwing = (double)9.0;	// ADPPL actual range +/-15ppm
#else
  	VcxoPosPpmSwing = (double)VcxoPosFreqSwing * PpmPer;
	PRTDVC(GN3,VCXO positive freq swing,VcxoPosFreqSwing);
#endif
	PRTFVC(GN3,VCXO positive ppm swing,VcxoPosPpmSwing);
	VcxoNegFreqSwing = 0 - (Phdet - CTP_PHDET_GUARD_BAND);
#ifdef XMC
  	VcxoNegPpmSwing = (double)-9.0;	// ADPPL actual range +/-15ppm
#else
  	VcxoNegPpmSwing = (double)VcxoNegFreqSwing * PpmPer;
	PRTDVC(GN3,VCXO negative freq swing,VcxoNegFreqSwing);
#endif
	PRTFVC(GN3,VCXO negative ppm swing,VcxoNegPpmSwing);
	break; // found a good measurement, bail out
      } else {
	//--- ref not configured, so reset it's state
	Ctp.Node[Card].ref[NewRef].valid = NO;
	Ctp.Node[Card].ref[NewRef].freq_cnt = 0;
      }
    }

    if( GoodRefMeasure ) {
      // If we got here, we know that we have at least one reference
      // configured AND that the VCXO is operating within the acceptable
      // range for the VCXO (Either because it is locked to a good
      // reference, or it is set to a good fixed value) . Otherwise, we
      // want to skip qualifying any of the references. If the SkipRefCheck
      // variable is set, we want to skip over this section this time
      // around because the Freq/Acc values are not good ones (Usually
      // because we have been using the frequency counter for something
      // else.
      //PRTDVC(OFF,--- Values for reference,OldRef);
      if(Bad || ( Ctp.Node[Card].SkipRefCheck > 0) ) {
	if( Ctp.Node[Card].SkipRefCheck > 1 ) {
	  PRTC(GN1,Skipping Reference check this time and all the time);
	} else if( Ctp.Node[Card].SkipRefCheck == 1 ) {
	  // The next time around, the values should be good.
	  PRTC(GN1,Skipping Reference check this one last time);
	  Ctp.Node[Card].SkipRefCheck = NO;
	} else {
	  PRTC(EVE,Ref Freq measurement indicated BAD);
	}
      } else {
	int los = 0;
	//PRTVC(OFF,Measured FreqVal,Freq);
	//PRTVC(OFF,Measured AccVal,Acc);
	FreqMeas = (double)Freq/((double)Acc*500);
	PRTFVC(GN2,Measured Ref Freq,FreqMeas);
	//--- Calculate and save Ppm Measurement
	// Only process LOS on port reference (not external ref)
	/* default frequency configured */
	FreqCfg = (double)(32*(Db.Node[Card].ref[OldRef].Div &
		  CTP_REF_DIV_MASK) );
        /* change frequency configured for T1 (or other non-Nx64) port */
	if( Db.Node[Card].ref[OldRef].Port < CTP_MAX_REFS_PER_NODE ) {
	  if( Db.Node[Card].ref[OldRef].Div & CTP_REF_1544_FLAG ) {
	    FreqCfg = (double)1544.0; // Set the configured frequency to 1544
	    // Check LOS 
	    // Since NOVA system cann't have T1 port as external reference, we need 
	    // to skip that for LOS check
	    // CTP150 T1E1 card will borrow the field in the 5th port 
	    // structure and store the LOS condition.
	    if((Db.Node[Card].ref[OldRef].Port < (CTP_MAX_REFS_PER_NODE-1)) ||
	      (IS_T1E1(Card) && ((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)))){  
	      if(pPortIntSt->T1RefLOS) los = 1;
	    }  
	  }
#ifdef XMC_REF4
	  else if( Db.Node[Card].ref[OldRef].Div & CTP_REF_4_FLAG ) FreqCfg = (double)4.0;
#endif
	  else if( Db.Node[Card].ref[OldRef].Div & CTP_REF_1000_FLAG ) FreqCfg = (double)1000.0;
	  else if( Db.Node[Card].ref[OldRef].Div & CTP_REF_5000_FLAG ) FreqCfg = (double)5000.0;
	  else if( Db.Node[Card].ref[OldRef].Div & CTP_REF_10000_FLAG ) FreqCfg = (double)10000.0;
	  else if ( ( pSysInfo->Clk.need_h110 ) && ( pSysInfo->Clk.clk_rtm_hub_slot >= 0 ) &&
	    ( pSysInfo->Card[Card].ClkRtm == SPOKE_CLK_RTM ) &&
	      ((!IS_T1E1(Card))||(pSysInfo->Clk.first_t1 == Card)) ) {       
	    // When H.110 in use and this slot is a slave slot, it will take clock from 
	    // RTM at frequency of 1.544 Mhz.
	    if(Ctp.Node[0].spoke_rtm_e1_input) FreqCfg = (double)2048.0;
	    else FreqCfg = (double)1544.0;
	  }
	}
	PRTFVC(GN2,Configured Ref Freq,FreqCfg);
	FreqDiff = (FreqMeas - FreqCfg) * 1000;
	PRTFVC(GN3,Ref Freq Difference,FreqDiff);
#ifdef XMC_REF4
	if( Db.Node[Card].ref[OldRef].Div & CTP_REF_4_FLAG ) {
	  Ppm = 0; 
	  PRTFVC(GN3,[Fake] Ref Ppm,Ppm);
	} else {	
#endif
	Ppm = (FreqDiff * 1000) / FreqCfg;
	PRTFVC(GN3,Ref Ppm,Ppm);
#ifdef XMC_REF4
	}
#endif
	Ctp.Node[Card].ref[OldRef].ppm = Ppm;
	Ctp.Node[Card].ref[OldRef].freq_meas = FreqMeas;
	//--- Check to make sure VCXO could lock to this reference
	if( ( ( (Ppm > 0 ) && (Ppm < VcxoPosPpmSwing ) ) ||
	      ( (Ppm < 0 ) && (Ppm > VcxoNegPpmSwing ) ) ||
	      ( Ppm == 0 )
	    ) &&
	    ( !los )
	  ) {
	  int RefCnt;
	  Ctp.Node[Card].ref[OldRef].freq_cnt++;
	  RefCnt = Ctp.Node[Card].ref[OldRef].freq_cnt;
	  PRTDVC(GN2,Measured ref count,RefCnt);
	  // If counter has reached max cnt, declare reference good
	  if( RefCnt >= CTP_MAX_REF_ACC_CNT ) {
	    Ctp.Node[Card].ref[OldRef].freq_cnt = CTP_MAX_REF_ACC_CNT;
	    if( Ctp.Node[Card].ref[OldRef].valid == NO ) {
	      // Aricent PR 1356307 fix - Start
              num = trap_number("TRAP_REF_VLD_CHG");
              if (trap_bitmap & (1 << (num - 1))){
                ctp_send_trap(0,OldRef,TRAP_REF_VLD_CHG,1);
              }
             // Aricent PR 1356307 fix - End
	    }
	    Ctp.Node[Card].ref[OldRef].valid = YES;
	  }
	} else {
	  //--- Check for pll loss of lock...
	  if( Ctp.Node[Card].PllLocked == YES) {
	    PRTC(DBG,Have pll locked but out of range indication);
	  } 
	  if( Ctp.Node[Card].ref[OldRef].valid == YES ) {
	    PRTU8C(MIN,reference disqualified - out of range,OldRef);
	    PRTFVC(GN2,PPM measurement,Ppm);
	    PRTFVC(GN2,Max ppm swing,VcxoPosPpmSwing);
	    PRTFVC(GN2,Measured Ref Freq,FreqMeas);
	    // Aricent PR 1356307 fix - Start
            num = trap_number("TRAP_REF_VLD_CHG");
            if (trap_bitmap & (1 << (num - 1))){
              ctp_send_trap(0,OldRef,TRAP_REF_VLD_CHG,0);
            }
           // Aricent PR 1356307 fix - End
	  }
	  Ctp.Node[Card].ref[OldRef].freq_cnt = 0;
	  Ctp.Node[Card].ref[OldRef].valid = NO;
	}
      }
    }
  }
}

//--------------------------------------------------------------------------
// This routine decides which reference should be used for the PLL. It also
// monitors the PLL lock detector and
//--------------------------------------------------------------------------
void ctp_proc_pll( int Card )
{
  #ifdef WRL
  u32	        PllLoss = 0;
  #else
  unsigned long	PllLoss = 0;
  #endif
  u8		i, NewRef;
  u32		RefDiv;
  u8		FoundGoodRef = NO;
  u8		FoundGoodHoldover = NO;
  u8		ReferenceConfigured = NO;
  u8		CurrentRef = Ctp.Node[Card].ChosenRef;	// Save current chosen ref
  int		CardDiagReadIndex;
  u32           HwDiagStatus;
  int           num;// Aricent PR 1356307 fix
  FUNC_PRT(ctp_proc_pll, PF_REF, -1);

  // Here we choose a reference for the PLL. The decision is really quite
  // simple. The lowest numbered valid reference wins. Barring that, the
  // lowest numbered reference with a valid holdover value is used. Barring
  // that, the VCXO is set to its center value.

  fpga_clr_fcfg();

  // First, Check to see if a reference has been selected at all
  for(i=0;i<CTP_MAX_REFS_PER_NODE;i++) {
    if( Db.Node[Card].ref[i].Port < CTP_REF_DISABLED ) {
      ReferenceConfigured = YES;
      break;
    }
  }
  if( ReferenceConfigured == NO ) {
    //PRT(OFF,Clearing Holdover state);
    Ctp.Node[Card].phdet_hold_valid = NO;
    Ctp.Node[Card].phdet_cnt = 0;
  }

  // First, Check for a valid configured and qualified reference
  for(i=0;i<CTP_MAX_REFS_PER_NODE;i++) {
    if( (Db.Node[Card].ref[i].Port < CTP_MAX_REFS_PER_NODE ) &&
	(Ctp.Node[Card].ref[i].valid == YES) ) {
      Ctp.Node[Card].ChosenRef = NewRef = i;		// Valid ref chosen
      //PRTDVC(OFF,Good ref found, NewRef);
      //PRTDVC(OFF,Good ref found- source, Db.Node[Card].ref[NewRef].Port);
      FoundGoodRef = YES;
      fpga_set_pll_led(PLL_LED_GREEN);
      break;
    }
  }
  // No success... Check for valid holdover value on selected reference
  if( FoundGoodRef == NO ) {
    if( Ctp.Node[Card].phdet_hold_valid == YES ) {
      Ctp.Node[Card].ChosenRef = NewRef = CTP_REF_HOLDOVER;	// Reference holdover chosen
      fpga_set_pll_led(PLL_LED_ORANGE);
      //PRTDVC(OFF,Good holdover found, Ctp.Node[Card].ChosenRef);
      //PRTDVC(OFF,Good holdover found- source, Db.Node[Card].ref[Ctp.Node[Card].ChosenRef].Port);
      FoundGoodHoldover = YES;
    }
  }
  // Bummer... Now we fall back to a preset fixed value.
  if( (FoundGoodRef == NO) && (FoundGoodHoldover == NO) ) {
    if( (Ctp.Node[Card].Calibration & 0x8000) == 0 ) {
      //PRTDV(OFF,Valid calibration value found,Ctp.Node[Card].Calibration);
      Ctp.Node[Card].ChosenRef = NewRef = CTP_REF_FIXED_CALIB;
    } else {
      Ctp.Node[Card].ChosenRef = NewRef = CTP_REF_FIXED_CENTER;
    }
    // Only light PLL
    if( ReferenceConfigured == YES )	fpga_set_pll_led(PLL_LED_RED);
    else				fpga_set_pll_led(PLL_LED_GREEN);
  }
  // If we are changing the ref we are using, we need to clear out
  // the holdover state so that we must reaquire a new holdover value
  // UNLESS the current chosen ref is HOLDOVER...
  if( (NewRef != CurrentRef) && (FoundGoodHoldover == NO) ) {
    PRT(GEN,Clearing Holdover state);
    Ctp.Node[Card].phdet_hold_valid = NO;
    Ctp.Node[Card].phdet_cnt = 0;
  }

  //PRTDV(OFF,NewRef,NewRef);
  //PRTDV(OFF,Ctp.Node[Card].RefInUse,Ctp.Node[Card].RefInUse);
  //--- If new reference chosen, configure reference in H/W ---
  if( NewRef < CTP_MAX_REFS_PER_NODE ) {
    if( NewRef != Ctp.Node[Card].RefInUse ) {
      int TmpInt = (int)NewRef;
      // Aricent PR 1356307 fix - Start
      num = trap_number("TRAP_PLL_REF_CHG");
      if (trap_bitmap & (1 << (num - 1))){
        ctp_send_trap(0,0,TRAP_PLL_REF_CHG,NewRef);
      }
      // Aricent PR 1356307 fix - End
      PRTDVC(GEN,Configuring PLL to use Reference,TmpInt);
      //--- We have selected a new reference, so reset holdover state
      Ctp.Node[Card].SkipRefCheck = 1;		// Ref is usually bad first time
      Ctp.Node[Card].phdet_cnt = 0;
      if( Ctp.Node[Card].RefInUse == CTP_REF_HOLDOVER) {
	PRTC(GEN,Old ref was holdover- do not mark as invalid);
      } else {
	Ctp.Node[Card].phdet_hold_valid = NO;
      }
      Ctp.Node[Card].RefExecCntr = 10;		// Allow 10 sec for PLL lock
    }
    fpga_set_ref_sel(Db.Node[Card].ref[i].Port);	// Set PLL reference source
    fpga_disable_phdet(INACTIVE_H);
#ifdef XMC_REF4
    if( (Db.Node[Card].ref[i].Div & CTP_REF_4_FLAG) == 0 ) {
      fpga_set_ref_bypass(INACTIVE_H);
    }
#else
    fpga_set_ref_bypass(INACTIVE_H);
#endif
#ifdef XMC
      fpga_set_clk_mod_pll_src(CLK_MOO_PLL_SRC_ADPLL);
#endif
    //--- Reference is 1.544, 1M, 5M or 10M

    if( (Db.Node[Card].ref[i].Div & CTP_REF_1544_FLAG ) ||
#ifdef XMC_REF4
	(Db.Node[Card].ref[i].Div & CTP_REF_4_FLAG ) ||
#endif
	(Db.Node[Card].ref[i].Div & CTP_REF_1000_FLAG ) ||
	(Db.Node[Card].ref[i].Div & CTP_REF_5000_FLAG ) ||
	(Db.Node[Card].ref[i].Div & CTP_REF_10000_FLAG ) ) {
      fpga_set_pll_div(1);				// Something benign
      fpga_set_32k_ext_ref(INACTIVE_H);
      if( Db.Node[Card].ref[i].Div & CTP_REF_1544_FLAG ) {
	fpga_set_ref_10_5_1_mhz(REF_10_5_1M_OFF);
	fpga_set_ref_t1(ACTIVE_H);
#ifdef XMC_REF4
      } else if( Db.Node[Card].ref[i].Div & CTP_REF_4_FLAG ) {
	fpga_set_ref_bypass(ACTIVE_H);
#endif
      } else {
	fpga_set_ref_t1(INACTIVE_H);
	if( Db.Node[Card].ref[i].Div & CTP_REF_1000_FLAG ) fpga_set_ref_10_5_1_mhz(REF_1M);
	if( Db.Node[Card].ref[i].Div & CTP_REF_5000_FLAG ) fpga_set_ref_10_5_1_mhz(REF_5M);
	if( Db.Node[Card].ref[i].Div & CTP_REF_10000_FLAG ) fpga_set_ref_10_5_1_mhz(REF_10M);
      }
	//--- Reference is coming from spoke clock RTM
//Aricent PR 1234113 fix - Start
    } else if ( ( pSysInfo->Clk.need_h110 ) &&			// H.110 bus not available
		( pSysInfo->Clk.clk_rtm_hub_slot >= 0 ) &&	// Node Has Hub RTM card
		( pSysInfo->Card[Card].ClkRtm == SPOKE_CLK_RTM ) &&	// Spoke RTM here
		( (!IS_T1E1(Card)) ||				// Serial or first T1E1 
		  (pSysInfo->Clk.first_t1 == Card) 
		  ) 
	      )
    {       
      // When H.110 in use and this slot is a slave slot, it will take clock from 
      // RTM at frequency of 1.544 Mhz. That is, unless it the BITS input is
      // E1, in which case it is 2.048 Mhz (PR-1234113)
	fpga_set_32k_ext_ref(INACTIVE_H);
      if ( Ctp.Node[0].spoke_rtm_e1_input == 0 ) {
	fpga_set_pll_div(1);                              // Something benign
	fpga_set_ref_t1(ACTIVE_H);
      } else {
	fpga_set_pll_div(32);                              // 2048
	fpga_set_ref_t1(INACTIVE_H);
      }
//Aricent PR 1234113 fix - End
	//--- Default: The rest...
    } else {
      fpga_set_ref_t1(INACTIVE_H);
      RefDiv = Db.Node[Card].ref[i].Div & CTP_REF_DIV_MASK;	// Remove flags
      if( RefDiv > 1 ) {
	fpga_set_pll_div(RefDiv >> 1);		// N x 64 KHz reference
	fpga_set_32k_ext_ref(INACTIVE_H);
      } else {					// 32 KHz reference
	fpga_set_pll_div(1);
	fpga_set_32k_ext_ref(ACTIVE_H);
      }
    }
  } else {
    if( NewRef == CTP_REF_HOLDOVER ) {
      if( NewRef != Ctp.Node[Card].RefInUse ) {
	PRTU8C(EVE,Fixing VCXO to h-over val from Ref, Ctp.Node[Card].ChosenRef);
	PRTU16C(EVE,Fixing VCXO to holdover val, Ctp.Node[Card].phdet_hold);
	// Aricent PR 1356307 fix - Start
        num = trap_number("TRAP_PLL_REF_CHG");
        if (trap_bitmap & (1 << (num - 1))){
          ctp_send_trap(0,0,TRAP_PLL_REF_CHG,NewRef);
        }
       // Aricent PR 1356307 fix - End
      }
#ifdef XMC_TODO 
      // Only until we get holdover working
      fpga_set_clk_mod_pll_src(CLK_MOO_PLL_SRC_DCO);
      fpga_set_clk_mod_dco(0x8000);	
#else
      fpga_set_ref_fixed(Ctp.Node[Card].phdet_hold);
      fpga_set_ref_fixed_period(CTP_PHDET_GEN_SPAN);
#endif
    } else if( NewRef == CTP_REF_FIXED_CALIB ) {
      if( NewRef != Ctp.Node[Card].RefInUse ) {
	PRTU16C(EVE,Setting VCXO to Fixed Calib Val,Ctp.Node[Card].Calibration);
	// Aricent PR 1356307 fix - Start
        num = trap_number("TRAP_PLL_REF_CHG");
        if (trap_bitmap & (1 << (num - 1))){
          ctp_send_trap(0,0,TRAP_PLL_REF_CHG,NewRef);
        }
       // Aricent PR 1356307 fix - End
      }
#ifdef XMC
      fpga_set_clk_mod_pll_src(CLK_MOO_PLL_SRC_DCO);
      fpga_set_clk_mod_dco(Ctp.Node[Card].Calibration);	// from EEPROM
#else
      fpga_set_ref_fixed( Ctp.Node[Card].Calibration );	// from EEPROM
      fpga_set_ref_fixed_period(CTP_PHDET_GEN_SPAN);
#endif
    } else if( NewRef == CTP_REF_FIXED_CENTER ) {
      if( NewRef != Ctp.Node[Card].RefInUse ) {
	int TmpInt = CTP_PHDET_SPAN >> 1;
	PRTDVC(EVE,Setting VCXO to Fixed Center Value,TmpInt);
	// Aricent PR 1356307 fix - Start
        num = trap_number("TRAP_PLL_REF_CHG");
        if (trap_bitmap & (1 << (num - 1))){
          ctp_send_trap(0,0,TRAP_PLL_REF_CHG,NewRef);
        }
        // Aricent PR 1356307 fix - End
      }
#ifdef XMC
      fpga_set_clk_mod_pll_src(CLK_MOO_PLL_SRC_DCO);
      fpga_set_clk_mod_dco(0x8000);	// Center Freq
#else
      fpga_set_ref_fixed( CTP_PHDET_SPAN >> 1 );	// set to middle value
      fpga_set_ref_fixed_period(CTP_PHDET_GEN_SPAN);
#endif
    }
#ifndef XMC
    fpga_set_ref_sel(CTP_REF_FIXED);		// Set PLL to use fixed value
    fpga_set_ref_bypass(ACTIVE_H);
    fpga_disable_phdet(ACTIVE_H);
#endif
  }

  Ctp.Node[Card].RefInUse = NewRef;			// Now update node state

  //--- Process PLL Lock detector H/W ---
  CardDiagReadIndex = fpga_get_fcfg_cycle();
  fpga_get_card_diag_read_reg();
  fpga_clear_pll_loss();
  //PRTDVC(OFF,About to run fpgs cmd for scc, pSysInfo->Card[Card].BaseSccNum);
  fpga_send_fcfg(pSysInfo->Card[Card].BaseSccNum);
  //--- Process PLL Lock detector results (if reference is in use)---
  if( Ctp.Node[Card].RefInUse < CTP_MAX_REFS_PER_NODE ) {
    fpga_get_hw_diag_val(CardDiagReadIndex,&HwDiagStatus);
    PRTVC(GN3,Read Card Diag Reg,HwDiagStatus);
#ifdef XMC
    if( HwDiagStatus & HW_DIAG_STATUS_DIGITAL_PLL_LOSS ) { PllLoss++; }
#else
    if( HwDiagStatus & HW_DIAG_STATUS_VCXO_PLL_LOSS ) { PllLoss++; }
#endif
    if( HwDiagStatus & HW_DIAG_STATUS_ALTERA_PLL_LOSS ) { PRTC(MIN, Got Altera PLL lock loss ); }
#if 0
    // TODO - make sure that this code will not cause continuous syslog
    // messages before enabling it (I have nodes in the lab that do this).
    if( HwDiagStatus & HW_DIAG_STATUS_DIGITAL_PLL_LOSS ) { PRTC(MIN, Got Digital PLL lock loss); }
    if( IS_CTP2000 ) {
      if( IS_SER(Card) ) {
	if( (HwDiagStatus & HW_DIAG_STATUS_POWER_GOOD) == 0 ) { 
	  PRTC(MAJ, Got Power bad indication); }
      }
      if( (HwDiagStatus & HW_DIAG_STATUS_TEMP_GOOD) == 0 ) { 
	PRTC(MAJ, Got Critical Temp indication); 
      }
    }
#endif
    /*fpga_get_pll_loss_val(0,&PllLoss);
    PRTDVC(GN3,Got Pll lock loss, PllLoss);*/
    Ctp.Node[Card].PllRuntime++;
    if( PllLoss ) {
      Ctp.Node[Card].PllLossSec++;
      if( Ctp.Node[Card].PllLocked == YES ) {
	PRTC(EVE,PLL lost lock);
	//ctp_send_trap(Card,TRAP_PLL_LCK_CHG,0);
      }
      Ctp.Node[Card].PllLocked = NO;
    } else {
      if( Ctp.Node[Card].PllLocked == NO ) {
	PRTC(EVE,PLL recovered lock);
	//ctp_send_trap(Card,TRAP_PLL_LCK_CHG,1);
      }
      Ctp.Node[Card].PllLocked = YES;
    }
  } else {
    Ctp.Node[Card].PllRuntime++;
    Ctp.Node[Card].PllLocked = NO;		// sometimes get a bogus YES
    Ctp.Node[Card].PllLossSec++;
  }
}

//-------------------------------------------
// We use a counter to determine the buffer level:
// If tx_clk_src = TT, the counter counts TT clock cycles
// If tx_clk_src = DIV, the counter counts the PRE-divided clock
//   ==> We need to know the source dds or 32M?
// if tx_clk_src = DDS, we use the dds clock.
//
// *** This code MUST be kept in sync with menutl_get_port_speed
// (menu_util.c) !!!
//
//-------------------------------------------
void set_nom_ctr_freq(int Card, int pNum)
{
  CTP_PORT_STATE	*pPortSt    = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  CTP_PORT_DBASE	*pDbP= &Db.Card[Card].Port[pNum];
  int                    bNum = util_get_next_bNum(pDbP, -1); //Aricent PR 996104
  u32			 Acc, Freq;
  FUNC_PRT(set_nom_ctr_freq, PF_PST, pNum);

  pPortIntSt->CntrRatio = 1;
  switch (pDbP->tx_sel) {
    //---------------------------------------------
    case CTP_CLK_SEL_DIV:
      //pPortIntSt->CntrSel = CTP_CLK_SEL_DIV;
      //PRTDV(EVE,Setting buf cntr exponent to , pPortIntSt->CntrRatio);
      switch (pDbP->div_src) {
	case CTP_DIV_SRC_OSC:
          pPortIntSt->CntrSel = CTP_FREE_CNT_SEL_SCC_EN;
          PRTP(DBG,Setting free cntr source to SCC clock);
	  pPortIntSt->NomCtrFreq = (double)((2 << 14)/(2 * pDbP->div_val));
	  break;
	case CTP_DIV_SRC_DDS:
	  pPortIntSt->CntrRatio =
	    2 * pDbP->div_val * util_power(10,pDbP->dds_div);
	  pPortIntSt->CntrSel = CTP_FREE_CNT_SEL_DDS_RAW;
	  PRTP(DBG,Setting free cntr source to DDS);
	  pPortIntSt->NomCtrFreq =
	    (double)((double)pDbP->dds_freq/0x20000);
	  break;
	default:
	  PRTP(MAJ,Invalid DIV_SRC);
      }
      break;
    //---------------------------------------------
    case CTP_CLK_SEL_DDS:
      if( pDbP->CfgFlags & CFG_PORT_FLAG_HI_SPD ) {
	pPortIntSt->CntrSel = CTP_FREE_CNT_SEL_SCC_EN;
      } else {
	pPortIntSt->CntrSel = CTP_FREE_CNT_SEL_DDS_RAW;
      }
      switch ( pDbP->dds_src ) {
	case CTP_DDS_SRC_USER:
	case CTP_DDS_SRC_ADAPTIVE:
	  if( pDbP->CfgFlags & CFG_PORT_FLAG_HI_SPD ) {
	    PRTP(DBG,Setting free cntr source to SCC en for high speed);
	  } else {
	    PRTP(DBG,Setting free cntr source to DDS);
	  }
	  pPortIntSt->CntrRatio = util_power(10,pDbP->dds_div);
          //Aricent PR 996104 fix - Start
          if(Db.Card[Card].all_h110_cesop == 1) {
             pPortIntSt->NomCtrFreq = 8192.000000;
          }
          //Aricent PR 996104 fix - End

          else
   	    pPortIntSt->NomCtrFreq =
	       (double)((double)pDbP->dds_freq/0x20000);
	  break;
	case CTP_DDS_SRC_AUTOBAUD:
	  if( pDbP->CfgFlags & CFG_PORT_FLAG_HI_SPD ) {
	    PRTP(DBG,Setting free cntr source to SCC en for high speed);
	  } else {
	    PRTP(DBG,Setting free cntr source to DDS AUTOBAUD);
	  }
	  pPortIntSt->CntrRatio = 1;
	  pPortIntSt->NomCtrFreq =
	    (double)((double)pPortSt->AdapDdsValue/0x20000);
	  break;
	default:
	  PRTP(MAJ,Invalid DDS_SRC);
      }
      break;
    //---------------------------------------------
    case CTP_CLK_SEL_TT:
      if( pDbP->CfgFlags & CFG_PORT_FLAG_HI_SPD ) {
	pPortIntSt->CntrSel = CTP_FREE_CNT_SEL_SCC_EN;
	PRTP(DBG,Setting free cntr source to SCC en for high speed);
      } else {
	pPortIntSt->CntrSel = CTP_FREE_CNT_SEL_TT;
	PRTP(DBG,Setting free cntr source to TT);
      }
      Freq = pPortSt->LocMeasFreq;
      Acc  = pPortSt->LocMeasFreqAcc;
      pPortIntSt->NomCtrFreq = (double)Freq/((double)Acc*500);
      break;
    //---------------------------------------------
    case CTP_CLK_SEL_ST:
      if(pDbP->IfType == IF_TYPE_DCE){
	int temp = (u8)pDbP->tx_sel;
	PRTDVP(MAJ,Invalid TX_SEL for DCE port,temp);
	break;
      }
      if( pDbP->CfgFlags & CFG_PORT_FLAG_HI_SPD ) {
	pPortIntSt->CntrSel = CTP_FREE_CNT_SEL_SCC_EN;
	PRTP(DBG,Setting free cntr source to SCC en for high speed);
      } else {
	pPortIntSt->CntrSel = CTP_FREE_CNT_SEL_ST;
	PRTP(DBG,Setting free cntr source to ST);
      }
      Freq = pPortSt->LocMeasFreq;
      Acc  = pPortSt->LocMeasFreqAcc;
      pPortIntSt->NomCtrFreq = (double)Freq/((double)Acc*500);
      break;
    //---------------------------------------------
    default:
      {
	int temp = (u8)pDbP->tx_sel;
	PRTDVP(MAJ,Invalid TX_SEL,temp);
      }
      break;
  }

#ifdef NOT_NOW
  // PR-1462843
  // Before DIV Clock = sample rate and DDS = 4 or 8 clock multiple (so
  // that we could run the free counter at the bit rate, we now have DDS =
  // sample rate, and DIV is used to generate an ST clock output. So now,
  // due to TRANS/TRANS8 encoding, our cntr ratio will be < 1 (either 1/4
  // or 1/8), which we pass to and handle in the nova driver.
  // In any case, the codee below is no longer needed.
  if( pDbP->IfEncoding == IF_ENC_TRANS ) {
    //--- Look to see if CntrRatio is divisable by 4 log error if it isn't
    if( pPortIntSt->CntrRatio % 4 != 0) {
      PRTP(MAJ,*** Requested encoding of TRANS and CntrRatio not compatable ***);
    } else {
      pPortIntSt->CntrRatio = pPortIntSt->CntrRatio >> 2;
    }
  }
  if( pDbP->IfEncoding == IF_ENC_TRANS8 ) {
    //--- Look to see if CntrRatio is divisable by 8 log error if it isn't
    if( pPortIntSt->CntrRatio % 8 != 0) {
      PRTP(MAJ,*** Requested encoding of TRANS8 and CntrRatio not compatable ***);
    } else {
      pPortIntSt->CntrRatio = pPortIntSt->CntrRatio >> 3;
    }
  }
#endif // NOT_NOW

  PRTDVP(GN3,Just set cntr ratio to ,pPortIntSt->CntrRatio);
  PRTFVP(GN3,Just set nom tx freq,pPortIntSt->NomCtrFreq);
}

//-------------------------------------------
// This routine does check of config  before trying
// to take the port UP. Goes to CFG_FAIL with reason.
//-------------------------------------------
int ctp_chk_port_cfg(int Card, int pNum)
{
  int rtn=0;
  CTP_PORT_DBASE	*pDbP = &Db.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  //Aricent PR 1290128 fix- Start
  int bNum;
  bNum = util_get_next_bNum(pDbP, -1);
  CTP_BNDL_DBASE * pDbB = &Db.Bndl[bNum];
  //Aricent PR 1290128 fix- End
  FUNC_PRT(ctp_chk_port_cfg, PF_PST, pNum);

  if( !rtn ) {				// Only report 1 cfg error
    //--- Check that node supports the IP protocol
    if(pDbB->RemAdCid.Node.Type == CTP_IPV6){ // Aricent PR 1290128 fix
      if( pSysInfo->ipProtocol == 0 ) {	// Box supports IPv4 Only!
	PRTP(MIN,Cannot bring up IPv6 port on IPv4 only system);
	rtn = CTP_PORT_STATE_REASON_PROTOCOL;
      }
    } else {
      if( pSysInfo->ipProtocol == 1 ) {	// Box supports IPv6 Only!
	PRTP(MIN,Cannot bring up IPv4 port on IPv6 only system);
	rtn = CTP_PORT_STATE_REASON_PROTOCOL;
      }
    }
  }

  //----- Fractional T1E1 checks ----------
  if( !(rtn) && (FRAC_T1E1(Card, pNum)) ) {	// Only report 1 cfg error
    int num_ds0 = pDbP->DcardCfg2;
    if( pDbP->DcardCfg1 & T1E1_MSK_E1 ) {
      num_ds0++;
      if( pDbP->DcardCfg1& T1E1_MSK_E1_CAS ) num_ds0++;
    }
    //--- Checks ----
    if( !(pDbP->DcardCfg1 & T1E1_MSK_E1) &&
	(pDbP->DcardCfg1& T1E1_MSK_E1_CAS) ) {
      //--- CAS not allowed with Frac T1!
      rtn = CTP_PORT_STATE_REASON_FT1_CAS;
      PRTP(MIN,CfgFAIL Fractional T1 port cannot have CAS enabled);
    } else if( Db.Bndl[util_get_next_bNum(pDbP,-1)].loc_pkt_size < 32*num_ds0 ) {
      rtn = CTP_PORT_STATE_REASON_FT1E1_PKT;
      PRTP(MIN,CfgFAIL Fractional T1E1 pkt size too small);
    } else if( (num_ds0 == 1) && (pPortIntSt->StartDel < 25) ) {
      rtn = CTP_PORT_STATE_REASON_FT1E1_BUF;
      PRTP(MIN,CfgFAIL Fractional T1E1 buffer too small);
    }
  }
  //----- Trans St check ----------
  if( !(rtn) && 	// Only report 1 cfg error
      ( (pDbP->IfType == IF_ENC_TRANS) || 
	(pDbP->IfType == IF_ENC_TRANS8) ) &&
      (pDbP->CfgFlags & CFG_PORT_FLAG_TRANS_ST_IN) &&
      (pDbP->CfgFlags & CFG_PORT_FLAG_TRANS_ST_OUT) ) {
    rtn = CTP_PORT_STATE_REASON_TRANS_ST;
    PRTP(MIN,CfgFAIL Transparent port with ST configured for both in and out);
  }
  return(rtn);
}


//-------------------------------------------
// This is the port state machine routine, which controls the operation of
// each port on the node. It receives events that help it decide what to do
// with the port. Here is a list of possible significant events:
// CTP_PORT_EVENT_DB_ACTIVE	- Port dbase state set to active
// CTP_PORT_EVENT_DB_DISABLED	- Port dbase state set to disabled
// CTP_PORT_EVENT_TIMER		- Received timer message from timer daemon
// CTP_PORT_EVENT_REM_OAM   	- Rcvd OAM packet from remote port
//-------------------------------------------
#define	PRT_REASON    util_prt_preason(Card,pNum,pPortSt->StReason);
#define	NEW_STATE(A)  pPortSt->State = A; \
		      util_prt_psc(Card,pNum,CurState,pPortSt->State);
int ctp_port_state_machine(int Card, int pNum, int Event, void * ptr)
{
  CTP_PORT_STATE	*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  int 			 Port = Card*pSysInfo->Card[Card].PortsOnCard + pNum;     // TODO Still port-centric
  CTP_PORT_DBASE	*pDbP = &Db.Card[Card].Port[pNum];
  CTP_Q_MSG		*pMsg = (CTP_Q_MSG *)ptr;
#ifdef LINUX64 
  CTP_MSG_REM_OAM	*pMsgOam = (CTP_MSG_REM_OAM *)&((CTP_Q_OAM_MSG *)pMsg)->CtpMsg.msg.RemOam;
#else
  CTP_MSG_REM_OAM	*pMsgOam = (CTP_MSG_REM_OAM *)&pMsg->CtpMsg.msg.RemOam;
#endif
  int			 status;
  int			 Ret;
  char			 CmdStr[140];
  u32			 restart_flag = Ctp.Card[Card].Cntr[pNum].Current.Buffer.restart_flag;
  double		 TtFreq;
  u32			 Acc, Freq;
  int			 CurState = pPortSt->State;
  double                 tmp_speed;
  int                    num;// Aricent PR 1356307 fix
  FUNC_PRT(ctp_port_state_machine, PF_PST, pNum);

  //--- What we have hot swap, do we have to check for change in
  //    availability & transition to NOT_PRSNT??
  //util_prt_pev(Port,Card,pNum,Event,pPortSt->State);
  util_prt_psm(Card,pNum,CurState,Event); // Aricent PR 1202814 fix

  switch(pPortSt->State) {
    //==============================================
    case CTP_PORT_STATE_NOT_CFG: // (DISABLD)
      //-----------------------------
      if( Event == CTP_PORT_EVENT_DB_ACTIVE ) {
	pPortSt->StReason = ctp_chk_port_cfg(Card, pNum);
	if( pPortSt->StReason ) {
	  NEW_STATE(CTP_PORT_STATE_CFG_FAIL);		// ??
	  PRT_REASON;
	//----- pkt mode ---------
	} else if( PBS(Card,pNum) ) {
	  //*** NOTE: CTP_PORT_CMD_CFG_CLKS must be done at proper time and
	  //has been moved to CTP_PORT_CMD_UP for PBS i/f's.
	  set_nom_ctr_freq(Card,pNum);
	  status = ctp_cfg_port(Card, pNum, CTP_PORT_CMD_UP);
	  if( status == SUCCESS ) {
	    PRTP(FNC,State transition from NotCFG to RUNNING for PBS interface);
	    NEW_STATE(CTP_PORT_STATE_RUNNING);
	    // Aricent PR 1356307 fix - Start
            num = trap_number("TRAP_PT_STCHG");
            if (trap_bitmap & (1 << (num - 1))){
              ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_RUNNING);
             }
            // Aricent PR 1356307 fix - End
	  } else if( status == TOO_FAST ) {
	    // No need to CTP_PORT_CMD_DOWN, since no checkout was done
	    NEW_STATE(CTP_PORT_STATE_TOO_FAST);		// 2
	  } else if( status == TOO_SLOW ) {
	    // No need to CTP_PORT_CMD_DOWN, since no checkout was done
	    NEW_STATE(CTP_PORT_STATE_TOO_SLOW);		// 3
	  } else {
	    PRTP(MAJ,Problem with driver start);
	    ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	    NEW_STATE(CTP_PORT_STATE_CFG_FAIL);
	  }
	//----- NON pkt mode (CktEm)---------
	//----- SAToP bundle ---------
	} else if( SAToP(Card,pNum) ) {
	  int SatPort = 8*Card  + pNum;
	  pPortIntSt->RtStaleCnt = 0;			// Clear rt indicator
	  //--- Go right to InSync & wait for driver to go running.
	  PRTP(FNC,CTP processing SAToP port);
	  set_nom_ctr_freq(Card,pNum);
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_CFG_CLKS);
	  usleep(1000);					// Sleep in usec
	  if(pDbP->rx_sel != CTP_CLK_SEL_TT ) {
	    status = ctp_cfg_port(Card, pNum, CTP_PORT_CMD_UP );
	    if( status == SUCCESS ) {
	      usleep(1000);				// Sleep in usec
	      status = ctp_cfg_port(Card, pNum, CTP_PORT_CMD_START);
	      if( status == SUCCESS ) {
		if(IPV6(Card,pNum)) {
		  sprintf(CmdStr,
		  "/sbin/ifconfig scc%d inet6 add ::172.1.%d.100/120",
		  pPortSt->SccNum, SatPort);
		} else {
		  sprintf(CmdStr,
		    "/sbin/ifconfig scc%d 172.0.1.%d pointopoint 172.0.1.%d",
		    pPortSt->SccNum, (SatPort + 120), SatPort);
		}
		Ret = acorn_system(CmdStr);
		PRTP(GEN,Just did ifconfig scc ptp);
		NEW_STATE(CTP_PORT_STATE_IN_SYNC);		// ??
	      } else {
		PRTP(MAJ,Problem with driver start);
		ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
		ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
		NEW_STATE(CTP_PORT_STATE_CFG_FAIL);		// ??
	      }
	    } else {
	      PRTP(DBG,Problem with driver UP);
	      ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	      NEW_STATE(CTP_PORT_STATE_CFG_FAIL);		// ??
	    }
	  } else {
	    NEW_STATE(CTP_PORT_STATE_EVAL);			// ??
	    pPortIntSt->OutSyncCntr = CTP_EVAL_WAIT_CNT;	// Wait for TT
	  }
	//----- CESoPSN bundle ---------
	} else if(ctp_bndl_type_wp(Card, pNum)) {
	/* That's all we need to bring up a winpath port */
	  set_nom_ctr_freq(Card,pNum);
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_CFG_CLKS);
	  usleep(1000);
	  status = ctp_cfg_port(Card, pNum, CTP_PORT_CMD_UP);
	  if( status) {
	    PRTP(MAJ,Problem with driver start);
	    ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	    NEW_STATE(CTP_PORT_STATE_CFG_FAIL);
	  }
	//----- CTP bundle ---------
	} else {
	  PRTP(FNC,CTP processing circuit emulation port);
	  pPortIntSt->RtStaleCnt = 0;			// Clear rt indicator
	  set_nom_ctr_freq(Card,pNum);
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_CFG_CLKS);
	  usleep(1000);
	  if(pPortSt->Diagnostics == NO ) {
	    if(pDbP->rx_sel != CTP_CLK_SEL_TT ) {
	      status = ctp_cfg_port(Card, pNum, CTP_PORT_CMD_UP );
	      if( status == SUCCESS ) {
		NEW_STATE(CTP_PORT_STATE_NO_SYNC);		// 1
		pPortIntSt->InSyncCntr = pPortIntSt->OamInSyncPkts;
	      } else if( pDbP->dds_src == CTP_DDS_SRC_AUTOBAUD ) {
		// TOO_FAST/TOO_SLOW are special, and don't require a DOWN
		if( (status != TOO_FAST) && (status != TOO_SLOW)) {
		  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
		}
		pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
		NEW_STATE(CTP_PORT_STATE_AUTO_WAIT);			// 11
	      } else if( status == TOO_FAST ) {
		// No need to CTP_PORT_CMD_DOWN, since no checkout was done
		NEW_STATE(CTP_PORT_STATE_TOO_FAST);		// 2
	      } else if( status == TOO_SLOW ) {
		// No need to CTP_PORT_CMD_DOWN, since no checkout was done
		NEW_STATE(CTP_PORT_STATE_TOO_SLOW);		// 3
		// Aricent PR 1356307 fix - Start
                num = trap_number("TRAP_PT_STCHG");
                if (trap_bitmap & (1 << (num - 1))){
                  ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_TOO_SLOW);
                }
                // Aricent PR 1356307 fix - End
	      } else {
		PRTP(MAJ,Problem with driver UP);
		ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
		NEW_STATE(CTP_PORT_STATE_CFG_FAIL);		// 4
		pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	      }
	    } else {
	      NEW_STATE(CTP_PORT_STATE_EVAL);			// 5
	      pPortIntSt->OutSyncCntr = CTP_EVAL_WAIT_CNT;	// Wait for TT
	    }
	  } else {
	    //--- Diagnostics mode, go straight to RUNNING state
	    sprintf(CmdStr, "/sbin/ifconfig scc%d 172.0.2.%d pointopoint 172.0.3.%d",
		pPortSt->SccNum, 251, 251);
	    Ret = acorn_system(CmdStr);
	    if( ctp_cfg_port(Card, pNum, CTP_PORT_CMD_UP) == SUCCESS ) {
	      if( ctp_cfg_port(Card, pNum, CTP_PORT_CMD_START) == SUCCESS ) {
		PRTP(EVE, placed in diagnostics mode);
		NEW_STATE(CTP_PORT_STATE_RUNNING);		// 6
		// Aricent PR 1356307 fix - Start
                num = trap_number("TRAP_PT_STCHG");
                if (trap_bitmap & (1 << (num - 1))){
                  ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_RUNNING);
                }
                 // Aricent PR 1356307 fix - End
	      } else {
		PRTP(MAJ,Problem with driver START);
		ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
		NEW_STATE(CTP_PORT_STATE_CFG_FAIL);		// 7
		pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	      }
	    } else {
	      PRTP(MAJ,Problem with driver UP);
	      ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	      NEW_STATE(CTP_PORT_STATE_CFG_FAIL);			// 8
	      pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	    }
	  }
	}
      }
      break;
    //==============================================
    case CTP_PORT_STATE_AUTO_WAIT:
      //-----------------------------
      if( Event == CTP_PORT_EVENT_REM_OAM ) {
	if( pPortIntSt->AutoComplete == YES ) {
	  set_nom_ctr_freq(Card,pNum);
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_CFG_CLKS);
	  status = ctp_cfg_port(Card, pNum, CTP_PORT_CMD_UP );
	  if( status) {
	    PRTP(MAJ,Problem with driver UP);
	    // TOO_FAST/TOO_SLOW are special, and don't require a DOWN
	    if( (status != TOO_FAST) && (status != TOO_SLOW)) {
	      ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	    }
	    NEW_STATE(CTP_PORT_STATE_CFG_FAIL);
	  }
	  pPortIntSt->AutoCompleteFlag = NO;	// clr flag
	  NEW_STATE(CTP_PORT_STATE_NO_SYNC);                    // 37
	}
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_DB_DISABLED ) {
	ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	NEW_STATE(CTP_PORT_STATE_NOT_CFG);			// 38
      }
      break;
    //==============================================
    case CTP_PORT_STATE_TOO_FAST:
      //-----------------------------
      if( (Event == CTP_PORT_EVENT_TIMER ) &&
	  (pPortIntSt->OutSyncCntr <= 0) ) {

        if(pPortIntSt->CheckedOutSpeed == 0) {
          calc_port_speed( Card, pNum, &tmp_speed );
          pPortIntSt->CheckedOutSpeed = tmp_speed;
        }
	//--- If we are tt, send back to eval to re-evaluate
	if(pDbP->rx_sel == CTP_CLK_SEL_TT ) {
	  pPortIntSt->OutSyncCntr = CTP_EVAL_WAIT_CNT;		// Wait for TT
	  NEW_STATE(CTP_PORT_STATE_EVAL);			// 9
	} else if( pDbP->dds_src == CTP_DDS_SRC_AUTOBAUD ) {
	  pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	  NEW_STATE(CTP_PORT_STATE_AUTO_WAIT);			// 11
        } else if((pPortIntSt->CheckedOutSpeed <= pSysInfo->Remn_kbps) && (pPortSt->CheckedOutPps <= pSysInfo->Remn_pps)) { //Aricent PR780649
          if(!(pPortIntSt->CheckedOutSpeed > pSysInfo->Max_kbps)) {
            pPortIntSt->CheckedOutSpeed = (double)0.0;
            if(PBS(Card,pNum)) {
              set_nom_ctr_freq(Card,pNum);
              status = ctp_cfg_port(Card, pNum, CTP_PORT_CMD_UP );
              if( status == SUCCESS ) {
                NEW_STATE(CTP_PORT_STATE_RUNNING);              
                // Aricent PR 1356307 fix - Start
                num = trap_number("TRAP_PT_STCHG");
                if (trap_bitmap & (1 << (num - 1))){
                  ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_RUNNING);
                }
                // Aricent PR 1356307 fix - End
              } else if( status == TOO_FAST ) {
                // No need to CTP_PORT_CMD_DOWN, since no checkout was done
                // State should remain TOO FAST
              } else {
                PRTP(MAJ,Problem with driver start);
                ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
                NEW_STATE(CTP_PORT_STATE_CFG_FAIL);
              }
            } else { 
              status = ctp_cfg_port(Card, pNum, CTP_PORT_CMD_UP );
              if( status == SUCCESS ) {
                NEW_STATE(CTP_PORT_STATE_NO_SYNC);              
                pPortIntSt->InSyncCntr = pPortIntSt->OamInSyncPkts;
              } else if( status == TOO_FAST ) {
                // No need to CTP_PORT_CMD_DOWN, since no checkout was done
                // State should remain TOO FAST
              } else {
                PRTP(MAJ,Problem with driver UP);
                ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
                NEW_STATE(CTP_PORT_STATE_CFG_FAIL);             
                pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
              }
            }
          }
	} else {      //-- Keep looping
	  pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	}
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_DB_DISABLED ) {
	//-- No need to take it down as it never got anywhere during up
	//   And, we don't want to release kbps that we never retrieved from
	//   the aggregate.
	NEW_STATE(CTP_PORT_STATE_NOT_CFG);			// 10
      }
      break;
    //==============================================
    case CTP_PORT_STATE_TOO_SLOW:
      //-----------------------------
      if( (Event == CTP_PORT_EVENT_TIMER ) &&
	  (pPortIntSt->OutSyncCntr <= 0) ) {
	//--- If we are tt, send back to eval to re-evaluate
	if( pDbP->rx_sel == CTP_CLK_SEL_TT ) {
	  pPortIntSt->OutSyncCntr = CTP_EVAL_WAIT_CNT;		// Wait for TT
	  NEW_STATE(CTP_PORT_STATE_EVAL);			// 11
	} else if( pDbP->dds_src == CTP_DDS_SRC_AUTOBAUD ) {
	  pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	  NEW_STATE(CTP_PORT_STATE_AUTO_WAIT);			// 11
	} else {      //-- Keep looping
	  pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	}
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_DB_DISABLED ) {
	//-- No need to take it down as it never got anywhere during up
	//   And, we don't want to release kbps that we never retrieved from
	//   the aggregate.
	NEW_STATE(CTP_PORT_STATE_NOT_CFG);			// 12
      }
      break;
    //==============================================
    case CTP_PORT_STATE_NOT_PRSNT:
      //-----------------------------
      if( (Event == CTP_PORT_EVENT_TIMER) &&
	  (pPortSt->Available) ) {
	NEW_STATE(CTP_PORT_STATE_NOT_PRSNT);			// 13
      }
      break;
    //==============================================
    case CTP_PORT_STATE_NO_SYNC:
      //-----------------------------
	// Aricent PR 1202814 fix - Start
        if( 
	    ( ( Event == CTP_PORT_EVENT_TIMER ) && 
	      ( NO_OAM(Card,pNum) ) 
	    ) ||
	    ( ( Event == CTP_PORT_EVENT_REM_OAM ) && 
	      ( pPortIntSt->InSyncCntr <= 0 ) && 
	      ( !UNI_DIR_SRC(Card,pNum) ) 
	    )
	  ) 
        {
	// Aricent PR 1202814 fix - End
	if(( ctp_check_port_cfg_rates(Card,pNum,(CTP_Q_MSG *)ptr) == SUCCESS )
	  &&(ctp_check_uni_dst(Card, pNum, (CTP_Q_MSG *) ptr) == SUCCESS)) {
	  usleep(1000);					// Sleep in usec
	  if( (pDbP->dds_src == CTP_DDS_SRC_AUTOBAUD) &&
	      ( (pPortIntSt->AutoComplete == NO) ||
		(pPortIntSt->AutoCompleteFlag == YES) ) ) {
	    ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	    NEW_STATE(CTP_PORT_STATE_AUTO_WAIT);		// 39
	  } else {
	    status = ctp_cfg_port(Card, pNum, CTP_PORT_CMD_START);
	    if( status == SUCCESS ) {
	      //--- On transition to IN_SYNC, do ifconfig to establish
	      //    routing for interface
	      if(IPV6(Card,pNum)) {
	        sprintf(CmdStr,
		  "/sbin/ifconfig scc%d inet6 add ::172.0.%d.100/120",
		  pPortSt->SccNum, pPortIntSt->LocAdCid.Cid);
	      } else {
	        sprintf(CmdStr,
		  "/sbin/ifconfig scc%d 172.0.2.%d pointopoint 172.0.3.%d",
		  pPortSt->SccNum, pPortIntSt->LocAdCid.Cid, pPortIntSt->LocAdCid.Cid);
	      }
	      Ret = acorn_system(CmdStr);
	      PRTP(GEN,Just did ifconfig scc ptp);
              if(IS_T1E1(Card) && (pDbP->tx_sel == 0x2) ) {	
      /* To fix problem that when looptimed and loopplug is on the port
         the receive clock is missing. first "train" the clock in the loop
         then take it out when transition from no sync to insync state. This only happen for
         bundle type CTP/SAToP, other bundles may not go through the state machine
         to correct the clock settings later.
      */
                ctp_cfg_port(Card, pNum, CTP_PORT_CMD_CFG_CLKS);      
              }
	      NEW_STATE(CTP_PORT_STATE_IN_SYNC);		// 14
	    } else if( status == BAD_MTU ) {
	      pPortSt->StReason = CTP_PORT_STATE_REASON_MTU;
	      NEW_STATE(CTP_PORT_STATE_MISCFG);			// 16
	      PRT_REASON;
	      pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	    } else {
	      PRTP(MAJ,Problem with driver START);
	      //TODO ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	      ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	      NEW_STATE(CTP_PORT_STATE_CFG_FAIL);		// 15
	      pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	    }
	  }
	} else {
	  pPortSt->StReason = CTP_PORT_STATE_REASON_OAM_CHECK;
	  NEW_STATE(CTP_PORT_STATE_MISCFG);			// 16
	  PRT_REASON;
	  pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	}
      }
      //-----------------------------
      else if(Event == CTP_PORT_EVENT_TIMER) {
	if( ctp_route_chk( Card, pNum ) ) {	// Route changed!
	  PRTP(MIN,Restarting port due to route change);
	  //--- Send port to CFG_FAIL
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	  NEW_STATE(CTP_PORT_STATE_CFG_FAIL);			// 41
	  pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	}
	else if( UNI_DIR_SRC(Card,pNum) ) {
	  //--- Take port directly to RUNNING state
	  if( ctp_cfg_port(Card, pNum, CTP_PORT_CMD_START) == SUCCESS ) {
	    //--- On transition to IN_SYNC, do ifconfig to establish
	    //    routing for interface
	    sprintf(CmdStr,
		"/sbin/ifconfig scc%d 172.0.2.%d pointopoint 172.0.3.%d",
		pPortSt->SccNum, pPortIntSt->LocAdCid.Cid, pPortIntSt->LocAdCid.Cid);
	    Ret = acorn_system(CmdStr);
	    PRTP(GEN,Just did ifconfig scc ptp);
            if(IS_T1E1(Card) && (pDbP->tx_sel == 0x2) ) {	
      /* To fix problem that when looptimed and loopplug is on the port
         the receive clock is missing. first "train" the clock in the loop
         then take it out when transition from no sync to insync state. This only happen for
         bundle type CTP/SAToP, other bundles may not go through the state machine
         to correct the clock settings later.
      */
              ctp_cfg_port(Card, pNum, CTP_PORT_CMD_CFG_CLKS);      
              PRTP(MAJ, "reset clk on T1E1 Card!");
            }
	    // Aricent PR 1324769 fix - Start
	    if(ctp_chk_pp_uni_dir_src(Card,pNum)== FAILURE){
	      PRTP(MAJ, "Packet protector configuration check failed for unidirectional src");
	      ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	      NEW_STATE(CTP_PORT_STATE_MISCFG);
	      pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	    } else {
	      NEW_STATE(CTP_PORT_STATE_RUNNING);                // 14
	      // Aricent PR 1356307 fix - Start
            num = trap_number("TRAP_PT_STCHG");
            if (trap_bitmap & (1 << (num - 1))){
              ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_RUNNING);
             }
             // Aricent PR 1356307 fix - End
	    }
	    // Aricent PR 1324769 fix - End
	  } else {
	    PRTP(MAJ,Problem with driver START);
	    //TODO ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	    ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	    NEW_STATE(CTP_PORT_STATE_CFG_FAIL);		// 15
	    pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	  }
	}
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_DB_DISABLED ) {
	ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	NEW_STATE(CTP_PORT_STATE_NOT_CFG);			// 17
      }
      break;
    //==============================================
    case CTP_PORT_STATE_IN_SYNC:
      //-----------------------------
      if(Event == CTP_PORT_EVENT_TIMER) {
        if( ctp_route_chk( Card, pNum ) ) {	// Route changed! /*PR 1478968 fix*/
	  PRTP(MIN,Restarting port due to route change);
	  //--- Send port to CFG_FAIL
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	  NEW_STATE(CTP_PORT_STATE_CFG_FAIL);			// 41
	  pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	}
	else if( ( (pDbP->rt_sel == CTP_CLK_SEL_TT) ||
	      (pDbP->tx_sel == CTP_CLK_SEL_TT) ||
	      (pDbP->st_sel == CTP_CLK_SEL_TT) ||
	      (pDbP->rf_sel == CTP_CLK_SEL_TT) ||
	      (pDbP->rx_sel == CTP_CLK_SEL_TT) ) &&
	    (ctp_qualify_tt(Card, pNum) == FAILURE) ) {
	  //--- Send port to TT_FAIL
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	  NEW_STATE(CTP_PORT_STATE_TT_FAIL);			// 42
	  pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	}
	//--- Here we check to see if the arp entry was filled correctly
	//    when the port came up. If not, send the state back to
	//    NoSYNC.
	else if( (pPortIntSt->OutSyncCntr <= 0) &&
		(! NO_OAM(Card,pNum) ) &&	// Aricent PR 1202814 fix
	    (!SAToP(Card,pNum) ) ) {
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	  NEW_STATE(CTP_PORT_STATE_NO_SYNC);                    // 18
          // Aricent PR 1356307 fix - Start
          num = trap_number("TRAP_PT_STCHG");
          if (trap_bitmap & (1 << (num - 1))){
            ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_NO_SYNC);
          }
          // Aricent PR 1356307 fix - End	  
	  pPortIntSt->InSyncCntr = pPortIntSt->OamInSyncPkts;
	}
	else {
	  if( FRAC_T1E1(Card, pNum) ) {
	    // Check to see if the SendNrz flag should be unblocked for
	    // Frac T1E1 ports. Proc timer reads & stores the fractional flags
	    // Note: we unblock without regard to whether it is already
	    // unblocked. As long as we are in InSYNC & have frame in net
	    // bound direction we do the read/modify/write ioctls to
	    // unblock.
	    if( !(pPortIntSt->FracFlags & CTP_FT1_FLAG_LOF_NB) ) {
	      ctp_cfg_port(Card, pNum, CTP_PORT_CMD_UNBLOCK_RX_PKTS);
	      PRTP(MIN, Unblocking rx);
              // PR 1309312 - Start
              // Fixing this PR using the available Dallas API
              // leaves all channels idled after config. We need to unidle
              // the channels used in the Fractional T1 bundle, and this
              // seems to be the best place to do it.
              if( IS_CTP_FRAC_T1_WO_FRAME_ON_T1CARD ) {
                char SccBuf[40];
                u32 IdleChannelMask = ((1 << pDbP->DcardCfg2) - 1) & 0xffffffff; ;
                sprintf(SccBuf,"scc%d",pPortSt->SccNum);
                struct acrndrv_command        ncmd;
                //PRT(OFF,PR1309312 - Disable Dallas Idle);
                ncmd.CmdType = SCC_CMD_SET_DALLAS_IDLE;
                ncmd.CmdObj = pNum;
                ncmd.CmdObj2 = IdleChannelMask; // Idle unused channels
                ncmd.CmdObj3 = 0;               // disable idle
                ncmd.CmdObj4 = 1;               // t1 7 port signaling off
                ncmd.CmdObj6 = 0;               // bundle    signaling off
                ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
              }
              // PR 1309312 - End
	    }
	  }
          //Start: - Aricent PR 608223 - SAToP unidirectional ports do not work
          // Take port directly to RUNNING state if the
          // SAToP Unidirectional Source is Enable for the Port
          if ((restart_flag == 0) || ( UNI_DIR_SRC(Card,pNum) ) ) {
          //End: - Aricent PR 608223 - SAToP unidirectional ports do not work
	    if( FRAC_T1E1(Card, pNum) ) {
	      // Transition from InSYNC -> Running for fractional T1E1 ports
	      // requires cleared LOF_NB as well as cleared restart_flag
	      if( !(pPortIntSt->FracFlags & CTP_FT1_FLAG_LOF_NB) ) {
		NEW_STATE(CTP_PORT_STATE_RUNNING);			// 19
                // Aricent PR 1356307 fix - Start
                num = trap_number("TRAP_PT_STCHG");
                if (trap_bitmap & (1 << (num - 1))){
                  ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_RUNNING);
                }
                // Aricent PR 1356307 fix - End		
	      }
	    } else {
	      // All other ports goto RUNNING when restart_flag is clear
	      NEW_STATE(CTP_PORT_STATE_RUNNING);			// 19
	      // Aricent PR 1356307 fix - Start
              num = trap_number("TRAP_PT_STCHG");
                if (trap_bitmap & (1 << (num - 1))){
                  ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_RUNNING);
                }
              // Aricent PR 1356307 fix - End
	    }
	  }
	}
      }
      //-----------------------------
      else if( (Event == CTP_PORT_EVENT_REM_OAM ) &&
	  (ctp_check_port_cfg_rates(Card,pNum,(CTP_Q_MSG *)ptr) != SUCCESS) ) {
	ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	pPortSt->StReason = CTP_PORT_STATE_REASON_OAM_CHECK;
	NEW_STATE(CTP_PORT_STATE_MISCFG);			// 20
	pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_DB_DISABLED ) {
	ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	NEW_STATE(CTP_PORT_STATE_NOT_CFG);			// 21
      }
      break;
    //==============================================
    case CTP_PORT_STATE_EVAL:
      //-----------------------------
      // In this state, we need to make sure that we do not exceed the PPS
      // max for the port. We set a timer to expire after there is sure to
      // be a good measurement of the local TT clock.
      if( SAToP(Card,pNum) ) {
	PRTDVP(GEN,Proc state machine in EVAL for SAToP port with cntr,pPortIntSt->OutSyncCntr);
      }
      if( (Event == CTP_PORT_EVENT_TIMER ) &&
	  (pPortIntSt->OutSyncCntr <= 0) ) {
	if( (pPortSt->LocMeasFreqAcc & 0x100) == 0 ) {
	  Freq = pPortSt->LocMeasFreq;
	  Acc  = pPortSt->LocMeasFreqAcc;
	  TtFreq = (double)Freq/((double)Acc*500);
	  PRTFVP(EVE,TT Frequency meaurement,TtFreq);
	  set_nom_ctr_freq(Card,pNum);	// Set based on TT
	  if( PBS(Card,pNum) ) {
	    PRTP(EVE,CTP processing PBS TT port);
	    NEW_STATE(CTP_PORT_STATE_RUNNING);
	    // Aricent PR 1356307 fix - Start
            num = trap_number("TRAP_PT_STCHG");
            if (trap_bitmap & (1 << (num - 1))){
              ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_RUNNING);
            }
           // Aricent PR 1356307 fix - End
	  }
	  else if( SAToP(Card,pNum) ) {
	    int SatPort = 8*Card  + pNum;
	    //--- Go right to InSync & wait for driver to go running.
	    status = ctp_cfg_port(Card, pNum, CTP_PORT_CMD_UP );
	    if( status == SUCCESS ) {
	      usleep(1000);				// Sleep in usec
	      status = ctp_cfg_port(Card, pNum, CTP_PORT_CMD_START);
	      if( status == SUCCESS ) {
  	        if(IPV6(Card,pNum)) {
	          sprintf(CmdStr,
		    "/sbin/ifconfig scc%d inet6 add ::172.1.%d.100/120",
		    pPortSt->SccNum, SatPort);
	        } else {
		  sprintf(CmdStr,
		      "/sbin/ifconfig scc%d 172.0.1.%d pointopoint 172.0.1.%d",
		      pPortSt->SccNum, (SatPort+120), SatPort);
	        }
		Ret = acorn_system(CmdStr);
		PRTP(GEN,Just did ifconfig scc ptp);
		NEW_STATE(CTP_PORT_STATE_IN_SYNC);		// ??
	      } else {
		PRTP(MAJ,Problem with driver start);
		ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
		ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
		NEW_STATE(CTP_PORT_STATE_CFG_FAIL);		// ??
	      }
	    } else {
	      PRTP(MAJ,Problem with driver UP);
	      ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	      NEW_STATE(CTP_PORT_STATE_CFG_FAIL);		// ??
	    }
	  }
	  //----- NON pkt mode ---------
	  else if( (ctp_qualify_tt(Card, pNum) == SUCCESS) &&
	           (ctp_check_netbound_pps(Card, pNum) == SUCCESS) ) {
	    status = ctp_cfg_port(Card, pNum, CTP_PORT_CMD_UP );
	    if( status == SUCCESS ) {
	      NEW_STATE(CTP_PORT_STATE_NO_SYNC);		// 22
	      pPortIntSt->InSyncCntr = pPortIntSt->OamInSyncPkts;
	    } else if( status == TOO_FAST ) {
	      // No need to CTP_PORT_CMD_DOWN, since no checkout was done
	      pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	      NEW_STATE(CTP_PORT_STATE_TOO_FAST);		// 23
	    } else if( status == TOO_SLOW ) {
	      // No need to CTP_PORT_CMD_DOWN, since no checkout was done
	      pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	      NEW_STATE(CTP_PORT_STATE_TOO_SLOW);		// 24
	      // Aricent PR 1356307 fix - Start
              num = trap_number("TRAP_PT_STCHG");
              if (trap_bitmap & (1 << (num - 1))){
                ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_TOO_SLOW);
              }
              // Aricent PR 1356307 fix - End 
	    } else {
	      PRTP(MAJ,Problem with driver UP);
	      ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	      NEW_STATE(CTP_PORT_STATE_CFG_FAIL);		// 25
	      pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	    }
	  } else {
	    NEW_STATE(CTP_PORT_STATE_TT_FAIL);		// 25
	    pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	  }
	} else {
	  PRTP(EVE,TT Freq measurement is not good yet);
	}
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_DB_DISABLED ) {
	NEW_STATE(CTP_PORT_STATE_NOT_CFG);			// 26
      }
      break;
    //==============================================
    case CTP_PORT_STATE_RUNNING:
      //-----------------------------
      if( Event == CTP_PORT_EVENT_TIMER ) {
	if( ctp_route_chk( Card, pNum ) ) {	// Route changed!
	  PRTP(MIN,Restarting port due to route change);
	  //--- Send port to CFG_FAIL
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	  NEW_STATE(CTP_PORT_STATE_CFG_FAIL);			// 41
	  pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	}
	else if( ( (pDbP->rt_sel == CTP_CLK_SEL_TT) ||
	           (pDbP->tx_sel == CTP_CLK_SEL_TT) ||
	           (pDbP->st_sel == CTP_CLK_SEL_TT) ||
	           (pDbP->rf_sel == CTP_CLK_SEL_TT) ||
	           (pDbP->rx_sel == CTP_CLK_SEL_TT) ) &&
	         (ctp_qualify_tt(Card, pNum) == FAILURE) ) {
	  //--- Send port to TT_FAIL
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	  NEW_STATE(CTP_PORT_STATE_TT_FAIL);			// 41
	  pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	}
	else if( UNI_DIR_SRC(Card,pNum) ) {
	  PRTP(FNC,CTP processing unidirectional port);
	  PRTP(FNC,Hit CTP_PORT_EVENT_TIMER in port state machine for unidirectional port);
	  pPortIntSt->OutSyncCntr = 5;
	}
	else if( SAToP(Card,pNum) ) {
	  PRTP(FNC,Hit CTP_PORT_EVENT_TIMER in port state machine for SAToP port);
	  pPortIntSt->OutSyncCntr = 5;
	  if( restart_flag == 1 ) {
	    // check for restart flag & send to InSYNC if it is lit
	    NEW_STATE(CTP_PORT_STATE_IN_SYNC);			// 28
	    // Aricent PR 1356307 fix - Start
            num = trap_number("TRAP_PT_STCHG");
            if (trap_bitmap & (1 << (num - 1))){
              ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_IN_SYNC);
             }
            // Aricent PR 1356307 fix - End
	  }
	}
	else if( PBS(Card,pNum) ) {
	  PRTP(FNC,CTP processing pkt based serial port);
	  PRTP(EVE,Hit CTP_PORT_EVENT_TIMER in port state machine for pkt based serial interface);
	  pPortIntSt->OutSyncCntr = 5;
	}
	else if( (pPortIntSt->OutSyncCntr <= 0 ) &&
	  ( ! NO_OAM(Card,pNum) )){ // Aricent PR 1202814 fix
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	  NEW_STATE(CTP_PORT_STATE_NO_SYNC);			// 27
	  // Aricent PR 1356307 fix - Start
          num = trap_number("TRAP_PT_STCHG");
          if (trap_bitmap & (1 << (num - 1))){
            ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_NO_SYNC);
          }
          // Aricent PR 1356307 fix - End
	  pPortIntSt->InSyncCntr = pPortIntSt->OamInSyncPkts;
	}
	else if ( restart_flag == 1 ) {
          // check for restart flag & send to InSYNC if it is lit
	  NEW_STATE(CTP_PORT_STATE_IN_SYNC);			// 28
	  // Aricent PR 1356307 fix - Start
          num = trap_number("TRAP_PT_STCHG");
           if (trap_bitmap & (1 << (num - 1))){
             ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_IN_SYNC);
          }
          // Aricent PR 1356307 fix - End
	}
	else if ( (FRAC_T1E1(Card, pNum)) &&
	          (pPortIntSt->FracFlags & CTP_FT1_FLAG_LOF_NB) &&
		  (pPortIntSt->FracFlags & CTP_FT1_FLAG_LOF_NB_LAST) ) {
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_BLOCK_RX_PKTS);
	  PRTP(MIN, Blocking rx);
	  NEW_STATE(CTP_PORT_STATE_IN_SYNC);			//  ???
	}
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_REM_OAM ) {
	if( (pDbP->dds_src == CTP_DDS_SRC_AUTOBAUD) &&
	    ( (pPortIntSt->AutoComplete == NO) ||
	      (pPortIntSt->AutoCompleteFlag == YES) ) ) {
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	  NEW_STATE(CTP_PORT_STATE_AUTO_WAIT);			// 40
	}
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_DB_DISABLED ) {
	//----- pkt mode ---------
	if( PBS(Card,pNum) ) {
	  PRT(FNC,CTP processing PBS port);

	  //--- ifconfig so routing engine gets what it needs
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	  PRTP(EVE,State transition from RUNNING to NotCFG for PBS interface);
	  NEW_STATE(CTP_PORT_STATE_NOT_CFG);		// TODO
	}
	//----- NON pkt mode ---------
	else {
	  PRTP(FNC,CTP processing trans port);
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	  NEW_STATE(CTP_PORT_STATE_NOT_CFG);			// 15
	}
      }
      break;
    //==============================================
    case CTP_PORT_STATE_MISCFG:
      //-----------------------------
//Aricent Fix for PR659222 - Start
      if( (Event == CTP_PORT_EVENT_REM_OAM ) &&
          (ctp_check_port_cfg_rates(Card,pNum,(CTP_Q_MSG *)ptr) != SUCCESS) ) {
          pPortSt->StReason = CTP_PORT_STATE_REASON_OAM_CHECK;
          NEW_STATE(CTP_PORT_STATE_MISCFG);                       // 20
          pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
      }
      else if( ( Event == CTP_PORT_EVENT_TIMER ) &&
//      if( ( Event == CTP_PORT_EVENT_TIMER ) &&
//Aricent Fix for PR659222 - End
	  (pPortIntSt->OutSyncCntr <= 0) ) {
	  pPortSt->StReason = CTP_PORT_STATE_REASON_NONE;
	  NEW_STATE(CTP_PORT_STATE_NO_SYNC);			// 30
	  pPortIntSt->InSyncCntr = pPortIntSt->OamInSyncPkts;
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_DB_DISABLED ) {
	ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
	ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	NEW_STATE(CTP_PORT_STATE_NOT_CFG);			// 31
      }
      break;
    //==============================================
    case CTP_PORT_STATE_CFG_FAIL:
      //-----------------------------
      if( (Event == CTP_PORT_EVENT_TIMER) &&
	  (pPortIntSt->OutSyncCntr <= 0) ) {
	pPortSt->StReason = ctp_chk_port_cfg(Card, pNum);
	if( !pPortSt->StReason ) {
	  set_nom_ctr_freq(Card,pNum);
	  pPortIntSt->RtStaleCnt = 0;
	  ctp_cfg_port(Card, pNum, CTP_PORT_CMD_CFG_CLKS);
	  if(pDbP->rx_sel != CTP_CLK_SEL_TT ) {
	    if( ctp_cfg_port(Card, pNum, CTP_PORT_CMD_UP) == SUCCESS ) {
	      pPortSt->StReason = CTP_PORT_STATE_REASON_NONE;
            // Aricent PR 741454 Start
               pPortSt->StReason = CTP_PORT_STATE_REASON_NONE;
               if( SAToP(Card,pNum) ) {
                   usleep(1000);      // Sleep in usec
                if (ctp_cfg_port(Card, pNum, CTP_PORT_CMD_START) == SUCCESS) {
                     NEW_STATE(CTP_PORT_STATE_IN_SYNC);                 // 32
                }
                else  {
                   PRTP(MAJ,Problem with driver Start);
                   ctp_cfg_port(Card, pNum, CTP_PORT_CMD_STOP);
                   ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
                   pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
                   }
               }
               else {
                 NEW_STATE(CTP_PORT_STATE_NO_SYNC);
                 pPortIntSt->InSyncCntr = pPortIntSt->OamInSyncPkts;
                }
            // Aricent PR 741454 End
	    } else {
	      PRTP(DBG,Problem with driver UP);
	      ctp_cfg_port(Card, pNum, CTP_PORT_CMD_DOWN);
	      pPortIntSt->OutSyncCntr = CTP_FAIL_RETRY_CNT;
	    }
	  } else {
	    pPortSt->StReason = CTP_PORT_STATE_REASON_NONE;
	    NEW_STATE(CTP_PORT_STATE_EVAL);			// 33
	    pPortIntSt->OutSyncCntr = CTP_EVAL_WAIT_CNT;	// Wait for TT
	  }
	} else {
	  PRT_REASON;
	}
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_DB_DISABLED ) {
	pPortSt->StReason = CTP_PORT_STATE_REASON_NONE;
	NEW_STATE(CTP_PORT_STATE_NOT_CFG);			// 34
      }
      break;
    //==============================================
    case CTP_PORT_STATE_TT_FAIL:
      //-----------------------------
      if( (Event == CTP_PORT_EVENT_TIMER) &&
	  (pPortIntSt->OutSyncCntr <= 0) ) {
	NEW_STATE(CTP_PORT_STATE_EVAL);				// 35
	pPortIntSt->OutSyncCntr = CTP_EVAL_WAIT_CNT;	// Wait for TT
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_DB_DISABLED ) {
	NEW_STATE(CTP_PORT_STATE_NOT_CFG);			// 36
      }
      break;
    //==============================================
    default:
      PRTVP(MAJ,Bad State,pPortSt->State);
      NEW_STATE(CTP_PORT_STATE_NOT_CFG);
      break;
  }

  //==============================================
  // We want to allow the port to be looped/BERT'd even if it is not running
  if( Event == CTP_PORT_EVENT_SER_LOOP_CHANGE ) {
    ctp_cfg_port(Card, pNum, CTP_PORT_CMD_PROC_SER_LOOP);
  } else if( Event == CTP_PORT_EVENT_BERT_CHANGE ) {
    ctp_cfg_port(Card, pNum, CTP_PORT_CMD_PROC_BERT);
  }

  if( Event == CTP_PORT_EVENT_TIMER ) {
    // decrement sync loss counter. It triggers events when it reaches 0.
    // Do not let continue it decrementing, however. Freeze it at 0.
    pPortIntSt->OutSyncCntr--;
    if( pPortIntSt->OutSyncCntr < 0 ) pPortIntSt->OutSyncCntr = 0;
    //PRTDVP(OFF,OutSyncCntr,pPortIntSt->OutSyncCntr);
    pPortIntSt->SeqNum++;		// increment sequence in OAM pkt
  } else if ( Event == CTP_PORT_EVENT_REM_OAM ) {
    // If the port is in one of the FAIL or EVAL states, we want to let the
    // counter count down without getting reset by an arriving OAM pkt.
    // Otherwise, the counter will never expire and we will be stuck in
    // this state.
    if( (pPortSt->State != CTP_PORT_STATE_CFG_FAIL) &&
	(pPortSt->State != CTP_PORT_STATE_EVAL) &&
	(pPortSt->State != CTP_PORT_STATE_MISCFG) &&
	(pPortSt->State != CTP_PORT_STATE_TOO_SLOW) &&
	(pPortSt->State != CTP_PORT_STATE_TOO_FAST) &&
	(pPortSt->State != CTP_PORT_STATE_TT_FAIL) ) {
      // reset sync loss counter
      pPortIntSt->OutSyncCntr = pMsgOam->OamSecPerPkt * pPortIntSt->OamOutSyncPkts;
    }
    pPortIntSt->InSyncCntr--;
    if( pPortIntSt->InSyncCntr < 0 ) pPortIntSt->InSyncCntr = 0;
    //PRTDVP(OFF,InSyncCntr,pPortIntSt->InSyncCntr);
  }
  return(SUCCESS);
}

//==================================================================
// This routine copies common entries from a request message to response msg
//==================================================================
void ctp_copy_msg_hdr( CTP_Q_MSG * pMsgRx, CTP_Q_MSG * pMsgTx )
{
  FUNC_PRT(ctp_copy_msg_hdr, PF_IPC, -1);
  pMsgTx->mtype			= pMsgRx->mtype;
  pMsgTx->CtpMsg.MsgType	= pMsgRx->CtpMsg.MsgType;
  pMsgTx->CtpMsg.OrigTask	= pMsgRx->CtpMsg.DestTask;
  pMsgTx->CtpMsg.OrigNode	= pMsgRx->CtpMsg.DestNode; //TODO Don't see how this can work!
  pMsgTx->CtpMsg.OrigTaskQid	= pMsgRx->CtpMsg.DestTaskQid;
  pMsgTx->CtpMsg.DestTask	= pMsgRx->CtpMsg.OrigTask;
  pMsgTx->CtpMsg.DestNode	= pMsgRx->CtpMsg.OrigNode; //TODO Don't see how this can work!
  pMsgTx->CtpMsg.DestTaskQid	= pMsgRx->CtpMsg.OrigTaskQid;
  pMsgTx->CtpMsg.Status		= SUCCESS;
  pMsgTx->CtpMsg.SubType	= RESPONSE;
  pMsgTx->CtpMsg.Ident		= pMsgRx->CtpMsg.Ident;
}

void ctp_cfg_nref(void)
{
  //ctp_get_nrefs_info(); //PR-1874138
  int old_type = pNRefs->Type;
  int i = 0;    /* Aricent PR 1117979, 1133355 Fix */
  int old_state_type = pNRefs->State;    //Aricent PR 1141812 fix
  FUNC_PRT(ctp_cfg_nref, PF_REF, -1);
  
  pNRefs->Type = Db.Node[0].NetRef.Type;
  memcpy(&pNRefs->Node[0],
         &Db.Node[0].NetRef.Node[0],
	 CTP_MAX_NETREF_SLVS*sizeof(CTP_NODE_STORAGE));
  pNRefs->ttl = Db.Node[0].NetRef.ttl;
  pNRefs->tos = Db.Node[0].NetRef.tos;

  //Aricent PR 1141812 fix - Start
  if(pNRefs->Type == CTP_NETREF_TYPE_SLV) {
    pNRefs->NetRef_time_cnt = 0;  /* Aricent PR 1534914 fix*/
    /* Aricent PR 1117979, 1133355 Fix - Start */
    for ( i =0 ; i < CTP_MAX_NETREF_MSTRS ; i++ ) {
/* Aricent PR 1534914 start */
      pNRefs->recv_pkt[i] = 0;
      pNRefs->recv_pkt_flag[i] = 0;
/* Aricent PR 1534914 end */
      if ( Db.Node[0].NetRef.Node[i].v4 != (u32)ntohl(inet_addr("127.0.0.1")) ) {
        pNRefs->AssignedPriority[i] = i+1;
        pNRefs->ActualPriority[i] = i+1;
      } else {
        pNRefs->AssignedPriority[i] = 0;
        pNRefs->ActualPriority[i] = 0;
      }
    }
    /* Aricent PR 1117979, 1133355 Fix - End */
/* Aricent PR 1534914 start */
    struct nref_slave_info nref_data;
    for ( i =0 ; i < CTP_MAX_NETREF_MSTRS ; i++ ) {
      if(pNRefs->AssignedPriority[i] == 1) {
        break;
      }
    }
    if (i < CTP_MAX_NETREF_MSTRS) { // prio 1 is not available
      nref_data.nref_master_prio_one_ip = pNRefs->Node[i].v4;
      nref_data.nref_slave_en = 1;
    }
    else {
      nref_data.nref_master_prio_one_ip = (u32)ntohl(inet_addr("127.0.0.1"));
      nref_data.nref_slave_en = 0;
    }
    ioc_priv("scc0",SCC_CFG_NETREF_SLAVE,&nref_data);
/* Aricent PR 1534914 end */
  }
  //Aricent PR 1141812 fix - End
  //--- Manage state if we are disabling NetRef
  if( (old_type == CTP_NETREF_TYPE_SLV) &&
      (old_type != pNRefs->Type) ) {
/* Aricent PR 1534914 start */
    struct nref_slave_info nref_data;
    nref_data.nref_master_prio_one_ip = (u32)ntohl(inet_addr("127.0.0.1"));
    nref_data.nref_slave_en = 0;
    ioc_priv("scc0",SCC_CFG_NETREF_SLAVE,&nref_data);
/* Aricent PR 1534914 end */
    if( (pNRefs->Type != CTP_NETREF_TYPE_BNDL) &&	// Do not process state if netref is using bundle.....
	(pNRefs->State != CTP_NETREF_STATE_DIS)) {	// Otherwise NetRef state should be disabled.
      switch(pNRefs->State) {
	case CTP_NETREF_STATE_WAIT:
	  PRT(MIN,NetRef state transition: wait -> disabled);
	  break;
	case CTP_NETREF_STATE_AGGR:
	  PRT(MIN,NetRef state transition: aggressive -> disabled);
	  break;
	case CTP_NETREF_STATE_MNTN:
	  PRT(MIN,NetRef state transition: maintain -> disabled);
	  break;
	//Aricent PR 662088 start
	case CTP_NETREF_STATE_STRV:
	  PRT(MIN,NetRef state transition: starvation -> disabled);
	  break;
	//Aricent PR 662088 End
	default:
	  PRT(MIN,NetRef state transition: unknown -> disabled);
	  break;
      }
      ctp_set_led(PLL_LED_RED, 0);
      pNRefs->State = CTP_NETREF_STATE_DIS; 
      ctp_set_pll_fixed( Ctp.Node[0].Calibration, 1);
    }
  }
}
//==================================================================
// This routine processes a Database config message.
//==================================================================
int ctp_proc_msg_db_cfg( CTP_Q_MSG * pMsg )
{
  CTP_Q_MSG		TMsg;
  CTP_NODE_DBASE	*pDbN;
  int 			Card, pNum;
  int			OldDbCsum, NewDbCsum;
  int			Status;
  FUNC_PRT(ctp_proc_msg_db_cfg, PF_IPC, -1);
#ifdef DBG_MSG_QUEUE
  PRT(EVE,CTP processing database cfg message);
#endif
  ctp_copy_msg_hdr( pMsg, &TMsg );	// build header of response message

  switch(pMsg->CtpMsg.MsgType) {
    //-------------------------------------------------------
    case CTPMSGTYPE_DB_CFG_NODE:
      PRT(GEN,Received DB_CFG_NODE msg);
      OldDbCsum = util_csum((char *)&Db.Node[0], sizeof(CTP_NODE_DBASE));
      NewDbCsum = util_csum((char *)&pMsg->CtpMsg.msg.DbN.Db,
        sizeof(CTP_NODE_DBASE));

      pDbN = (CTP_NODE_DBASE *)&pMsg->CtpMsg.msg.DbN.Db;

      //-- If the Database has changed, process the change --
      if(NewDbCsum != OldDbCsum) {
        PRT(GEN, Dbase Changed - Processing);
        bcopy(&pMsg->CtpMsg.msg.DbN.Db,&Db.Node[0],sizeof(CTP_NODE_DBASE));
	ctp_cfg_nref();
        ctp_cfg_node_clks(0, -1);
        //--- Now check database for system specific requirements
        ctp_check_dbase();
      }

      ctp_send_msg( &TMsg );
      break;

    //-------------------------------------------------------
    case CTPMSGTYPE_DB_CFG_PORT:
      Card = pMsg->CtpMsg.msg.DbP.Card;
      pNum = pMsg->CtpMsg.msg.DbP.pNum;
      PRTP(GEN,Received DB_CFG_PORT msg);

      if( Card > CTP_MAX_CARDS ) {
	PRTDVP(MIN,Got CTP_MAX_CARDS < Passed card:,Card);
	pMsg->CtpMsg.Status = FAILURE;
      }
      if( pNum > pSysInfo->Card[Card].PortsOnCard ) {
	PRTDVP(GN1,Got pSysInfo->Card[Card].PortsOnCard < Passed pNum:,pNum);
	pMsg->CtpMsg.Status = FAILURE;
      }
      PRTP(GN2,Sending response msg);
      ctp_send_msg( &TMsg );			// Send response
      ctp_port_cfg(Card, pNum, &pMsg->CtpMsg.msg.DbP.Db);
      break;
    //-------------------------------------------------------
    case CTPMSGTYPE_DB_CFG_BNDL:
      {
//	PRTP(GEN,Received DB_CFG_BNDL msg);
        pMsg->CtpMsg.Status=ctp_bndl_cfg(&pMsg->CtpMsg.msg.DbB);
	ctp_send_msg( &TMsg ); // send response as soon as we got the message
      }
      break;
    //-------------------------------------------------------
    case CTPMSGTYPE_DB_CFG_CARD:
      {
//	PRTP(GEN,Received DB_CFG_CARD msg);
        pMsg->CtpMsg.Status=ctp_card_cfg(&pMsg->CtpMsg.msg.DbC);
	ctp_send_msg( &TMsg ); // send response as soon as we got the message
      }
      break;
    //-------------------------------------------------------
   default:
      PRTV(MIN,Unexpected message type,pMsg->CtpMsg.MsgType);
      TMsg.CtpMsg.Status = FAILURE;
      break;
  }
  return(TMsg.CtpMsg.Status);
}

//==================================================================
// Here we enforce connection rules between port & bundle databases.
// **** Assume that port data base has been configured already.
// Will tweak the
//==================================================================
int ctp_check_bndl_cfg( CTP_BNDL_DBASE * pOldDbB,  int bNum )
{
  CTP_BNDL_DBASE * pNewDbB = &Db.Bndl[bNum];
  CTP_PORT_DBASE * pDbP;
  int i, Card, pNum;
  int msk_indx =  bNum/CTP_BNDL_MASK_SIZE;
  int msk_bit  =  bNum%CTP_BNDL_MASK_SIZE;
  char prtbuf[100];
  int rtn = 1;

  FUNC_PRT(ctp_check_bndl_cfg, PF_BNDL, -1);

  if( (pOldDbB->Type != CTP_BNDL_TYPE_NONE) &&
      (pNewDbB->Type == CTP_BNDL_TYPE_NONE) ) {
    PRTB(GN2,Checking new bundle dbase with type NONE);

    //==> Bundle was configured and is being deleted.

    //--- What port was it connected to?
    Card = util_bndl_src_card(0, pOldDbB);
    pNum = util_bndl_src_pNum(0, pOldDbB);
    pDbP = &Db.Card[Card].Port[pNum];
    //--- When all is said & done....
    //    -> Bundle dbase should get initialized
    util_init_bndl_dbase(pNewDbB, bNum);
    //    -> If port is not in use, port dbase should get initialized
    if( !util_port_is_bndld( pDbP) ) {
      if( IS_T1E1(Card) ) util_init_t1_dbase(pDbP);
      else                util_init_port_dbase(pDbP, CTP_PORT_DBASE_VERSION);
    }
  } else if( (pOldDbB->Type == CTP_BNDL_TYPE_NONE) &&
             (pNewDbB->Type != CTP_BNDL_TYPE_NONE) ) {
    //==> Bundle was not configured, but is now.

    //--- If Winpath, check flowId/srcBundle
    //Aricent PR 947222 fix
    if((pNewDbB->Type == CTP_BNDL_TYPE_WP)&&(!util_chk_cesopsn_bndl(bNum, Db.Bndl, &Db))) { 
      PRTDV(MIN,CTPMSGTYPE_DB_CFG_BNDL problems with flowId for bNum,bNum);
      rtn = 0;
    }
  }

  if( pNewDbB->State == CTP_DBSTATE_UP) {
    PRTB(GN2,Checking new bundle dbase being activated);
    //--- Check that SAToP bundles are attached to a port with
    //    (1) a T1E1 dcard present &
    //    (2) the if mode is configured to use the T1E1 dcard.
    //    Don't conflict with any other port's CID
    if( pNewDbB->Type == CTP_BNDL_TYPE_SO ) {
      int bn;
      Card = util_bndl_src_card( 0, pNewDbB );
      pNum = util_bndl_src_pNum( 0, pNewDbB );
      if( Dcard.Card[Card].Info[pNum].Type != DCARD_T1E1 ) {
	sprintf(prtbuf,"SAToP Bndl cfgd with no T1E1 dcard present. Deleting bundle.\n");
	PRTSB(MIN,,prtbuf);
	util_init_bndl_dbase(pNewDbB, bNum);
	util_init_port_dbase(&Db.Card[Card].Port[pNum], CTP_PORT_DBASE_VERSION);
	rtn = 0;
      } else if( (Db.Card[Card].Port[pNum].if_mode != IF_MODE_DCARD) &&
	  (!Ctp.Card[Card].Port[pNum].Diagnostics) ) {
	sprintf(prtbuf,"SAToP bundle without if port mode set for dcard. Enable dcard.\n");
	PRTSB(MIN,,prtbuf);
	Db.Card[Card].Port[pNum].if_mode |= IF_MODE_DCARD;
      }
      //Aricent PR 1171607 Fix - Start
      if(!(Db.Bndl[bNum].Bndl.so_bndl.CfgFlags & CFG_BNDL_FLAG_TR_GRE)) {
        //--- Scan through looking for other active bundles with matching CID
        for(bn=0; bn<CTP_MAX_BNDLS; bn++) {
          if((bNum != bn) &&
             (Db.Bndl[bn].Type == CTP_BNDL_TYPE_SO) &&
             (!(Db.Bndl[bn].Bndl.so_bndl.CfgFlags & CFG_BNDL_FLAG_TR_GRE)) &&
             (Db.Bndl[bn].State == CTP_DBSTATE_UP) &&
             (Db.Bndl[bn].RemAdCid.Cid == pNewDbB->RemAdCid.Cid) ) {
            sprintf(prtbuf,"Cant have 2 SAToP bndls active with src udp port %d. Disabling bndl.\n",
            pNewDbB->RemAdCid.Cid);
            PRTSB(MIN,,prtbuf);
            Db.Card[Card].Port[pNum].State = CTP_DBSTATE_DOWN;	//TODO port state needed? Can we remove this line? Might be needed by CESoPSN bundle
            pNewDbB->State = CTP_DBSTATE_DOWN;
            rtn = 0;
          }
        }
      }
      //Aricent PR 1171607 Fix - End
      //--- If still up, check that bndl is configured for IPT.
      if( pNewDbB->State == CTP_DBSTATE_UP ) {
	if( !(pNewDbB->Bndl.so_bndl.CfgFlags & CFG_BNDL_FLAG_IPT) ){
	  sprintf(prtbuf,"Bndl cfgd for SAToP with direct drive enabled. Turning off direct drive.\n");
	  PRTSB(MIN,,prtbuf);
	  pNewDbB->Bndl.so_bndl.CfgFlags |= CFG_BNDL_FLAG_IPT;
	}
      }	// End if port state UP
    }	// End Bndl type SAToP
  }	// Final check of new bundle dbase states that are up.

  return(rtn);
}

//==================================================================
// This routine adds a port to the system. It adds an OAM connection to the
// remote node Then the port is added to all the appropriate lists and the
// port serial driver is started.
// Note: Port State & Port Internal State DIFFER in where & how they are
// set up as well as what they were indended to be used for.....
// Port State was intended to be used outside ctpd (eg menu/cmd)
// Port Internal State was intended only to be used in ctpd.
// Port State gets setup by ctp_check, ctp_load_port_state & by CTPMSGTYPE_ST_CFG_PORT messages!!
// Port Internal State gets setup here (ctp_add_port)!
//==================================================================
int ctp_add_port( int Card, int pNum )
{
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  CTP_PORT_STATE	*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_DBASE	*pDbP = &Db.Card[Card].Port[pNum];
  CTP_PORT_CNTRS	*pPortCnt = &Ctp.Card[Card].Cntr[pNum];
  int 			 bNum = util_get_next_bNum(pDbP, -1);
  CTP_BNDL_DBASE	*pDbB = &Db.Bndl[bNum];
  struct acrndrv_command ncmd;
  int			 Ret;
  char			 SccBuf[10];
  struct timeval 	t_end;
#ifdef DBG_ADD_PORT
  struct timeval	 t_start;
  int	 diff_msec;
#endif // DBG_ADD_PORT
  int    num;// Aricent PR 1356307 fix
  FUNC_PRT(ctp_add_port, PF_PST, pNum);

  //--- ctp_add_port is only used for scc ports!!
  if( !SCC_CARD(Card) ) return(FAILURE);

  if( ctp_verify_dbase_and_hw(Card,pNum) ) return(FAILURE);
  if( IS_H110(Card, pNum)) {
  // In case of vcomp bundles on a T1E1 port. This is special since
  // the bundle is not setup at port level, so bundle configuration will
  // only result in configuration on timeslot/dsp etc but not the real port
  // configuration. And we can not treat these ports as PBS ports since we don't
  // want port to go through the statemachine which assumes that the port has
  // one bundle associated with it. So ctp_add_port for T1E1 vcomp ports will
  // only configure physical layer staff then exit.
    set_nom_ctr_freq(Card,pNum);
    PRTP(GN3,Calling CTP_PORT_CMD_CFG_CLKS);
    ctp_cfg_port(Card, pNum, CTP_PORT_CMD_CFG_CLKS);
    usleep(50000);					// Sleep in usec
    // Aricent PR 880784 fix - Don't program for serial CESoPSN bundle 
    if(IS_T1E1(Card)) {
      ctp_enable_Dallas_tx_output(bNum, 1); // PR 1407511 fix
      ctp_add_t1e1_h110(pDbP, pPortSt, 1);
      ctp_proc_t1_loop(Card,pNum);
    }
    return(SUCCESS);
  }
 
#ifdef DBG_ADD_PORT
  gettimeofday (&t_start, NULL);
  while (t_start.tv_usec < 0)
  {
    t_start.tv_usec += 1000000;
    t_start.tv_sec--;
  }
  while (t_start.tv_usec >= 1000000)
  {
    t_start.tv_usec -= 1000000;
    t_start.tv_sec++;
  }
#endif	//DBG_ADD_PORT

  // Don't want to init port here, because some values (like Diagnostics)
  // need to be at their set values. Here we only load up the runtime
  // settable variables  => Port State is setup during ctp_check (see above)
  ctp_load_port_state(Card, pNum);		// Load adaptive parameters from dbase

  //--- Default port internal state params so Diags work....
  sprintf(pPortIntSt->NetDev, "NONE");
  pPortIntSt->StartDel	= 0x060000;		// 12 mS Default for diags!
  pPortIntSt->MinDel	= 0x040000;		// 8 mS  Default for diags!
  pPortIntSt->MaxDel	= 0x080000;		// 16 mS Default for diags!
  pPortIntSt->ReqInSeq    = 15;
  pPortIntSt->StarveCnt   = 5;
  pPortIntSt->use_vip     = 0;
  pPortIntSt->RemAdCid.Node.Type = CTP_IPV4;
  pPortIntSt->RemAdCid.Node.v4 = 0xa000001;
  pPortIntSt->RemAdCid.Cid = Card*pSysInfo->Card[Card].PortsOnCard + pNum;
  pPortIntSt->loc_pkt_size = 1024;
  pPortIntSt->LocAdCid.Cid = 255;		// Diagnostics!

  pPortIntSt->CfgFlags = pDbP->CfgFlags;	// Fill this in early so USE_VIP, HAIRPIN .. macros work

  if( (bNum == CTP_MAX_BNDLS) ||	// No bundle. PBS port??
      (pPortSt->Diagnostics) ) {	// Diagnostic port
    pPortIntSt->bNum  = ~0;
    pPortIntSt->bType = CTP_BNDL_TYPE_NONE;
  } else {
    //--- These always get set
    pPortIntSt->bNum  = bNum;
    pPortIntSt->bType = pDbB->Type;
    pPortIntSt->loc_pkt_size = pDbB->loc_pkt_size;
    switch(pDbB->Type) {
      //-------------------------------------------------------
      case CTP_BNDL_TYPE_CTP:
	//--- Fill in remote address and local & remote cid
	memcpy( &pPortIntSt->RemAdCid, &pDbB->RemAdCid, sizeof(CTP_NC) );
	//--- LocAdCid.Node gets filled in when we know egress device.
	pPortIntSt->LocAdCid.Cid = pDbB->Bndl.cp_bndl.LocCid;
	PRTDVP(GN2,ctp_add_port for CTP bndl with remote CID,pPortIntSt->RemAdCid.Cid);
	PRTDVP(GEN,ctp_add_port for CTP bndl with local CID,pPortIntSt->LocAdCid.Cid);
	memcpy(&pPortIntSt->Conn.Node, &pDbB->RemAdCid.Node, sizeof(CTP_NODE_STORAGE));
	//--- Grab stuff from bundle dbase
	pPortIntSt->svc_type    = pDbB->svc_type;
	pPortIntSt->Conn.Tos    = pDbB->oam_svc_type;	// For OAMs
	pPortIntSt->time_to_live= pDbB->time_to_live;
	pPortIntSt->StartDel	= pDbB->StartDel;
	pPortIntSt->MinDel	= pDbB->MinDel;
	pPortIntSt->MaxDel	= pDbB->MaxDel;
	pPortIntSt->OamSecPerPkt   = pDbB->Bndl.cp_bndl.OamSecPerPkt;
	pPortIntSt->OamInSyncPkts  = pDbB->Bndl.cp_bndl.OamInSyncPkts;
	pPortIntSt->OamOutSyncPkts = pDbB->Bndl.cp_bndl.OamOutSyncPkts;
	pPortIntSt->SigOutDelay = pDbB->Bndl.cp_bndl.SigOutDelay;
	pPortIntSt->PktProtect  = pDbB->Bndl.cp_bndl.PktProtect;
	pPortIntSt->pFFfill     = pDbB->Bndl.cp_bndl.pFFfill;
	pPortIntSt->ReqInSeq    = pDbB->Bndl.cp_bndl.ReqInSeq;
	pPortIntSt->StarveCnt   = pDbB->Bndl.cp_bndl.StarveCnt;
	pPortIntSt->use_vip     = pDbB->Bndl.cp_bndl.use_vip;
	memcpy( &pPortIntSt->virtual_ip, &pDbB->Bndl.cp_bndl.virtual_ip, sizeof(CTP_NODE_STORAGE) );
	pPortIntSt->BndlCfgFlags= pDbB->Bndl.cp_bndl.CfgFlags;
	pPortIntSt->BndlCfgFlags |= CFG_BNDL_FLAG_IPT;    // Aricent PR 1306683 fix - Turn on iptables flag
	if( (Db.Node[0].NetRef.Type == CTP_NETREF_TYPE_BNDL) &&
	    (Db.Node[0].NetRef.bNum == bNum) &&
	    (pDbP->dds_src          == CTP_DDS_SRC_ADAPTIVE) )  {
	  PRTP(EVE,Adaptive bundle to be used by NetRef);
	  pPortSt->NetRefAdapBndl = 1;
	  pNRefs->State = CTP_NETREF_STATE_WAIT;
	  pNRefs->last_ppm_adj  = 0.0;
	  pNRefs->bNum  = bNum;
	} else {
	  PRTP(EVE,Adaptive bundle not used by NetRef);
	  pPortSt->NetRefAdapBndl = 0;
	}

	// Check for TDM operation. If tdm_rate is not 0, it will change
	// the buffer management calculations in the driver, so we want to
	// make sure that the port is truly configured for TDM Encoding
	// before we set the tdm_rate internal port state variable.

	if( ( (pSysInfo->SysType == SYS_TYPE_CTP_2000) ||		//CTP-2000 & CTP-150 support TDM/TDC
	      ((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) ) && 
	    (pDbP->IfEncoding == IF_ENC_TDM) ) {
	  pPortIntSt->tdm_rate = pDbP->tdm_rate;
	} else {
	  pPortIntSt->tdm_rate = 0;
	}

	break;

      //-------------------------------------------------------
      case CTP_BNDL_TYPE_SO:
	//--- Fill in remote address & cid
	memcpy( &pPortIntSt->RemAdCid, &pDbB->RemAdCid, sizeof(CTP_NC_V1) );
	//--- LocAdCid.Node gets filled in when we know egress device.
	//--- Grab stuff from bundle dbase
	pPortIntSt->svc_type    = pDbB->svc_type;
	pPortIntSt->time_to_live= pDbB->time_to_live;
	pPortIntSt->StartDel	= pDbB->StartDel;
	pPortIntSt->MinDel	= pDbB->MinDel;
	pPortIntSt->MaxDel	= pDbB->MaxDel;
	pPortIntSt->pFFfill     = pDbB->Bndl.so_bndl.pFFfill;
	pPortIntSt->ReqInSeq    = pDbB->Bndl.so_bndl.ReqInSeq;
	pPortIntSt->StarveCnt   = pDbB->Bndl.so_bndl.StarveCnt;
	pPortIntSt->use_vip     = pDbB->Bndl.so_bndl.use_vip;
	// PR 1820995 fix start
	if( pDbB->Bndl.so_bndl.CfgFlags & CFG_BNDL_FLAG_SAME_SRC_DST_UDP ) { 
	  pPortIntSt->dup = pDbB->RemAdCid.Cid;
	} else {
	  pPortIntSt->dup = pDbB->Bndl.so_bndl.dst_udp_port;
	} 
	// PR 1820995 fix end
	memcpy( &pPortIntSt->virtual_ip, &pDbB->Bndl.so_bndl.virtual_ip, sizeof(CTP_NODE_STORAGE) );
	pPortIntSt->BndlCfgFlags  = pDbB->Bndl.so_bndl.CfgFlags;
	pPortIntSt->BndlCfgFlags |= CFG_BNDL_FLAG_SATOP;	// Turn on SAToP flag - required!
	pPortIntSt->BndlCfgFlags |= CFG_BNDL_FLAG_IPT;		// Turn on iptables flag - required!
	if( SAToP_GRE(Card,pNum) ) {
	  pPortIntSt->MPLS_LI = pDbB->Bndl.so_bndl.MPLS_LI;
	  pPortIntSt->MPLS_LO = pDbB->Bndl.so_bndl.MPLS_LO;
	}
	break;

      //-------------------------------------------------------
      case CTP_BNDL_TYPE_WP:
        memcpy( &pPortIntSt->RemAdCid, &pDbB->RemAdCid, sizeof(CTP_NC_V1) ); //Aricent PR 1290128 fix
        //PR 1452875 fix -Start
        pPortIntSt->use_vip = pDbB->Bndl.wp_bndl.use_vip;
        memcpy( &pPortIntSt->virtual_ip, &pDbB->Bndl.wp_bndl.virtual_ip, sizeof(CTP_NODE_STORAGE) );
        //PR 1452875 fix -End
	break;

      //-------------------------------------------------------
      default:
	pPortIntSt->bType = CTP_BNDL_TYPE_NONE;
	break;
    }
    // Aricent PR 1173307 fix - Start
    if ( (pPortSt->SdActivity == 0) && (IS_SER(Card)) && (!PBS(Card,pNum))) {
      PRTP(MAJ,SD input (From IF) lost activity);
      // Aricent PR 1356307 fix - Start
      num = trap_number("TRAP_PT_SDINACTIVE");
      if (trap_bitmap & (1 << (num - 1))){
        ctp_send_trap(Card,pNum,TRAP_PT_SDINACTIVE,0);
      }
     // Aricent PR 1356307 fix - End
    }
    // Aricent PR 1173307 fix - End
  }

  if( pPortSt->Diagnostics == NO ) {
    // This port is not in diagnostics mode, so we can go ahead and
    // try to acquire SYNC with the remote port.
#if 0	// TODO - Do we want this check anymore? (Sending pkts to 0.0.0.0 is a problem)
    Ret = util_bad_node_addr(&pPortIntSt->RemAdCid.Node);
    BAILTESTm(Ret,Improper remote host address);
    memcpy(&pPortIntSt->Conn.Node, pDbP->.RemNcp.Node, sizeof(CTP_NODE_STORAGE));
#endif
    //--- Load the local node info.
    memcpy(&pPortIntSt->LocAdCid.Node, &Ctp.LocNode, sizeof(CTP_NODE_STORAGE));
    pPortIntSt->NodeToUseSt = CTP_PORT_LOC_ADDR_DFLT;
    //--- open OAM socket conn
    int conFlag = 0;
    if(USE_VIP(Card,pNum)) {
      conFlag |= CON_FLAG_USE_VIP;
      memcpy(&pPortIntSt->LocAdCid.Node, &pPortIntSt->virtual_ip, sizeof(CTP_NODE_STORAGE));
      pPortIntSt->NodeToUseSt = CTP_PORT_LOC_ADDR_VIP;
    }
    if(IPV6(Card,pNum)) { conFlag |= CON_FLAG_USE_IPV6; }
    if(pDbB->port_mirror_rx.numTail) { conFlag |= CON_FLAG_USE_SRC_PORT_MIRROR; }
    // Aricent PR 1605449 fix - Start
      Ret = ctp_con_rem_node(&pPortIntSt->Conn, conFlag, pPortIntSt->virtual_ip);
      //util_dump_nodestruct((void *) &pPortIntSt->Conn, NSTYPE_CTP_NODE_CONN);
      BAILTESTM(Ret,Cant connect to remote host);
    // Aricent PR 1605449  fix - End
    // If redundant port with S/W link enabled, open rdnt OAM socket conn
    if( pDbP->RdntConfig & CFG_RDNT_MODE_MASK ) {
      if( pDbP->RdntConfig & CFG_RDNT_FLAG_SW_LINK ) {
	memcpy(&pPortIntSt->RdntConn.Node, &pDbP->RdntNode, sizeof(CTP_NODE_STORAGE));
	pPortIntSt->RdntConn.Tos = pPortIntSt->Conn.Tos;
	Ret = ctp_con_rem_node(&pPortIntSt->RdntConn, conFlag, pPortIntSt->virtual_ip);
	//util_dump_nodestruct((void *) &pPortIntSt->RdntConn, NSTYPE_CTP_NODE_CONN);
	BAILTESTM(Ret,Cant connect to remote host);
      }
    }
  } else {
    //--- Diagnostics
    if( pDbP->dds_freq == 0x3e80000 ) {	// Slow ports / 5k
      PRTP(GEN,ctp_add_port for slow Diagnostics);
      pPortIntSt->loc_pkt_size = 32;
    } else {
      pPortIntSt->loc_pkt_size = 1024;
    }
  }

  //--- Init port regs.
  ncmd.CmdType = SCC_CMD_INIT_PORT_REGS;
  ncmd.CmdObj = pNum;
  sprintf(SccBuf,"scc%d", pPortSt->SccNum);
  if( ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd) ) {
    PRTP(MIN, Cant IOCTL scc to init port regs);
  }

  Ret = ctp_port_state_machine(Card,pNum,CTP_PORT_EVENT_DB_ACTIVE,NULL);	// bring port up
  BAILTESTF(Ret,Port State machine function unsuccessful);
  gettimeofday (&t_end, NULL);
  pPortCnt->TimeLastClr = t_end.tv_sec;
  //Start Aricent PR 721069 - Last counter clear status is dashed out in bundle query
  //--- Clear bundle counters
  if(!PBS(Card, pNum) && !IS_BRIDGE(Card, pNum)) {
     Ctp.Bndl_cnt[bNum].Bndl.ctp.TimeLastClr = t_end.tv_sec;
  }
  //End Aricent PR 721069 - Last counter clear status is dashed out in bundle query
#ifdef DBG_ADD_PORT
  while (t_end.tv_usec < 0)
  {
    t_end.tv_usec += 1000000;
    t_end.tv_sec--;
  }
  while (t_end.tv_usec >= 1000000)
  {
    t_end.tv_usec -= 1000000;
    t_end.tv_sec++;
  }
  diff_msec = (int)((t_end.tv_usec - t_start.tv_usec) / 1000);
  while ( diff_msec < 0 ) { diff_msec += 1000; }
  if( diff_msec > 50 ) {
    PRTDV(MIN,ctp_add_port processing time, diff_msec);
  }
#endif	//DBG_ADD_PORT

  return(SUCCESS);
}

//==================================================================
// This routine checks the database against the actual hardware in the
// system. If there are any anomalies, the function returns failure. This
// function is used to prevent bundles/ports from being configured when
// cards have been moved around the system.
//==================================================================
int ctp_verify_dbase_and_hw( int Card, int pNum )
{
  CTP_PORT_DBASE	*pDbP = &Db.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  int 		 	 bNum = util_get_next_bNum(pDbP, -1);
  CTP_BNDL_DBASE	*pDbB = &Db.Bndl[bNum];
  char			dbaseFile[100];
  int			 pType,pMode,bType;
  int                    ret = SUCCESS;      
  FUNC_PRT(ctp_verify_dbase_and_hw, PF_PST, pNum);

  if(CARDTYPE(Card) == NOCARD) {
    ret = FAILURE;
    PRTP(MIN,No Port available to bring up Bundle);
  }

  if( Ctp.Card[Card].Port[pNum].Diagnostics ) return(SUCCESS);

  // We need to run this so that the port speed calculation will succeed.
  if( !VOICE(Card) && !Db.Card[Card].all_h110_cesop) //Aricent PR-947222 
   set_nom_ctr_freq(Card,pNum);

  pType = utl_get_port_type(Card,pNum);		// Gets physical card info
  pMode = utl_get_port_mode(Card,pNum);		// PBS/BRIDGE/CKTEM
  bType = pDbB->Type;
  // Make sure the bundle type matches up with the HW type. Even though we
  // are not likely to traverse this path for VC bundles, we do the checks
  // here anyway. Also, do some port mode (CktEm/PBS/Bridge) checks against
  // the HW.

  switch(pType) {
    case PORT_TYPE_SER_CARD:
      if( pMode == PORT_MODE_CKTEM ) {
         // Aricent PR 880784 fix
	if( (bType != CTP_BNDL_TYPE_CTP) 
	 && (bType != CTP_BNDL_TYPE_WP) 
	  ) {
	  PRTP(MIN,Bundle type is not CTP_BNDL_TYPE_CTP or CTP_BNDL_TYPE_WP);
	  ret = FAILURE;
	}
      }
      break;
    case PORT_TYPE_SER_DCARD_4WTO_DCARD:
    case PORT_TYPE_SER_DCARD_IRIG_DCARD:
    case PORT_TYPE_SER_DCARD_MS_DCARD:
      if( pMode == PORT_MODE_CKTEM ) {
         // Aricent PR 880784 fix
	if( (bType != CTP_BNDL_TYPE_CTP) 
          && (bType != CTP_BNDL_TYPE_WP)
          ) {
	  PRTP(MIN,Bundle type is not CTP_BNDL_TYPE_CTP or CTP_BNDL_TYPE_WP);
	  ret = FAILURE;
	}
      }
      break;
    case PORT_TYPE_SER_DCARD_T1E1_DCARD:
      if( pMode == PORT_MODE_CKTEM ) {
         // Aricent PR 880784 fix
	if( (bType != CTP_BNDL_TYPE_CTP) &&
	    (bType != CTP_BNDL_TYPE_SO ) &&
            (bType != CTP_BNDL_TYPE_WP) ) {
	  PRTP(MIN,Bundle type is not CTP_BNDL_TYPE_CTP or CTP_BNDL_TYPE_SO 
              or CTP_BNDL_TYPE_WP);
	  ret = FAILURE;
	}
      }
      break;
    case PORT_TYPE_T1E1_CARD:
      if( pMode != PORT_MODE_CKTEM) {
	PRTP(MIN,This HW only supports PORT_MODE_CKTEM );
	ret = FAILURE;
      }
#if 0	// TODO need to fix this so that it works (Bugzilla Bug #412)
      if( bType == CTP_BNDL_TYPE_CTP ) {
	double speed;
	// TODO calc_port_speed() is bad since it will vary with other
	// variables (e.g. pkt protector and port mirroring)
	//calc_port_speed( Card, pNum, &speed );
	// TODO this might not work for a loop timed port (not right on)
	speed = (double)(pPortIntSt->NomCtrFreq/pPortIntSt->CntrRatio);
	if( (speed != 1544.0) && (speed != 2048.0 ) ) {
	  PRTFVP(MIN,T1E1 port running at bad speed,speed);
	  return(FAILURE);
	}
      }
#endif
      break;
    case PORT_TYPE_4WEM:
    case PORT_TYPE_FXS:
    case PORT_TYPE_FXO:
      if( pMode != PORT_MODE_CKTEM) {
	PRTP(MIN,This HW only supports PORT_MODE_CKTEM );
	ret = FAILURE;
      }
      // Aricent PR-947222 Start
      if( bType != CTP_BNDL_TYPE_VC && bType != CTP_BNDL_TYPE_WP ) {
       PRTP(MIN,Bundle type is not CTP_BNDL_TYPE_VC or CTP_BNDL_TYPE_WP);
       ret = FAILURE;
      }
      // Aricent PR-947222 End 
      if(pDbB->Bndl.vc_bndl.Companding == VCB_COMPANDING_TRANS) {
	PRTP(MIN,Companding can not be transparent);
	ret = FAILURE;
      }
      break;
    default:
      PRTP(MIN,Unknown port type - please add to checking);
      ret = FAILURE;
      break;
  }

  // If port is configed for DCARD operation, make sure it has the right HW
  if( pDbP->if_mode == IF_MODE_DCARD ) {
    switch( pDbP->DcardType ) {
      case DCARD_T1E1:
	if( (pType != PORT_TYPE_SER_DCARD_T1E1_DCARD) &&
	    (pType != PORT_TYPE_T1E1_CARD) ) { // T1E1 module port emulates DCARD
	  PRTP(MIN,Port is configured for T1E1 DCARD but hw is not there);
	  ret = FAILURE;
	}
	break;
      case DCARD_4WTO:
	if(pType != PORT_TYPE_SER_DCARD_4WTO_DCARD) {
	  PRTP(MIN,Port is configured for 4WTO DCARD but hw is not there);
	  ret = FAILURE;
	}
	break;
      case DCARD_IRIG:
	if(pType != PORT_TYPE_SER_DCARD_IRIG_DCARD) {
	  PRTP(MIN,Port is configured for IRIG DCARD but hw is not there);
	  ret = FAILURE;
	}
	break;
      case DCARD_MS:
	if(pType != PORT_TYPE_SER_DCARD_MS_DCARD) {
	  PRTP(MIN,Port is configured for MS DCARD but hw is not there);
	  ret = FAILURE;
	}
	break;
    }
  }
//Aricent PR 601910 start
  if((Card == -1 || pNum == -1)) {
     return FAILURE;}

  sprintf(&dbaseFile[0],"%s/%s", CTP_DB_DIR, CTP_DB_FILE );
  if(bNum < CTP_MAX_BNDLS) { // should not be executed for bNum >= 64
    if(pDbB->card_type == (PORT_TYPE_LAST+1 )) {
        pDbB->card_type = pType;
	ctp_dbase_write( &Db, dbaseFile );
    }
    else {
      if(!(((pType == PORT_TYPE_T1E1_CARD) && (pDbB->card_type == PORT_TYPE_SER_DCARD_T1E1_DCARD)) || 
    	((pType == PORT_TYPE_SER_DCARD_T1E1_DCARD) && (pDbB->card_type == PORT_TYPE_T1E1_CARD))) || 
  	(ret == FAILURE)) {
          if((pType != pDbB->card_type) || (ret == FAILURE)) {
             if(!(Card == -1 && pNum == -1)) { //PR689457 -Aricent Fix
       	       while(bNum != CTP_MAX_BNDLS) {
       	            if (IS_T1E1(Card)) 
                       util_init_t1_dbase(pDbP);
       		    else
	               util_init_port_dbase(pDbP,CTP_PORT_DBASE_VERSION);
	 	    util_init_bndl_dbase(pDbB,bNum);
		    bNum = util_get_next_bNum(pDbP,bNum);
               } 
            }
	    ctp_dbase_write( &Db, dbaseFile );
            return FAILURE;
         }
      }
    }
  }
//Aricent PR 601910 End
  return SUCCESS;
}

//==================================================================
// These next to routines convert (32M) ticks ,-> buffer counter ticks
// The minimum set point is saved as MinDel in ticks of 32Mhz clock.
// The buffer set point is saved as StartDel in ticks of 32Mhz clock.
// The maximum set point is saved as MaxDel in ticks of 32Mhz clock.
// acorn_drv cares uses units of buffer counter ticks. (see NomCtrFreq)
//==================================================================
u32 ticks_to_cntr( u32 Ticks, int Card, int pNum )
{
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  u32			Cntr;
  FUNC_PRT(ticks_to_cntr, PF_PSTAT, pNum);

  set_nom_ctr_freq(Card, pNum);
  if (pPortIntSt->NomCtrFreq != 0 ) {
    Cntr = (u32)(Ticks * pPortIntSt->NomCtrFreq / CTP_OSC_FREQ);
  } else {
    PRT(DBG,Got nominal Tx frequency of 0);
    Cntr = 0;
  }
  return(Cntr);
}

u32 cntr_to_ticks( u32 Cntr,  int Card, int pNum )
{
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  u32			Ticks;
  FUNC_PRT(cntr_to_ticks, PF_PSTAT, pNum);

  if (pPortIntSt->NomCtrFreq != 0 ) {
    Ticks = (u32)( Cntr * (CTP_OSC_FREQ / pPortIntSt->NomCtrFreq) );
  } else {
    PRT(DBG,Got nominal Tx frequency of 0);
    Ticks = 0;
  }
  return(Ticks);
}

//==================================================================
// This routine calculates the speed of a port/bundle
//==================================================================
int calc_port_speed( int Card, int pNum, double *speed )
{
  CTP_PORT_DBASE	*pDbP = &Db.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  CTP_BNDL_DBASE	*pDbB;
  int			 bNum, i, tsBitMask;
  double		 loc_speed;
  FUNC_PRT(calc_port_speed, PF_PST, pNum);

  if( PBS(Card,pNum) || (Ctp.Card[Card].Port[pNum].Diagnostics) ) {
    // Not sure how this might be used, but set it correctly anyway.
    loc_speed = (double)(pPortIntSt->NomCtrFreq/pPortIntSt->CntrRatio);
  } else {
    int tails;
    bNum = util_get_next_bNum(pDbP, -1);
    if(bNum == CTP_MAX_BNDLS) {
      PRTP(MAJ, Port not bundled);
    }
    pDbB = &Db.Bndl[bNum];

    switch( pDbB->Type ) {
      //---------------------------
      case CTP_BNDL_TYPE_CTP:
	loc_speed = (double)(pPortIntSt->NomCtrFreq/pPortIntSt->CntrRatio);

	if( (pDbP->rx_sel != CTP_CLK_SEL_DDS) &&
	    (pDbP->dds_src == CTP_DDS_SRC_AUTOBAUD) ) {
	  //--- Autobaud is special, always use database to calculate speed
	  //    to release, that way we checkout & release MAXIMUM kbps for
	  //    the port.
	  //--- TT with no_hi_tt_check is also special, since the incoming
	  //    clock can vary from 0 to the configured rate, we check out
	  //    the full confugured (Maximum) rate for the port.
	  // NOTE! One exception is when we are using a DCARD which takes a
	  // DDS clock from the port and feeds back a completely different
	  // TT for packet generation. In this case, the normal calculation
	  // applies (measured TT). This is true for 4WTO and IRIG-B.
	  int loc_speed_int;
	  loc_speed = (double)((double)pDbP->dds_freq/0x20000);
	  loc_speed_int = (int)loc_speed;
	  PRTDVP(EVE,Variable speed port so set to max:,loc_speed_int);
	} 
	 // PR 1820351 fix start
         // For TRANS ports, the data rate is 4x
         if( pDbP->IfEncoding == IF_ENC_TRANS ) { loc_speed *= 4; }
         // For TRANS8 ports, the data rate is 8x
         if( pDbP->IfEncoding == IF_ENC_TRANS8 ) { loc_speed *= 8; }
         // For TDM ports, the interleaved data must be factored in
         if( pDbP->IfEncoding == IF_ENC_TDM ) { loc_speed *= 32 / (32 - pDbP->tdm_rate); }
         // For TDM_TDC low speed ports don't generate net bandwidth
         if( pDbP->CanClkCfg == CTP_CLKCFG_TDM_TDC ) { loc_speed = 0; }
         // PR 1820351 fix end

	if( pPortIntSt->PktProtect) { 
          // Aricent PR 1082106 fix - Start
          if (pDbB->Bndl.cp_bndl.PktProtect & PP_CLONE_XOR) {
            loc_speed = loc_speed + (0.5*loc_speed);    //XOR Clone Packets use 50% additional bandwidth
          } else {
            loc_speed *= 2;    //Clone Packets use 100% additional bandwidth
          }
        }
        // Aricent PR 1082106 fix - End
        /* port mirroring speed calculation */
        /* Speed calculation for port mirroring is complex, current algorithm
           is very conservative. It is port speed = port speed *( 1+max(rxtails, txtails).
           and this speed will be check against system speed limitation as well
           as port speed limitation, meanwhile it will affect the pps checks.
           This algorithm could potentially be improved to reflect the real extra
           processing done by iptable and ip stack.*/
        tails = (pDbB->port_mirror_rx.numTail > pDbB->port_mirror_tx.numTail)?
	         pDbB->port_mirror_rx.numTail:pDbB->port_mirror_tx.numTail;
	/* Count on port mirroring tails bandwidth */
        loc_speed *= (1+ tails);

	break;
      //---------------------------
      case CTP_BNDL_TYPE_SO:
	if( pDbP->DcardCfg1 & T1E1_MSK_E1 ) {
	  loc_speed = (double)2048.0;
	} else {
	  loc_speed = (double)1544.0;
	}
	break;
      //---------------------------
      case CTP_BNDL_TYPE_WP:
	loc_speed = (double)0.0;
        // Aricent PR 880784 fix
	if( ((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) && ( IS_SER(Card) ) ) {
	  loc_speed = (double)(pPortIntSt->NomCtrFreq/pPortIntSt->CntrRatio);
          // Aricent PR 901134 fix
          if((pDbP->tx_sel == CTP_CLK_SEL_TT) || (pDbP->tx_sel == CTP_CLK_SEL_ST))
             loc_speed = (double)((double)pDbP->dds_freq/0x20000);
       } else if(Db.Card[Card].all_h110_cesop == 1) {
          loc_speed = (double)8192.0;
        } else {
	  tsBitMask = pDbB->Bndl.wp_bndl.tsBitMask;
	  for(i=0;i<32;i++) {
	    if( (1<<i) & tsBitMask ) loc_speed += (double)64.0;
	  }
	}
	break;
      //---------------------------
      case CTP_BNDL_TYPE_VC:
	// TODO This is just a token amount so that there is no problem
	// bringing up the bundle. The value that really matters is PPS for
	// this type of bundle.
	loc_speed = (double)1024.0;
	break;
      //---------------------------
      default:
	// If we forgot to add the algorithm for a new bundle type, we
	// don't want to set it to 0. So instead, we print a big message
	// and set it to a high bandwidth to remind us to add the right
	// algorithm.
	loc_speed = (double)8192000.0;	// 8 Mbps
	PRTDVP(MIN,Unknown bundle type,pDbB->Type);
	PRTP(MIN,Setting ABNORMALLY HIGH SPEED);
	break;
    }
  }

  PRTFVP(GN2,calc_port_speed: Calculated Speed,loc_speed);

  *speed = loc_speed;

  return(SUCCESS);
}

//==================================================================
// This routine calculates the speed of a port/bundle
//==================================================================
int calc_pps( int Card, int pNum, int speed, int *pps )
{
  CTP_PORT_DBASE	*pDbP = &Db.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortInt = &Ctp.Card[Card].PortInt[pNum];
  int 			 bNum, loc_pps, pkt_size;
  CTP_BNDL_DBASE	*pDbB;
  FUNC_PRT(calc_pps, PF_PST, pNum);

  if( PBS(Card,pNum) ) {
    PRTP(GEN,PBS port so pps is 0);
    *pps = 0;	// Set to 0 since not part of pps calculation
  } else {
    bNum = util_get_next_bNum(pDbP, -1);
    pDbB = &Db.Bndl[bNum];

    switch( pDbB->Type ) {
      //---------------------------
      case CTP_BNDL_TYPE_CTP:
      case CTP_BNDL_TYPE_SO:
	// You might wonder why the pkt_size is pulled from Int state and
	// not the dbase. this is because we may have different pkt sizes
	// for each direction. The ifbound is kept in int state.
	pkt_size = pPortInt->loc_pkt_size;	
	if( FRAC_T1E1(Card, pNum) ) {
	  //--- Use gapped clk speed as that will get pps correct
	  int channels = pDbP->DcardCfg2;
	  if( pDbP->DcardCfg1 & T1E1_MSK_E1 ) {
	    //--- E1, look for CAS
	    double dspeed = (double)speed;
	    if( pDbP->DcardCfg1 & T1E1_MSK_E1_CAS ) channels++;
	    speed = (int)(dspeed*((double)(64*channels)/2048.0));
	  } else {
	    //--- T1, sending frame?
	    int frm = (pDbP->DcardCfg1 & T1E1_MSK_NO_FRM) ? 8 : 0;
	    double dspeed = (double)speed;
	    speed = (int)(dspeed*((double)(64*channels + frm)/1544.0));
	  }
	}

        // PR 1820351 - Comensation for TRANS & TDM encoding is passed to this function
	loc_pps = (speed * 1000) / (pkt_size * 8);
	break;
      //---------------------------
      case CTP_BNDL_TYPE_WP:
	pkt_size = pDbB->loc_pkt_size;
	loc_pps = (speed * 1000) / (pkt_size * 8);
	break;
      //---------------------------
      case CTP_BNDL_TYPE_VC:
	// TODO - this 1000 pps value is based on 8 full T1 VCOMP bundles
	// consuming about 25% of the CPU. Compare this to CktEm bundles
	// where 12500 pps (full CTP2000 complement) consuming 40% CPU and
	// this seems about right. But this is less accurate when VCOMP
	// bundles are less than 24 channels. We will need to tweak this
	// to make it more accurate. But this is pretty good for now.
	loc_pps = CTP_VC_BNDL_PPS;
	break;
      //---------------------------
      case CTP_BNDL_TYPE_NONE:
	if( Ctp.Card[Card].Port[pNum].Diagnostics ) {
	  pkt_size = pPortInt->loc_pkt_size;
	  loc_pps = (speed * 1000) / (pkt_size * 8);
	} else {
	  loc_pps = (int)4000;	// abnormally large
	  PRTDVP(MIN,Unknown bundle type,pDbB->Type);
	  PRTP(MIN,Setting ABNORMALLY HIGH PPS);
	}
	break;
      default:
	// If we forgot to add the algorithm for a new bundle type, we
	// don't want to set it to 0. So instead, we print a big message
	// and set it to a high bandwidth to remind us to add the right
	// algorithm.
	loc_pps = (int)4000;	// abnormally large
	PRTDVP(MIN,Unknown bundle type,pDbB->Type);
	PRTP(MIN,Setting ABNORMALLY HIGH PPS);
	break;
    }
    PRTDVP(GN2,Calculated Pps,loc_pps);

    *pps = loc_pps;
  }

  return(SUCCESS);
}

//==================================================================
int redistribute_pps_to_pbs_ports ( int Card, int pNum )
{
  int 	bridge_ports_inuse = 0;
  int 	i,j;
  int	lev = GEN;
  FUNC_PRT(redistribute_pps_to_pbs_ports,PF_PST,pNum);

#ifndef VCTP
  for(i=0;i<pSysInfo->CardsPerCpu;i++) {
#else
  int c_idx;
  for(c_idx = 0; c_idx<pSysInfo->CardsPerCpu; c_idx++) {
    i = cardIndx[c_idx];
#endif
    if( pSysInfo->Card[i].Type ) {	// Any plugged in card type
      for(j=0;j<pSysInfo->PortsPerCard;j++) {
	if( IS_BRIDGE(i,j) ) {
	  if( (Db.Card[i].Port[j].State == CTP_DBSTATE_UP) &&
	      (Db.Card[i].Port[j].bridge_info.bridge[0].flags &
	       BRIDGE_FLAG_CONFIGURED) &&
	      (Db.Card[i].Port[j].bridge_info.bridge[0].flags &
	       BRIDGE_FLAG_ACTIVE) ) {
            bridge_ports_inuse++;
          }
        }
      }
    }
  }

  PRTDVP(lev,Active bridged ports, bridge_ports_inuse);
  if( bridge_ports_inuse ) {
    pSysInfo->pps_per_port = pSysInfo->Remn_pps / bridge_ports_inuse;
  } else {
    pSysInfo->pps_per_port = pSysInfo->Remn_pps;	// Set to max
  }
  PRTDVP(lev,Bridged port pps allocation,pSysInfo->pps_per_port);
  return(SUCCESS);
}

//==================================================================
// This routine checks out kbps if available, else returns failure
//==================================================================
int ctp_request_pps( int Card, int pNum, int pps )
{
  char	PrtBuf[100];
  int	lev = GEN;
  FUNC_PRT(ctp_request_pps, PF_PST, pNum);

  PRTDVP(GEN,Requesting pps, pps);

  // This is only for CktEm ports. PBS ports get what is left over once a
  // system-wide PPS allocation is figured out.
  if( !PBS(Card,pNum) ) {
    if ( pps < 0 ) {
      sprintf(PrtBuf,"Got neg pps: %d", pps );
      PRTSP(MIN,,PrtBuf );
      return(TOO_SLOW);
    } else if( pps > pSysInfo->Remn_pps ) {
      sprintf(PrtBuf,"Requested pps %d more than free: %d.",
	  pps, pSysInfo->Remn_pps);
      PRTSP(MIN,,PrtBuf);
      return(TOO_FAST);
    } else {
      pSysInfo->Remn_pps -= pps;
      sprintf(PrtBuf,"Checked out %d pps. Free after: %d.",
	  pps, pSysInfo->Remn_pps);
      PRTSP(lev,,PrtBuf);
    }
  }

  redistribute_pps_to_pbs_ports(Card,pNum);

  return(SUCCESS);
}

//==================================================================
// This routine releases pps from the aggregate used by activated ports
//==================================================================
int ctp_release_pps( int Card, int pNum, int pps )
{
  char	PrtBuf[100];
  int	lev = EVE;
  FUNC_PRT(ctp_release_pps, PF_PST, pNum);

  PRTDVP(GEN,Releasing pps, pps);

  // This is only for CktEm ports. PBS ports get what is left over once a
  // system-wide PPS allocation is figured out.
  if( !PBS(Card,pNum) ) {
    //--  Only release kbps from circuit em ports.
    pSysInfo->Remn_pps += pps;
    sprintf(PrtBuf,"Released %d pps. Free after: %d.",
	pps, pSysInfo->Remn_pps);
    PRTSP(lev,,PrtBuf);
  }

  redistribute_pps_to_pbs_ports(Card,pNum);

  return(SUCCESS);
}

//==================================================================
// This routine checks out kbps if available, else returns failure
//==================================================================
int ctp_request_kbps( int Card, int pNum, int speed, int speed_bps )
{
  char	PrtBuf[100];
  int	lev = EVE;
  FUNC_PRT(ctp_request_kbps, PF_PST, pNum);

  PRTDVP(GEN,Requesting kbps, speed);
  PRTDVP(GEN,Available  kbps, pSysInfo->Remn_kbps);

  if ( speed < 0 ) {
    sprintf(PrtBuf,"Got neg speed: %d", speed );
    PRTSP(MIN,,PrtBuf );
    return(TOO_SLOW);
  }

  if( PBS(Card,pNum) ) {
    //--- This is a PBS link
    if( (!(pSysInfo->Flags & SYSINFO_FLAG_NO_SPEED_CAP)) &&
	(speed > pSysInfo->Max_kbps ) ) {
      sprintf(PrtBuf,"Requested kbps %d > than max on PBS i/f %d.",
	  speed, pSysInfo->Max_kbps);
      PRTSP(MIN,,PrtBuf);
      return(TOO_FAST);
    } else {
      //- Do NOT check out kbps as pbs link does not contribute to aggr kbps
      return(SUCCESS);
    }
  } else {

    //--- This is a circuit em port
    if( speed > pSysInfo->Max_kbps ) {
      sprintf(PrtBuf,"Requested kbps %d more than max: %d.",
	  speed, pSysInfo->Max_kbps);
      PRTSP(MIN,,PrtBuf);
      return(TOO_FAST);
    } else if( speed < pSysInfo->Min_kbps ) {
      sprintf(PrtBuf,"Requested kbps %d less than min: %d.",
	  speed, pSysInfo->Min_kbps);
      PRTSP(MIN,,PrtBuf);
      return(TOO_SLOW);
    } else if ( (speed == 0) && (speed_bps == 0) ) {	// Zero is TooSlow!!
      sprintf(PrtBuf,"Requested kbps %d (%d bps) is zero",
	  speed, speed_bps);
      PRTSP(MIN,,PrtBuf);
      return(TOO_SLOW);
    } else if( speed > pSysInfo->Remn_kbps ) {
      sprintf(PrtBuf,"Requested kbps %d more than free: %d.",
	  speed, pSysInfo->Remn_kbps);
      PRTSP(MIN,,PrtBuf);
      return(TOO_FAST);
    } else {
      pSysInfo->Remn_kbps -= speed;
      sprintf(PrtBuf,"Checked out %d kbps. Free after: %d.",
	  speed, pSysInfo->Remn_kbps);
      PRTSP(lev,,PrtBuf);
      return(SUCCESS);
    }
  }
}

//==================================================================
// This routine releases kbps from the aggregate used by activated ports
//==================================================================
int ctp_release_kbps( int Card, int pNum, int speed )
{
  char	PrtBuf[100];
  int	lev = GEN;
  FUNC_PRT(ctp_release_kbps, PF_PST, pNum);

  PRTDVP(GN2,Releasing kbps, speed);

  if( !PBS(Card,pNum) ) {
    //--  Only release kbps from circuit em ports.
    pSysInfo->Remn_kbps += speed;
    sprintf(PrtBuf,"Released %d kbps. Free after: %d.",
	speed, pSysInfo->Remn_kbps);
    PRTSP(lev,,PrtBuf);
  }
  return(SUCCESS);
}

//------------------------------------------------------------------
int ctp_chk_hairpin( int Card, int pNum )
{
  int HairPin = 0;
  FUNC_PRT(ctp_chk_hairpin, PF_PST, pNum);

  if( (Ctp.Card[Card].Port[pNum].Diagnostics == NO) &&
      (!PBS(Card,pNum))  )
  {
    int if_type = ctp_nid_qry_ip(&Ctp.Card[Card].PortInt[pNum].RemAdCid.Node);
    if( (if_type == CTP_IF_TYPE_ETH) ||
	(if_type == CTP_IF_TYPE_PBS) ||
	(if_type == CTP_IF_TYPE_VIP) ) {
      HairPin = 1;
    } else if (if_type == CTP_IF_TYPE_NONE) {
      PRTP(GN2,ctp_chk_hairpin: Remote ip did not match any local ip);
    } else {
      PRTP(GN2,ctp_chk_hairpin: Remote ip did not match any local ip);
    }
  }

  if( HairPin) {
    PRTP(GN2,ctp_chk_hairpin: Hairpin enabled);
  } else {
    PRTP(GN2,ctp_chk_hairpin: Not a hairpin circuit);
  }

  return HairPin;
}

