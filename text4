//----- MAIN -----
int main(int argc, char *argv[])
{
  CTP_Q_MSG	RMsg;			// Rx Queue message
  int	i, ChildPid;
  int	x, Status;
  int	i_am_timer_task = FALSE;
  int	i_am_net_task   = FALSE;
  int	spawn_daemon    = FALSE;
  //char	Buf[100];
  char	DiskType[40],CmdStr[150];
  char  ips[INET6_ADDRSTRLEN];	// Used for both IPv4 & IPv6
  //struct msqid_ds msg_ds_buf;
  int	shmid;
  int	nr_sock;
  int   start_netref = 0;
  char *fn = "main";
  char	dbaseFile[100];
  short pf = PF_START;
#ifdef VCTP
  int c_idx;
#endif
   
/* ARICENT FIX Start - PR595506 */ 
   char                          EthBuf[8];
   struct eth_runtime_cfg        erc;
   int status, intf;
/* Aricent Fix End - PR595506 */

  
  ctp_init_sysinfo();
  /* Strange, seems SystemUnusable got assigned to 0x1 even if assigned 0x0 in ctp_init_sysinfo 
   it's value accessed from main is 0x1, but assiging 0x0 here fixes it */
  //pSysInfo->SystemUnusable=0;  //PR-1843238
  //FUNC_PRT(main, PF_START, -1);

  while( (x = getopt(argc,argv,"stnde:N:l:f:p:P:o:i:")) != -1) {
    switch(x) {
      case 't':
        i_am_timer_task = TRUE;
	break;
      case 'n':
        i_am_net_task = TRUE;
	break;
      case 'l':
	{
	  char	*ep;
	  char loglevel;
	  loglevel = (unsigned char)strtol(optarg,&ep,10);
	  if( *ep != 0 ) {
	    PRT(MAJ,Problems converting passed loglevel);
	  }
	  if( loglevel > FAT ) {
	    PRTDV(MAJ,Problems with passed loglevel - too large, loglevel);
	  } else {
	    pSysInfo->CtpPrt.LogLevel = loglevel;
#ifdef DBG_DATABASE
	    pSysInfo->CtpPrt.LogLevel = GN3;
#endif
	    if( pSysInfo->CtpPrt.Facility == PF_NONE ) {
	      // Default if loglevel is passed.
	      pSysInfo->CtpPrt.Facility = PF_START | PF_DBASE;
	    }
	    PRTDV(EVE,Got request to use loglevel, pSysInfo->CtpPrt.LogLevel);
	  }
	}
	break;
      case 'f':
	{
	  char	*ep;
	  int    facility;
	  // TODO mike - Not sure why this is the case, but
	  // /etc/sysconfig/ctp must set this as a decimal number to be
	  // process right. I tried to make it hex there and base 16 here,
	  // but it did not work... Maybe there is a way to do it in hex
	  // (which is much more convenient), but I have not figured it out
	  // yet.
	  facility = (int)strtol(optarg,&ep,10);
	  if( *ep != 0 ) {
	    PRT(MAJ,Problems converting passed log facility mask);
	  }
	  if( facility > PF_ALL ) {
	    PRTV(MAJ,Problems with passed log facility mask - too large, facility);
	  } else {
	    pSysInfo->CtpPrt.Facility = facility;
#ifdef DBG_DATABASE
	    pSysInfo->CtpPrt.Facility |= PF_DBASE;
#endif
	    PRTV(MIN,Got request to use log facility mask, pSysInfo->CtpPrt.Facility);
	  }
	}
	break;
      case 'P':
	{
	  char	*ep;
	  pSysInfo->protocol = strtol(optarg,&ep,10);
	  if( *ep != 0 ) {
	    PRT(MAJ,Problems converting protocol from char to int);
	  }
	  PRTDV(EVE,Got request to use protocol,pSysInfo->protocol);
	}
	break;
      case 'p':
	{
	  char	*ep;
	  pSysInfo->oam_port = strtol(optarg,&ep,10);
	  if( *ep != 0 ) {
	    PRT(MAJ,Problems converting oam port from char to int);
	  }
	  PRTDV(EVE,Got request to use oam port,pSysInfo->oam_port);
	}
	break;
      case 'o':
	{
	  char	*ep;
	  pSysInfo->oam_port_v6 = strtol(optarg,&ep,10);
	  if( *ep != 0 ) {
	    PRT(MAJ,Problems converting oam_v6 port from char to int);
	  }
	  PRTDV(EVE,Got request to use oam_v6 port,pSysInfo->oam_port_v6);
	}
      case 'e':
	break;
      case 'i':
	{
	  char	*ep;
	  pSysInfo->ipProtocol = strtol(optarg,&ep,10);
	  if( *ep != 0 ) {
	    PRT(MAJ,Problems converting IP protocol from char to int);
	  }
	  PRTDV(EVE,Got IP protocol ,pSysInfo->ipProtocol);
	}
	break;
	break;
      case 'd':
	PRT(EVE,Passed daemon option flag on command line);
	spawn_daemon = TRUE;
	break;
      default:
	PRT(MIN,Invalid option);
	exit(1);
    }
  }

  //--------- Check to see if we need to spawn daemon ----------
  if( spawn_daemon == TRUE ) {
    ChildPid = fork();
    if(ChildPid == 0)	// If I am the forked task
    {
      char opt_p[10], opt_P[10], opt_o[10], opt_i[10];
      sprintf(opt_p,"-p %d", pSysInfo->oam_port);
      sprintf(opt_o,"-o %d", pSysInfo->oam_port_v6);
      sprintf(opt_P,"-P %d", pSysInfo->protocol);
      sprintf(opt_i,"-i %d", pSysInfo->ipProtocol);
      PRT(DBG,I (CTP daemon) have successfully forked from the main task);
      if( (pSysInfo->CtpPrt.Facility != PF_NONE) ||
	  (pSysInfo->CtpPrt.LogLevel != EVE) ) {
	char log_l[10], log_f[10];
	sprintf(log_l,"-l %d", pSysInfo->CtpPrt.LogLevel);
	sprintf(log_f,"-f %d", pSysInfo->CtpPrt.Facility);
	execlp("/acorn/bin/ctpd","/acorn/bin/ctpd",log_l,log_f,opt_p,opt_P,opt_o, opt_i, "&",NULL);
      } else {
	execlp("/acorn/bin/ctpd","/acorn/bin/ctpd",opt_p,opt_P,opt_o,"&",NULL);
      }
      PRTDV(MAJ,ctpd daemon exec failed with errno,errno);
      PRTS(MAJ,ctpd daemon exec failed,strerror(errno));
      exit(1);
    }
    else	// I am the parent task
    {
      exit(0);
    }
  }

#ifdef VCTP
  getCardIndx();
#endif
  //--- Initialize Ctp.Node, Ctp.Task & Ctp.Card structures.
  //    Ctp.Card[c].Port[pn].available gets filled in during ctp_check() below
  ctp_init_ctp();

  //--------- Fill in all known ip addresses into SysInfo structure using
  //      netlink sockets.... Will replace netx section when complete....
  if( (i_am_timer_task == FALSE) && (i_am_net_task == FALSE) ) {
    Status = ctp_get_nid_info();
    PRTDV(MIN,Return from ctp_get_nid_info was, Status);
  }

  //--- Open All Queues ---
  ctp_get_qid((int)CTP_TASK);
  ctp_get_qid((int)CTP_TIMER_TASK);
  ctp_get_qid((int)CTP_NET_TASK);
  ctp_get_qid((int)CTP_MENU_TASK);

  //---------- Check for task restarting too often ----------
  if( (i_am_timer_task == FALSE) && (i_am_net_task == FALSE) ) {
    // The watchdog timer was increased to 8.5 minutes. This is considered
    // enough time to get into a machine to take care of business (either
    // disable CTP operation or the watchdog timer), so this function will
    // not be used for now.
  }

  //---------- Execute CTP TIMER task ----------
  if(i_am_timer_task)
  {
    PRT(GEN,Timer Task successfully started);
    ctp_timer_daemon();
    exit(0);		// Should never return, but in case it does...
  }

  //---------- Execute CTP NET task ----------
  if(i_am_net_task)
  {
    PRT(GEN,CTP Net Task successfully started);
    NetTaskRunning = YES;
    (void)signal(SIGTERM, (void *)ctp_netd_stop);
    ctp_open_socket_for_rx();	// Listen to all IP addresses on OAM UDP port
    ctp_net_daemon();
    exit(0);		// Should never return, but in case it does...
  }

  //-----------------------------------------------
  // If we got this far, this function was not called with an option
  // so this is the master daemon. So, we need to execute this task
  // a few more times to start up all the other subtasks (which call
  // this program again, but with the options set.
  //-----------------------------------------------

#ifndef NO_FORK
  //---------- Start CTP TIMER task ----------
  ChildPid = fork();

  if(ChildPid == 0)	// If I am the forked task
  {
    PRT(GEN,I (CTP Timer Task) have successfully forked from the main task);
    execlp("/acorn/bin/ctpd","/acorn/bin/ctpd","-t",NULL);
    exit(1);
  }
  else	// I am the parent task
  {
    Ctp.Task[CTP_TIMER_TASK].Pid = ChildPid;
    PRT(GEN,I successfully forked the Timer Task);
  }

  //--------- Start CTP NET task ----------
  ChildPid = fork();

  if(ChildPid == 0)	// If I am the forked task
  {
    char opt_p[10], opt_o[10];
    sprintf(opt_p,"-p %d", pSysInfo->oam_port);
    sprintf(opt_o,"-o %d", pSysInfo->oam_port_v6);
    PRT(GEN,I (CTP Net Task) successfully forked from the main task);
    execlp("/acorn/bin/ctpd","/acorn/bin/ctpd","-n",opt_p, opt_o,NULL);
    exit(1);
  }
  else
  {
    Ctp.Task[CTP_NET_TASK].Pid = ChildPid;
    PRT(GEN,I successfully forked the Net Task);
  }
#endif	// NO_FORK

  //--------- Continue with parent CTP task ----------

  //crash_func();			// crash parent ctp task only

  //-------- Init shared memory

  // This is shared memory for storing Voice signaling information. For
  // Analog Voice cards in particular, where each port has only one
  // channel, the ports Chan[x] storage is used for various AV specific
  // storage (see pVcSigs macros in ctp.h)
  PRT(GEN,Init shared memory);
  if((shmid = shmget(CTP_SIG_SHM_KEY, sizeof(CTP_VC_SIG_STATE), IPC_CREAT | 0666)) < 0) {
    PRT(MIN,Problems getting shared memory for vcsigs);
  } else {
    if((pVcSigs = (CTP_VC_SIG_STATE *)shmat(shmid, NULL, 0)) == (CTP_VC_SIG_STATE *) -1) {
      PRT(MIN,Problems attaching sharred memory);
    } else {
      int s, p, c;
      for(s=0; s<CTP_MAX_CARDS;s++) {
	for(p=0; p<CTP_MAX_PORTS_ON_CARD;p++) {
	  pVcSigs->Card[s].hRes[p] = VBBAD_HANDLE;
	}
      }
    }
  }
  // This is shared memory for storing NetRef information
  if((shmid = shmget(CTP_REF_SHM_KEY, sizeof(CTP_NREFS_STATE), IPC_CREAT | 0666)) < 0) {
    PRT(MIN,Problems getting shared memory for node refs);
  } else {
    if((pNRefs = (CTP_NREFS_STATE *)shmat(shmid, NULL, 0)) == (CTP_NREFS_STATE *) -1) {
      PRT(MIN,Problems attaching sharred memory);
    } else {
      //--- Init shared memory....
    }
  }

  // ctp_check() determines what hardware is available. By performing
  // an IOCTL to the driver, we can find out if what type of CTP hardware is
  // in the system. If not, there is no reason to continue. Also, if hardware
  // is found, its revision is stored. This is why this function is called
  // after ctp_init_ctp();
  // --- sets port <-> scc# mapping
  //     sets pSysInfo->SysType
  //     sets pSysInfo->PortsPerCard
  //     sets pSysInfo->Card[slot].PortsOnCard
  //     sets pSysInfo->Card[c].Type flag
  //     sets Ctp.Card[c].Port[pn].available flag
  //
  //     Also sets pSysInfo->Unusable = 1 if any CTP-2000 fpga revs or
  //     load_winmon revs are wrong.
  if(ctp_check()) {
    fprintf(stderr,"Problem starting Acorn CTP daemon\n");
    fprintf(stderr,"Check /var/log/messages for more info.\n");
    exit(1);
  }
  // Aricent PR-947222 Start
  //--- ctp_scan_hw() get daughter card info & checks that winmon is running.
  if( pSysInfo->SystemUnusable ) {
    PRTV(MIN,==============>System is unusable so skipping rest of system startup,pSysInfo->SystemUnusable);
    PRTDV(MIN,==============>System is unusable so skipping rest of system startup,pSysInfo->SystemUnusable);
    //printf("==============>System is unusable so skipping rest of system startup : %d\n", pSysInfo->SystemUnusable);
    PRT(MIN,System is unusable so skipping rest of system startup);
  } else {
    ctp_scan_hw();
    //PRT(OFF,Finished ctp_scan_hw);
  }
  // Aricent PR-947222 End 

  // PR 855242 - The following section of code was suppose to handle the
  // upgrade process automatically when the need was detected, but this is
  // frought with problems. So for now, we are going to make the
  // update_cards process initiated by the user and see if this is a
  // problem.
  //Aricent PR 596068 fix - Start
  if( chk_sys_unusable_fpga() ) {
    acorn_system("echo 0 > /tmp/fpga_fail");
    fprintf(stderr,"Some card FPGAs have incorrect versions.\n");
    fprintf(stderr,"Attempting to automatically upgrade cards.\n");
    PRT(MIN,Attempting to automatically upgrade cards);
  }
  //Aricent PR 596068 fix - End

  sprintf(&dbaseFile[0],"%s/%s", CTP_DB_DIR, CTP_DB_FILE );
  ctp_dbase_read( &Db, dbaseFile); // needed configuration to get started right
  //PRT(OFF,Finished ctp_dbase_read);

  // Now that we know systype, check system specific requirements, eg refs
  ctp_check_dbase();
  //PRT(OFF,Finished ctp_check_dbase);
  
  // Save database after check
  ctp_dbase_write( &Db, dbaseFile );

  if( pSysInfo->ipProtocol != 1 ) {
    util_ip_string(Ctp.LocNode.v4, ips);
    PRTS(GEN,IPv4 enabled with local host IP:, ips);
    PRT(MIN,IPv4 enabled);
  } else {
    u32 tmpaddr;
    sprintf(ips, "127.0.0.1");
    inet_pton(AF_INET, ips, &tmpaddr);
    Ctp.LocNode.v4 = htonl(tmpaddr);
    util_ip_string(Ctp.LocNode.v4, ips);
    PRTS(GEN,Local host IPv4 address set to loopback:, ips);
    PRT(MIN,IPv4 disabled);
  }
  if( pSysInfo->ipProtocol != 0 ) {
    inet_ntop(AF_INET6, &Ctp.LocNode.v6, ips, sizeof(ips));
    PRTS(MIN,IPv6 enabled with local host IP:, ips);
  } else {
    sprintf(ips, "::1");
    inet_pton(AF_INET6, ips, &Ctp.LocNode.v6);
    inet_ntop(AF_INET6, &Ctp.LocNode.v6, ips, sizeof(ips));
    PRTS(GEN,Local host IPv6 address set to loopback:, ips);
    PRT(MIN,IPv6 disabled);
  }
  ctp_update_enable_trap_info();// Aricent PR 1356307 fix

  //--------- Store SNMP info to CTP structure ----------
 Status = ctp_update_trap_info();
 system("/acorn/perl/scripts/trap_clock.pl set 2>/dev/null"); //PR-1846896 
// BAILTESTF(Status,Couldnt get snmp trap info);
  //PRT(OFF,Finished ctp_update_trap_info);

  //ctp_wr_qinfo_to_file();
  openlog("ctpd",0,LOG_DAEMON);    // TODO 9.1R1 - Not working
  if( !pSysInfo->SystemUnusable ) {
    ctp_scan_db();			// Bundles brought up here
#ifndef VCTP
    for(i=0;i<pSysInfo->CardsPerCpu;i++) {
#else
    int c_idx;
    for(c_idx = 0; c_idx<pSysInfo->CardsPerCpu; c_idx++) {
      i = cardIndx[c_idx];
#endif
      if(SCC_CARD(i)) {			// Reference processing started here
	ctp_get_pll_cal(i);
	ctp_get_vcxo_range(i);
      }
    }
  }

  ctp_get_eeprom_text();   
  //PRT(OFF,Finished ctp_get_eeprom_text);

  memset(&Session[0],INACTIVE_H,CTP_MAX_SESSIONS);	// Clear all sessions

  memset(snmpTrapBuf, 0, (SNMP_TRAP_BUF_RING_SIZE * SNMP_TRAP_BUF_SIZE));

  //--- Check that eth devices have access to scc0 for generating
  //    timestamps. NEED to worry about AAS doing ethernet failover on us
  //    and losing the connection to ssc0?
  //--- Use set_config (?) as function call from eth dev to scc?
  //    -> set_config( struct net_device *dev, struct ifmap *map);
  //      -> See if.h for ifmap struct def.
  //      -> ifmap->port used to specify media type (see sis900 driver).
  //      Use magic key to specify hrc read request (eg 0xff or anything > 0x6)
  //      Must move all info under dev (dpriv) structure.
  //    -> Check in eth dev if it is null!
  //    -> get scc0 via:
  //         sprintf(DevBuf,"scc",0);
  //         pSDev = dev_get_by_name(DevBuf);
  //         dev_put(pSDev);
  //    Don't even try if there is no scc on card 0
  if( SCC_CARD(0) ) {
    start_netref = 1;
/*** PR1311627 - start ***/
#ifdef XMC
/****
 * Setting count rate (NOVA_CARD_TEST_REG [31:28]) to 32MHz
 * which make vCTP's count rate backward compatible with
 * CTP nodes (runs 32MHz count rate).
 * */
    struct acrndrv_command ncmd;
    memset(&ncmd, 0 , sizeof(struct acrndrv_command));
    ncmd.CmdType = SCC_CMD_TEST_READ_REG;
    ncmd.CmdObj = NOVA_CARD_TEST_REG; 
    ncmd.CmdObj2 = 0;
    ioc_priv("scc0",SCC_IOCTL_CMD,&ncmd); 
    if ( (ncmd.CmdObj2 & 0x10000000) != 0x10000000 ) {
      ncmd.CmdType = SCC_CMD_TEST_WRITE_REG;
      ncmd.CmdObj = NOVA_CARD_TEST_REG; 
      ncmd.CmdObj2 |= 0x10000000;
      ioc_priv("scc0",SCC_IOCTL_CMD,&ncmd);
    }
#endif
/*** PR1311627 - end ***/
  }
  //--- Start netref 
  if( start_netref ) {
    nr_sock = ctp_netref_open_socket();
    ChildPid = fork();
    if(ChildPid == 0) { ctp_netref_server(nr_sock); }
    else { Ctp.Task[CTP_NETREF_SERVER].Pid = ChildPid; }
    ChildPid = fork();
    if(ChildPid == 0) { ctp_netref_client(nr_sock); }
    else { Ctp.Task[CTP_NETREF_CLIENT].Pid = ChildPid; }
    ChildPid = fork();
    if(ChildPid == 0) { ctp_netref_ts_proc(); }
    else { Ctp.Task[CTP_NETREF_TSPROC].Pid = ChildPid; }
  }

#if 0	// TODO Executing this block causes acorn_system( ) calls to fail
  if( pSysInfo->SysType == SYS_TYPE_CTP_2000 ) {
    ChildPid = fork();
    if(ChildPid == 0) { 
      ctp_check_ipmi_ps(1); // initial check for ipmi capabitlity;
      exit(0);
    } else { 
      struct sigaction my_action;
      Ctp.Task[CTP_IPMI_MON].Pid = ChildPid; 
  // ignore SIGCLD signal when child process terminates.
      my_action.sa_handler = SIG_IGN;
      sigaction (SIGCLD, &my_action, NULL);    
    }
  }
#endif
  if( pSysInfo->SysType  == SYS_SUBTYPE_CTP_150 ) {
      Status = acorn_system("/acorn/perl/scripts/sensors_pwr_fan.pl -l sys_on");
      if(Status) {
          PRT(MIN,Failed to Setting the LED sys_on );
      }
  }
/* ARICENT Fix Start PR595506 */ 
/* WRL - TODO currently this is not required for non-dd right now(under testing phase)**/
# if 0 
   for( intf=0; intf<CTP_MAX_NID; intf++) {
      if( pSysInfo->interface[intf].type == CTP_IF_TYPE_ETH) {
         // PR 689121, cannot IOCTL VLAN ports.
         if( strlen(pSysInfo->interface[intf].name) <= 5) {
           sprintf(EthBuf, "%s", pSysInfo->interface[intf].name);
           status = ioc_priv(EthBuf,ETH_GET_RUNTIME_CFG,&erc);
           BAILTESTF(status,Cant IOCTL eth);
           erc.protocol  = pSysInfo->protocol;
           status = ioc_priv(EthBuf,ETH_SET_RUNTIME_CFG,&erc);
           BAILTESTF(status,Cant IOCTL eth);
         }
      }
    }
#endif
/* ARICENT Fix End PR595506 */ 
  //-----------------------------------------------
  //----------------- Main Loop -------------------
  //-----------------------------------------------

  //--- Flush any stale messages from the Queue ---
  do
  {
    Status = msgrcv(Ctp.Task[CTP_TASK].Qid,
	(CTP_Q_MSG *)&RMsg,
	CTP_MAX_MSG_SIZE,
	0, 				// Receive all IPC mtypes
	IPC_NOWAIT );
    PRTDV(GEN,Flushing message queue Status:,Status);
    if(Status != -1)
    {
      PRT(EVE,Flushed stale message from IPC Queue);
    }
  } while ( (Status != -1) && (errno != ENOMSG));

  //Status = msgctl(Ctp.Task[CTP_TASK].Qid, IPC_STAT, &msg_ds_buf );
  //PRTDV(MAJ,Message queue bytes, msg_ds_buf.msg_qbytes);
  // Wait on my Queue and Process incoming messages
 //--------- Initialize semaphore for menu/cmd access ----------
  initSemaphore( CTPD_KEY_NUM + CTP_MENU_SEMAPHORE );

  while(StayInProgram == YES)
  {
    /* Read any message from the queue */
    msgrcv(Ctp.Task[CTP_TASK].Qid,
	(CTP_Q_MSG *)&RMsg,
	CTP_MAX_MSG_SIZE,
	0, 				// Receive all IPC mtypes
	0 );
    //util_mtype_string(RMsg.CtpMsg.MsgType,Buf);
    //PRTS(GEN,--- CTP Msg rcvd,Buf);
    //util_prt_msg(&RMsg);
    //PRTDV(OFF,--- CTP Msg rcvd - mtype,RMsg.mtype);

    if( RMsg.mtype == 1 ) {
      ctp_proc_msg_ses_id(&RMsg);
    } else {
      if( !pSysInfo->SystemUnusable ) {
	switch(RMsg.CtpMsg.MsgType) {
	  case CTPMSGTYPE_TIMER:
	    ctp_proc_msg_timer(&RMsg);
	    break;
	  case CTPMSGTYPE_RDNT_LINK_OAM:
	    PRT(DBG,Rcvd Rdnt link OAM Msg);	// DBG since very often
