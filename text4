int ctp_ts_state_add_sn_src(u16 seq_num, CTP_NODE_STORAGE node)
{
  int stat = FAILURE;
  int i,j;
  FUNC_PRT(ctp_ts_state_add_sn_src, PF_REF, -1);

  for(j=0; j<CTP_MAX_TS_STATE; j++){
    i = (j + pNRefs->last_indx) % CTP_MAX_TS_STATE;
    if(pNRefs->TsState[i].state == CTP_TS_STATE_UNUSED) {
      char buf[80];
      //--- Copy seq_num & node
      pNRefs->TsState[i].seq_num = seq_num;
      memcpy(&pNRefs->TsState[i].node, &node, sizeof(CTP_NODE_STORAGE));
      //--- Set state to wait.
      pNRefs->TsState[i].state = CTP_TS_STATE_WAIT;
      pNRefs->TsState[i].age = 0;	// Reset
      stat = SUCCESS;
      sprintf(buf,"Added sn %d to location %d state set to wait.",seq_num,i);
      PRTS(GN2,, buf);
      pNRefs->last_indx = i;
      break;
    } else {
      if( pNRefs->TsState[i].age++ >= CTP_MAX_TS_AGE ) { ctp_ts_state_clear(i); }
    }
  }
  return(stat);
}

