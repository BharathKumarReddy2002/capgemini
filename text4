// This function check the packet protector configuration for bidirectional bundles.
// If any configuration mismatch then bundle state change into MisCfg state.
int ctp_chk_pkt_protect_cfg_endpoints( int Card, int pNum, CTP_Q_MSG * ptr)
{
  CTP_OAM_MSG           *pMsg                     = &(((CTP_Q_OAM_MSG *)ptr)->CtpMsg);
  CTP_MSG_REM_OAM       *pMsgOam                  = &(pMsg->msg.RemOam);
  CTP_PORT_DBASE        *pPortDb                  = (CTP_PORT_DBASE *)&Db.Card[Card].Port[pNum];
  int                    bNum                     = util_get_next_bNum(pPortDb , -1);
  CTP_BNDL_DBASE        *pDbB                     = (CTP_BNDL_DBASE *)&Db.Bndl[bNum];
  u8                     PPCfg                    = pDbB->Bndl.cp_bndl.PktProtect;
  u8                     mask_send                = PP_CLONE_OUT;
  u8                     mask_rcv                 = PP_CLONE_IN;
  u8                     mask_send_and_rcv        = PP_CLONE_OUT | PP_CLONE_IN;
  u8                     mask_send_dly            = PP_CLONE_OUT | PP_CLONE_DELAY;
  u8                     mask_send_and_rcv_dly    = PP_CLONE_IN | PP_CLONE_OUT | PP_CLONE_DELAY;
  u8                     mask_rcv_xor             = PP_CLONE_IN | PP_CLONE_XOR;
  u8                     mask_send_xor            = PP_CLONE_OUT | PP_CLONE_XOR;
  u8                     mask_send_and_rcv_xor    = PP_CLONE_IN | PP_CLONE_OUT | PP_CLONE_XOR;
  char                   buf[120];

  FUNC_PRT (ctp_chk_pkt_protect_cfg_endpoints, PF_PST, pNum);
  if( UNI_DIR_DST(Card, pNum)){
    if(ctp_chk_pp_uni_dir_dst(Card, pNum, PPCfg, ptr)== SUCCESS) {
      PRTP(GN3, "Passed: Packet protector configuration passed for unidirectional destination");
      return(SUCCESS);
    } else {
      PRTP(MAJ, "Mismatch: Packet protector configuration failed for unidirectional destination");
      return(FAILURE);
    }
  }
  if( ((PPCfg == mask_send             ) && (pMsgOam->PktProtect == mask_rcv              )) ||
      ((PPCfg == mask_rcv              ) && (pMsgOam->PktProtect == mask_send             )) ||
      ((PPCfg == mask_send_and_rcv     ) && (pMsgOam->PktProtect == mask_send_and_rcv     )) ||
      ((PPCfg == mask_send_and_rcv     ) && (pMsgOam->PktProtect == mask_send_and_rcv_dly )) ||
      ((PPCfg == mask_send_and_rcv_dly ) && (pMsgOam->PktProtect == mask_send_and_rcv     )) ||
      ((PPCfg == mask_send_and_rcv_dly ) && (pMsgOam->PktProtect == mask_send_and_rcv_dly )) ||
      ((PPCfg == mask_send_dly         ) && (pMsgOam->PktProtect == mask_rcv              )) ||
      ((PPCfg == mask_rcv              ) && (pMsgOam->PktProtect == mask_send_dly         )) ||
      ((PPCfg == mask_send_xor         ) && (pMsgOam->PktProtect == mask_rcv_xor          )) ||
      ((PPCfg == mask_rcv_xor          ) && (pMsgOam->PktProtect == mask_send_xor         )) ||
      ((PPCfg == mask_send_and_rcv_xor ) && (pMsgOam->PktProtect == mask_send_and_rcv_xor )) ) {
    sprintf(buf,"Passed: Incoming OAM PP field: 0x%x Local db PP field: 0x%x", pMsgOam->PktProtect , PPCfg);
    R_PRTS(GN3,,buf);
    return(SUCCESS);
  }
  sprintf(buf,"Mismatch: Incoming OAM PP field: 0x%x Local db PP field: 0x%x", pMsgOam->PktProtect , PPCfg);
  R_PRTS(EVE,,buf);
  return(FAILURE);
}

// This function check packet protector configuration for Unidirectional src.
// If any configuration mismatch then bundle state change into MisCfg state.
int ctp_chk_pp_uni_dir_src(int Card, int pNum)
{
  CTP_PORT_DBASE        *pPortDb                  = (CTP_PORT_DBASE *)&Db.Card[Card].Port[pNum];
  int                    bNum                     = util_get_next_bNum(pPortDb , -1);
  CTP_BNDL_DBASE        *pDbB                     = (CTP_BNDL_DBASE *)&Db.Bndl[bNum];
  u8                     PPCfg                    = pDbB->Bndl.cp_bndl.PktProtect;
  u8                     mask_send                = PP_CLONE_OUT;
  u8                     mask_rcv                 = PP_CLONE_IN;
  u8                     mask_send_and_rcv        = PP_CLONE_OUT | PP_CLONE_IN;
  u8                     mask_send_dly            = PP_CLONE_OUT | PP_CLONE_DELAY;
  u8                     mask_send_and_rcv_dly    = PP_CLONE_IN | PP_CLONE_OUT | PP_CLONE_DELAY;
  u8                     mask_rcv_xor             = PP_CLONE_IN | PP_CLONE_XOR;
  u8                     mask_send_xor            = PP_CLONE_OUT | PP_CLONE_XOR;
  u8                     mask_send_and_rcv_xor    = PP_CLONE_IN | PP_CLONE_OUT | PP_CLONE_XOR;
  char                   buf[120];
  FUNC_PRT (ctp_chk_pp_uni_dir_src, PF_PST, pNum);

  if ( PPCfg == PP_CLONE_DISABLE){
    PRTP(GN3, skip packet protector check );
    return(SUCCESS);
  }
  if( (PPCfg == mask_send) || (PPCfg == mask_send_dly) || (PPCfg == mask_send_xor)) {
    sprintf(buf,"Passed: Local db PP field: 0x%x", PPCfg);
    R_PRTS(GN3,,buf);
    return(SUCCESS);
  }
  sprintf(buf,"Mismatch: Local db PP field: 0x%x", PPCfg);
  R_PRTS(EVE,,buf);
  return(FAILURE);
}

