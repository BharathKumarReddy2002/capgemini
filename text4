#ifdef TARGET
      PpmValue += ncmd.CmdObj2 << 8;
#else // not TARGET
      PpmValue = 100;                           // Bogus value
#endif // TARGET
    } // CAP PR - 1739392 End
  }

  // PpmValue cann't be 0 or larger than 0x8000
  if((!PpmValue) || ( (PpmValue & 0x8000) == 0 )) {
    Ctp.Node[Card].VcxoPpmRange = PpmValue;	// Good value, set struct
    PRTU16C(EVE,Valid VcxoPpmRange value,PpmValue);
