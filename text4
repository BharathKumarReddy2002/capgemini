//-------------------------------------------------------------------------
// This function will configure various 4WTO daughter card parameters
// and clear it to 0.
//-------------------------------------------------------------------------
int dcard_4w_set_config(int Card, int pNum, int IoEn, int SingleEnded, int Loop,
			int SigEn, int DualChan, int Chan)
{
  u32 data;
  int sccNum = Ctp.Card[Card].Port[pNum].SccNum;
  FUNC_PRT(dcard_4w_set_config, PF_DCARD, pNum);

  BAILTESTF(IoEn>1,Invalid IoEnable ID);
  BAILTESTF(SingleEnded>1,Invalid SingleEnded ID);
  BAILTESTF(Loop>1,Invalid Loop ID);
  BAILTESTF(SigEn>1,Invalid SigEn ID);
  BAILTESTF(DualChan>1,Invalid DualChan ID);
  BAILTESTF(Chan>1,Invalid Channel ID);
  //----- Configure CARD_CFG register
  data = 0;
  if( IoEn ) data |= 0x1;
  if( SingleEnded ) data |= 0x2;
  if( Loop ) data |= 0x4;
  if( SigEn ) data |= 0x8;
  fpga_clr_fcfg();
  pld_set_reg(pNum,0x0,data,2);
  fpga_send_fcfg(sccNum);

  //----- Configure CARD_CFG register
  data = 0;
  if( DualChan ) {
    data |= 0x3;
  } else {
    if( Chan )	data |= 0x2;
    else	data |= 0x1;
  }
  fpga_clr_fcfg();
  pld_set_reg(pNum,0x1,data,2);
  fpga_send_fcfg(sccNum);

  return(SUCCESS);
}

//-------------------------------------------------------------------------
// This function writes an 8 bit codeword to a 6 bit addr on the T1 LIU.
//-------------------------------------------------------------------------
int dcard_t1_set_liu_reg( int Card, int pNum, u32 Addr, u32 Data )
{
  u32 paddr = 0x4;				// PLD address of LIU SIO
  u32 pdata;
  int	i;
#ifdef DBG_T1E1
  char			Buf[100];
#endif
  int sccNum = Ctp.Card[Card].Port[pNum].SccNum;
  FUNC_PRT(dcard_t1_set_liu_reg, PF_DCARD, pNum);

  //------------ Init: Set CSn active/Clk low & send Cmd bit (0) -----------
  fpga_clr_fcfg();
  pdata = 0x0;					// Write command
  pld_set_reg( pNum, paddr, pdata, 0x2 );	// CSn and CLK low
  pdata |= 0x2;					// Set clock High
  pld_set_reg( pNum, paddr, pdata, 0x2 );	// CLK high
  fpga_send_fcfg(sccNum);
  //-------------- Output address (7 bits) ----------------
  fpga_clr_fcfg();
  for(i=1;i<8;i++) {				// A0 is skipped (R/W bit)
    if( (1<<i) & Addr )	pdata = 0x4;		// Clk low, w/ Addr bit high
    else		pdata = 0x0;		//              "    "  low
    pld_set_reg( pNum, paddr, pdata, 0x2 );
    pdata |= 0x2;				// Clk High
    pld_set_reg( pNum, paddr, pdata, 0x2 );
    fpga_send_fcfg(sccNum);
    fpga_clr_fcfg();
  }
  //-------------- Output data (8 bits) ----------------
  fpga_clr_fcfg();
  for(i=0;i<8;i++) {
    if( (1<<i) & Data ) pdata = 0x4;		// Clk low, w/ Data bit high
    else		pdata = 0x0;		//              "    "  low
    pld_set_reg( pNum, paddr, pdata, 0x2 );
    pdata |= 0x2;				// Clk High
    pld_set_reg( pNum, paddr, pdata, 0x2 );
    fpga_send_fcfg(sccNum);
    fpga_clr_fcfg();
  }
  //-------------- Finish: Set CSn inactive ----------
  fpga_clr_fcfg();
  pdata = 0x1;					// CSn high
  pld_set_reg( pNum, paddr, pdata, 0x2 );
  fpga_send_fcfg(sccNum);

#ifdef DBG_T1E1
  sprintf(Buf,"Wrote    C%dP%d LIU. Addr 0x%x = 0x%x",Card,pNum,Addr,Data);
  PRTS(MIN,,Buf);
  dcard_t1_get_liu_reg( Card, pNum, Addr, (u32 *)&pdata );
  sprintf(Buf,"Readback C%dP%d LIU. Addr 0x%x = 0x%x",Card,pNum,Addr,pdata);
  PRTS(MIN,,Buf);
  if( (Addr != 0x22) && (Data != pdata) ) {
    PRT(MIN,!!! T1E1 DCard write verification failed !!!);
  }
#endif

  return(0);
}

