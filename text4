//-------------------------------------------------------------------------
// This function writes an 8 bit codeword to a 6 bit addr on the T1 LIU.
//-------------------------------------------------------------------------
int dcard_t1_get_liu_reg( int Card, int pNum, u32 Addr, u32 * pData )
{
  u32 paddr = 0x4;				// PLD address of LIU SIO
  u32 pdata, rdata;
  int	i;
#ifdef DBG_T1E1
  char			Buf[100];
#endif
  int sccNum = Ctp.Card[Card].Port[pNum].SccNum;
  FUNC_PRT(dcard_t1_get_liu_reg, PF_DCARD, pNum);

#ifdef LIU_READ_IN_DRIVER
  fpga_clr_fcfg();
  pld_get_liu_reg( pNum, Addr);
  fpga_send_fcfg(sccNum);
  pld_get_reg_val( 0, pData );
#else
  //------------ Init: Set CSn active/Clk low & send Cmd bit (1) -----------
  *pData = 0;					// Clear read storage
  fpga_clr_fcfg();
  pdata = 0x4;					// Read command
  pld_set_reg( pNum, paddr, pdata, 0x2 );	// CSn and CLK low
  pdata |= 0x2;					// Set clock High
  pld_set_reg( pNum, paddr, pdata, 0x2 );	// CLK high
  fpga_send_fcfg(sccNum);
  //-------------- Output address (7 bits) ----------------
  fpga_clr_fcfg();
  for(i=1;i<8;i++) {				// A0 is skipped (R/W bit)
    if( (1<<i) & Addr ) pdata = 0x4;		// Clk low, w/ Addr bit high
    else		pdata = 0x0;		//              "    "  low
    pld_set_reg( pNum, paddr, pdata, 0x2 );
    pdata |= 0x2;				// Clk High
    pld_set_reg( pNum, paddr, pdata, 0x2 );
    fpga_send_fcfg(sccNum);
    fpga_clr_fcfg();
  }
  //-------------- Input data (8 bits) ----------------
  fpga_clr_fcfg();
  for(i=0;i<8;i++) {
    pdata = 0x0;				// Clk Low
    pld_set_reg( pNum, paddr, pdata, 0x2 );
    pdata |= 0x2;				// Clk High
    pld_set_reg( pNum, paddr, pdata, 0x2 );
    pld_get_reg( pNum, paddr, 0x2 );		// Read serial data out
    fpga_send_fcfg(sccNum);
    pld_get_reg_val( 2, (u32 *)&rdata );
    if(0x1 & rdata) *pData |= (0x1 << i);	// Store bit to register
    fpga_clr_fcfg();
  }
  //-------------- Finish: Set CSn inactive ----------
  fpga_clr_fcfg();
  pdata = 0x1;					// CSn high
  pld_set_reg( pNum, paddr, pdata, 0x2 );
  fpga_send_fcfg(sccNum);
#endif

#ifdef DBG_T1E1
  sprintf(Buf,"Read     C%dP%d LIU. Addr 0x%x = 0x%x",Card,pNum,Addr,*pData);
  PRTS(MIN,,Buf);
#endif

  return(0);
}

//-------------------------------------------------------------------------
// This function sends a trap
//-------------------------------------------------------------------------
int ctp_trans_trap(void)
{
  int i, j, status = SUCCESS;   //Aricent PR 1362733 fix
  //char	CmdStr[150];
  FILE *fp; //PR 1401407
  FUNC_PRT(ctp_trans_trap, PF_TRAP, 0);
  if( snmpTrapBufPtrTail != snmpTrapBufPtrHead ) {
    snmpTrapBufPtrTail++;
    snmpTrapBufPtrTail %= SNMP_TRAP_BUF_RING_SIZE;
    PRTDV(GEN,Processing snmpTrapBufPtrTail,snmpTrapBufPtrTail);
    //strcpy(CmdStr,&snmpTrapBuf[snmpTrapBufPtrTail][0]);
    //PRTS(EVE,Send node trap:, CmdStr);
    for(i=0;i<CTP_MAX_TRAP_HOSTS;i++) {
      if( strcmp(Ctp.Snmp.TrapHost[i],"none") != 0 ) {
        //Aricent PR 912147 Fix
    if (is_v2 != 0) {
#ifdef WRL
        sprintf( snmpTrapCmdBuf,
            "/usr/bin/snmptrap -v 2c -c %s %s \'\' %s",
            Ctp.Snmp.TrapComm,
            Ctp.Snmp.TrapHost[i],
            &snmpTrapBuf[snmpTrapBufPtrTail][0]);
#else
        sprintf( snmpTrapCmdBuf, 
	    "/usr/local/bin/snmptrap -v 2c -c %s %s \'\' %s",
	    Ctp.Snmp.TrapComm, 
	    Ctp.Snmp.TrapHost[i], 
	    &snmpTrapBuf[snmpTrapBufPtrTail][0]);
#endif
        PRTS(EVE,Sent node trap, snmpTrapCmdBuf);
//Aricent PR 1401407 fix - start
#ifdef WRL
	fp = popen(snmpTrapCmdBuf, "r");
	if(!fp){
          PRTS(EVE, Could not open pipe for output, snmpTrapCmdBuf);
          PRT(MAJ,send_trap: system call failed.);
          status = FAILURE;
//PR-1846896 Start
        } else {
          pclose(fp); 
	}//PR-1846896 End
#else
        if( acorn_system(snmpTrapCmdBuf) ) {
          PRT(MAJ,send_trap: system call failed.);
          status = FAILURE;
        }
#endif
    }
    if (Ctp.Snmp.TrapType == 3) {
       for(j=0;j<CTP_MAX_TRAP_HOSTS;j++) {
#ifdef WRL
          if( strcmp(Ctp.Snmp.TrapUser[j],"none") != 0 ) {
              sprintf( snmpTrapCmdBuf,
                  "/usr/bin/snmptrap -e %s -v 3 -u %s -a SHA -A %s -x AES %s \'\' %s",
                  Ctp.Snmp.TrapEngine, Ctp.Snmp.TrapUser[j],
                  Ctp.Snmp.TrapPass[j], Ctp.Snmp.TrapHost[i],
                  &snmpTrapBuf[snmpTrapBufPtrTail][0]);
              PRTS(EVE,Sent node trap, snmpTrapCmdBuf);

              fp = popen(snmpTrapCmdBuf, "r");
              if(!fp){
                PRTS(EVE, Could not open pipe for output, snmpTrapCmdBuf);
                PRT(MAJ,send_trap: system call failed.);
                status = FAILURE;
//PR-1846896 Start
              } else {  
                pclose(fp);
	      } //PR-1846896 End 
          }
#else
          if( strcmp(Ctp.Snmp.TrapUser[j],"none") != 0 ) {
              sprintf( snmpTrapCmdBuf,
                  "/usr/local/bin/snmptrap -e %s -v 3 -u %s -a SHA -A %s -x AES %s \'\' %s",
                  Ctp.Snmp.TrapEngine, Ctp.Snmp.TrapUser[j],
                  Ctp.Snmp.TrapPass[j], Ctp.Snmp.TrapHost[i],
                  &snmpTrapBuf[snmpTrapBufPtrTail][0]);
              PRTS(EVE,Sent node trap, snmpTrapCmdBuf);

              if( acorn_system(snmpTrapCmdBuf) ) {
                PRT(MAJ,send_trap: system call failed.);
                status = FAILURE;
              }
          }
#endif
       }
    }
//Aricent PR 1401407 fix - End
      } else { break; }	// hit a "none", so stop processing traps
    }
    memset(&snmpTrapBuf[snmpTrapBufPtrTail][0], 0, SNMP_TRAP_BUF_SIZE);
  }
  return status;
}

//-------------------------------------------------------------------------
// This function assembles a trap message
//-------------------------------------------------------------------------
int ctp_send_trap( int Card, int pNum, int Type, int Val )
{
  char	pBufType[100], pBufStr[300], pBuf2[100], CmdStr[400]; //Aricent PR687736 & PR1054258
  char	* pBuf3;
  int   status = SUCCESS;
  int   i;
#ifdef VCTP
  int c_idx;
#endif

  FUNC_PRT(ctp_send_trap, PF_TRAP, pNum);

  /* Aricent PR1054258 : START */
  char pDesc[65]={0};
  char bDesc[65]={0};
  if((Type >= 0 && Type <= 4) || (Type >= 11 && Type <=13)) 
     { // Aricent PR 1362733 fix
	CTP_BNDL_DBASE        *pDbB = &Db.Bndl[trap_bNum];
	int my_Card = util_bndl_src_card(0, pDbB);
	int my_pNum = util_bndl_src_pNum(0, pDbB);

	CTP_PORT_DBASE * pDbP;
	pDbP = &Db.Card[my_Card].Port[my_pNum];
	sprintf(pDesc,"%s", pDbP->PortDesc);

	sprintf(bDesc,"%s", Db.Bndl[trap_bNum].BndlDesc);
  }
  /* Aricent PR1054258 : END */

  PRTDV(GN3,trap Card, Card);
  PRTDV(GN3,trap pNum, pNum);
  PRTDV(GN3,trap Type, Type);
  PRTDV(GN3,trap  Val,  Val);

  /* CAP PR 1852567 : START */
  if((Type == 15)) {
    CTP_PORT_DBASE *pDbP = &Db.Card[Card].Port[pNum];
    int bNum = util_get_next_bNum(pDbP, -1);
    trap_bNum=bNum;
    sprintf(pDesc,"%s", pDbP->PortDesc);
    sprintf(bDesc,"%s", Db.Bndl[trap_bNum].BndlDesc);
  }
 /* CAP PR 1852567 : END */

  if( Ctp.Snmp.TrapAble ) {
    switch(Type) {
      case TRAP_PT_STCHG:
	pBuf3 = CTP_TRAP_PORT_RUNSTATE;
	strcpy(pBufType,"s");
	util_pstate_string(Val,pBuf2);
	sprintf(pBufStr,"\"Port %d/%d state changed to %s BD : %s, PD : %s\"",Card, pNum, pBuf2, bDesc, pDesc);
	break;
      case TRAP_PT_UFLOW:
	pBuf3 = CTP_TRAP_PORT_UFLOW;
	strcpy(pBufType,"s");
	sprintf(pBufStr,"\"Port %d/%d Underflowed. Count = %d BD : %s, PD : %s\"",Card,pNum,Val, bDesc, pDesc);
	break;
      case TRAP_PT_OFLOW:
	pBuf3 = CTP_TRAP_PORT_OFLOW;
	strcpy(pBufType,"s");
	sprintf(pBufStr,"\"Port %d/%d Overflowed. Count = %d BD : %s, PD : %s\"",Card,pNum,Val, bDesc, pDesc);
	break;
      case TRAP_PT_STARVE:
	pBuf3 = CTP_TRAP_PORT_STARVE;
	strcpy(pBufType,"s");
	sprintf(pBufStr,"\"Port %d/%d Starved. Count: %d BD : %s, PD : %s\"",Card,pNum,Val, bDesc, pDesc);
	break;
      case TRAP_PT_MISSING:
	pBuf3 = CTP_TRAP_PORT_MISSING;
	strcpy(pBufType,"s");
	sprintf(pBufStr,"\"Port %d/%d missing packets. Count: %d  BD : %s, PD : %s\"",Card,pNum,Val, bDesc, pDesc);
	break;
      case TRAP_PT_LATE:
	pBuf3 = CTP_TRAP_PORT_LATE;
	strcpy(pBufType,"s");
	sprintf(pBufStr,"\"Port %d/%d has late packets. Count: %d BD : %s, PD : %s\"",Card,pNum,Val, bDesc, pDesc);
	break;
      case TRAP_PT_TT_BAD:
	pBuf3 = CTP_TRAP_PORT_TT_BAD;
	strcpy(pBufType,"s");
	sprintf(pBufStr,"\"Port %d/%d TT not toggling BD : %s, PD : %s\"",Card,pNum, bDesc, pDesc);
	break;
      case TRAP_PLL_REF_CHG:
	pBuf3 = CTP_TRAP_PLL_REF_CHG;
	strcpy(pBufType,"s");
	util_prt_ref(Val,pBuf2);
	sprintf(pBufStr,"\"PLL Ref in use is now %s\"", pBuf2);
	break;
      case TRAP_REF_VLD_CHG:
	pBuf3 = CTP_TRAP_REF_VLD_CHG;
	strcpy(pBufType,"s");
	sprintf(pBufStr,"\"Reference %d valid = %d\"",pNum,Val);
	break;
      case TRAP_HW_FAN:
	pBuf3 = CTP_TRAP_CHASSIS_FANS;
	strcpy(pBufType,"s");
	if((pSysInfo->SysType == SYS_TYPE_CTP_2000) && 
	  (!pSysInfo->Chassis.ipmi_ps_capable)) {
	  if( Val ) { sprintf(pBufStr,"\"Fan and Power Supply OK\""); }
	  else { sprintf(pBufStr,"\"Fan and/or Power Supply fault\""); }
	} else {
	  if( Val ) { sprintf(pBufStr,"\"Fan OK\""); }
	  else { sprintf(pBufStr,"\"Fan%s fault\"",fan_pos); }  //PR :1863969 Fix
	}
	break;
      case TRAP_HW_PS:
	pBuf3 = CTP_TRAP_CHASSIS_PS;
	strcpy(pBufType,"s");
	if( Val ) { sprintf(pBufStr,"\"Power supply OK\""); }
	else { sprintf(pBufStr,"\"Power supply fault\""); }
	break;
      case TRAP_HW_TEMP:
	pBuf3 = CTP_TRAP_CHASSIS_TEMP;
	strcpy(pBufType,"s");
	if( Val ) { sprintf(pBufStr,"\"Temperatures OK\""); }
	else { sprintf(pBufStr,"\"Temperature fault\""); }
	break;
      case TRAP_T1_ALARM:
      {
        int card = 0;
	pBuf3 = CTP_TRAP_PORT_T1_ALARM;
	strcpy(pBufType,"s");
	sprintf(pBufStr, "\"LOS ");   
	for(card = 0 ; card < CTP_MAX_CARDS; card ++ ) 
	  sprintf(pBufStr, "%s %02x", pBufStr, Ctp.Card[card].t1LosPortBitMap);	
	sprintf(pBufStr, "%s LOF", pBufStr);   
	for(card = 0 ; card < CTP_MAX_CARDS; card ++ ) 
	  sprintf(pBufStr, "%s %02x", pBufStr, Ctp.Card[card].t1LofPortBitMap);	
	sprintf(pBufStr, "%s ", pBufStr);   
      }
	sprintf(pBufStr,"%s BD:%s, PD:%s\"", pBufStr, bDesc, pDesc);	//Appending Bundle-Descriptor & Port-Descriptor to Trap Msz
        break;	
      case TRAP_HW_PS_MISSING:
	pBuf3 = CTP_TRAP_PS_MISSING;
	strcpy(pBufType,"s");
	if( !Val ) { sprintf(pBufStr,"\"Power supply missing\""); }
	else { sprintf(pBufStr,"\"Power supplies present\""); }
	break;
      // Aricent PR 1173307 fix - Start
      case TRAP_PT_SDINACTIVE:
        pBuf3 = CTP_TRAP_PORT_SDINACTIVE;
        strcpy(pBufType,"s");
        sprintf(pBufStr,"\"Port %d/%d Flag : SdInactive, BD : %s, PD : %s\"", Card, pNum, bDesc, pDesc);
        break;
      // Aricent PR 1173307 fix - End
      default:
	BAILTESTm(1,Unknown TRAP type);
	status = FAILURE;
	break;
    }
    if( status == SUCCESS ) {
      snmpTrapBufPtrHead++;
      snmpTrapBufPtrHead %= SNMP_TRAP_BUF_RING_SIZE;
      if( snmpTrapBufPtrHead == snmpTrapBufPtrTail ) {
	sprintf(CmdStr,
	    "%s.%s.%s.%s %s.%s.%s.%s %s %s",  
	    CTP_TRAP_BASE, CTP_TRAP_PREFIX, CTP_TRAP_NOTIFY, pBuf3,
	    CTP_TRAP_BASE, CTP_TRAP_PREFIX, CTP_TRAP_INFO,   pBuf3,
	    pBufType, pBufStr );
	PRTS(MIN, Ring full - Cant send trap notify:, CmdStr);
	snmpTrapBufPtrHead += (SNMP_TRAP_BUF_RING_SIZE - 1);
	snmpTrapBufPtrHead %= SNMP_TRAP_BUF_RING_SIZE;
	PRTDV(GEN,snmpTrapBufPtrHead reset to,snmpTrapBufPtrHead);
      } else {
	sprintf(&snmpTrapBuf[snmpTrapBufPtrHead][0],
	    "%s.%s.%s.%s %s.%s.%s.%s %s %s",  
	    CTP_TRAP_BASE, CTP_TRAP_PREFIX, CTP_TRAP_NOTIFY, pBuf3,
	    CTP_TRAP_BASE, CTP_TRAP_PREFIX, CTP_TRAP_INFO,   pBuf3,
	    pBufType, pBufStr );

	strcpy(CmdStr,&snmpTrapBuf[snmpTrapBufPtrHead][0]);
	PRTS(GEN,Sent node trap:, CmdStr);
	PRTDV(GEN,snmpTrapBufPtrHead incr and filled at,snmpTrapBufPtrHead);
      }
    }
  }
  return status;
}

