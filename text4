int l2bridge_send_cmd(struct t_brcmd *brcmd) {
  int sock_fd;
  struct sockaddr_nl src_addr, dst_addr;
  struct nlmsghdr *nlh;
  struct msghdr msg;
  struct iovec iov;
  int err;

  FUNC_PRT(l2bridge_send_cmd, PF_START, -1);

  sock_fd = socket(PF_NETLINK, SOCK_RAW, NETLINK_USERSOCK);
  if (sock_fd < 0) {
    PRT(MAJ,Unable to open socket with l2bridge kernel module);
    return BC_RESULT_SOCK_ERR;
  }
  memset(&src_addr, 0, sizeof(src_addr));
  src_addr.nl_family = AF_NETLINK;
  src_addr.nl_pid = getpid();  /* self pid */
  src_addr.nl_groups = 0;  /* not in mcast groups */
  err = bind(sock_fd, (struct sockaddr*)&src_addr, sizeof(src_addr));
  if (err < 0) {
    PRT(MAJ,Unable to bind socket with l2bridge kernel module);
    close(sock_fd);
    return BC_RESULT_SOCK_ERR;
  }
  memset(&dst_addr, 0, sizeof(dst_addr));
  dst_addr.nl_family = AF_NETLINK;
  dst_addr.nl_pid = 0;   /* For Linux Kernel */
  dst_addr.nl_groups = 0; /* unicast */
  nlh=(struct nlmsghdr *)malloc(NLMSG_SPACE(sizeof(struct t_brcmd)));
  /* Fill the netlink message header */
  nlh->nlmsg_len = NLMSG_SPACE(sizeof(struct t_brcmd));
  nlh->nlmsg_pid = getpid();  /* self pid */
  nlh->nlmsg_flags = 0;

  memcpy(NLMSG_DATA(nlh), brcmd, sizeof(struct t_brcmd));

  iov.iov_base = (void *)nlh;
  iov.iov_len = nlh->nlmsg_len;
  memset(&msg,0,sizeof(msg));
  msg.msg_name = (void *)&dst_addr;
  msg.msg_namelen = sizeof(dst_addr);
  msg.msg_iov = &iov;
  msg.msg_iovlen = 1;
  err = sendmsg(sock_fd, &msg, 0);
  if (err < 0) {
    PRT(MAJ,Unable to communicate with l2bridge kernel module);
    close(sock_fd);
    return BC_RESULT_SOCK_ERR;
  }
  /* Read message from kernel */
  memset(nlh, 0, NLMSG_SPACE(sizeof(struct t_brcmd)));
  err = recvmsg(sock_fd, &msg, 0);
  if (err < 0) {
    PRT(MAJ,Unable to receive message from l2bridge kernel module);
    close(sock_fd);
    return BC_RESULT_SOCK_ERR;
  }

  memcpy(brcmd, NLMSG_DATA(nlh), sizeof(struct t_brcmd));

  /* Close Netlink Socket */
  close(sock_fd);

  return brcmd->result;
}

void ctp_set_t1e1_alarm(int Card, int pNum, int status, int preStatus)
{
  int aisAlarm= T1_ALARM_LOF | T1_ALARM_LOS |T1_ALARM_AIS;
  int t1alarm = WIN_PORT_ALARM_NONE;
  char SccBuf[40];
  struct acrndrv_command        ncmd;
  CTP_PORT_DBASE *pDbP = (CTP_PORT_DBASE *)&Db.Card[Card].Port[pNum];
  FUNC_PRT(ctp_set_t1e1_alarm, PF_PST, -1);

  sprintf(SccBuf,"scc%d",Ctp.Card[Card].Port[pNum].SccNum);
  ncmd.CmdType = SCC_CMD_SET_T1_ALARM;
  ncmd.CmdObj  = pNum;
  if(status & aisAlarm) {
    if((preStatus & aisAlarm) == 0) {
      // set ais in winpath and send rai in Dallas
      t1alarm = WIN_PORT_ALARM_AIS;
      if((pDbP->DcardCfg1 & T1E1_MSK_E1) == 0) {
        ncmd.CmdObj2  = 1;
        ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
      }
    }
  } else if(preStatus & aisAlarm) {
    if((pDbP->DcardCfg1 & T1E1_MSK_E1) == 0) {
      ncmd.CmdObj2  = 0;
      ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
    }
  }
  if((status & T1_ALARM_RAI) && (t1alarm == WIN_PORT_ALARM_NONE)) {
    if((preStatus & T1_ALARM_RAI)==0) {
      t1alarm = WIN_PORT_ALARM_RAI;
    }
  }
}

