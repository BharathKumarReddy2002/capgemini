int ctp_vb_chk_slot ( int Card ) {
	int	vb_slot = ctp_map_vb_slot(Card);
        int     rtn = 0, pNum;	// Default to no VoiceBoard found
	int 	pid = (int) getpid();
	char 	prtbuf[100];
        int     card; //Aricent PR-947222 and PR 1010274 fix
        VBBOARDHANDLE		hBoard;
	FUNC_PRT(ctp_vb_chk_slot, PF_START, -1);

	PRTDV(EVE,++++ ctp_vb_chk_slot for card, Card);
	PRTDV(DBG,++++ ctp_vb_chk_slot for vb_slot, vb_slot);
	PRTDV(DBG,++++ ctp_vb_chk_slot with pid, pid);

	hBoard = vbBoardInit( vb_slot, 0, 0, 0);
	if (hBoard != VBBAD_HANDLE) {
	  int dev_num;
	  VBHANDLE hCpu;
	  PRTDVC(GN2,ctp_vb_chk_slot board handle, hBoard);

	  hCpu = vbOpenEx(hBoard, VB_CPURES, 0, 0, VBNO_HANDLE);
	  if( hCpu != VBBAD_HANDLE) {
	    int infoLen=CTP_MAX_VB_INFO*sizeof(rsrcEntryInfoType);
	    rsrcEntryInfoType info[CTP_MAX_VB_INFO];
	    int NumEntries = CTP_MAX_VB_INFO;

	    if( cpuGetResources(hCpu, 0, infoLen,(rsrcEntryInfoType *)&info, &NumEntries) == VB_OK) {
	      int i;
	      PRTDVC(GN2,cpuGetResources returned with num entries, NumEntries);
	      for( i=0; i<NumEntries; i++) {
		PRTDVC(DBG,checking cpuGetResources entry, i);
		PRTU8(DBG,entry has type, info[i].rsrcId);
		if( info[i].rsrcId == CPURESNUM ) {
		  int numPorts = (info[i].misclInfo[3]>>16)&0xff;
		  PRTVC(GEN,VB card returned misclInfo[3], info[i].misclInfo[3]);
		  switch( info[i].misclInfo[3]&0xff ) {
		    case 4:
		    case 7:	// Combo card
		      pSysInfo->Card[Card].Type = FXOCRD;
		      PRTDVC(MAJ, **** Got FXO CARD **** with number of ports, numPorts);
		      PRTDVC(DBG,**** Got FXO CARD **** in vb_slot, vb_slot);
                      card_found |= 1<<Card;    //Aricent PR 1079714 fix
		      break;
		    case 5:
		      pSysInfo->Card[Card].Type = EMCARD;
		      PRTDVC(MAJ, **** Got 4W E&M CARD **** with number of ports, numPorts);
                      card_found |= 1<<Card;    //Aricent PR 1079714 fix
		      break;
		    case 3:
		    case 6:
		      pSysInfo->Card[Card].Type = FXSCRD;
		      PRTDVC(MAJ, **** Got FXS CARD **** with number of ports, numPorts);
		      PRTDVC(DBG,**** Got FXS CARD **** in vb_slot, vb_slot);
                      card_found |= 1<<Card;    //Aricent PR 1079714 fix
		      break;
		    default:
		      {
			int card_type = info[i].misclInfo[3]&0xff;
			pSysInfo->Card[Card].Type = NOCARD;
			PRTDVC(MAJ, **** Got UNKNOWN VB CARD ****, card_type  );
		      }
		      break;
		  }
		  if(pSysInfo->Card[Card].Type != NOCARD) {
		    pSysInfo->Card[Card].PortsOnCard = numPorts;
		    pSysInfo->Card[Card].MiscInfo = info[i].misclInfo[2];
		    pSysInfo->Card[Card].FpgaRev  = info[i].misclInfo[0];
		    pSysInfo->Card[Card].PldRev   = info[i].misclInfo[1];
		    pSysInfo->Card[Card].hBoard = hBoard;
		    rtn = 1;
		  }
		}
	      }
	    } else {
	      PRTC(MAJ,cpuGetResources did not return VB_OK);
	    }
	    vbClose(hCpu);
	  } else {
	    PRTC(MIN,Bad CPU handle);
	  }

	} else {
	  PRTC(GEN,Bad board handle);
	}

	if( pSysInfo->Card[Card].PortsOnCard ) {
	  VBBOARDHANDLE hBoard = pSysInfo->Card[Card].hBoard;
	  for(pNum=0;pNum<pSysInfo->Card[Card].PortsOnCard;pNum++) {
	    switch(CARDTYPE(Card)) {
	      case EMCARD:
		PRTDVP(GN1,Opening handle to VB_AUDRES with pid, pid);
		pVcSigs->Card[Card].hRes[pNum] = vbOpenEx(hBoard, VB_AUDRES, pNum, 0, hMsgQ);
		break;
	      case FXSCRD:
		PRTDVP(GN1,Opening handle to VB_NCORES with pid, pid);
		pVcSigs->Card[Card].hRes[pNum] = vbOpenEx(hBoard, VB_NCORES, pNum, 0, hMsgQ);
	        break;
	      case FXOCRD:
		PRTDVP(GN1,Opening handle to VB_LINRES with pid, pid);
		pVcSigs->Card[Card].hRes[pNum] = vbOpenEx(hBoard, VB_LINRES, pNum, 0, hMsgQ);
		break;
	      default:
		break;
	    }

	      //--- These go away when we move from ports -> [card, portNum]
	    Ctp.Card[Card].Port[pNum].SccNum = CTP_SCC_NONE; // Aricent PR-947222 and PR 1010274 fix;
	    Ctp.Card[Card].Port[pNum].Available = YES; //Aricent PR-947222 
	  }
	  sprintf(prtbuf,"Found card %d type %s with ports %d, sn(2) 0x%x, sw(0) 0x%x, loader(1) 0x%x", 
	      Card,
	      (CARDTYPE(Card) == EMCARD)? "4W-EM":
	      (CARDTYPE(Card) == FXSCRD)? "FXS":
	      (CARDTYPE(Card) == FXOCRD)? "FXO": "??",
	      pSysInfo->Card[Card].PortsOnCard,
	      pSysInfo->Card[Card].MiscInfo,
	      pSysInfo->Card[Card].FpgaRev,
	      pSysInfo->Card[Card].PldRev
	      );
	  PRTSC(GEN,,prtbuf);
	}

	//--- If still no card found, set SysInfo to reflect this
	if( pSysInfo->Card[Card].Type == NOCARD ) pSysInfo->Card[Card].PortsOnCard = 0;
	
        return rtn;
}

void ctp_vb_cfg_h110_clks( int Card )
{
  VBHANDLE hRes;
  UINT_32 parmVal;
  int status = VB_OK;
  FUNC_PRT(ctp_vb_cfg_h110_clks, PF_H110, -1);

  status = ctp_wait_for_handle(Card,0);
  if( status == SUCCESS ) {
    //--- Set voice Card to be slave on H110
    hRes = pVcSigs->Card[Card].hRes[0];

    if( hRes != VBBAD_HANDLE ) {
      //--- Disable primary
      status = scSetCfg(hRes, MPSCP_PRICLK, MPSCP_PRICLK_DIS);
      if( status != VB_OK )	PRTC(MIN,Problem with VBSCP_PRICLK);

      //--- Disable secondary
      status = scSetCfg(hRes, MPSCP_SECCLK, MPSCP_SECCLK_DIS);
      if( status != VB_OK )	PRTC(MIN,Problem with VBSCP_SECCLK);

      //--- Disable driving NETREF1 & NETREF2 into main clock mux since we are
      //    going to be slave on H110
      status = scSetCfg(hRes, VBSCP_SREFOUT, VBSCP_SREFOUT_DIS);
      if( status != VB_OK ) PRTC(MIN,Problem with VBSCP_SREFOUT);

      //--- Use Clk 'A' as source for main clock mux (to drive everything...)
      status = scSetCfg(hRes, VBSCP_CLKXREF, VBSCP_CLKREF_BUSA);
      if( status != VB_OK ) PRTC(MIN,Problem with VBSCP_SREFOUT);

      //--- Configure H110 for 8MHz bus (external)
      status = scSetCfg( hRes, MPSCP_BUSRATE, MPSCP_BUSRATE_8);
      if( status != VB_OK ) PRTC(MIN,Problem with MPSCP_BUSRATE);

      //--- Configure H110 for 8MHz bus (local)
      status = scSetCfg( hRes, MPSCP_BUSRATE_LOCAL, MPSCP_LCL_BUSRATE_8);
      if( status != VB_OK ) PRTC(MIN,Problem with MPSCP_BUSRATE_LOCAL);

      //--- Reset H110 connection
      status = scSetCfg(hRes, MPSCP_RESET, MPSCP_RESET_CONNS);
      if( status != VB_OK ) PRTC(MIN,Problem with MPSCP_RESET);

      //--- Enable H110 on card
      status = scSetCfg(hRes, MPSCP_ENABLE, MPSCP_ENABLE_ON);
      if( status != VB_OK ) PRTC(MIN,Problem with MPSCP_ENABLE);

      if( status == VB_OK ) PRTC(EVE,Configured as H110 client);
    } else {
      status = VBBAD_HANDLE;
    }
    ctp_release_handle(Card,0);
  } else {
    status = VBBAD_HANDLE;
  }
}

void ctp_vb_qry_h110_clks( int Card )
{
  VBHANDLE hRes;
  int status;
  UINT_32 parmVal;
  FUNC_PRT(vb_get_h110_clk_cfg, PF_H110, -1);

  status = ctp_wait_for_handle(Card,0);
  if( status == SUCCESS ) {
    //--- Set voice Card to be slave on H110
    hRes = pVcSigs->Card[Card].hRes[0];

    if( hRes != VBBAD_HANDLE ) {
      //--- H110
      status = scGetCfg( hRes, MPSCP_ENABLE, (UINT_32 *)&parmVal);
      if( status == VB_OK ) {
	switch (parmVal) {
	  case MPSCP_ENABLE_ON:
	    PRTC(MIN,Found H110 enabled.);
	    break;
	  case MPSCP_ENABLE_OFF:
	    PRTC(MIN,Found H110 NOT enabled.);
	    break;
	  default:
	    PRTC(MIN,Could not determine H110 enable status.);
	    break;
	}
      } else {
	PRTC(MIN,scGetCfg returned error.);
      }

      //--- Primary clock
      status = scGetCfg( hRes, MPSCP_PRICLK, (UINT_32 *)&parmVal);
      if( status == VB_OK ) {
	switch (parmVal) {
	  case MPSCP_PRICLK_EN:
	    PRTC(MIN,Found H110 primary clock enabled.);
	    break;
	  case MPSCP_PRICLK_DIS:
	    PRTC(MIN,Found H110 primary clock NOT enabled.);
	    break;
	  default:
	    PRTC(MIN,Could not determine H110 primary clock enable status.);
	    break;
	}
      } else {
	PRTC(MIN,scGetCfg returned error.);
      }

      //--- secondary clock
      status = scGetCfg( hRes, MPSCP_SECCLK, (UINT_32 *)&parmVal);
      if( status == VB_OK ) {
	switch (parmVal) {
	  case MPSCP_SECCLK_EN:
	    PRTC(MIN,Found H110 secondary clock enabled.);
	    break;
	  case MPSCP_SECCLK_DIS:
	    PRTC(MIN,Found H110 secondary clock NOT enabled.);
	    break;
	  default:
	    PRTC(MIN,Could not determine H110 secondary clock enable status.);
	    break;
	}
      } else {
	PRTC(MIN,scGetCfg returned error.);
      }
      //--- Clock rate
      status = scGetCfg( hRes, MPSCP_BUSRATE, (UINT_32 *)&parmVal);
      if( status == VB_OK ) {
	switch (parmVal) {
	  case MPSCP_BUSRATE_2:
	    PRTC(MIN,Found H110 running at 2 MHz.);
	    break;
	  case MPSCP_BUSRATE_4:
	    PRTC(MIN,Found H110 running at 4 MHz.);
	    break;
	  case MPSCP_BUSRATE_8:
	    PRTC(MIN,Found H110 running at 8 MHz.);
	    break;
	  default:
	    PRTC(MIN,Could not determine H110 bus rate.);
	    break;
	}
      } else {
	PRTC(MIN,scGetCfg returned error.);
      }

    } else {
      status = VBBAD_HANDLE;
    }
    ctp_release_handle(Card,0);
  } else {
    status = VBBAD_HANDLE;
  }
}

//--------------------------------------------------------------------------
// This routine is responsible for making sure that a port is not sending
// too many packets pers second into the network. The current maximum PPS
// is CTP_MAX_PPS. The menu interface already checks for this when the
// system synthesizes the clock. This routines main reason is to check to
// see if the user is send to fast a TT clock when the port is configured
// to use this clock. If the system is configured to synthesize the clock,
// we automatically pass OK, since the menu program should have verified
// that the maximum PPS is not exceeded. It is assumed the frequency
// counter has already been started and has a good frequency measurement
// for us.
int ctp_check_netbound_pps( int Card, int pNum )
{
  u32	pps, bps, bpp, Acc, Freq;
  CTP_PORT_STATE	*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_DBASE	*pPortDb = &Db.Card[Card].Port[pNum];
  int   bNum = util_get_next_bNum(pPortDb, -1);
  FUNC_PRT(ctp_check_netbound_pps, PF_PST, pNum);

  if( pPortDb->rx_sel == CTP_CLK_SEL_TT ) {
    Freq = pPortSt->LocMeasFreq;
    Acc = pPortSt->LocMeasFreqAcc;
    bps = (Freq * 2) / Acc;
    bpp = Db.Bndl[bNum].loc_pkt_size * 8;
    pps = bps / bpp;
    if( FRAC_T1E1(Card, pNum) ) {
      int cas = (pPortDb->DcardCfg1 & T1E1_MSK_E1_CAS)? 1 : 0;
      int frm = (pPortDb->DcardCfg1 & T1E1_MSK_NO_FRM) ? 0 : 1;
      if( pPortDb->DcardCfg1 & T1E1_MSK_E1 ) {
	pps *= ((pPortDb->DcardCfg2 + 1 + cas)*8)/256;	// Fractional E1
      } else {
	pps *= (pPortDb->DcardCfg2*8 + frm)/193;	// Fractional T1
      }
    }
    //PRTDV(OFF,Calculated BPS,bps);
    //PRTDV(OFF,Calculated BPP,bpp);
    PRTDV(GN2,Calculated PPS,pps);
  } else {
    pps = 0;			// no user clock, so put in benign value
  }
//Aricent fix for PR-675300.
  if( pSysInfo->Flags & SYSINFO_FLAG_NO_SPEED_CAP ) {
    return(SUCCESS);
  } else {
    if(pps <= CTP_MAX_BNDL_PPS)	return(SUCCESS);
    else {
      PRTDV(MIN,PPS too high: calculated ,pps);
      return(FAILURE);
    }
  }
}

//--------------------------------------------------------------------------
int ctp_check_port_cfg_endpoints( int Card, int pNum, CTP_Q_MSG * ptr)
{
  CTP_OAM_MSG		*pMsg = &(((CTP_Q_OAM_MSG *)ptr)->CtpMsg);
  CTP_MSG_REM_OAM	*pMsgOam = &pMsg->msg.RemOam;
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  char			 buf0[100],buf1[100],buf2[200];
  CTP_NODE_STORAGE	 Local_Node = pPortIntSt->LocAdCid.Node;
  CTP_Q_MSG 		*pQMsg;
  FUNC_PRT(ctp_check_port_cfg_endpoints, PF_PST, pNum);

  PRTDVP(GN2,ctp_check_port_cfg_endpoints for LocCid, pPortIntSt->LocAdCid.Cid);
  if( NO_OAM(Card,pNum) ) {	// Aricent PR 1202814 fix
    PRTP(GEN,Skipping OAM Endpoint check);// Aricent PR 1202814 fix
    return(SUCCESS);// Aricent PR 1202814 fix
  }
  // hairpin flow need not to check endpoints since the way we assemble the
  // OAM message heavily dependant on route look up with hairpin the route
  // lookup will fail thus we can not get the correct interface address
  // which the check endpoints expect. TBD if we really want to protect
  // hairpin messages
  if(!(HAIRPIN(Card,pNum))) {
    if(nutl_comp_host(pMsg, &pPortIntSt->RemAdCid.Node, NODE_TYPE_OAM_MSG_ORIG)==FAILURE){
      if(pPortIntSt->RemAdCid.Node.Type == CTP_IPV4) {
        unsigned int loc_addr = (unsigned int)htonl(pPortIntSt->RemAdCid.Node.v4);
        unsigned int oam_addr = (unsigned int)htonl(pMsgOam->LocNcp.Node.Node.v4);
        inet_ntop(AF_INET, &loc_addr, buf0, 40);
        inet_ntop(AF_INET, &oam_addr, buf1, 40);
      } else if (pPortIntSt->RemAdCid.Node.Type == CTP_IPV6) {
        inet_ntop(AF_INET6, &pPortIntSt->RemAdCid.Node.v6, buf0, 46);
        inet_ntop(AF_INET6, &pMsg->OrigIp6addr, buf1, 46);
      }
      pQMsg = (CTP_Q_MSG *)pMsg;
      sprintf(buf2,"Remote address mismatch: Incoming OAM: %s !=  dbase: %s, type src %d dest %d ",
	buf1, buf0, pMsg->msg.RemOam.LocNcp.Node.Type, pPortIntSt->RemAdCid.Node.Type );
      PRTSP(GEN,,buf2);
      return(FAILURE);
    }
    // If the socket accept the packet then the destination ip is to local node.
    // Only virtual ip need to ensure the ip address is not wrong.
    if((USE_VIP(Card,pNum))&&(nutl_comp_host(pMsg, &Local_Node, NODE_TYPE_OAM_MSG_DEST) == FAILURE)) {
      if(Local_Node.Type == CTP_IPV4) {
	unsigned int loc_addr = (unsigned int)htonl(Local_Node.v4);
	unsigned int oam_addr = (unsigned int)htonl(pMsgOam->RemNcp.Node.Node.v4);
        inet_ntop(AF_INET, &loc_addr, buf0, 40);
        inet_ntop(AF_INET, &oam_addr, buf1, 40);
      } else if (Local_Node.Type == CTP_IPV6) {
        inet_ntop(AF_INET6, &Local_Node.v6, buf0, 46);
        inet_ntop(AF_INET6, &pMsg->DestIp6addr, buf1, 46);
      }
      sprintf(buf2,"Local address mismatch: Incoming OAM %s != dbase: %s, type src %d dest %d",
	buf1, buf0, pMsg->msg.RemOam.LocNcp.Node.Type, Local_Node.Type);
      PRTSP(GEN,,buf2);
      return(FAILURE);
    }
  }

  if( pMsgOam->RemNcp.Port != (u8)pPortIntSt->LocAdCid.Cid ) {
    sprintf(buf2,"Local CID mismatch: Incoming OAM %d != dbase %d",
	pMsgOam->RemNcp.Port, (u8)pPortIntSt->LocAdCid.Cid);
    PRTSP(GEN,,buf2);
    return(FAILURE);
  }

  if( pMsgOam->LocNcp.Port != (u8)pPortIntSt->RemAdCid.Cid ) {
    sprintf(buf2,"Remote CID mismatch: Incoming OAM %d != dbase %d",
	pMsgOam->LocNcp.Port, (u8)pPortIntSt->RemAdCid.Cid);
    PRTSP(GEN,,buf2);
    return(FAILURE);
  }
  // Otherwise, things must be kosher...
  PRTP(GN3,All OAM endpoint checks passed);
  return(SUCCESS);
}

