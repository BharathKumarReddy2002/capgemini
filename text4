void send_net_bound_vc_sig_change(u8 Card,u8 pNum,u8 old_sigs,u8 bNum,u8 sNum) {
  struct acrndrv_command ncmd;
  u8 new_frm_net_sigs = VC_SIGS_IN(Card,pNum,0);
  u8 new_to_net_sigs = VC_SIGS_OUT(Card,pNum,0);
  u8 old_frm_net_sigs = old_sigs & 0xf;
  u8 old_to_net_sigs = (old_sigs >> 4) & 0xf;
  int prt_tmp;
  char PrtBuf[400];
  FUNC_PRT(send_net_bound_vc_sig_change, PF_VSIG, -1);
  prt_tmp = new_to_net_sigs & 0xf;
  PRTVP(GEN,New signaling  to  Network ===> (ABCD):,prt_tmp);

  if( bNum >= CTP_MAX_BNDLS ) {
    int temp = (int)bNum;
    // Setting this to GEN to put these messages below the radar, since
    // unused AV ports going off/on hook will trigger it. Can still get
    // these messages for debugging if user sets level to GEN.
    PRTDVP(GEN,voice_state_machine: Invalid bundle number,temp); 
    return;
  }

  if( Db.Bndl[bNum].Type == CTP_BNDL_TYPE_WP ) {
    char SccBuf[10];
    sprintf(SccBuf, "cbc%d", Db.Bndl[bNum].Bndl.wp_bndl.cbc_num);
    ncmd.CmdType = SCC_CMD_SET_ANALOG_SIG;
    ncmd.CmdObj = new_to_net_sigs;
    ncmd.CmdObj2 = 1;
    ncmd.CmdObj3 = GetH110Chan(bNum, pNum); //Aricent PR-1017820
    ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
  } else if( Db.Bndl[bNum].Type == CTP_BNDL_TYPE_VC ) {
    ctp_vc_send_sig_ch_oam(bNum, Card, pNum, 0, sNum);
  } else {
    sprintf(PrtBuf,"%s: Bndl %d has invalid type 0x%x", fn,bNum,Db.Bndl[bNum].Type);
    PRTSP(MIN,,PrtBuf);
  }
}

// This function will enable the ringback tone in the callers ear. It is
// triggered by the variable RINGBACK_ON( ). There is the VCOMP version,
// where the tone is generated by DSPs, and also CESoPSN, where the T1E1
// FPGA generates a ringback tone on one H.110 channel
void proc_plar_ringback( u8 bNum, u8 Card, u8 pNum, u8 sNum) {
  CTP_BNDL_STATE	*pBndlSt = &Ctp.Bndl[bNum];
  FUNC_PRT(proc_plar_ringback, PF_VSIG, -1);
  if( (Db.Bndl[bNum].Type == CTP_BNDL_TYPE_VC) && 
      (Db.Bndl[bNum].Bndl.vc_bndl.vc_chan[0].flags & CFG_VCC_TONE_REL) 
    ) {    // Aricent PR 1265050 fix
    PRTDVP(GN2, calling adt_RingBackGen with ringback, RINGBACK_ON(Card,pNum));
    adt_RingBackGen(pBndlSt->Bndl.vc_bndl.dsp,
	pBndlSt->Bndl.vc_bndl.dsp_chn[sNum],
	RINGBACK_ON(Card,pNum));
  } else if( Db.Bndl[bNum].Type == CTP_BNDL_TYPE_WP ) {	 //Aricent PR-947222
    if( RINGBACK_ON(Card,pNum) )	{ 
      PRTP(GEN,PLAR: Set CESoPSN ringback tone on); 
      // Connect AV port output to ringback tone (Str 30, Chan 2)
      ctp_vb_port_h110_conn( Card, pNum, 3, 3842 );	// PR 1600681 
    } else { 
      PRTP(GEN,PLAR: Set CESoPSN ringback tone off); 
      // Connect AV port back to standard backplane timeslots
      ctp_vb_port_h110_conn( Card, pNum, 1, 0 );	// PR 1600681
    }
  }
}

