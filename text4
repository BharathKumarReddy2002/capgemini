void voice_state_machine(u8 bNum, u8 Card, u8 pNum, u8 event, u8 event_val, u8 sNum) {
  u8 port_proto;
  u8 card_type = (u8)CARDTYPE(Card);
  u8 cur_state = (u8)AV_STATE(Card,pNum);
  CTP_BNDL_STATE *pBndlSt = &Ctp.Bndl[bNum];
  u8 old_sigs, old_frm_net_sigs, old_to_net_sigs, old_frm_net_ab_bits, old_to_net_b_bit;
  u8 new_frm_net_b_bit, new_frm_net_a_bit, new_frm_net_sigs;
  int temp;
  char PrtBuf[400];

  FUNC_PRT(voice_state_machine, PF_VSIG, -1);

  if( bNum >= CTP_MAX_BNDLS ) {
    int temp = (int)bNum;
    PRTDVP(GEN,voice_state_machine: Invalid bundle number,temp);
    return;
  }

  sprintf(PrtBuf,"%s: Called with event",fn);
  switch(event){
    case CTP_VP_EVENT_OFFHOOK:	sprintf(PrtBuf,"%s %s",PrtBuf,"OFFHOOK");	break;
    case CTP_VP_EVENT_ONHOOK:	sprintf(PrtBuf,"%s %s",PrtBuf,"ONHOOK");	break;
    case CTP_VP_EVENT_RING:	sprintf(PrtBuf,"%s %s",PrtBuf,"RING");		break;
    case CTP_VP_EVENT_RING_GND:	sprintf(PrtBuf,"%s %s",PrtBuf,"RING_GND");	break;
    case CTP_VP_EVENT_TIP_GND:	sprintf(PrtBuf,"%s %s",PrtBuf,"TIP_GND");	break;
    case CTP_VP_EVENT_TIP_OPEN:	sprintf(PrtBuf,"%s %s",PrtBuf,"TIP_OPEN");	break;
    case CTP_VP_EVENT_ONE_SEC:	sprintf(PrtBuf,"%s %s",PrtBuf,"ONE_SEC");	break;
    case CTP_VP_EVENT_SIG_CHG:	sprintf(PrtBuf,"%s %s",PrtBuf,"SIG_CHG");	break;
    default: sprintf(PrtBuf,"%s %s",PrtBuf,"XXX");	break;
  }
  if( event == CTP_VP_EVENT_ONE_SEC ) { PRTSP(GN2,,PrtBuf); } 
  else {				PRTSP(GEN,,PrtBuf); }
  temp = event_val & 0xff;
  PRTVP(GN2,event_val,event_val);

  if( GROUND_START(Card,pNum) )		port_proto = (u8)CTP_VP_PROTO_GND_START;
  else if ( PLAR_PORT(Card,pNum) )	port_proto = (u8)CTP_VP_PROTO_LOOP_START_PLAR;
  else					port_proto = (u8)CTP_VP_PROTO_LOOP_START;

  old_sigs = VC_SIGS(Card,pNum,0);
  old_to_net_sigs = VC_SIGS_OUT(Card,pNum,0);
  old_frm_net_sigs = VC_SIGS_IN(Card,pNum,0);
  old_frm_net_ab_bits = (old_frm_net_sigs >> 2) & 0x3;

  if( event == CTP_VP_EVENT_SIG_CHG ) {
    new_frm_net_sigs = event_val & 0xf;
    temp = new_frm_net_sigs & 0xf;
    PRTVP(GEN,New signaling from Network <--- (ABCD):,temp);
    new_frm_net_b_bit = new_frm_net_sigs & 0x4;
    new_frm_net_a_bit = new_frm_net_sigs & 0x8;
    VC_SIGS(Card,pNum,0) &= 0xf0;
    VC_SIGS(Card,pNum,0) |= new_frm_net_sigs;	// put new sigs from net to storage
  }

  {
    int temp = old_sigs;
    PRTVP(GN2,VC Signaling: ToNet[ABCD]FrmNet[ABCD] =,temp);
  }

  switch(port_proto) {
    //#####################################################
    case CTP_VP_PROTO_GND_START:
      PRTP(MAJ,GND_START protocol not yet supported);
      break;
    //#####################################################
    //### loopStart (non-PLAR)
    //#####################################################
    case CTP_VP_PROTO_LOOP_START:
      switch(card_type) {
	//===================================================
	case FXSCRD:
	  switch(cur_state) {
	    //-----------------------------------------------------
	    case AV_STATE_ONHOOK:
	    case AV_STATE_ONHOOK_RING_OFF:
	      switch(event) {
		case CTP_VP_EVENT_OFFHOOK:
		  NEW_AV_STATE(Card,pNum,AV_STATE_OFFHOOK_CONN);
		  //--- Detected off hook, so turn off ringer and send signaling
		  RING_ON(Card,pNum) = 0;
		  ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
		  VC_SIGS_OUT_SET_A_BIT(Card,pNum);	// Off Hook
		  VC_SIGS_OUT_SET_B_BIT(Card,pNum);	// Ring Off
		  send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  break;
		case CTP_VP_EVENT_SIG_CHG:
		  if( new_frm_net_b_bit == 0 ) {
		    //--- Remote side is ringing, so we ring
		    NEW_AV_STATE(Card,pNum,AV_STATE_ONHOOK_RING_ON);
		    RING_ON(Card,pNum) = 1;
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_ON);
		    //VC_SIGS_TO_NET_CFG(Card,pNum,new_frm_net_sigs); // echo sigs back
		    //send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  }
		  break;
		case CTP_VP_EVENT_ONE_SEC:
		  break;	// Ignore event
		case CTP_VP_EVENT_RING:
		  PRTP(GEN,FXS port got a RING event); // benign but seen occasionally
		  break;
		case CTP_VP_EVENT_ONHOOK:
		  PRTP(GEN,FXS port got a ONHOOK event); // benign but seen occasionally
		  break;
		default:
		  util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  break;
	      }
	      break;
	    //-----------------------------------------------------
	    case AV_STATE_ONHOOK_RING_ON:
	      switch(event) {
		case CTP_VP_EVENT_OFFHOOK:
		  NEW_AV_STATE(Card,pNum,AV_STATE_OFFHOOK_CONN);
		  //--- Detected off hook, so turn off ringer and send signaling
		  RING_ON(Card,pNum)  = 0;
		  ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
		  VC_SIGS_OUT_SET_A_BIT(Card,pNum);	// Off Hook
		  VC_SIGS_OUT_SET_B_BIT(Card,pNum);	// Ring Off
		  send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  break;
		case CTP_VP_EVENT_SIG_CHG:
		  if( new_frm_net_b_bit != 0 ) {
		    //--- Remote side is ringing, so we ring
		    NEW_AV_STATE(Card,pNum,AV_STATE_ONHOOK_RING_OFF);
		    RING_ON(Card,pNum) = 0;
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
		    //VC_SIGS_TO_NET_CFG(Card,pNum,new_frm_net_sigs); // echo sigs back
		    //send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  }
		  break;
		case CTP_VP_EVENT_ONE_SEC:
		  break;	// Ignore event
		default:
		  util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  break;
	      }
	      break;
	    //-----------------------------------------------------
	    case AV_STATE_OFFHOOK_CONN:
	      switch(event) {
		case CTP_VP_EVENT_ONHOOK:
		  //--- FXS detected hangup
		  NEW_AV_STATE(Card,pNum,AV_STATE_ONHOOK);
		  VC_SIGS_OUT_CLR_A_BIT(Card,pNum);	// On Hook
		  VC_SIGS_OUT_SET_B_BIT(Card,pNum);	// Ring Off
		  send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  break;
		case CTP_VP_EVENT_SIG_CHG:
		  //VC_SIGS_TO_NET_CFG(Card,pNum,new_frm_net_sigs); // echo sigs back
		  //send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  break;
		case CTP_VP_EVENT_ONE_SEC:
		  break;	// Ignore event
		default:
		  util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  break;
	      }
	      break;
	    //-----------------------------------------------------
	    default:
	      util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, CTP_VP_EVENT_LAST);
	      break;
	  }
	  break;
	//===================================================
	case FXOCRD:
	  switch(cur_state) {
	    //-----------------------------------------------------
	    case AV_STATE_ONHOOK:
	    case AV_STATE_ONHOOK_RING_OFF:
	      switch(event) {
		case CTP_VP_EVENT_RING:
		  if(event_val == 1) {
		    NEW_AV_STATE(Card,pNum,AV_STATE_ONHOOK_RING_ON);
		    VC_SIGS_OUT_CLR_A_BIT(Card,pNum);	// On Hook
		    VC_SIGS_OUT_CLR_B_BIT(Card,pNum);	// Ring On
		    send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  } else {
		    util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  }
		  break;
		case CTP_VP_EVENT_SIG_CHG:
		  if( new_frm_net_a_bit != 0 ) {
		    NEW_AV_STATE(Card,pNum,AV_STATE_OFFHOOK_CONN);
		    //--- Detected off hook, so turn off ringer and send signaling
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_OFF_HOOK);
		    VC_SIGS_OUT_SET_A_BIT(Card,pNum);	// Off Hook
		    VC_SIGS_OUT_SET_B_BIT(Card,pNum);	// Ring Off
		    send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  }
		  // We can ignore other signaling changes from network:
		  //   B bit is only meaningful for FXS, so that it can ring
		  //   A bit high, would be unexpected, but whateva
		  break;
		case CTP_VP_EVENT_ONHOOK:
		  // This is a special case for bundle bringup, where
		  // FXS/FXO receive ONHOOK events to initialize the port.
		  ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_ON_HOOK);
		  NEW_AV_STATE(Card,pNum,AV_STATE_ONHOOK);      // Test/init event only
		  break;
		case CTP_VP_EVENT_OFFHOOK:
		  NEW_AV_STATE(Card,pNum,AV_STATE_OFFHOOK_CONN);	// Test/init event only
		  break;
		case CTP_VP_EVENT_ONE_SEC:
		  break;	// Ignore event
		default:
		  util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  break;
	      }
	      break;
	    //-----------------------------------------------------
	    case AV_STATE_ONHOOK_RING_ON:
	      switch(event) {
		case CTP_VP_EVENT_RING:
		  if(event_val == 0) {
		    NEW_AV_STATE(Card,pNum,AV_STATE_ONHOOK_RING_OFF);
		    VC_SIGS_OUT_CLR_A_BIT(Card,pNum);	// On Hook
		    VC_SIGS_OUT_SET_B_BIT(Card,pNum);	// Ring Off
		    send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  } else {
		    util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  }
		  break;
		case CTP_VP_EVENT_SIG_CHG:
		  if( new_frm_net_a_bit != 0 ) {
		    NEW_AV_STATE(Card,pNum,AV_STATE_OFFHOOK_CONN);
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_OFF_HOOK);
		    VC_SIGS_OUT_SET_A_BIT(Card,pNum);	// Off Hook
		    VC_SIGS_OUT_SET_B_BIT(Card,pNum);	// Ring Off
		    send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  }
		  // We can ignore other signaling changes from network:
		  //   B bit is only meaningful for FXS, so that it can ring
		  //   A bit high, would be unexpected, but whateva
		  break;
		case CTP_VP_EVENT_ONHOOK:
		  NEW_AV_STATE(Card,pNum,AV_STATE_ONHOOK);	// Test/init event only
		  break;
		case CTP_VP_EVENT_OFFHOOK:
		  NEW_AV_STATE(Card,pNum,AV_STATE_OFFHOOK_CONN);	// Test/init event only
		  break;
		case CTP_VP_EVENT_ONE_SEC:
		  break;	// Ignore event
		default:
		  util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  break;
	      }
	      break;
	    //-----------------------------------------------------
	    case AV_STATE_OFFHOOK_CONN:
	      switch(event) {
		case CTP_VP_EVENT_SIG_CHG:
		  if( new_frm_net_a_bit == 0 ) {
		    NEW_AV_STATE(Card,pNum,AV_STATE_ONHOOK);
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_ON_HOOK);
		    VC_SIGS_OUT_CLR_A_BIT(Card,pNum);	// On Hook
		    VC_SIGS_OUT_SET_B_BIT(Card,pNum);	// Ring Off
		    send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  } else {
		    util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  }
		  break;
		case CTP_VP_EVENT_ONHOOK:
		  NEW_AV_STATE(Card,pNum,AV_STATE_ONHOOK);	// Test/init event only
		  break;
		case CTP_VP_EVENT_ONE_SEC:
		  break;	// Ignore event
		case CTP_VP_EVENT_RING:
		  PRTP(GEN,FXO port got a RING event); // benign but seen occasionally
		  break;
		default:
		  util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  break;
	      }
	      break;
	    //-----------------------------------------------------
	    default:
	      util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, CTP_VP_EVENT_LAST);
	      break;
	  }
	  break;
	//===================================================
	default:
	  util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, AV_STATE_LAST, CTP_VP_EVENT_LAST);
	  break;
      }
      break;
    //#####################################################
    //### LoopStart PLAR 
    //#####################################################
    case CTP_VP_PROTO_LOOP_START_PLAR:
      switch(card_type) {
	//===================================================
	case FXSCRD:
	  switch(cur_state) {
	    //-----------------------------------------------------
	    case AV_STATE_ONHOOK:
	      switch(event) {
		case CTP_VP_EVENT_OFFHOOK:
		  if( old_frm_net_ab_bits == 0x3 ) {
		    //--- Both sides went off hook at the same time...
		    NEW_PLAR_STATE(Card,pNum,AV_STATE_OFFHOOK_CONN);
		    //--- Send answer to remote end, and turn off ringer
		    RING_ON(Card,pNum)  = 0;
		    RING_SEC(Card,pNum) = 0;
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
		    VC_SIGS_OUT_SET_A_BIT(Card,pNum);
		    VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		    send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  } else {
		    //--- This side initiating call, turn on ringback
		    NEW_PLAR_STATE(Card,pNum,AV_STATE_OFFHOOK_RING);
		    RINGBACK_ON(Card,pNum) = 1;
		    proc_plar_ringback(bNum,Card,pNum,sNum);
		    RING_SEC(Card,pNum) = 6;
		    //--- And initiate ring at remote end.
		    VC_SIGS_OUT_CLR_B_BIT(Card,pNum);
		    send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  }
		  break;
		case CTP_VP_EVENT_RING:
		  PRTP(GEN,FXS port got a RING event); // benign but seen occasionally
		  break;
		case CTP_VP_EVENT_ONHOOK:
		  break;
		case CTP_VP_EVENT_ONE_SEC:
		  break;
		case CTP_VP_EVENT_SIG_CHG:
		  if( new_frm_net_b_bit == 0 ) {
		    //--- Remote initiated call & wants AC ring on...
		    NEW_PLAR_STATE(Card,pNum,AV_STATE_ONHOOK_RING_ON);
		    RINGBACK_ON(Card,pNum) = 0;
		    RING_ON(Card,pNum)  = 1;
		    RING_SEC(Card,pNum) = 7;	// 1st ring is longer to avoid remote ONHOOK
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_ON);
		  }
		  break;
		default:
		  util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  break;
	      }
	      break;
	    //-----------------------------------------------------
	    case AV_STATE_ONHOOK_RING_ON:
	      switch(event) {
		case CTP_VP_EVENT_OFFHOOK:
		  //--- Remote side initiated the call, and we are answering...
		  NEW_PLAR_STATE(Card,pNum,AV_STATE_OFFHOOK_CONN);
		  //--- Send answer to remote end, and turn off ringer
		  RING_ON(Card,pNum)  = 0;
		  RING_SEC(Card,pNum) = 0;
		  ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
		  VC_SIGS_OUT_SET_A_BIT(Card,pNum);
		  VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		  send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  break;
		case CTP_VP_EVENT_ONHOOK:
		  RING_ON(Card,pNum)  = 0;
		  RING_SEC(Card,pNum) = 0;
		  ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
		  NEW_PLAR_STATE(Card,pNum,AV_STATE_ONHOOK);
		  VC_SIGS_OUT_CLR_A_BIT(Card,pNum);
		  VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		  send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  break;
		case CTP_VP_EVENT_ONE_SEC:
		  //--- This is the answer side...
		  if( RING_SEC(Card,pNum) == 4 ) {
		    //--- Turn off ringing...
		    VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		    PRTP(GEN,Ring timeout- Turning off RING);
		    RING_ON(Card,pNum)  = 0;
		    RING_SEC(Card,pNum) = 0;
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
		    NEW_PLAR_STATE(Card,pNum,AV_STATE_ONHOOK_RING_OFF);
		  } else {
		    int ring_sec = RING_SEC(Card,pNum);
		    PRTDVP(GN1,Ringing count sec,ring_sec);
		    RING_SEC(Card,pNum)--;
		  }
		  break;
		case CTP_VP_EVENT_SIG_CHG:
		  if( new_frm_net_b_bit != 0 ) {
		    //--- Remote side calling & wants AC ring off...
		    NEW_PLAR_STATE(Card,pNum,AV_STATE_ONHOOK_RING_OFF);
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
		  }
		  break;
		default:
		  util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  break;
	      }
	      break;
	    //-----------------------------------------------------
	    case AV_STATE_ONHOOK_RING_OFF:
	      switch(event) {
		case CTP_VP_EVENT_OFFHOOK:
		  //--- Remote side initiated the call, and we are answering...
		  NEW_PLAR_STATE(Card,pNum,AV_STATE_OFFHOOK_CONN);
		  //--- Send answer to remote end, and turn off ringer
		  VC_SIGS_OUT_SET_A_BIT(Card,pNum);
		  VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		  send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  RING_ON(Card,pNum)  = 0;
		  RING_SEC(Card,pNum) = 0;
		  ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
		  break;
		case CTP_VP_EVENT_ONHOOK:
		  NEW_PLAR_STATE(Card,pNum,AV_STATE_ONHOOK);
		  VC_SIGS_OUT_CLR_A_BIT(Card,pNum);
		  VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		  send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  break;
		case CTP_VP_EVENT_ONE_SEC:
		  // If the other end is still OFFHOOK and ringing us, we
		  // will get B bit transitions from the network. This code
		  // handles the case where the other end has hung up, no
		  // more B bit transitions are going to be coming from the
		  // network and we want to eventually go back to the
		  // ONHOOK state. 
		  if( RING_SEC(Card,pNum) == 0 ) {
		    VC_SIGS_OUT_CLR_A_BIT(Card,pNum);
		    VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		    NEW_PLAR_STATE(Card,pNum,AV_STATE_ONHOOK);
		  } else {
		    int ring_sec = RING_SEC(Card,pNum);
		    PRTDVP(GN1,Ringing count sec,ring_sec);
		    RING_SEC(Card,pNum)--;
		  }
		  break;
		case CTP_VP_EVENT_SIG_CHG:
		  if( new_frm_net_b_bit == 0 ) {
		    //--- Remote side calling & wants AC ring on...
		    NEW_PLAR_STATE(Card,pNum,AV_STATE_ONHOOK_RING_ON);
		    RINGBACK_ON(Card,pNum) = 0;
		    RING_ON(Card,pNum)  = 1;
		    RING_SEC(Card,pNum) = 6;
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_ON);
		  }
		  break;
		default:
		  util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  break;
	      }
	      break;
	    //-----------------------------------------------------
	    case AV_STATE_OFFHOOK_RING:
	      switch(event) {
		case CTP_VP_EVENT_OFFHOOK:
		  break;
		case CTP_VP_EVENT_ONHOOK:
		  //--- We are hanging up for whatever reason...
		  NEW_PLAR_STATE(Card,pNum,AV_STATE_ONHOOK);
		  //Turn off ringback & remote ringer
		  RINGBACK_ON(Card,pNum) = 0;
		  proc_plar_ringback(bNum,Card,pNum,sNum);
		  VC_SIGS_OUT_CLR_A_BIT(Card,pNum);
		  VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		  send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  break;
		case CTP_VP_EVENT_ONE_SEC:
		  //--- We initiated call, generate signaling....
		  switch( RING_SEC(Card,pNum) ) {
		    case 0:
		      //--- RINGBACK_ON -> we initiated call.
		      RING_SEC(Card,pNum) = 6;				// Reset
		      RINGBACK_ON(Card,pNum) = 1;
		      proc_plar_ringback(bNum,Card,pNum,sNum);
		      VC_SIGS_OUT_CLR_B_BIT(Card,pNum);
		      send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		      break;
		    case 4:
		      RINGBACK_ON(Card,pNum) = 0;
		      proc_plar_ringback(bNum,Card,pNum,sNum);
		      VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		      send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		      break;
		  }
		  if( RING_SEC(Card,pNum) ) {
		    int ring_sec = RING_SEC(Card,pNum);
		    PRTDVP(GN1,Ringing count sec,ring_sec);
		    RING_SEC(Card,pNum)--;
		  }
		  break;
		case CTP_VP_EVENT_SIG_CHG:
		  if( (new_frm_net_a_bit != 0) && (new_frm_net_b_bit != 0) ) {
		    //--- Remote side picked up to answer call
		    NEW_PLAR_STATE(Card,pNum,AV_STATE_OFFHOOK_CONN);
		    RINGBACK_ON(Card,pNum) = 0;
		    proc_plar_ringback(bNum,Card,pNum,sNum);
		    RING_ON(Card,pNum)     = 0;
		    RING_SEC(Card,pNum)    = 0;
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
		    VC_SIGS_OUT_SET_A_BIT(Card,pNum);
		    VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		    send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  }
		  break;
		default:
		  util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  break;
	      }
	      break;
	    //-----------------------------------------------------
	    case AV_STATE_OFFHOOK_CONN:
	      switch(event) {
		case CTP_VP_EVENT_OFFHOOK:
		  break;
		case CTP_VP_EVENT_ONHOOK:
		  //--- We are hanging up for whatever reason...
		  NEW_PLAR_STATE(Card,pNum,AV_STATE_ONHOOK);
		  //Turn off ringback & remote ringer
		  RINGBACK_ON(Card,pNum) = 0;
		  proc_plar_ringback(bNum,Card,pNum,sNum);
		  VC_SIGS_OUT_CLR_A_BIT(Card,pNum);
		  VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		  send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  break;
		case CTP_VP_EVENT_ONE_SEC:
		  break;
		case CTP_VP_EVENT_SIG_CHG:
		  if( new_frm_net_a_bit == 0 ) {
		    //--- Remote side hung up...
		    NEW_PLAR_STATE(Card,pNum,AV_STATE_OFFHOOK_DISCONN);
		    VC_SIGS_OUT_SET_A_BIT(Card,pNum);
		    VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		    send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  }
		  break;
		default:
		  util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  break;
	      }
	      break;
	    //-----------------------------------------------------
	    case AV_STATE_OFFHOOK_DISCONN:
	      switch(event) {
		case CTP_VP_EVENT_OFFHOOK:
		  //--- Send answer to remote end, and turn off ringer
		  RING_ON(Card,pNum)  = 0;
		  RING_SEC(Card,pNum) = 0;
		  ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
		  VC_SIGS_OUT_SET_A_BIT(Card,pNum);
		  VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		  send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  break;
		case CTP_VP_EVENT_ONHOOK:
		  //--- We are hanging up for whatever reason...
		  NEW_PLAR_STATE(Card,pNum,AV_STATE_ONHOOK);
		  //Turn off ringback & remote ringer
		  RINGBACK_ON(Card,pNum) = 0;
		  proc_plar_ringback(bNum,Card,pNum,sNum);
		  VC_SIGS_OUT_CLR_A_BIT(Card,pNum);
		  VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		  send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  break;
		case CTP_VP_EVENT_ONE_SEC:
		  break;
		case CTP_VP_EVENT_SIG_CHG:
		  if( new_frm_net_a_bit != 0 ) {
		    //--- Remote side went off hook while we were off hook...
		    NEW_PLAR_STATE(Card,pNum,AV_STATE_OFFHOOK_CONN);
		    VC_SIGS_OUT_SET_A_BIT(Card,pNum);
		    VC_SIGS_OUT_SET_B_BIT(Card,pNum);
		    send_net_bound_vc_sig_change(Card,pNum,old_sigs,bNum,sNum);
		  }
		  break;
		default:
		  util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, event);
		  break;
	      }
	      break;
	    //-----------------------------------------------------
	    default:
	      util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, cur_state, CTP_VP_EVENT_LAST);
	      break;
	  }
	  break;
	//===================================================
	default:
	  util_prt_invalid_voice_event( Card, pNum, port_proto, card_type, AV_STATE_LAST, CTP_VP_EVENT_LAST);
	  break;
      }
      break;
    //#####################################################
    default:
      util_prt_invalid_voice_event( Card, pNum, port_proto, LASTCARD, AV_STATE_LAST, CTP_VP_EVENT_LAST);
      break;
  }
}
