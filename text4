	  //     accuracy and one everything else that has reqAcc set to 3.
	  //     Note also: a reqAcc of 3 produces an accuracy of 5 due to
	  //     our timer being 1 second!
	  tempTt = (double)Freq/((double)Acc*500.0);
	  if     ( tempTt < 0.75 ) reqAcc =29;
	  else if( tempTt < 1.5  ) reqAcc =19;
	  else if( tempTt < 3.0  ) reqAcc = 9;
	  else                     reqAcc = 3;	// No change above 3 kHz

	  if( ((Acc & 0x100) == 0) && ((Acc & 0xff) > reqAcc) ) {
