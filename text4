//--- Search through existing nid elements looking for name
//    match. Fill in remaining elements & return 0 if match is found.
int ctp_nid_qry_dev( int Card, int pNum, struct CtpNidInfo *passed_if )
{
  int	i, rtn = 1;
  char	prtBuf[100];
  char Buf1[40];
  FUNC_PRT(ctp_nid_qry_dev, PF_PST, -1);

  for( i=0; i<CTP_MAX_NID; i++) {
    struct CtpNidInfo *iface= &(pSysInfo->interface[i]);
    if( strncmp(iface->name,passed_if->name,CTP_MAX_NAME_LEN) == 0 ) {
      util_ip_string(iface->addr_store.v4, Buf1);
      sprintf(prtBuf, "Match if %s loc %d, indx %d, ip %s speed %d and mtu %d",
	  iface->name, i, iface->if_index, Buf1, iface->speed, iface->mtu);
      PRTSP(GEN,ctp_nid_qry_dev,prtBuf);

      //--- Fill in the remaining info.
      passed_if->mtu      = iface->mtu;
      passed_if->type     = iface->type;
      passed_if->speed    = iface->speed;
      passed_if->if_index = iface->if_index;
      passed_if->addr_store.v4   = iface->addr_store.v4;
      passed_if->addr_store.v6   = iface->addr_store.v6;
      passed_if->addr_store.Type = iface->addr_store.Type;

      rtn = 0;
    } else {
      sprintf(prtBuf, "No match for if in loc %d, iface->name %s : dev name %s",
	  i, iface->name, passed_if->name);
      PRTSP(DBG,ctp_nid_qry_dev,prtBuf);
    }
  }
  return rtn;
}

