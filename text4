//-------------------------------------------------------------------------
// This function attempts to read the standard read locations of a daughter
// card. These are the first 3 read locations of the PLD memory map.
//-------------------------------------------------------------------------
int clk_rtm_get_info( int Card )
{
  char	 Buf[100], SccBuf[40];
  u32	 ReadVal, WriteVal;
  int	 i, Errors = 0;
  int	 Dev = I2C_ADR_CLKRTM;
  int sccNum = pSysInfo->Card[Card].BaseSccNum;
  struct acrndrv_command        ncmd;
  FUNC_PRT(clk_rtm_get_info, PF_START, -1);

  // This section of code does a test to see if there is a real Clock RTM
  // in this card slot.

  //----- Pulse RTM Reset bit
  fpga_clr_fcfg();
  fpga_reset_rtm(Card);
  fpga_send_fcfg(sccNum);

  for(i=0;i<2;i++) {
    if( i == 0 )	WriteVal = 0xb;
    else		WriteVal = 0x4;
    if( !Errors ) {
      //----- Read RTM Type Register
      ReadVal = ctp_i2c_read(Card,Dev,0x0,8);	// Read RTM type
      sprintf(Buf,"CLK RTM scan card=%d,Type=0x%x", Card,ReadVal);
      PRTSC(GN3,,Buf);

      if( ReadVal == 0x4 ) {	// Type 0x4 is only valid type
	//----- Write Test Register
	ctp_i2c_write(Card,Dev,0xf,WriteVal);
        sprintf(Buf,"RTM write card=%d,Addr=0x%x,Val=0x%x",Card,0xf,WriteVal);
	PRTSC(GN3,,Buf);
	//----- Read back Test Register
	ReadVal = ctp_i2c_read(Card,Dev,0xf,8);
        sprintf(Buf,"RTM read  card=%d,Addr=0x%x,Val=0x%x",Card,0xf,ReadVal);
	PRTSC(GN3,,Buf);
	if( ReadVal != WriteVal ) Errors++;
      }
      else Errors++;
    }
  }
  if( Errors == 0 ) {
	  //----- Read F/W version reg
	  int FwRev = ctp_i2c_read(Card,Dev,0x2,8);
          pSysInfo->Card[Card].ClkRtmRev = (u8)FwRev;
	  sprintf(Buf,"RTM C%d: FwRev = 0x%x", Card, FwRev);
	  PRTSC(GN3,,Buf);

	  //PR-1265458
	  // Originally, both hub and spoke cards had the same PLD load, with rev
	  // 0x4. The LIU BPV output on hub was the only way to differentiate
	  // between them. With new hub pca without LIU, the PLD rev was bumped
	  // to 0x5, so we have that way to check also.
	  if( FwRev == 0x5 ) {
		  pSysInfo->Card[Card].ClkRtm = HUB_CLK_RTM;
		  PRTVC(MIN,Found HUB RTM (sans T1 LIU) on card,Card);
	  } else if( FwRev == 0x4 ) {
		  // Determine if HUB card by checking LIU:
		  ctp_i2c_write(Card,Dev,0xd,0x75);	// Reset LIU
		  ReadVal = ctp_i2c_read(Card,Dev,0x10,8);	
		  sprintf(Buf,"RTM C%d: Status = 0x%x", Card, ReadVal);
		  PRTSC(GN3,,Buf);
		  // BPV bit (bit 2) will be 1 (PLD weak pullup) on a spoke card
		  if( ReadVal & 0x2 ) {
			  pSysInfo->Card[Card].ClkRtm = SPOKE_CLK_RTM;
			  PRTVC(MIN,Found SPK RTM on card,Card);
		  } else {
			  pSysInfo->Card[Card].ClkRtm = HUB_CLK_RTM;
			  PRTVC(MIN,Found HUB RTM on card,Card);
		  }
		  ctp_i2c_write(Card,Dev,0xd,0x45);	// Unreset LIU
	  } else {
		  sprintf(Buf,"Invalid rev on RTM C%d: FwRev = 0x%x", Card, FwRev);
		  PRTSC(MIN,,Buf);
	  }
  } else {
	  PRTVC(MIN,Found NO! RTM on card,Card);
  }
  return(0);
}

//-------------------------------------------------------------------------
// This function attempts to read the standard read locations of a daughter
// card. These are the first 3 read locations of the PLD memory map.
//-------------------------------------------------------------------------
int dcard_get_info( int Card, int pNum, u8 *pType, u8 *pHwRev, u8 *pFwRev )
{
  char	 Buf[100];
  u32	 ReadVal, WriteVal;
  int	 i, Errors = 0;
  int sccNum = Ctp.Card[Card].Port[pNum].SccNum;
  FUNC_PRT(dcard_get_info, PF_DCARD, pNum);

  // This section of code does a test to make sure that there is a real
  // DCARD in this port slot. The first check is to make sure that a DCARD
  // type read (addr 0) is considered a valid type. If this hurdle is
  // passed, then the test register is written with first 0xb and then 0x4.
  // If the written value is not read back properly, then it is considered
  // to be a bogus DCARD access and there is no DCARD for this port.
  // Otherwise, it is considered and good DCARD, the other card info is
  // read and passed up to the calling routine.

  if(SCC_CARD(Card) ) {
    for(i=0;i<2;i++) {
      if( i == 0 )	WriteVal = 0xb;
      else		WriteVal = 0x4;
      //----- Flush DCARD
      fpga_clr_fcfg();
      pld_get_reg( pNum, (u32)0, (u32)4 );
      fpga_send_fcfg(sccNum);
      //----- Read Type Register
      fpga_clr_fcfg();
      pld_get_reg( pNum, (u32)0, (u32)4 );
      fpga_send_fcfg(sccNum);
      pld_get_reg_val( (int)0, (u32 *)&ReadVal);
      sprintf(Buf,"DCARD scan c/p=%d/%d,Type=0x%x", Card,pNum,ReadVal);
      PRTSP(GEN,,Buf);
      if( (ReadVal > DCARD_NONE) && (ReadVal < DCARD_LAST) ) {
	u32 test_reg_addr = (u32)0xf;
	u32 test_reg_chunks = (u32)2;
	// All DCARDs but IRIG-B have a 4 bit R/W register at address 0xf.
	// IRIG-B doesn't, but it does have an 8 bit R/W reg at addr 0x7.
	if( (ReadVal == DCARD_IRIG) || (ReadVal == DCARD_MS) ) {
	  test_reg_addr = 0x7;
	  test_reg_chunks = 4;
	}
        sprintf(Buf,"DCARD test c/p=%d/%d,Addr=0x%x,Chunks=0x%x,Val=0x%x",
            Card,pNum,test_reg_addr,test_reg_chunks,WriteVal);
	PRTSP(GEN,,Buf);
	//----- Flush DCARD
	fpga_clr_fcfg();
	pld_get_reg( pNum, (u32)0, (u32)4 );
	fpga_send_fcfg(sccNum);
	//----- Test Reg = 0xb
	fpga_clr_fcfg();
	pld_set_reg( pNum, test_reg_addr, (u32)WriteVal, test_reg_chunks);
	fpga_send_fcfg(sccNum);
	//----- Flush DCARD
	fpga_clr_fcfg();
	pld_get_reg( pNum, (u32)0, (u32)4 );
	fpga_send_fcfg(sccNum);
	//----- Read Test Reg
	fpga_clr_fcfg();
	pld_get_reg( pNum, test_reg_addr, test_reg_chunks);
	fpga_send_fcfg(sccNum);
	pld_get_reg_val( (int)0, (u32 *)&ReadVal);
        sprintf(Buf,"DCARD test ReadVal=0x%x", ReadVal);
	PRTSP(GEN,,Buf);
	//----- Check results
	if( ReadVal != WriteVal ) Errors++;
      }
      else Errors++;
    }
    if( Errors == 0 ) {
      u32 read_val;
      fpga_clr_fcfg();
      pld_get_reg( pNum, (u32)0, (u32)4 );
      pld_get_reg( pNum, (u32)1, (u32)4 );
      pld_get_reg( pNum, (u32)2, (u32)4 );
      fpga_send_fcfg(sccNum);
      pld_get_reg_val( 0, &read_val );
      *pType  = (u8)read_val;
      pld_get_reg_val( 1, &read_val );
      *pHwRev = (u8)read_val;
      pld_get_reg_val( 2, &read_val );
      *pFwRev = (u8)read_val;
      sprintf(Buf,"DCARD: Type = 0x%x, HwRev = 0x%x, FwRev = 0x%x",
	  (unsigned int)*pType,(unsigned int)*pHwRev,(unsigned int)*pFwRev);
      PRTSP(GEN,,Buf);
    }
  }

  return(0);
}

//-------------------------------------------------------------------------
// This function writes a 24 bit codeword to a winpot device.
//-------------------------------------------------------------------------
int dcard_4w_set_wpot_reg( int Card, int pNum, int chan, u32 wdata )
{
  u32 addr, data, i;
#ifdef DBG_WPOT
  char			Buf[100];
#endif
  int sccNum = Ctp.Card[Card].Port[pNum].SccNum;
  FUNC_PRT(dcard_4w_set_wpot_reg, PF_DCARD, pNum);

  BAILTESTF(chan>=2,Invalid channel ID);

  addr = chan + 0x4;				// PLD reg addr (4 or 5)
  //--------------
  fpga_clr_fcfg();
  data = 0x8;
  pld_set_reg( pNum, addr, data, 0x2 );		// WPn high, CS and CLK low
  fpga_send_fcfg(sccNum);
#ifdef NOT_DBG_WPOT
  PRT(EVE,Initialized Pot signals);
#endif
  //--------------
  fpga_clr_fcfg();
  for(i=0;i<24;i++) {
    if( (1<<(23-i)) & wdata )	data = 0xc;	// WPn high, Clk low, w/ Data
    else			data = 0x8;
    pld_set_reg( pNum, addr, data, 0x2 );
    data |= 0x2;				// Set clock High
    pld_set_reg( pNum, addr, data, 0x2 );	// Clock High
    if((i & 0x3) == 0x3 ) {
      fpga_send_fcfg(sccNum);
      fpga_clr_fcfg();
    }
#ifdef NOT_DBG_WPOT
    PRTDV(EVE,Iteration,i);
#endif
  }
  //--------------
  data = 0x9;					// CS high, WPn and CLK low
  pld_set_reg( pNum, addr, data, 0x2 );
  fpga_send_fcfg(sccNum);
#ifdef DBG_WPOT
  sprintf(Buf,"Wrote C%dP%dCh%d = 0x%6x",Card,pNum,chan,wdata);
  PRTS(EVE,,Buf);
#endif

  return(0);
}

//-------------------------------------------------------------------------
// This function reads a 24 bit codeword from a winpot device.
//-------------------------------------------------------------------------
int dcard_4w_get_wpot_reg( int Card, int pNum, int chan, u32 *pData )
{
  u32 addr, data, i;
  u32 read_data = 0;
  int sccNum = Ctp.Card[Card].Port[pNum].SccNum;
  FUNC_PRT(dcard_4w_get_wpot_reg, PF_DCARD, pNum);

  BAILTESTF(chan>=2,Invalid channel ID);
  addr = chan + 0x4;
  //--------------
  fpga_clr_fcfg();
  data = 0x8;					// WPn, Data, CS & CLK low
  pld_set_reg( pNum, addr, data, 0x2 );
  fpga_send_fcfg(sccNum);
  //--------------
  *pData = 0x0;
  for(i=0;i<24;i++) {
    fpga_clr_fcfg();
    data = 0x8;					// WPn, Data, CS & CLK low
    pld_set_reg( pNum, addr, data, 0x2 );
    data |= 0x2;				// Set Clock High
    pld_set_reg( pNum, addr, data, 0x2 );
    pld_get_reg( pNum, addr, 0x2 );
    fpga_send_fcfg(sccNum);
    pld_get_reg_val( 2, (u32 *)&read_data );
    if(read_data & 0x1) *pData |= (1 << (23-i));
  }
  //--------------
  fpga_clr_fcfg();
  data = 0x9;					// CS high, WPn and CLK low
  pld_set_reg( pNum, addr, data, 0x2 );
  fpga_send_fcfg(sccNum);

  return(0);
}

//-------------------------------------------------------------------------
// Waits for the ready signal to be active on a WPOT
//-------------------------------------------------------------------------
int dcard_4w_w4_wpot_ready( int Card, int pNum, int chan )
{
  int	max_wait = 10;
  u32	addr, read_data;
  int sccNum = Ctp.Card[Card].Port[pNum].SccNum;
  FUNC_PRT(dcard_4w_w4_wpot_ready, PF_DCARD, pNum);

  BAILTESTF(chan>=2,Invalid channel ID);

  addr = chan + 0x4;
  while( max_wait ) {
    fpga_clr_fcfg();
    pld_get_reg( pNum, addr, 0x2 );		// read busy bit
    fpga_send_fcfg(sccNum);
    pld_get_reg_val( 0, (u32 *)&read_data );
#ifdef NOT_DBG_WPOT
    PRTV(EVE,Read busy value,read_data);
#endif
    if((read_data & 0x2) == 0x2) {
      break;					// Ready bit went active
    } else {
      usleep(11000);				// Min 1 tick (at least 10 ms)
    }
    max_wait--;
  }

  if( max_wait ) {
    return(SUCCESS);	// No timeout
  }
  else {
    PRT(MIN,WPOT ready signal never went active);
    return(FAILURE);	// Timeout
  }
}

//-------------------------------------------------------------------------
// This function programs a value into a winpot device.
//-------------------------------------------------------------------------
int dcard_4w_prog_wpot( int Card, int pNum, int chan, int pot, int nvmem, u32 value)
{
  u32 data = 0;
  u32 read_data = 0;
#ifdef DBG_WPOT
  char			Buf[100];
#endif
  FUNC_PRT(dcard_4w_prog_wpot, PF_DCARD, pNum);

  BAILTESTF(chan>1,Invalid channel ID);
  BAILTESTF(pot>3,Invalid potentiometer ID);
  BAILTESTF(value>511,Invalid potentiometer value);
#ifdef DBG_WPOT
  sprintf(Buf,"Wrote Port%dCh%dPot%dMem%d = 0x%6x",Port,chan,pot,nvmem,value);
  PRTS(EVE,,Buf);
#endif
  //----- Reset chip -----
  dcard_4w_set_wpot_reg( Card, pNum, chan, WPOT_RESET );
  if( dcard_4w_w4_wpot_ready(Card,pNum,chan) ) {
    PRT(MIN,Chip didnt reset);
    return(FAILURE);
  }
  //----- Wake up chip -----
  dcard_4w_set_wpot_reg( Card, pNum, chan, WPOT_WAKE_UP );
  if( dcard_4w_w4_wpot_ready(Card,pNum,chan) ) {
    PRT(MIN,Chip didnt wake up);
    return(FAILURE);
  }
  //----- Erase NVMEM -----
  data = WPOT_ERASE_NVMEM | ((pot & 0x3) << 16) | ((nvmem & 0x3) << 18);
  dcard_4w_set_wpot_reg( Card, pNum, chan, data );
  if( dcard_4w_w4_wpot_ready(Card,pNum,chan) ) {
    PRT(MIN,Chip didnt erase NVMEM);
    return(FAILURE);
  }
  //----- Program NVMEM -----
  data = WPOT_WRITE_NVMEM | ((pot & 0x3) << 16) | ((nvmem & 0x3) << 18);
  data |= (value & 0xff);
  dcard_4w_set_wpot_reg( Card, pNum, chan, data );
  if( dcard_4w_w4_wpot_ready(Card,pNum,chan) ) {
    PRT(MIN,Chip didnt program NVMEM);
    return(FAILURE);
  }
  //----- Reset chip -----
  dcard_4w_set_wpot_reg( Card, pNum, chan, WPOT_RESET );
  if( dcard_4w_w4_wpot_ready(Card,pNum,chan) ) {
    PRT(MIN,Chip didnt reset again);
    return(FAILURE);
  }
  //----- Wake up chip -----
  dcard_4w_set_wpot_reg( Card, pNum, chan, WPOT_WAKE_UP );
  if( dcard_4w_w4_wpot_ready(Card,pNum,chan) ) {
    PRT(MIN,Chip didnt wake up again);
    return(FAILURE);
  }
  //----- Send Read NVMEM Command -----
  data = WPOT_READ_NVMEM | ((pot & 0x3) << 16) | ((nvmem & 0x3) << 18);
  dcard_4w_set_wpot_reg( Card, pNum, chan, data );
  if( dcard_4w_w4_wpot_ready(Card,pNum,chan) ) {
    PRT(MIN,Chip didnt read NVMEM);
    return(FAILURE);
  }
  //----- Read NVMEM -----
  dcard_4w_get_wpot_reg(Card,pNum,chan,(u32 *)&read_data);
  //----- Verify Readback -----
  if( ((read_data ^ value) & 0x1ff) != 0 ) {
    PRT(MIN,Read bad NVMEM value);
    return(FAILURE);
  } else {
    return(SUCCESS);
  }
}

