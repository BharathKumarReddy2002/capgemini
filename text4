//--------------------------------------------------------------------------
int ctp_check_port_cfg_rates( int Card, int pNum, CTP_Q_MSG * ptr)
{
#ifdef LINUX64 
  CTP_Q_OAM_MSG		*pMsg = (CTP_Q_OAM_MSG *)ptr;
#else
  CTP_Q_MSG		*pMsg = (CTP_Q_MSG *)ptr;
#endif
  CTP_MSG_REM_OAM	*pMsgOam = (CTP_MSG_REM_OAM *)&pMsg->CtpMsg.msg.RemOam;
  int			 LocCid = Ctp.Card[Card].PortInt[pNum].LocAdCid.Cid;
  CTP_PORT_DBASE 	*pLocDb = (CTP_PORT_DBASE *)&Db.Card[Card].Port[pNum];
  u8			 ignore_rem_clk_to_here, ignore_rem_clk_to_there;
  u8			 ignore_loc_clk_to_there, ignore_loc_clk_to_here;
  double		 rem_clk_to_here, rem_clk_to_there;
  double		 loc_clk_to_there, loc_clk_to_here;
  double		 dds_clk, divider;
  char			 buf1[100],buf2[100];
  //static u8		 LastCheckOk = NO;
  // Aricent PR 1324769 fix - Start
  int                   bNum  = util_get_next_bNum(pLocDb , -1);
  CTP_BNDL_DBASE        *pDbB  = (CTP_BNDL_DBASE *)&Db.Bndl[bNum];
  u8                    PPCfg = pDbB->Bndl.cp_bndl.PktProtect;
  // Aricent PR 1324769 fix - End
  FUNC_PRT (ctp_check_port_cfg_rates, PF_PST, pNum);

  if( NO_OAM(Card,pNum) ) {	//Aricent PR 1202814 fix
    PRTP(GEN, Skipping OAM Cfg Rate check);//Aricent PR 1202814 fix
    return(SUCCESS);//Aricent PR 1202814 fix
  }

  // TODO mike - I have seen bundles transition to CfgFail due to stray
  // OAMs arriving from active bundles elsewhere in the network which have
  // clocking configurations that do not match. If we were
  // to include the check below, it would prevent these OAMs from messing
  // up an otherwist happy bundle. But I am having trouble recreating it,
  // so I am leaving this commented out for now.
  //
  //
  //if( ctp_check_port_cfg_endpoints(Card, pNum, ptr) == FAILURE ) {
  //  PRTP(OFF,OAM endpoints dont match so skip rate check);
  //  return(SUCCESS);
  //}

  //PRT(OFF,+++++ Dumping received OAM ++++++);	// debug
  //util_prt_oam_msg( pMsg, 1, TMP);		// debug

  //PRT(OFF,__________________________);
  //PRTV(OFF,Remote DDS clk,rem_dds_clk);
  //PRTV(OFF,dds_src,pMsgOam->dds_src);
  //PRTV(OFF,div_src,pMsgOam->div_src);
  //PRTV(OFF,div_val,pMsgOam->div_val);
  //PRTV(OFF,dds_freq,pMsgOam->dds_freq);
  //PRTV(OFF,rx_sel,pMsgOam->rx_sel);
  //PRTV(OFF,tx_sel,pMsgOam->tx_sel);

  // These are the possible clock configurations, with rate formula
  // -[1]--> TT,		rate = ?
  // -[2]--> DDS(USER),		rate = (DDS/div10)
  // -[3]--> DDS(ADAP),		rate = (DDS/div10)
  // -[4]--> DDS(AUTO),		rate = ?
  // -[5]--> DIV(DDS(USER)),	rate = (DDS/div10)/DIV
  // -[6]--> DIV(DDS(ADAP)),	rate = (DDS/div10)/DIV
  // -[7]--> DIV(DDS(AUTO)),	rate = ?
  // -[8]--> DIV(OSC),		rate = OSC/DIV
  // -[9]--> ST,		rate = ?
  //----- Do clock calculations for remote clock towards here
#if 0	// XXX remove this bug fix so that FT1 works again
//Aricent Fix for PR659222 - Start
  if(pMsgOam->dds_freq != pLocDb->dds_freq)
       return(FAILURE);
//Aricent Fix for PR659222 - End
#endif
  // Aricent PR 1324769 fix - Start
  if(pMsgOam->version == 6) {
    if (( PPCfg == PP_CLONE_DISABLE) && (pMsgOam->PktProtect == PP_CLONE_DISABLE)){
      PRTP(GN3, skip packet protector configuration check);
    } else {
      if (ctp_chk_pkt_protect_cfg_endpoints( Card, pNum,  ptr) == FAILURE){
	PRTP(MAJ, packet protector configuration mismatch);
	return(FAILURE);
      }
    }
  }
  // Aricent PR 1324769 fix - End
  if( ( (pMsgOam->rx_sel == CTP_CLK_SEL_DDS) && 		// 1
	(pMsgOam->dds_src == CTP_DDS_SRC_USER) ) ||
      ( (pMsgOam->rx_sel == CTP_CLK_SEL_DDS) && 		// 2
	(pMsgOam->dds_src == CTP_DDS_SRC_ADAPTIVE) ) ) {
    ignore_rem_clk_to_here = 0;
    divider = util_power(10,pMsgOam->dds_div);
    rem_clk_to_here = (double)pMsgOam->dds_freq/(0x20000 * divider);
    PRTFVP(GN3,remote DDS clock towards here,rem_clk_to_here);
  }
  else if( (pMsgOam->rx_sel == CTP_CLK_SEL_TT) ||		// 1
         (pMsgOam->rx_sel == CTP_CLK_SEL_ST) ||			// 9
	 ( (pMsgOam->rx_sel == CTP_CLK_SEL_DDS) && 		// 2
	   (pMsgOam->dds_src == CTP_DDS_SRC_AUTOBAUD) ) ||
	 ( (pMsgOam->rx_sel == CTP_CLK_SEL_DIV) && 		// 3
	   (pMsgOam->div_src == CTP_DIV_SRC_DDS) &&
	   (pMsgOam->dds_src == CTP_DDS_SRC_AUTOBAUD) ) ) {
    ignore_rem_clk_to_here = 1;
    PRTP(GN3,Dont know remote clock towards here);
  }
  else if( ( (pMsgOam->rx_sel == CTP_CLK_SEL_DIV) && 		// 1
	     (pMsgOam->div_src == CTP_DIV_SRC_DDS) &&
	     (pMsgOam->dds_src == CTP_DDS_SRC_USER) ) ||
	   ( (pMsgOam->rx_sel == CTP_CLK_SEL_DIV) && 		// 2
	     (pMsgOam->div_src == CTP_DIV_SRC_DDS) &&
	     (pMsgOam->dds_src == CTP_DDS_SRC_ADAPTIVE) ) ) {
    ignore_rem_clk_to_here = 0;
    divider = util_power(10,pMsgOam->dds_div);
    dds_clk = (double)pMsgOam->dds_freq/(0x20000 * divider);
    rem_clk_to_here = dds_clk / (2 * (double)pMsgOam->div_val);
    PRTFVP(GN3,remote DDS/DIV clock towards here,rem_clk_to_here);
  }
  else if( ( (pMsgOam->rx_sel == CTP_CLK_SEL_DIV) && 		// 1
	     (pMsgOam->div_src == CTP_DIV_SRC_OSC) ) ) {
    ignore_rem_clk_to_here = 0;
    rem_clk_to_here = (double)CTP_OSC_FREQ / (2.0 * (double)pMsgOam->div_val);
    PRTFVP(GN3,remote OSC/DIV clock towards here,rem_clk_to_here);
  }
  else {
    PRTP(MIN,remote clock towards here FELL THROUGH CASES - setting to 0);
    ignore_rem_clk_to_here = 0;
    rem_clk_to_here = 0.0;
  }

  //----- Do clock calculations for remote clock towards there
  if( ( (pMsgOam->tx_sel == CTP_CLK_SEL_DDS) && 		// 1
	(pMsgOam->dds_src == CTP_DDS_SRC_USER) ) ||
      ( (pMsgOam->tx_sel == CTP_CLK_SEL_DDS) && 		// 2
	(pMsgOam->dds_src == CTP_DDS_SRC_ADAPTIVE) ) ) {
    ignore_rem_clk_to_there = 0;
    divider = util_power(10,pMsgOam->dds_div);
    rem_clk_to_there = (double)pMsgOam->dds_freq/(0x20000 * divider);
    PRTFVP(GN3,remote DDS clock to there,rem_clk_to_there);
  }
  else if( (pMsgOam->tx_sel == CTP_CLK_SEL_TT) || 		// 1
    	 (pMsgOam->tx_sel == CTP_CLK_SEL_ST) || 		// 9
	 ( (pMsgOam->tx_sel == CTP_CLK_SEL_DDS) && 		// 2
	   (pMsgOam->dds_src == CTP_DDS_SRC_AUTOBAUD) ) ||
	 ( (pMsgOam->tx_sel == CTP_CLK_SEL_DIV) && 		// 3
	   (pMsgOam->div_src == CTP_DIV_SRC_DDS) &&
	   (pMsgOam->dds_src == CTP_DDS_SRC_AUTOBAUD) ) ) {
    ignore_rem_clk_to_there = 1;
    PRTP(GN3,Dont know remote clock to there);
  }
  else if( ( (pMsgOam->tx_sel == CTP_CLK_SEL_DIV) && 		// 1
	     (pMsgOam->div_src == CTP_DIV_SRC_DDS) &&
	     (pMsgOam->dds_src == CTP_DDS_SRC_USER) ) ||
	   ( (pMsgOam->tx_sel == CTP_CLK_SEL_DIV) && 		// 2
	     (pMsgOam->div_src == CTP_DIV_SRC_DDS) &&
	     (pMsgOam->dds_src == CTP_DDS_SRC_ADAPTIVE) ) ) {
    ignore_rem_clk_to_there = 0;
    divider = util_power(10,pMsgOam->dds_div);
    dds_clk = (double)pMsgOam->dds_freq/(0x20000 * divider);
    rem_clk_to_there = dds_clk / (2 * (double)pMsgOam->div_val);
    PRTFVP(GN3,remote DDS/DIV clock to there,rem_clk_to_there);
  }
  else if( ( (pMsgOam->tx_sel == CTP_CLK_SEL_DIV) && 		// 1
	     (pMsgOam->div_src == CTP_DIV_SRC_OSC) ) ) {
    ignore_rem_clk_to_there = 0;
    rem_clk_to_there = 16384.0 / (double)pMsgOam->div_val;
    PRTFVP(GN3,remote OSC/DIV clock to there,rem_clk_to_there);
  }
  else {
    PRTP(MIN,remote clock to there FELL THROUGH CASES - setting to 0);
    ignore_rem_clk_to_there = 0;
    rem_clk_to_there = 0.0;
  }

  //----- Do clock calculations for local clock towards there
  if( ( (pLocDb->rx_sel == CTP_CLK_SEL_DDS) && 			// 1
	(pLocDb->dds_src == CTP_DDS_SRC_USER) ) ||
      ( (pLocDb->rx_sel == CTP_CLK_SEL_DDS) && 			// 2
	(pLocDb->dds_src == CTP_DDS_SRC_ADAPTIVE) ) ) {
    ignore_loc_clk_to_there = 0;
    divider = util_power(10,pLocDb->dds_div);
    loc_clk_to_there = (double)pLocDb->dds_freq/(0x20000 * divider);
    if( FRAC_T1E1(Card, pNum) ) {
      //--- Calculate the fractional clock
      if( pLocDb->DcardCfg1 & T1E1_MSK_E1 ) {
	int cas = (pLocDb->DcardCfg1 & T1E1_MSK_E1_CAS) ? 1 : 0;
	loc_clk_to_there = (pLocDb->DcardCfg2 + 1 + cas) * 64;
      } else {
	int frm = (pLocDb->DcardCfg1 & T1E1_MSK_NO_FRM) ? 0 : 8;
	loc_clk_to_there = pLocDb->DcardCfg2 * 64 + frm;
      }
    }
    PRTFVP(GN3,local DDS clock to there,loc_clk_to_there);
  }
  else if( (pLocDb->rx_sel == CTP_CLK_SEL_TT) || 		// 1
    	 ( (pLocDb->rx_sel == CTP_CLK_SEL_ST) &&
  	   (pLocDb->IfType == IF_TYPE_DTE)) || 			// 9
	 ( (pLocDb->rx_sel == CTP_CLK_SEL_DDS) && 		// 2
	   (pLocDb->dds_src == CTP_DDS_SRC_AUTOBAUD) ) ||
	 ( (pLocDb->rx_sel == CTP_CLK_SEL_DIV) && 		// 3
	   (pLocDb->div_src == CTP_DIV_SRC_DDS) &&
	   (pLocDb->dds_src == CTP_DDS_SRC_AUTOBAUD) ) ) {
    ignore_loc_clk_to_there = 1;
    PRTP(GN3,Dont know local clock to there);
  }
  else if( ( (pLocDb->rx_sel == CTP_CLK_SEL_DIV) && 		// 1
	     (pLocDb->div_src == CTP_DIV_SRC_DDS) &&
	     (pLocDb->dds_src == CTP_DDS_SRC_USER) ) ||
	   ( (pLocDb->rx_sel == CTP_CLK_SEL_DIV) && 		// 2
	     (pLocDb->div_src == CTP_DIV_SRC_DDS) &&
	     (pLocDb->dds_src == CTP_DDS_SRC_ADAPTIVE) ) ) {
