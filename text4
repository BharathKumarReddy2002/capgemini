int ctp_port_cfg(int Card, int pNum, CTP_PORT_DBASE *pNewDbP)
{
  CTP_PORT_DBASE	*pDbP;
  CTP_PORT_STATE	*pPortSt;
  CTP_PORT_INT_STATE	*pPortIntSt;
  int			OldPortDbState;
  u32			OldPortDbPbsIp;
  int			OldDbCsum, NewDbCsum;
  int 			bNum ; //Aricent PR-947222 
  FUNC_PRT(ctp_port_cfg, PF_IPC, -1);

  pDbP = &Db.Card[Card].Port[pNum];
  pPortSt = &Ctp.Card[Card].Port[pNum];
  pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  OldPortDbState = pDbP->State;	// Save current port state
  OldPortDbPbsIp = pDbP->pkt_info.Local_IP;
  OldDbCsum = util_csum((char *)pDbP,sizeof(CTP_PORT_DBASE));
  bcopy(pNewDbP,pDbP,sizeof(CTP_PORT_DBASE));
  bNum = util_get_next_bNum(pDbP, -1); //Aricent PR-947222
  if(pPortSt->Available == NO) return SUCCESS;
  //--- Check if we need to add element to CtpNidInfo structure
  if( PBS(Card,pNum) ) {
    /*
      * In bridge mode, we need bogus IPs assigned to the scc interfaces.
      * The user shouldn't have to deal with them, so if the port is a bridge
      * port, we just force the IPs to bogus values here. We set the local
      * and remote IPs to 127.0.0.(2+port). The hope is that that won't
      * conflict with anything. This also resets MTU to 1500 and deletes any
      * static routes. No need to let the user adjust MTU since he can do
      * that with the devices on either side of the bridge.
      */
    if (pDbP->CfgFlags & CFG_PORT_FLAG_BRIDGE) {
      pDbP->pkt_info.Local_IP = 0x7f000002 + pPortSt->SccNum;    // 127.0.0.2+scc#
      pDbP->pkt_info.Remote_IP = 0x7f000002 + pPortSt->SccNum;   // 127.0.0.2+scc#
      pDbP->pkt_info.Mtu = 1500;
      pDbP->pkt_info.Routes[0].use = NO;
      pDbP->pkt_info.Routes[1].use = NO;
      pDbP->pkt_info.Routes[2].use = NO;
    }
    //--- Check if we need to add element to CtpNidInfo structure
    if( (OldPortDbPbsIp != 0) &&
        (OldPortDbPbsIp != pDbP->pkt_info.Local_IP )) {
      ctp_nid_del_ip( OldPortDbPbsIp );
    }
    if( pDbP->pkt_info.Local_IP != 0 ) {
      char ifs[16];
      int speed = 0;
      CTP_NODE_STORAGE addNode;
      if( pPortIntSt->CntrRatio != 0) {
        speed = (int)(pPortIntSt->NomCtrFreq/pPortIntSt->CntrRatio);
      }
      sprintf(ifs,"scc%d", pPortSt->SccNum);
      addNode.Type = CTP_IPV4;
      addNode.v4 = pDbP->pkt_info.Local_IP;
      ctp_nid_add_ip( 100+pPortSt->SccNum, CTP_IF_TYPE_PBS, ifs, &addNode, speed ,(int)pDbP->pkt_info.Mtu);
    }
  }

  //PRT(OFF,=== Printing Dbase Element copied from Msg);
  //util_prt_db_port(&pMsg->CtpMsg.msg.DbP.Db);
  //PRT(OFF,=== Printing New Configured Dbase Element);
  //util_prt_db_port(pDbP);


  //--- Activate PBS or Diagnostics or non-CTP port via Port DB state
  if( (OldPortDbState == CTP_DBSTATE_DOWN) &&
      (pDbP->State == CTP_DBSTATE_UP) &&
      (pPortSt->Available) &&
      ( (PBS(Card,pNum)) ||
        (pPortSt->Diagnostics) ||
        (IS_H110(Card, pNum)) ||
        (ctp_bndl_type_wp(Card, pNum))) ) {
    int Status;
    PRTP(GEN,activate diagnostic/PBS/T1 port - calling ctp_add_port);
    // Aricent PR-947222 Start
    if(Db.Card[Card].all_h110_cesop){
      set_nom_ctr_freq(Card,pNum); //this make CntrRatio to 1
    }
    // Aricent PR-947222 End 
    else if(!VOICE(Card) && !Db.Card[Card].all_h110_cesop) {
     Status = ctp_add_port(Card, pNum);	//--- ctp_add_pbs_port ???
    // Don't continue with port setup unless things are a go
    if( Status == SUCCESS ) {
      // After adding the port, initialize DSR/CTS to configured in-sync
      // values for crypto resync
      ctp_set_single_sig_out( Card, pNum, CTP_SIG_OUT_DSR,
          CRYPTO_DSR_NORM(pDbP->CryptoResync2) ? 1 : 0);
      ctp_set_single_sig_out( Card, pNum, CTP_SIG_OUT_CTS,
          CRYPTO_CTS_NORM(pDbP->CryptoResync2) ? 1 : 0);
    } else {
      PRTP(MIN,Add port failed);
    }
   }
  }
  //--- Disable PBS & Diagnostics ports via Port DB state
  else if( (OldPortDbState == CTP_DBSTATE_UP) &&
            (pDbP->State == CTP_DBSTATE_DOWN) &&
            ( (PBS(Card,pNum)) ||
              (pPortSt->Diagnostics) ||
              (IS_H110(Card, pNum)) ||
            (ctp_bndl_type_wp(Card, pNum))) ) { 
    PRTP(GEN,deactivate diagnostic port - calling ctp_del_port);
    if(!VOICE(Card))         //Aricent PR-947222 fix
      ctp_del_port(Card, pNum);	//--- ctp_del_pbs_port ???
  }
  // This test will check to see if *anything* has changed in the
  // port database. If it has, and the port is active in the
  // database, the port gets deleted and reinstalled. Although this
  // might seem like overkill, it is important to delete the port if
  // the remote node has changed. I can make this more subtle
  // later... We make sure only to bring up the port if it is
  // actually ACTIVE in the database
  else if( (util_csum((char *)pDbP,sizeof(CTP_PORT_DBASE)) != OldDbCsum) &&
            (pDbP->State == CTP_DBSTATE_UP) &&
            (pPortSt->Available) ) {
    if( PBS(Card,pNum) ) {
      ctp_del_port(Card, pNum);	//TODO ctp_add_pbs_port ???
      ctp_add_port(Card, pNum);	//TODO ctp_add_pbs_port ???
    } else {
      int bNum = util_get_next_bNum(pDbP, -1);
      if( Db.Bndl[bNum].State == CTP_DBSTATE_UP ) {
        PRTDVP(MIN,Port config with active bundle,bNum);
      }
    }
  }
 // Aricent PR-947222 Start
   analog_port_cfg(Card, pNum, pDbP);
 // Aricent PR-947222 End

  return SUCCESS;
}

int ctp_bndl_remove_without_db( int bNum ) 
{
  CTP_BNDL_STATE *pBndlSt=&Ctp.Bndl[bNum];
  FUNC_PRT(ctp_bndl_remove_without_db, PF_IPC, -1);

  PRTDV(GEN,Disabling bundle, bNum);
  switch(Db.Bndl[bNum].Type){
    case CTP_BNDL_TYPE_VC:
      ctp_vc_bndl_act(bNum,0);
      break;
    case CTP_BNDL_TYPE_WP:
      ctp_wp_bndl_act(bNum,0);
      break;
    default:
    {
      int Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
      int pNum = util_bndl_src_pNum(0, &Db.Bndl[bNum]);
      ctp_del_port(Card,pNum);
      pBndlSt->State = CTP_PORT_STATE_NOT_CFG;
    }
      break;
  }
  // Close any open buffer monitoring files
  if( (void *)pBndlSt->pBufStatsFile != NULL ) {
    FILE *pBufFile = (FILE *)pBndlSt->pBufStatsFile;
    PRT(GEN,Closing Stats file);
    if( fclose(pBufFile) != 0 ) { PRT(MIN,Error closing Stats file); }
    pBndlSt->pBufStatsFile = (u32)NULL;
  }
  return SUCCESS;
}

int ctp_bndl_add_without_db( int bNum ) 
{
  CTP_BNDL_STATE *pBndlSt=&Ctp.Bndl[bNum];
  FUNC_PRT(ctp_bndl_add_without_db, PF_IPC, -1);
  PRTDV(GEN,Activating bundle, bNum);
  switch(Db.Bndl[bNum].Type){
    case CTP_BNDL_TYPE_VC:
      ctp_vc_bndl_act(bNum,1);
      break;
    case CTP_BNDL_TYPE_WP:
      ctp_wp_bndl_act(bNum,1);
      break;
    default:
    {
      int Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
      int pNum = util_bndl_src_pNum(0, &Db.Bndl[bNum]);
      ctp_add_port(Card,pNum);
      pBndlSt->State = CTP_PORT_STATE_NO_SYNC;
    }
      break;
  }
  pBndlSt->BufStatsExecCntr = CTP_STATS_PER;
  pBndlSt->pBufStatsFile = (u32)NULL;
  return SUCCESS;
}
