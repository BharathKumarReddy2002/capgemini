void ctp_port_mirror_cfg(int Card, int pNum, u8 add)
{
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  CTP_PORT_DBASE	*pPortDb = &Db.Card[Card].Port[pNum];
  int 			bNum= util_get_next_bNum(pPortDb, -1);
  CTP_BNDL_DBASE	*pBndlDb;
  FUNC_PRT(ctp_port_mirror_cfg, PF_BNDL, -1);
//--- Port mirroring mangle table rules
//--- find bndl number used by this port.
  PRTDVP(GEN, ctp_port_mirror_cfg for bndl,bNum);
  if(bNum < 0){
    PRT(GEN, UP: the port is not attached to any bundle);
  } else {
    pBndlDb = &Db.Bndl[bNum];
    if(pBndlDb->port_mirror_rx.numTail) {
      ctp_pm_tail_cfg(bNum, pPortIntSt, add, 1);
    }
    if (pBndlDb->port_mirror_tx.numTail) {
      ctp_pm_tail_cfg(bNum, pPortIntSt, add, 0);
    }
  }
}

void ctp_add_t1e1_h110(CTP_PORT_DBASE *pDbP, CTP_PORT_STATE *pPortSt, int add)
{
  t1_config	t1Cfg;
  u32 val;
  char SccBuf[8];
  int Card = pPortSt->Card;
  int pNum = pPortSt->pNum;
  int all_h110 = Db.Card[Card].card_all_h110;
  FUNC_PRT(ctp_add_t1e1_h110, PF_MISC, -1);
  PRTDVP(GN3,ctp_add_t1e1_h110 function enter with card all_h110, all_h110);
  t1Cfg.onOff = add?2:0;
  t1Cfg.framing = pDbP->DcardCfg1 & T1E1_MSK_E1;
  t1Cfg.lineCoding = (pDbP->DcardCfg1 & T1E1_MSK_T1_AMI) >> 1;
  t1Cfg.framemode = (pDbP->DcardCfg1 & T1E1_MSK_T1_D4) >> 2;
  t1Cfg.cableLength = (pDbP->DcardCfg1 & T1E1_MSK_BUILDOUT)>>4;
  t1Cfg.signaling = (pDbP->DcardCfg1 & T1E1_MSK_E1_CAS)?1:0;
  if( 1 == all_h110 ) { //Aricent PR-947222
   t1Cfg.h110 = 1; 
  } else           { t1Cfg.h110 = 2; }
  // The following config is needed since the Dallas TxSer mux was
  // decoupled and configured with it's own dedicated FPGA config bits
  sprintf(SccBuf,"scc%d", pPortSt->SccNum);
  if( ioc_priv(SccBuf,SCC_SET_T1_CFG,&t1Cfg) ) {
    PRTS(MIN, Cant IOCTL scc to set H110, SccBuf);
  }
  return;
}

