void ctp_wp_bndl_act(int bNum,int AddBun) {
  int BndlEngineCard = Db.Bndl[bNum].Card;
  // Get the first port from SRC_INFO port list
  int Card = Db.Bndl[bNum].Bndl.wp_bndl.SrcInfo[0].Card;
  int pNum = Db.Bndl[bNum].Bndl.wp_bndl.SrcInfo[0].pNum;
  char PrtBuf[80];
  int	pps;
  int   hairpin_temp, i, numSlots = 0;
  CTP_BNDL_STATE * pBndlSt = &Ctp.Bndl[bNum];
  CTP_PORT_DBASE * pDbP = &Db.Card[Card].Port[pNum];
  CTP_BNDL_DBASE * pDbB = &Db.Bndl[bNum];
  CTP_PORT_STATE *pPortSt = &Ctp.Card[Card].Port[pNum];   //Aricent PR 1022643 fix
  FUNC_PRT(ctp_wp_bndl_act, PF_BNDL, -1);
  //Aricent PR601906 start
/* Aricent PR-717367 start.
 * Fill 'HpinFlag' during activation of a CESoPSN bundle.
 * 'HpinFlag' is used for marking a bundle as hairpin
 * 'HpinFlag' takes values as follows for ctp2000
 * PORT_RUN_FLAG_HAIRPIN - hairpined / not hairpined.
 * PORT_RUN_FLAG_HAIRPIN_NODE_IP - self ip(6 ethernets, 6 PBS, 12 virtual IPs) / 172.0.1.x
 * PORT_RUN_FLAG_HP_REM_CID - paired hairpin bundle found / not found.
 *  This is set only if paired hairpin bndl is found in active state.
 */
  if( AddBun ){
// Aricent PR-717367 end.
  Ctp.Bndl[bNum].HpinFlag = 0;
  if(pDbB->Bndl.wp_bndl.HpinRUdpPort != 0 && ((pDbB->RemAdCid.Node.v4 & 0xffffff00) == 0xac000100)) {
    Ctp.Bndl[bNum].HpinFlag |= PORT_RUN_FLAG_HAIRPIN;
    Ctp.Bndl[bNum].HpinFlag &= ~PORT_RUN_FLAG_HAIRPIN_NODE_IP;
  }
  else if (pDbB->Bndl.wp_bndl.HpinRUdpPort != 0) {
/* Aricent PR-717367.
        if(memcmp(&pSysInfo->interface[hairpin_temp].addr_store.v4, &pDbB->RemAdCid.Node.v4, sizeof(u32))) 
*/
// Aricent PR-717367 end.
          Ctp.Bndl[bNum].HpinFlag |= PORT_RUN_FLAG_HAIRPIN;
          Ctp.Bndl[bNum].HpinFlag |= PORT_RUN_FLAG_HAIRPIN_NODE_IP;
    }
  }
//Aricent PR601906 stop
  if((AddBun && pBndlSt->State != CTP_PORT_STATE_NOT_CFG) ||
    ((!AddBun)&&(pBndlSt->State == CTP_PORT_STATE_NOT_CFG))) {
    PRTB(MIN,ctp_wp_bndl_act: already activated/disabled);
    return;
  }

  for(i = 0; i < 32 ; i ++) {
     if(pDbB->Bndl.wp_bndl.tsBitMask & (1 << i)) numSlots++;
  }
  //Aricent PR 996104 fix - Start - Check H.110 channels are available or NOT
  if( AddBun ){
    int i, count=0;
    unsigned int avail_chan = 0;
    for(i=0; i<4; i++) {
      if((H110_used_chan[i] & 0xffffffff) != 0xffffffff)
        avail_chan += 0xffffffff - H110_used_chan[i];
    }
    if(numSlots > avail_chan) {
      sprintf(PrtBuf,"Only %lu H.110 Channels are available out of 128 ! \n",
          avail_chan);
      PRTS(MAJ,ctp_wp_bndl_act:,PrtBuf);
      return;
    }
  }
  //Aricent PR 996104 fix - End


  pps=util_calc_cesopsn_pps(pDbB, pDbP);
  pPortSt->CheckedOutPps = pps;   //Aricent PR 1022643 fix
  if( AddBun ) {
    if( ctp_verify_dbase_and_hw(Card,pNum) ) return;
    if( ctp_request_pps(Card,pNum,pps) ) return;
  } else {
    ctp_release_pps(Card, pNum, pps);
  }

  // Check for valid srcBundle;
  //Aricent PR 947222 fix
  if( util_chk_cesopsn_bndl(bNum, Db.Bndl, &Db) && util_chk_sup(bNum, Db.Bndl)) {
    int enable = AddBun?0:1;	  
    sprintf(PrtBuf,"Bndl %d with srcBundle 0x%x %s\n",
	bNum, Db.Bndl[bNum].Bndl.wp_bndl.srcBundle,
	AddBun? "Activated":"Disabled");
    PRTS(EVE,ctp_wp_bndl_act:,PrtBuf);
    if( enable ) {	PRTB(MIN,Disabling CESoPSN bundle); }
    else {              PRTB(MIN,Activating CESoPSN bundle); }
    if( AddBun ) {
      int sigSize;
      pBndlSt->RemAdCid= pDbB->RemAdCid;
      if((pDbP->DcardCfg1 & T1E1_MSK_FRAME) && (pDbP->DcardType == DCARD_T1E1)) { //PR 1524860
        if(pDbP->DcardCfg1 & T1E1_MSK_E1_CAS) { // signaling mode 
          sigSize = (numSlots % 2) ? ((numSlots/2)+1): (numSlots/2);
        }  
      }
      //Aricent PR-947222 Start
      if(Db.Card[Card].all_h110_cesop) { 
       pBndlSt->Bndl.ctp.activeBundle = 1;   // Aricent PR 1009496 Fix 
       cesopsn_h110_cfg(Card, pNum, bNum);
      }
      //Aricent PR-947222 End
      /* This parameter is converted by the following formula
         size of the packets(bare size) / number of slots 
         then / 8 comes milliseconds. and the tick is 32.768k
         per seconds*/
      pBndlSt->Type  = CTP_BNDL_TYPE_WP;
      pBndlSt->TicksPerPkt = ((double)(pDbB->loc_pkt_size-sigSize))*0x1000/numSlots;
      ctp_bndl_state_machine(bNum, CTP_PORT_EVENT_DB_ACTIVE); //Aricent PR-799637
     // Aricent PR-947222 Start
      if(Db.Card[Card].all_h110_cesop) { 
       ctp_wp_bndl_h110_conn(bNum, AddBun);
      }
     // Aricent PR-947222 End 
    } else {
      //Aricent PR-996102 Start
      if(Db.Card[Card].all_h110_cesop) { 
      pBndlSt->Bndl.ctp.numVCh = 0;
      pBndlSt->Bndl.ctp.activeBundle = 0;  // Aricent PR 1009496 Fix
      //Aricent PR-996102 End 
      //--- If voice ports, mute (ie minimize gains)
      if( VOICE(Card) ) {
       int sNum = 0;
       while( pDbB->Bndl.wp_bndl.SrcInfo[sNum].Used ) {
        int src_Card = pDbB->Bndl.wp_bndl.SrcInfo[sNum].Card;
        int src_pNum = pDbB->Bndl.wp_bndl.SrcInfo[sNum].pNum;
        ctp_vb_port_mute(src_Card, src_pNum);
        sNum++;
       }
      }
      ctp_wp_h110_intr(bNum, 0); //Disabling interrupt
      ctp_set_vc_sig(bNum, Card, pNum, 0); //disabling register 1c0080 to stop bogus interrupt
      ctp_wp_bndl_h110_disconn(bNum); // Aricent PR 998675. Call for unmapping local timeslot to Zarlink
     }
     ctp_bndl_state_machine(bNum, CTP_PORT_EVENT_DB_DISABLED); //Aricent PR-799637
     ctp_bndl_clear_all(bNum);//Aricent PR 704072
     /* Aricent PR 1117979, 1133355 Fix - Start */
     CTP_BNDL_CNTRS *pBndlCnt = &Ctp.Bndl_cnt[bNum];
     pBndlCnt->Bndl.ctp.LongBufMon.Buffer.Largest = 0;
     pBndlCnt->Bndl.ctp.LongBufMon.Buffer.Smallest = 0;
     /* Aricent PR 1117979, 1133355 Fix - End */
     pBndlSt->Type  = CTP_BNDL_TYPE_NONE;
    }
    ctp_enable_Dallas_idle(bNum, enable);
  }
}

//--------------------------------------------------------------------------
// This routine returns 1 if the port is configured for CESoPSN
// See also menu_bndl_type_wp in menu_utl
//--------------------------------------------------------------------------
int ctp_bndl_type_wp( int Card, int pNum ){
  int rtn=0;
  // Aricent PR-947222 Start
  CTP_PORT_DBASE        *pDbP = &Db.Card[Card].Port[pNum];
  int bNum = util_get_next_bNum(pDbP, -1);
  int bType = Db.Bndl[bNum].Type;
  // Aricent PR-94722 End
  if(IS_T1E1(Card)){
  /* In case of diagnostics on T1 card, it is always bundle type wp */
    if(Ctp.Card[Card].Port[pNum].Diagnostics) rtn = 1;
  /* Currently only winpath bundle and vcomp bundle will set T1E1_MSK_FRAME bit */
    else if((!IS_H110(Card, pNum)) &&
      (Db.Card[Card].Port[pNum].DcardCfg1 & T1E1_MSK_FRAME)) rtn = 1;
   // Aricent PR-947222 Start
    else if (IS_T1E1_2000(Card) &&
       Db.Card[Card].all_h110_cesop) rtn = 1;
   // Aricent PR-947222 End

  }
  //Aricent PR 880784 fix - Start
  else if( ((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) && ( IS_SER(Card) ) ) {
    if (bType == CTP_BNDL_TYPE_WP) rtn = 1;
  //Aricent PR 880784 fix - End
  }else if (VOICE(Card) && Db.Card[Card].all_h110_cesop ) rtn = 1; //Aricent PR-947222
  return rtn;
}

//--------------------------------------------------------------------------
// This routine initializes Card structure in SysInfo and ctp state
//--------------------------------------------------------------------------
void ctp_init_card(int Card)
{
    int pNum;
    pSysInfo->Card[Card].Type         = NOCARD;	// Init all slots to unoccupied
    pSysInfo->Card[Card].BaseSccNum   = CTP_SCC_NONE;  	// Init to bogus value
    pSysInfo->Card[Card].FpgaRev      = ~0;	// Init to bogus value
    pSysInfo->Card[Card].PcaRev       = ~0;	// Init to bogus value
    pSysInfo->Card[Card].PldRev       = ~0;	// Init to bogus value
    pSysInfo->Card[Card].MiscInfo     = 0;	// Init to bogus value
    pSysInfo->Card[Card].PortsOnCard  = 0;	// Init to no ports
    for(pNum=0;pNum<CTP_MAX_PORTS_PER_CARD;pNum++) {
      Ctp.Card[Card].Port[pNum].Available = NO;
      Ctp.Card[Card].Port[pNum].SccNum    = CTP_SCC_NONE;
    }
    //--- Init all board handles to VBBAD_HANDLE
    pSysInfo->Card[Card].hBoard = VBBAD_HANDLE;
}

//--------------------------------------------------------------------------
// This routine initializes the SysInfo structure.
//--------------------------------------------------------------------------
void ctp_init_sysinfo()
{
  int Card, i, shmid_sys;
  void *shm_sysinfo = (void *)0;
  struct shmid_ds sysinfo_ds;
#ifdef VCTP
  int c_idx;
#endif
  shmid_sys = shmget((key_t)CTP_SHM_SYS_INFO, sizeof(CTP_SYS), 0666|IPC_CREAT);
  if(shmid_sys == -1) {
    syslog(LOG_ERR, "shmget sysinfo failed!\n");
    exit(EXIT_FAILURE);
  }
  if(shmctl(shmid_sys, IPC_STAT, &sysinfo_ds) == -1) {
    syslog(LOG_ERR, "shmctl sysinfo failed!\n");
    exit(EXIT_FAILURE);
  }
  shm_sysinfo = shmat(shmid_sys, (void *)0, 0);
  if(shm_sysinfo == (void *)-1) {
    syslog(LOG_ERR, "shmat sysinfo failed!\n");
    exit(EXIT_FAILURE);
  }
  pSysInfo = (CTP_SYS *)shm_sysinfo;
  FUNC_PRT(ctp_init_sysinfo, PF_MISC, -1);
  /* only the creator initialize the shared memory */
  if(sysinfo_ds.shm_cpid != getpid()) return; 
  PRTDV(MAJ, Initialize SysInfo shared Memory with Pid, sysinfo_ds.shm_cpid);
  //--- Setting default pSysInfo->EthNum as well as
  //    parsing command line options was moved from after opening the
  //    message queues.	-gw
  //
  memset(pSysInfo,0,sizeof(CTP_SYS));

  pSysInfo->EthNum = 0;		// Default to eth0!!
  pSysInfo->flash = 1;		// Initialize to flash system type
  pSysInfo->CtpPrt.Card = -2;		// Default to any
  pSysInfo->CtpPrt.Port = -2;		// Default to any
  pSysInfo->CtpPrt.Facility = PF_NONE;	// Default to standard
  pSysInfo->CtpPrt.LogLevel = GEN;	// Default to GEN
  pSysInfo->LongBuffEnable = 1;	// Default
  pSysInfo->protocol = 47;	// Default
  pSysInfo->oam_port = 16;	// Default
  pSysInfo->oam_port_v6 = 32; 	// Default
  pSysInfo->LongBufCntr = 0;	// Initialize cntr
  pSysInfo->Chassis.fans_ok = 1;		// Initialize as OK
  pSysInfo->Chassis.fans_failed_once = 0;	// Initialize as OK
  pSysInfo->Chassis.ps_ok = 1;		// Initialize as OK
  pSysInfo->Chassis.ps_failed_once = 0;	// Initialize as OK
  pSysInfo->Chassis.temp_ok = 1;		// Initialize as OK
  pSysInfo->Chassis.temp_failed_once = 0;	// Initialize as OK
  pSysInfo->Clk.need_h110 = 0;	// Clock variables set in ctp_hw_scan()
  pSysInfo->Clk.has_scc = 0;
  pSysInfo->Clk.first_t1 = -1;		// 0 is valid slot, so...
  pSysInfo->Clk.first_scc = -1;
  pSysInfo->Clk.clk_rtm_hub_slot = -1;

  // In ctp_check(), 1st ioclt pulls these in from hw. For now set to non-NOVA
  pSysInfo->PortsPerCard   = 4; 	// Determined by sys type
  pSysInfo->SysType = SYS_TYPE_CTP_2000;
  pSysInfo->allowed_pbs_mask = 0x0;	// default none
  // Set this to 1 initially, then reset it after 1st ioctl.
  // this requires 1st card to be present.
  pSysInfo->CardsPerCpu = 7;
  pSysInfo->H110_InUse  = 0;

  // Iitialize all cards as not occupied and ports as not available.
  // Port availability flag is in port internal structure.
  // These get set according to hw installed by ctp_check();
  for(Card=0;Card<CTP_MAX_CARDS;Card++) {	// Must loop over CTP_MAX_CARDS here
          ctp_init_card(Card);
  }
  for( i=0; i<CTP_MAX_NID; i++) pSysInfo->interface[i].type = CTP_IF_TYPE_NONE;
}

