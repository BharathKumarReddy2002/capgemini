void ctp_bndl_clear_all( int bNum )
{
  CTP_BNDL_CNTRS *pBndlCnt = &Ctp.Bndl_cnt[bNum];
  char				 SccBuf[40];
  struct acrndrv_command	 ncmd;
  int Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
  // Aricent PR 1030232 fix - Start
  int pNum = util_bndl_src_pNum( 0, &Db.Bndl[bNum]);
  CTP_PORT_CNTRS                *pPortCnt = &Ctp.Card[Card].Cntr[pNum];
  // Aricent PR 1030232 fix - End
  struct timeval	 	 now;
  
  switch(Db.Bndl[bNum].Type) {
    case CTP_BNDL_TYPE_CTP:
    case CTP_BNDL_TYPE_SO:	      
      return;
    case CTP_BNDL_TYPE_WP:
    {
      sprintf(SccBuf,"cbc%d",Db.Bndl[bNum].Bndl.wp_bndl.cbc_num); //Aricent PR-947222
      break;
    }
    default:
      break;
  }	    
  ncmd.CmdType = SCC_CMD_CLR_CNTRS;
  ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
  ncmd.CmdType = SCC_CMD_CLR_FLAGS;
  ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
  memset( (char *)&pBndlCnt->Bndl.ctp.Previous,
	0,sizeof(struct acrndrv_runtime_stats));
  // Aricent PR 1030232 fix - Start
  pPortCnt->BertRunSec  = 0;
  pPortCnt->BertSyncSec = 0;
  pPortCnt->BertErrSec  = 0;
  pPortCnt->BertSync    = 0;
  pPortCnt->BertSyncLossCnt = 0;
  pPortCnt->BertErrCnt      = 0;
  // Aricent PR 1030232 fix - End
  pBndlCnt->Bndl.ctp.Current.Counters.underflow_cnt = 0;
  pBndlCnt->Bndl.ctp.Current.Counters.overflow_cnt  = 0;
  pBndlCnt->Bndl.ctp.LongBufMon.Counters.underflow_cnt = 0;
  pBndlCnt->Bndl.ctp.LongBufMon.Counters.overflow_cnt  = 0;
 //Aricent PR 1273976 fix - Start
  if(IS_T1E1_2000(Card) || IS_T1E1(Card)||(IS_SER(Card)&& (*(&Db.Card[Card].Port[pNum].DcardType) == DCARD_T1E1)))
    pBndlCnt->Bndl.ctp.LOFOccurCnt = 0;
  //Aricent PR 1273976 fix - End
  //--- clear buf counts
  ncmd.CmdType = SCC_CMD_RESET_BUFMON;
  ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
  
  gettimeofday(&now,NULL);
  pBndlCnt->Bndl.ctp.TimeLastClr = now.tv_sec;
  return;
}

void ctp_port_clear_all( int Card, int pNum, int bNum )  // Aricent PR 947222 Fix. Function definition changed
{
  struct acrndrv_command	 ncmd;
  struct eth_command		 ecmd;
  CTP_PORT_CNTRS		*pPortCnt = &Ctp.Card[Card].Cntr[pNum];
  CTP_PORT_STATE		*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_DBASE		*pPortDb = &Db.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE		*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  char				 SccBuf[40], EthBuf[8];
  struct timeval	 	 now;

  FUNC_PRT(ctp_port_clear_all, PF_MISC, -1);

  // Aricent PR 947222 Fix - Start
  if(bNum >= 0 && bNum < CTP_MAX_BNDLS) {
    sprintf(SccBuf,"cbc%d",Db.Bndl[bNum].Bndl.wp_bndl.cbc_num);
  }
  else {
    if(pPortSt->SccNum == CTP_SCC_NONE) return;
    sprintf(SccBuf,"scc%d",pPortSt->SccNum);
  }
  // Aricent PR 947222 Fix - End
  //--- clear scc counts
  ncmd.CmdType = SCC_CMD_CLR_CNTRS;
  ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
  ncmd.CmdType = SCC_CMD_CLR_FLAGS;
  ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
  memset( (char *)&pPortCnt->Previous,
      0,sizeof(struct acrndrv_runtime_stats));
#ifndef DBG_NO_ETH_IOCTL
  if( !strncmp(pPortIntSt->NetDev,"eth",3) ) {
    //Aricent PR 830151 --- clear eth counts
    if(strlen(pPortIntSt->NetDev) > 5) {
       sscanf(pPortIntSt->NetDev, "%4s", EthBuf);
    } else {
       sprintf(EthBuf, "%s", pPortIntSt->NetDev);
    }
    ecmd.CmdType = ETH_CMD_CLR_CNTRS;
    ioc_priv(EthBuf,ETH_IOCTL_CMD,&ecmd);
    ecmd.CmdType = ETH_CMD_CLR_FLAGS;
    ioc_priv(EthBuf,ETH_IOCTL_CMD,&ecmd);
  }
#endif //DBG_NO_ETH_IOCTL
  //--- clear buf counts
  ncmd.CmdType = SCC_CMD_RESET_BUFMON;
  ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
  //--- clear bert counts
  pPortCnt->BertRunSec  = 0;
  pPortCnt->BertSyncSec = 0;
  pPortCnt->BertErrSec  = 0;
  pPortCnt->BertSync    = 0;
  pPortCnt->BertSyncLossCnt = 0;
  pPortCnt->BertErrCnt      = 0;
  pPortCnt->Current.Counters.underflow_cnt = 0;
  pPortCnt->Current.Counters.overflow_cnt  = 0;
  pPortCnt->LongBufMon.Counters.underflow_cnt = 0;
  pPortCnt->LongBufMon.Counters.overflow_cnt  = 0;
  gettimeofday(&now,NULL);
  pPortCnt->TimeLastClr = now.tv_sec;
  /* Aricent PR 1117979, 1133355 Fix - Start */
  if (Db.Bndl[bNum].Type == CTP_BNDL_TYPE_CTP) {
    pPortCnt->Latency = 0;
  }
  /* Aricent PR 1117979, 1133355 Fix - End */
  //--- clear bundle counters 
  if(!PBS(Card, pNum) && !IS_BRIDGE(Card, pNum)) {
    // Aricent PR 947222 Fix - Start
    if(!(bNum >= 0 && bNum < CTP_MAX_BNDLS))
      bNum = pPortIntSt->bNum;
    // Aricent PR 947222 Fix - End
    CTP_BNDL_CNTRS *pBndlCnt = &Ctp.Bndl_cnt[bNum];
    pBndlCnt->Bndl.ctp.Current.Counters.underflow_cnt = 0;
    pBndlCnt->Bndl.ctp.Current.Counters.overflow_cnt  = 0;
    pBndlCnt->Bndl.ctp.LongBufMon.Counters.underflow_cnt = 0;
    pBndlCnt->Bndl.ctp.LongBufMon.Counters.overflow_cnt  = 0;
    //Aricent PR 1273976 fix start
    if(IS_T1E1_2000(Card) || IS_T1E1(Card)|| (pPortDb->DcardType == DCARD_T1E1)) {
      pBndlCnt->Bndl.ctp.LOFOccurCnt= 0;
    }
    //Aricent PR 1273976 fix end
    pBndlCnt->Bndl.ctp.TimeLastClr = now.tv_sec;
    /* Aricent PR 1116706, 1117979, 1133355 Fix - START */
    if (Db.Bndl[bNum].Type == CTP_BNDL_TYPE_CTP) {
      pBndlCnt->Bndl.ctp.Latency = 0;
    }
    /* Aricent PR 1116706, 1117979, 1133355 Fix - END */
  }  
  
  //--- clear irig-b latched bits
  if( (pPortDb->State == CTP_DBSTATE_UP) &&
      (pPortDb->if_mode == IF_MODE_DCARD) &&
      ( 
       (pPortDb->DcardType == DCARD_IRIG) ||
       (pPortDb->DcardType == DCARD_MS) 
      ) 
    ) {
    u32 CurVal, NewVal;

    fpga_clr_fcfg();
    pld_get_reg(pNum,0xe,4);
    fpga_send_fcfg(pPortSt->SccNum);
    pld_get_reg_val(0,&CurVal);

    fpga_clr_fcfg();
    NewVal = CurVal ^ 0x2;		// Toggle reset bit
    pld_set_reg(pNum,0xe,NewVal,4);	// Set reset bit
    fpga_send_fcfg(pPortSt->SccNum);

    fpga_clr_fcfg();
    pld_set_reg(pNum,0xe,CurVal,4);	// Clear reset bit
    fpga_send_fcfg(pPortSt->SccNum);

    PRTVP(GEN,Write IRIG-B DCARD reset reg with,NewVal);
    PRTVP(GEN,Write IRIG-B DCARD reset reg with,CurVal);
  }
}

int ctp_get_frac_flags( int Card, int pNum )
{
  int ft1_flag_data = 0;
  u32 temp;
  CTP_PORT_DBASE *pDbP = &Db.Card[Card].Port[pNum]; // PR 1309312
  FUNC_PRT(ctp_get_frac_flags, PF_MISC, -1);

  // Save current LOF_NB status (for detecting changes, and hystersis)
  ft1_flag_data |= (Ctp.Card[Card].PortInt[pNum].FracFlags & CTP_FT1_FLAG_LOF_NB) ? CTP_FT1_FLAG_LOF_NB_LAST : 0x0;
  // Get new Fractional T1 flags from FPGA
  fpga_clr_fcfg();
  fpga_get_port_read_reg( pNum );
  fpga_send_fcfg(Ctp.Card[Card].Port[pNum].SccNum);
  // PR 1309312 - Start
  if( IS_CTP_FRAC_T1_WO_FRAME_ON_T1CARD ) {
    temp = ctp_get_t1_state(Card, pNum);        // Read Dallas framer alarms instead
    if( temp & (T1_ALARM_LOS|T1_ALARM_LOF|T1_ALARM_AIS) ) {
      //PRT(OFF,PR1309312 - Dallas flags setting CTP_FT1_FLAG_LOF_NB );
      ft1_flag_data |= CTP_FT1_FLAG_LOF_NB;     // LOS/LOF/AIS all qualify...
    }
  } else {
  // PR 1309312 - End
    fpga_get_port_ft1e1_fs_nb(0, &temp);
    if( !temp ) { ft1_flag_data |= CTP_FT1_FLAG_LOF_NB; }
  } // PR 1309312
  PRTDVP(GN3,CTPCMDTYPE_READ_FT1E1_FLAGS got ft1e1_fs_nb,temp);
  fpga_get_port_ft1e1_fs_ib(0, &temp);
  PRTDVP(GN3,CTPCMDTYPE_READ_FT1E1_FLAGS got ft1e1_fs_ib,temp);
  if( !temp ) { ft1_flag_data |= CTP_FT1_FLAG_LOF_IB; }
  PRTDVP(GEN,**** Returning ft1_flag_data, ft1_flag_data);

  return (ft1_flag_data);
}

