//--------------------------------------------------------------------------
// This routine checks the entire database, looking for active ports. For
// every active port, an OAM connection is made to the remote host (if one
// does not already exist) and the port is added to the appropriate linked
// list for monitoring.
//--------------------------------------------------------------------------
int ctp_scan_db()
{
  int			Card, pNum, bNum;
#ifdef VCTP
  int c_idx;
#endif
  FUNC_PRT(ctp_scan_db, PF_DBASE, -1);

  if(SCC_CARD(0)){
    // mike - Maybe this should be moved to ctp_scan_hw as that is
    //where h110 gets set & I thought other reference stuff got setup
    // mike (reponse to above) - although that would be a nice idea to
    //consolidate things, unfortunately at ctp_scan_hw time, there is no
    //access to the node dbase, since ctp_scan_db happens later

    //--- Set external 32kHz out according to database.
    ctp_cfg_node_clks( 0, -1 );
  }

  //--- Scan nova_t1e1 cards & set all_vcomp mode   ---
  for(Card=0;Card<CTP_MAX_CARDS;Card++) {
    if( IS_T1E1_2000(Card) ) {
      ctp_card_cfg_all_h110(Card,1);
      if( !Db.Card[Card].card_all_h110 ) ctp_card_cfg_all_h110(Card,0);
    }
  }

  //--- Scan for active PBS ports and bring them up ---
  for(Card=0;Card<CTP_MAX_CARDS;Card++) {
    for( pNum=0; pNum<pSysInfo->Card[Card].PortsOnCard; pNum++) {
      if( (Db.Card[Card].Port[pNum].State == CTP_DBSTATE_UP) &&
	  (Ctp.Card[Card].Port[pNum].Available) &&
//TODO Now not only PBS but also winpath bundle need the State field.
//TODO is it ok? Or am I violating some rules.
// Why the IS_H110() qualifier here, you ask? Well, it would appear that
// there is a very small chunk of code at the beginngin of ctp_add_port()
// that does some config on the T1E1 card and then returns.
// TODO we should take this chunk of code out of ctp_add_port(). Actually,
// this should only be for bringing up PBS/Bridge ports.
	  (PBS(Card,pNum)|| ctp_bndl_type_wp(Card, pNum) || IS_H110(Card, pNum)) ) {
	ctp_add_port(Card, pNum);	//TODO: ctp_add_pbs_port ??
	usleep(100000);		// sleep 100 ms before bringing up the next port
      }
    }
  }
//Aricent PR 601910 Start
  for(Card=0;Card<CTP_MAX_CARDS;Card++) {
    for(pNum=0;pNum<CTP_MAX_PORTS_ON_CARD;pNum++) {
      PRTP(FNC,Initializing port database);
      if(util_get_next_bNum(&Db.Card[Card].Port[pNum], -1) == CTP_MAX_BNDLS) {
        if (IS_T1E1(Card))
           util_init_t1_dbase(&Db.Card[Card].Port[pNum]);
        else {
           if(!PBS(Card,pNum)) { //Aricent PR741094 Fix
             util_init_port_dbase(&Db.Card[Card].Port[pNum],CTP_PORT_DBASE_VERSION);
           }
        }
      }
    }
  }
//Aricent PR 601910 End
  for(bNum=0; bNum < CTP_MAX_BNDLS; bNum++) {
    if(Db.Bndl[bNum].State == CTP_DBSTATE_UP) {
        // Here we only take care of wp bndl, need to move port stuff here
        // to add ctp/satop bundles
      Card = util_bndl_src_card( 0, &Db.Bndl[bNum]);
      pNum = util_bndl_src_pNum( 0, &Db.Bndl[bNum]);
      if(!Ctp.Card[Card].Port[pNum].Available) continue;
      ctp_bndl_add_without_db(bNum);
    }
 //Aricent PR 601910 start
    else if((Db.Bndl[bNum].State == CTP_DBSTATE_DOWN) && (Db.Bndl[bNum].Type != CTP_BNDL_TYPE_NONE)) { //Aricent PR 697538
      Card = util_bndl_src_card( 0, &Db.Bndl[bNum]);
      pNum = util_bndl_src_pNum( 0, &Db.Bndl[bNum]);
      ctp_verify_dbase_and_hw(Card,pNum); 
    }
  }
//Aricent PR 601910 End
  //util_prt_node_list(&Ctp.NodeList);

  ctp_cfg_nref();	// Load NetRef state

  return(SUCCESS);
}

