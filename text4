int ctp_get_nrefs_info(void)
{
  void *shm_nrefs = (void *)0;
  int shm_id;

  shm_id = shmget((key_t)CTP_REF_SHM_KEY, sizeof(CTP_NREFS_STATE), 0666);
  if (shm_id == -1) {
    fprintf(stderr, "shmget nrefs failed!\n");
    return FAILURE;
  }
  shm_nrefs = shmat(shm_id, (void *)0, 0);
  if (shm_nrefs == (void *)-1) {
    fprintf(stderr, "shmat nrefs failed!\n");
    return FAILURE;
  }
  pNRefs = (CTP_NREFS_STATE *)shm_nrefs;
  return SUCCESS;
}
int ctp_free_nrefs_info( void )
{
  if(shmdt(pNRefs) == -1) {
    fprintf(stderr, "shmdt netref failed !\n");
    return (FAILURE);
  }
  return(SUCCESS);
}
