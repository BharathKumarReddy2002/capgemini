	}
	PRTS(EVE,,prtbuf);
      }
      //--- Update MaxPorts, note: cards may not be probed in order!
      if( (slot+1)*pSysInfo->Card[slot].PortsOnCard > pSysInfo->MaxPorts ) {
        //--- TODO Probably not useful, since cards can have different number of
        //    TODO ports now.
        pSysInfo->MaxPorts = (slot+1)*pSysInfo->Card[slot].PortsOnCard;
      }

      {
	int mp = pSysInfo->MaxPorts & 0xff;
	int bs = pSysInfo->Card[slot].BaseSccNum & 0xff;
	int pbs = pSysInfo->Card[slot].PbsPorts & 0xffff;
