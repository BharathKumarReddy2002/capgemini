int ctp_ts_state_find_node(CTP_NODE_STORAGE node)
{
  int index = -1;
  int i,j;
  FUNC_PRT(ctp_ts_state_find_node, PF_REF, -1);

  for(j=0; j<CTP_MAX_TS_STATE; j++){
    i = (j + pNRefs->last_indx) % CTP_MAX_TS_STATE;
    if(pNRefs->TsState[i].state == CTP_TS_STATE_READY) {
      if( (pNRefs->TsState[i].node.Type == node.Type) &&
	  ((node.Type == 0) && (pNRefs->TsState[i].node.v4 == node.v4)) ) {
        index = i;
	pNRefs->last_indx = i;
	break;
      }
      //--- Age used entries & clear out entries that have timed out
      //    TODO: Since we always start at index 0, entries do not age at the
      //    same rate!
      if( pNRefs->TsState[i].age++ >= CTP_MAX_TS_AGE ) {
	ctp_ts_state_clear(i);
      }
    }
  }
  return(index);
}

