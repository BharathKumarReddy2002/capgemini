int ctp_vb_port_init_sigs( int Card, int pNum, int bNum, int sNum)
{
  int status = FAILURE;
  int loopStart;
  int sigs;
  FUNC_PRT(ctp_vb_port_init_sigs, PF_VSIG, pNum);

  switch(CARDTYPE(Card)) {
    case EMCARD:
      pVcSigs->Card[Card].Port[pNum].Chan[0] = 0;
      status = ctp_vb_port_cfg_sigs(Card,pNum,pVcSigs->Card[Card].Port[pNum].Chan[0], bNum, sNum);
      break;
    case FXOCRD:
      loopStart = GROUND_START(Card,pNum) ? 0 : 1;
      if( loopStart ) pVcSigs->Card[Card].Port[pNum].Chan[0] = 0x55;
      else            pVcSigs->Card[Card].Port[pNum].Chan[0] = 0x5f;
      break;
    case FXSCRD:
      loopStart = GROUND_START(Card,pNum) ? 0 : 1;
      if( loopStart ) pVcSigs->Card[Card].Port[pNum].Chan[0] = 0x55;
      else            pVcSigs->Card[Card].Port[pNum].Chan[0] = 0xf5;
      status = ctp_vb_port_cfg_sigs(Card,pNum,pVcSigs->Card[Card].Port[pNum].Chan[0], bNum, sNum);
      break;
    default:
      break;
  }
  sigs = (pVcSigs->Card[Card].Port[pNum].Chan[0] & 0xff);
  PRTVP(DBG,ctp_vb_port_init_sigs with sigs, sigs);

  return(status);
}
