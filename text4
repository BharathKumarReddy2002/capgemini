int ctp_bndl_cfg(CTP_BNDL_DBASE *pNewDbB)
{
  int bNum  = pNewDbB->bNum & 0xff;
  int bType = pNewDbB->Type & 0xff;
  int 			Card, pNum;
  int			OldDbCsum, NewDbCsum;
  CTP_BNDL_DBASE OldDbB;
  CTP_BNDL_STATE *pBndlSt=&Ctp.Bndl[bNum];
  FUNC_PRT(ctp_bndl_cfg, PF_IPC, -1);

  //-- Save old bundle dbase
  bcopy(&Db.Bndl[bNum], &OldDbB, sizeof(CTP_BNDL_DBASE));

  PRTDVB(GEN,got CTPMSGTYPE_DB_CFG_BNDL of type,bType);
  //--- Copy bundle database from message
  // Aricent PR-947222 Start
  if(  CTP_BNDL_TYPE_WP == Db.Bndl[bNum].Type ){
   pNewDbB->Bndl.wp_bndl.cbc_num = Db.Bndl[bNum].Bndl.wp_bndl.cbc_num;
  }
  // Aricent PR-947222 End 
  bcopy(pNewDbB, &Db.Bndl[bNum],sizeof(CTP_BNDL_DBASE));
  
#ifdef LINUX64
  if( (OldDbB.Type != CTP_BNDL_TYPE_NONE) &&
      (pNewDbB->Type == CTP_BNDL_TYPE_NONE) ) {
    Card = util_bndl_src_card(0, &OldDbB);
    pNum = util_bndl_src_pNum(0, &OldDbB);
  }
  else {
    Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
    pNum = util_bndl_src_pNum(0, &Db.Bndl[bNum]);
  }
#else
  Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
  pNum = util_bndl_src_pNum(0, &Db.Bndl[bNum]);
#endif
  //PR 1673506
  if ( (Card >= 0) && (pNum >= 0)) {
    /* if Port is not available then only update the Database */
    if(Ctp.Card[Card].Port[pNum].Available == NO) return SUCCESS;
  }
  if( !ctp_check_bndl_cfg(&OldDbB, bNum) ) {
    PRTB(MIN,CTPMSGTYPE_DB_CFG_BNDL problems with bundle database);
    // Restore old bundle database
    bcopy(&OldDbB, &Db.Bndl[bNum], sizeof(CTP_BNDL_DBASE));
  } else {
    if( (OldDbB.State == CTP_DBSTATE_DOWN) &&
        (Db.Bndl[bNum].State == CTP_DBSTATE_UP) ) {
      //--- Activate bundle
      ctp_bndl_add_without_db( bNum ); 
    } else if ( (OldDbB.State == CTP_DBSTATE_UP) &&
        (Db.Bndl[bNum].State == CTP_DBSTATE_DOWN) ) {
      //--- Disable bundle
      ctp_bndl_remove_without_db(bNum);                
    } else {
      //--- Bundle cfg change w/o activate/disable
      ctp_check_dbase();
    }
  }
  return SUCCESS;
}

// With a possibility of the slot being voice board, 
// this board will be used to determine chassis type if
// that field in sysinfo is not defined.
int ctp_card_add_check_vb_slot ( int Card )
{
  VBBOARDHANDLE		hBoard;
  FUNC_PRT(ctp_card_add_check_vb_slot, PF_START, -1);
  if(pSysInfo->ChassisType == CTP_CHAS_TYPE_UNKNOWN) {
    hBoard = vbBoardInit( (3 - Card), 0, 0, 0);
    if (hBoard != VBBAD_HANDLE) {
      pSysInfo->ChassisType = CTP_CHAS_TYPE_3_MONO;
      PRT(MAJ, Chassis Type is 3 mono);
      vbBoardRemove(hBoard);
      return ctp_vb_chk_slot(Card);
    }  
    hBoard = vbBoardInit( (7 - Card), 0, 0, 0);
    if (hBoard != VBBAD_HANDLE) {
      pSysInfo->ChassisType = CTP_CHAS_TYPE_7;
      vbBoardRemove(hBoard);
      PRT(MAJ, Chassis Type is 7);
      return ctp_vb_chk_slot(Card);
    }  
    hBoard = vbBoardInit( (2 + Card), 0, 0, 0);
    if (hBoard != VBBAD_HANDLE) {
      pSysInfo->ChassisType = CTP_CHAS_TYPE_3;
      vbBoardRemove(hBoard);
      PRT(MAJ, Chassis Type is 3);
      return ctp_vb_chk_slot(Card);
    } else return 0;
  }
  return ctp_vb_chk_slot(Card);
}

int ctp_card_add(int Card)
{
  int bndl, pNum, status, card;  //Aricent PR 1010274 fix
  char sccbuf[8];
  struct acrndrv_static_stat	nstat;
  u32 att_bndl_bmask[(CTP_MAX_BNDLS/32)];
  
  FUNC_PRT(ctp_card_add, PF_IPC, -1);
  sprintf(sccbuf,"scc%d", Card * pSysInfo->PortsPerCard);
  // Check voice board first
  // this step initialize sysInfo fields and set the type of chassis if
  // there is none.
  if(ctp_card_add_check_vb_slot(Card)) { 
    PRTDV(MAJ, **** Got Voice Board CARD **** for card, Card);
    // set the clock to be slave
    ctp_vb_cfg_h110_clks(Card);
    for(pNum=0;pNum<pSysInfo->Card[Card].PortsOnCard;pNum++) {
    // Attach port to assigned H110 backplane ts
      ctp_vb_port_h110_conn(Card,pNum,1,0);
      // Mute port to start
      ctp_vb_port_mute(Card,pNum);
    }
    // Set signaling sensing
    ctp_set_vb_sig_sense(Card);
  } else if(ioc_priv(sccbuf,SCC_GET_STATIC_STAT,&nstat) == 0) {
  /* Start Card level initialization */
    //--- Set PortsOnCard
    pSysInfo->Card[Card].PortsOnCard = nstat.PortsSupported;
    //--- Set BaseSccNum
    pSysInfo->Card[Card].BaseSccNum = Card*pSysInfo->Card[Card].PortsOnCard;
    
    pSysInfo->Card[Card].PcaRev = nstat.board_rev;
    // Note: Must be after SysType, PcaRev and BaseSccNum are set.
    pSysInfo->Card[Card].PldRev  = nstat.pld_rev;
    pSysInfo->Card[Card].FpgaRev = nstat.fpga_rev;
    
    if(nstat.card_type == HW_CPCI_T1E1) {
      pSysInfo->Card[Card].Type = T1CARD;
      pSysInfo->Card[Card].SubType = nstat.card_sub_type;
      PRTDV(MAJ, **** Got CTP2000 T1/E1 CARD **** for card, Card);
    } else if(nstat.card_type == HW_PCIE_T1E1) {
      pSysInfo->Card[Card].Type = T1CARD;
      pSysInfo->Card[Card].SubType = nstat.card_sub_type;
      PRTDV(MAJ, **** Got CTP151 T1/E1 CARD **** for card, Card); //PR 1422568
    } else if( nstat.card_type == HW_PCIE_SER ) {
      pSysInfo->Card[Card].Type = SCCARD;
      pSysInfo->Card[Card].SubType = nstat.card_sub_type;
      pSysInfo->allowed_pbs_mask |= 0xf<<(4*Card);	// all 4 ports/card
      PRTDV(MAJ, **** Got CTP151 SERIAL CARD **** for card, Card);//PR 1422568
    } else if( nstat.card_type == HW_CPCI_NOVA ) {
      pSysInfo->Card[Card].Type = SCCARD;
      pSysInfo->Card[Card].SubType = nstat.card_sub_type;
      pSysInfo->allowed_pbs_mask |= 0xff<<(8*Card);	// all 8 ports/card
      PRTDV(MAJ, **** Got CTP2000 SERIAL CARD **** for card, Card);
    } else {		//--- Unknown!
      PRTDV(MAJ, **** Got UNKNOWN CARD **** for card, Card);
    }


    if(ctp_check_fpga(Card) == FAILURE) return FAILURE;
      //--- Assign scc numbers to port
      //    Flag port as available
    for(pNum=0;pNum<pSysInfo->Card[Card].PortsOnCard;pNum++) {
      Ctp.Card[Card].Port[pNum].SccNum = pNum+pSysInfo->Card[Card].BaseSccNum;
      Ctp.Card[Card].Port[pNum].Available = YES;
      Ctp.Card[Card].Port[pNum].Card = Card;
      Ctp.Card[Card].Port[pNum].pNum = pNum;
      if(SCC_CARD(Card) && !IS_T1E1(Card)) {  // Aricent PR 1010381 and 1198066 Fix
	int sccNum = Ctp.Card[Card].Port[pNum].SccNum;
	//--- DCARD reset activate ( PR 974139 )
	fpga_clr_fcfg();
	fpga_set_sig_reg(pNum,0);			// Reset entire register
	fpga_set_signals_inactive(pNum);		// Signaling leads inactive
	fpga_set_if_dce(pNum);				// Daughter card reset
	fpga_send_fcfg(sccNum);
	//--- DCARD reset release
	fpga_clr_fcfg();
	fpga_set_if_dcard(pNum);			// Daughter card unreset
	fpga_send_fcfg(sccNum);
      }
    }
    
    usleep(5000);
    
    ctp_scan_scc_dcard(Card);
    if((pSysInfo->SysType != SYS_TYPE_CTP_150) && (pSysInfo->SysType != SYS_SUBTYPE_CTP_150))
      clk_rtm_get_info( Card );
    ctp_cfg_node_clks(1, Card); // initialize card reference stuff
    ctp_cfg_node_clks(0, Card); // Here really configure card reference 
    
    if(SCC_CARD(Card) && !IS_T1E1(Card)) {  // Aricent PR 1010381 and 1198066 Fix
      for(pNum=0;pNum<pSysInfo->Card[Card].PortsOnCard;pNum++) {
	if (Ctp.Card[Card].Port[pNum].Available == YES) {
	  fpga_clr_fcfg();
	  fpga_set_sig_reg(pNum,0);			// Reset entire register
	  fpga_set_signals_inactive(pNum);		// Signaling leads inactive
	  fpga_set_if_disable(Card,pNum);		// Tristated I/F //CAP PR 1734636
	  fpga_send_fcfg(Ctp.Card[Card].Port[pNum].SccNum);
	}
      }
    }
    if(IS_T1E1_2000(Card)) { ctp_t1e1_proc_sigs(Card); }
    ctp_get_pll_cal(Card);
    ctp_get_vcxo_range(Card);
  }

 // Aricent Pr-947222 and PR 1010274 fix Start
 if(IS_T1E1_2000(0)) {
  ctp_t1e1_proc_h110_sigs(0);
 }
 // Aricent Pr-947222 and PR 1010274 fix End 

  /* End of Card level initialization */
  if(SCC_CARD(Card)) {
    // Serial and T1E1 card handling 	  
    for( pNum = 0; pNum < pSysInfo->Card[Card].PortsOnCard; pNum++) {
      CTP_PORT_DBASE *pDbP = &Db.Card[Card].Port[pNum];
      CTP_PORT_STATE *pPortSt = &Ctp.Card[Card].Port[pNum];   
      pPortSt->BertPat = BERT_PAT_15; 
      if((pDbP->State == CTP_DBSTATE_UP) &&
        ( (PBS(Card,pNum)) || (pPortSt->Diagnostics) || (IS_H110(Card, pNum)) ||
        (ctp_bndl_type_wp(Card, pNum))) ) {
       if(!VOICE(Card)) { //Aricent PR-947222
        PRTP(MIN,activate diagnostic port - calling ctp_add_port);
        ctp_add_port(Card, pNum);	//--- ctp_del_pbs_port ???  
       }
      }
    }
  }  
  /* init attention bundle bitmask */
  for(bndl = 0; bndl < (CTP_MAX_BNDLS/32); bndl++) att_bndl_bmask[bndl] = 0;  
  
  for(bndl = 0; bndl < CTP_MAX_BNDLS; bndl++) {
    /* database is up */      
    if(Db.Bndl[bndl].State != CTP_DBSTATE_UP) continue;
    /* card is not matching */
    if(util_bndl_src_card(0, &Db.Bndl[bndl]) != Card) continue;
    
    if((Db.Bndl[bndl].Type==CTP_BNDL_TYPE_WP) &&
      (Db.Bndl[bndl].Bndl.wp_bndl.adpMaster)) {
      att_bndl_bmask[bndl/32] |= 1<<(bndl%32);
      /* add adaptive master bundle first */
      ctp_bndl_add_without_db(bndl);
    }
  }
  
  for(bndl = 0; bndl < CTP_MAX_BNDLS; bndl++) {
    /* database is up */      
    if(Db.Bndl[bndl].State != CTP_DBSTATE_UP) continue;
    /* card is not matching */
    if(VOICE(Card) && util_find_vb_src_card(Card, &Db.Bndl[bndl])) {
    /* voice board handling */	    
    } else {	    
      if(util_bndl_src_card(0, &Db.Bndl[bndl]) != Card) continue;
      if(att_bndl_bmask[bndl/32] & (1<<(bndl%32))) continue;
    }  
    ctp_bndl_add_without_db(bndl);
  }

  return SUCCESS;
}

/* This function is to remove all the active bundles on the card
   as well as other configurations, then initialize card/port/bundle 
   runtime status, and set the card/port status to unavailable 
*/   
int ctp_card_remove(int Card)
{
  int bndl, pNum, i;
  u32 att_bndl_bmask[(CTP_MAX_BNDLS/32)];
  FUNC_PRT(ctp_card_remove, PF_IPC, -1);
 
  /* init attention bundle bitmask */
  for(i = 0; i < (CTP_MAX_BNDLS/32); i ++) att_bndl_bmask[i] = 0;  
  for(bndl = 0; bndl < CTP_MAX_BNDLS; bndl++) {
    /* database is up */      
    if(Db.Bndl[bndl].State != CTP_DBSTATE_UP) continue;
    /* card is not matching */
    if(VOICE(Card) && util_find_vb_src_card(Card, &Db.Bndl[bndl])) {
    /* voice card handling */	    
    } else {	    
      if(util_bndl_src_card(0, &Db.Bndl[bndl]) != Card) continue;
    
      if((Db.Bndl[bndl].Type==CTP_BNDL_TYPE_WP) &&
        (Db.Bndl[bndl].Bndl.wp_bndl.adpMaster)) {
        att_bndl_bmask[bndl/32] |= 1<<(bndl%32);
        continue;
      }
    }  
    PRTU8(GEN, Remove bndl, bndl);
    ctp_bndl_remove_without_db(bndl);                
  }
  PRT(GEN, finished Remove bndl);

  /* There are adaptive master bundles */
  for(i = 0; i < (CTP_MAX_BNDLS/32); i ++) {
    for(bndl = 0 ; bndl < 32; bndl ++) {
      if(att_bndl_bmask[i] & (1<<bndl)) 
        ctp_bndl_remove_without_db(i*32+bndl);
    }
  }
  
  for( pNum = 0; pNum < pSysInfo->Card[Card].PortsOnCard; pNum++) {
    CTP_PORT_DBASE *pDbP = &Db.Card[Card].Port[pNum];
    CTP_PORT_STATE *pPortSt = &Ctp.Card[Card].Port[pNum];    
    if((pDbP->State == CTP_DBSTATE_DOWN) &&
      ( (PBS(Card,pNum)) || (pPortSt->Diagnostics) || (IS_H110(Card, pNum)) ||
      (ctp_bndl_type_wp(Card, pNum))) ) {
      PRTP(MIN,deactivate diagnostic port - calling ctp_del_port);
       ctp_del_port(Card, pNum);	//--- ctp_del_pbs_port ???  
    }
  }
  
  if(VOICE(Card)) {
  // voice board handling
    for( pNum = 0; pNum < pSysInfo->Card[Card].PortsOnCard; pNum++ ) {
      ctp_wait_for_handle(Card, pNum);	    
      vbClose(pVcSigs->Card[Card].hRes[pNum]);	
      ctp_release_handle(Card,pNum);    
    }
    vbBoardRemove(pSysInfo->Card[Card].hBoard);
    // clear VcSigs datastructure 
    memset(&pVcSigs->Card[Card], 0, sizeof(CTP_VC_SIG_CARD_STATE));
  } else {	  
    ctp_set_led(PLL_LED_OFF, Card);
    if(IS_T1E1_2000(Card)) {
      char CmdStr[100];
    //--- remove pktX (posphy) stack interface for T1E1 card
      PRT(MAJ,Building string);
      sprintf(CmdStr,
         "/sbin/ifconfig pkt%d 172.0.1.%d pointopoint 172.0.1.%d down\n",
          Card, 164 +Card, 64 +Card );
      PRTS(EVE,About to issue cmd,CmdStr);
      acorn_system(CmdStr); 
      //--- Kill signal task for T1 card ---//
      if(Ctp.Task[CTP_CARD0_SIG+Card].Pid != 0) 
        kill(Ctp.Task[CTP_CARD0_SIG+Card].Pid,SIGTERM);
    }
  }  
  
  /* Initialize the state structure */
  memset(&Ctp.Card[Card],0,sizeof(CTP_CARD_STATE));
  memset(&Ctp.Node[Card],0,sizeof(CTP_NODE_STATE));

  Ctp.Node[Card].RefInUse = ~0;		// Set to invalid reference
  Ctp.Node[Card].Calibration = ~0;	// Set to invalid Calibration
  
  /* Initialize SysInfo structure about this card */
  ctp_init_card(Card);
  
  return SUCCESS;
}

