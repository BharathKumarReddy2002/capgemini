  else if( ( (pLocDb->rx_sel == CTP_CLK_SEL_DIV) && 		// 1
	     (pLocDb->div_src == CTP_DIV_SRC_OSC) ) ) {
    ignore_loc_clk_to_there = 0;
    loc_clk_to_there = CTP_OSC_FREQ / (double)(2*pLocDb->div_val);
    PRTFVP(GN3,local OSC/DIV clock to there,loc_clk_to_there);
  }
  else {
    PRTP(MIN,local clock to there FELL THROUGH CASES - setting to 0);
    ignore_loc_clk_to_there = 0;
    loc_clk_to_there = 0.0;
  }

  //----- Do clock calculations for local clock towards here
  if( ( (pLocDb->tx_sel == CTP_CLK_SEL_DDS) && 			// 1
	(pLocDb->dds_src == CTP_DDS_SRC_USER) ) ||
      ( (pLocDb->tx_sel == CTP_CLK_SEL_DDS) && 			// 2
	(pLocDb->dds_src == CTP_DDS_SRC_ADAPTIVE) ) ) {
    ignore_loc_clk_to_here = 0;
    divider = util_power(10,pLocDb->dds_div);
    loc_clk_to_here = (double)pLocDb->dds_freq/(0x20000 * divider);
    if( FRAC_T1E1(Card, pNum) ) {
      //--- Calculate the fractional clock
      if( pLocDb->DcardCfg1 & T1E1_MSK_E1 ) {
	int cas = (pLocDb->DcardCfg1 & T1E1_MSK_E1_CAS) ? 1 : 0;
	loc_clk_to_here = (pLocDb->DcardCfg2 + 1 + cas) * 64;
      } else {
	int frm = (pLocDb->DcardCfg1 & T1E1_MSK_NO_FRM) ? 0 : 8;
	loc_clk_to_here = pLocDb->DcardCfg2 * 64 + frm;
      }
    }
    PRTFVP(GN3,local DDS clock to here,loc_clk_to_here);
  }
  else if( (pLocDb->tx_sel == CTP_CLK_SEL_TT) || 		// 1
    	 ( (pLocDb->tx_sel == CTP_CLK_SEL_ST) && 		// 9
   	   (pLocDb->IfType == IF_TYPE_DTE)) ||
	 ( (pLocDb->tx_sel == CTP_CLK_SEL_DDS) && 		// 2
	   (pLocDb->dds_src == CTP_DDS_SRC_AUTOBAUD) ) ||
	 ( (pLocDb->tx_sel == CTP_CLK_SEL_DIV) && 		// 3
	   (pLocDb->div_src == CTP_DIV_SRC_DDS) &&
	   (pLocDb->dds_src == CTP_DDS_SRC_AUTOBAUD) ) ) {
    ignore_loc_clk_to_here = 1;
    PRTP(GN3,Dont know local clock to here);
  }
  else if( ( (pLocDb->tx_sel == CTP_CLK_SEL_DIV) && 		// 1
	     (pLocDb->div_src == CTP_DIV_SRC_DDS) &&
	     (pLocDb->dds_src == CTP_DDS_SRC_USER) ) ||
	   ( (pLocDb->tx_sel == CTP_CLK_SEL_DIV) && 		// 2
	     (pLocDb->div_src == CTP_DIV_SRC_DDS) &&
	     (pLocDb->dds_src == CTP_DDS_SRC_ADAPTIVE) ) ) {
    ignore_loc_clk_to_here = 0;
    divider = util_power(10,pLocDb->dds_div);
    dds_clk = (double)pLocDb->dds_freq/(0x20000 * divider);
    loc_clk_to_here = dds_clk / (2 * (double)pLocDb->div_val);
    PRTFVP(GN3,local DDS/DIV clock to here,loc_clk_to_here);
  }
  else if( ( (pLocDb->tx_sel == CTP_CLK_SEL_DIV) && 		// 1
	     (pLocDb->div_src == CTP_DIV_SRC_OSC) ) ) {
    ignore_loc_clk_to_here = 0;
    loc_clk_to_here = CTP_OSC_FREQ / (double)(2*pLocDb->div_val);
    PRTFVP(GN3,local OSC/DIV clock to here,loc_clk_to_here);
  }
  else {
    PRTP(MIN,remote clock towards here FELL THROUGH CASES - setting to 0);
    ignore_loc_clk_to_here = 0;
    loc_clk_to_here = 0.0;
  }

  //--- Now, lets compare local and remote settings to make sure their
  //--- compatible. Flag an error on a mismatch.

  if( ( ignore_loc_clk_to_here == 0 ) &&
      ( ignore_rem_clk_to_here == 0 ) &&
      ( rem_clk_to_here != loc_clk_to_here ) ) {
    util_ip_string( pMsgOam->LocNcp.Node.Node.v4, buf1);
    sprintf(buf2,"IF bound clk cfg mismatch from %s RemCid %d to LocCid %d",
	buf1, pMsgOam->LocNcp.Port, LocCid);
    PRTSP(EVE,,buf2);
    return(FAILURE);
  }

  if( ( ignore_rem_clk_to_there == 0 ) &&
      ( ignore_loc_clk_to_there == 0 ) &&
      ( loc_clk_to_there != rem_clk_to_there ) ) {
    util_ip_string( pMsgOam->LocNcp.Node.Node.v4, buf1);
    sprintf(buf2,"NET bound clk cfg mismatch from %s RemCid %d to LocCid %d",
	buf1, pMsgOam->LocNcp.Port, LocCid);
    PRTSP(EVE,,buf2);
    return(FAILURE);
  }

  // Otherwise, things must be kosher...
  PRTP(GN3,ctp_check_port_cfg_rates passed all rate tests);
  return(SUCCESS);
}

