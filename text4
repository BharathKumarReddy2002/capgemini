  return(SUCCESS);
}

//--------------------------------------------------------------------------
// This routine sends a message to another task. We check the destination
// node to see if we send this message via IPC or a socket. Msg Types
// KILL_NET_TASK and REM_OAM are special cases that will always be sent
// across the network. The exception to this is the NET_TASK, which ALWAYS
// sends its output messages to the local CTPD task via IPC.
//--------------------------------------------------------------------------
int ctp_send_msg( CTP_Q_MSG * pMsg )
{
  CTP_NODE_CONN		*pNodeConn;
  int			 status, MsgSize, isIpv4=1;
  int			 LocCid, Card, pNum;
  struct sockaddr_in6	 d_addr;
  char			 str[INET6_ADDRSTRLEN];
#ifdef LINUX64 
  CTP_Q_OAM_MSG_UDP	 RMsg,*pOamMsg ;
  CTP_Q_VC_OAM_MSG_UDP	 RVcMsg, *pVcOamMsg; 
#else
  CTP_Q_OAM_MSG         *pOamMsg = (CTP_Q_OAM_MSG *)pMsg;
  CTP_Q_VC_OAM_MSG	*pVcOamMsg = (CTP_Q_VC_OAM_MSG *)pMsg;
#endif
  FUNC_PRT(ctp_send_msg, PF_IPC, -1);

  //util_dump_qmsg((void *)pMsg);

  //============================================================
  if( pMsg->CtpMsg.MsgType == CTPMSGTYPE_REM_OAM ) {
    //----- message goes across network
#ifdef LINUX64 
    RMsg.mtype = (int)pMsg->mtype;
    memcpy(&RMsg.CtpMsg, &pMsg->CtpMsg, sizeof(RMsg.CtpMsg));
    pOamMsg = (CTP_Q_OAM_MSG_UDP *)&RMsg;
    LocCid = pOamMsg->CtpMsg.msg.RemOam.LocNcp.Port;
#else
    LocCid = pMsg->CtpMsg.msg.RemOam.LocNcp.Port;
#endif
    Card = pSysInfo->LocCid[LocCid].Card;
    pNum = pSysInfo->LocCid[LocCid].pNum;

    //PRTDV(GN2,Got LocCid for NodeConn, LocCid);
    if(IPV6(Card,pNum)) isIpv4 = 0;
    pNodeConn = &Ctp.Card[Card].PortInt[pNum].Conn;

#ifdef LINUX64 
    pOamMsg->CtpMsg.OrigNode = *((CTP_NODE*)&Ctp.Card[Card].PortInt[pNum].LocAdCid.Node);
#else
    pMsg->CtpMsg.OrigNode = *((CTP_NODE*)&Ctp.Card[Card].PortInt[pNum].LocAdCid.Node);
#endif

    if( pMsg->CtpMsg.MsgType == CTPMSGTYPE_REM_OAM ) {
#ifdef LINUX64 
      MsgSize = sizeof(CTP_Q_OAM_MSG_UDP);
#else
      MsgSize = sizeof(CTP_Q_OAM_MSG);
#endif
    } else {
      MsgSize = sizeof(CTP_Q_MSG);
    }
    if(isIpv4 == 0)
    {
      pOamMsg->CtpMsg.OrigIp6addr = Ctp.Card[Card].PortInt[pNum].LocAdCid.Node.v6;
      pOamMsg->CtpMsg.DestIp6addr = pNodeConn->Node.v6;
      pOamMsg->CtpMsg.msg.RemOam.LocNcp.Node.Type = CTP_IPV6;
      pOamMsg->CtpMsg.msg.RemOam.RemNcp.Node.Type = CTP_IPV6;
      d_addr.sin6_addr=pNodeConn->Node.v6;
      d_addr.sin6_flowinfo = 0;
      d_addr.sin6_scope_id = 0;
      d_addr.sin6_port = htons(pSysInfo->oam_port_v6);	// OAM port
      d_addr.sin6_family = AF_INET6;

      if(inet_ntop(AF_INET6, &d_addr.sin6_addr, str, sizeof(str)) ) {
        PRTS(GN3, Sending OAM to, str);
      }

      status = sendto(pNodeConn->TxSock,	// socket
#ifdef LINUX64 
        pOamMsg,					// msg to send
#else
        pMsg,					// msg to send
#endif
	MsgSize,				// size of msg to send
	MSG_DONTWAIT,				// flags (don't block!)
        (struct sockaddr *)&d_addr,		// addr to send to
        sizeof(d_addr));			// size of addr spec
    } else {
      status = sendto(pNodeConn->TxSock,	// socket
#ifdef LINUX64 
	  pOamMsg,					// msg to send
#else
	  pMsg,					// msg to send
#endif
	  MsgSize,				// size of msg to send
	  MSG_DONTWAIT,				// flags (don't block!)
	  (struct sockaddr *)&pNodeConn->RemAddr,	// addr to send to
	  sizeof(struct sockaddr));		// size of addr spec
    }
    if( (status < 0) && (status != EAGAIN) ) {
      PRTVP(MAJ,Error sending OAM msg to remote device - error,errno);
      //perror("sending msg to socket");
      /*** PR1314902 - start 
       * Re-open the TX socket for OAM >>> ctp_con_rem_node() 
       * */
      if( errno == 0x58) {
	CTP_PORT_DBASE        *pDbP = &Db.Card[Card].Port[pNum];
	int flag=0;
	int bNum = util_get_next_bNum(pDbP, -1);
	if(pNodeConn->Node.Type == CTP_IPV6) flag |= CON_FLAG_USE_IPV6;
	if(Db.Bndl[bNum].port_mirror_rx.numTail) { flag |= CON_FLAG_USE_SRC_PORT_MIRROR; }
	if ( SUCCESS == ctp_con_rem_node(pNodeConn, flag, Ctp.Card[Card].PortInt[pNum].virtual_ip) )
	  PRTVP(MAJ, Recovered OAM error , errno);
      }
      /*** PR1314902 - end ***/ 
      return(FAILURE);
    }
    //PRT(DBG,Msg sent);
  }
  //============================================================
  else if( pMsg->CtpMsg.MsgType == CTPMSGTYPE_RDNT_LINK_OAM ) {
#ifdef LINUX64 
    RMsg.mtype = (int)pMsg->mtype;
    memcpy(&RMsg.CtpMsg, &pMsg->CtpMsg, sizeof(RMsg.CtpMsg));
    pOamMsg = (CTP_Q_OAM_MSG_UDP *)&RMsg;
    LocCid = pOamMsg->CtpMsg.msg.RemRdntOam.LocNcp.Port;
#else
    //----- message goes across network
    LocCid = pMsg->CtpMsg.msg.RemRdntOam.LocNcp.Port;
#endif
    Card = pSysInfo->LocCid[LocCid].Card;
    pNum = pSysInfo->LocCid[LocCid].pNum;

    //PRTDV(GN2,Got LocCid for NodeConn, LocCid);
    if(IPV6(Card,pNum)) isIpv4 = 0;
    pNodeConn = &Ctp.Card[Card].PortInt[pNum].RdntConn;

#if 0
    PRT(MIN, Sending Rdnt OAM);
    PRTV(MIN,LocCid,LocCid);
    PRTV(MIN,Card,Card);
    PRTV(MIN,pNum,pNum);
    util_dump_nodestruct((void *)pNodeConn,NSTYPE_CTP_NODE_CONN); 
#endif

#ifdef LINUX64 
    pOamMsg->CtpMsg.OrigNode = *((CTP_NODE*)&Ctp.Card[Card].PortInt[pNum].LocAdCid.Node);
    MsgSize = sizeof(CTP_Q_OAM_MSG_UDP);
#else
    pMsg->CtpMsg.OrigNode = *((CTP_NODE*)&Ctp.Card[Card].PortInt[pNum].LocAdCid.Node);

    MsgSize = sizeof(CTP_Q_OAM_MSG);
#endif

    if(isIpv4 == 0)
    {
      pOamMsg->CtpMsg.OrigIp6addr = Ctp.Card[Card].PortInt[pNum].LocAdCid.Node.v6;
      pOamMsg->CtpMsg.DestIp6addr = pNodeConn->Node.v6;
      pOamMsg->CtpMsg.msg.RemRdntOam.LocNcp.Node.Type = CTP_IPV6;
      //pOamMsg->CtpMsg.msg.RemRdntOam.RemNcp.Node.Type = CTP_IPV6;
      d_addr.sin6_addr=pNodeConn->Node.v6;
      d_addr.sin6_flowinfo = 0;
      d_addr.sin6_scope_id = 0;
      d_addr.sin6_port = htons(pSysInfo->oam_port_v6);	// OAM port
      d_addr.sin6_family = AF_INET6;

      if(inet_ntop(AF_INET6, &d_addr.sin6_addr, str, sizeof(str)) ) {
        PRTS(GN3, Sending IPv6 Rdnt OAM to, str);
      }

      status = sendto(pNodeConn->TxSock,	// socket
#ifdef LINUX64 
        pOamMsg,				// msg to send
#else
        pMsg,					// msg to send
#endif
	MsgSize,				// size of msg to send
	MSG_DONTWAIT,				// flags (don't block!)
        (struct sockaddr *)&d_addr,		// addr to send to
        sizeof(d_addr));			// size of addr spec
    } else {
      //u32 temp = (u32)pNodeConn->TxSock;
      //PRTDV(GN3, Sending IPv4 Rdnt OAM to socket, temp);
      status = sendto(pNodeConn->TxSock,	// socket
#ifdef LINUX64 
	  pOamMsg,				// msg to send
#else
	  pMsg,					// msg to send
#endif
	  MsgSize,				// size of msg to send
	  MSG_DONTWAIT,				// flags (don't block!)
	  (struct sockaddr *)&pNodeConn->RemAddr,	// addr to send to
	  sizeof(struct sockaddr));		// size of addr spec
    }
    if( (status < 0) && (status != EAGAIN) ) {
      PRTVP(MAJ,Error sending rdnt OAM msg to remote device - error,errno);
      //perror("sending msg to socket");
      return(FAILURE);
    }
    //PRT(DBG,Msg sent);
  }
  //============================================================
  else if( pMsg->CtpMsg.MsgType == CTPMSGTYPE_REM_VC_OAM ) {
#ifdef LINUX64 
    RVcMsg.mtype = (int)pMsg->mtype;
    memcpy(&RVcMsg.CtpMsg, &pMsg->CtpMsg, sizeof(RVcMsg.CtpMsg));
    pVcOamMsg = (CTP_Q_VC_OAM_MSG_UDP *)&RVcMsg;
    int bNum = (int)pVcOamMsg->CtpMsg.msg.RemVcOam.bNum;
    MsgSize =  (pVcOamMsg->CtpMsg.msg.RemVcOam.type == CTP_VC_OAM_TYPE_ALL) ?
               sizeof(CTP_Q_VC_OAM_MSG_UDP) : sizeof(CTP_Q_VC_SIG_MSG_UDP);
#else
    int bNum = (int)pVcOamMsg->CtpMsg.msg.RemVcOam.bNum;
    CTP_Q_VC_OAM_MSG * pVcMsg = (CTP_Q_VC_OAM_MSG *)pMsg;
    MsgSize =  (pVcMsg->CtpMsg.msg.RemVcOam.type == CTP_VC_OAM_TYPE_ALL) ?
               sizeof(CTP_Q_VC_OAM_MSG) : sizeof(CTP_Q_VC_SIG_MSG);
#endif
    pNodeConn = &Ctp.Bndl[bNum].Conn;

    PRTDVB(GN3,Sending VC_OAM to remote msg size, MsgSize);
    
    if(pNodeConn->Node.Type == CTP_IPV6) {
      d_addr.sin6_addr=pNodeConn->Node.v6;
      d_addr.sin6_flowinfo = 0;
      d_addr.sin6_scope_id = 0;
      d_addr.sin6_port = htons(pSysInfo->oam_port_v6);	// OAM port
      d_addr.sin6_family = AF_INET6;

      status = sendto(pNodeConn->TxSock,	// socket
#ifdef LINUX64 
        pVcOamMsg,				// msg to send
#else
        pMsg,					// msg to send
#endif
	MsgSize,				// size of msg to send
	MSG_DONTWAIT,				// flags (don't block!)
        (struct sockaddr *)&d_addr,		// addr to send to
        sizeof(d_addr));			// size of addr spec
    } else {
      status = sendto(pNodeConn->TxSock,		// socket
#ifdef LINUX64 
	  pVcOamMsg,				// msg to send
#else
	  pMsg,					// msg to send
#endif
	  MsgSize,				// size of msg to send
	  MSG_DONTWAIT,				// flags (don't block!)
	  (struct sockaddr *)&pNodeConn->RemAddr,	// addr to send to
	  sizeof(struct sockaddr));		// size of addr spec
    }
    if( (status < 0) && (status != EAGAIN) ) {
      PRTVB(MAJ,Error sending VC OAM msg to remote device - error,errno);
      //perror("sending msg to socket");
      return(FAILURE);
    }
  } 
  //============================================================
  else {
    //----- message is local to this node
    PRT(DBG,Sending message to local task);
    status = msgsnd(
	pMsg->CtpMsg.DestTaskQid,	// destination Queue
	pMsg, 				// msg to send
	sizeof(CTP_Q_MSG), 		// size of msg to send
	0				// flags
	);

    if( status < 0 )
    {
      PRT(MAJ,Error sending msg to local task);
      //perror("sending message via IPC");
      return(FAILURE);
    }
  }
  return(SUCCESS);
}

//--------------------------------------------------------------------------
// Used by net_daemon only!
// This routine sends a message to another task via IPC only. It should only
// be used by the NET task, which needs to send *all* its messages via IPC.
// Otherwise, the generic ctp_send_msg() routine should be used, which
// determines if the message should be sent via IPC or to another node via
// the network.
//--------------------------------------------------------------------------

int ctp_send_msg_via_ipc( CTP_Q_MSG * pMsg )
{
  int			status;
  FUNC_PRT(ctp_send_msg_via_ipc, PF_IPC, -1);
  status = msgsnd(
#ifdef LINUX64 
      Ctp.Task[CTP_TASK].Qid,
#else
      pMsg->CtpMsg.DestTaskQid,		// destination Queue
#endif
      pMsg, 				// msg to send
      sizeof(CTP_Q_MSG), 		// size of msg to send
      0					// flags 
      );

  if( status < 0 ) 
  {
    PRT(MAJ,Error sending msg to local task);
    //perror("sending message");
    return(FAILURE);
  }
  return(SUCCESS);
}

//--------------------------------------------------------------------------
// Used by net_daemon only
//  - Does minimal checking of message received from socket, then
//  passes to main ctpd daemon via ipc
//--------------------------------------------------------------------------
void ctp_proc_sock_data (char* pMsg, int size)
{
  CTP_Q_OAM_MSG		*pRMsg;
  struct timeval	now;
#ifdef LINUX64 
//  CTP_Q_MSG 		RMsg,*pQMsg;
  CTP_Q_OAM_MSG_UDP     *pRcvdMsg;
  CTP_Q_OAM_MSG		RMsg1, *pQMsg;

  if(sizeof(CTP_Q_OAM_MSG_UDP) != size) {
//    PRT(MAJ, Rcvd OAM pkt size != CTP_Q_OAM_MSG_UDP);
    return;
  }
  pRcvdMsg = (CTP_Q_OAM_MSG_UDP *)pMsg;
  RMsg1.mtype = (long)pRcvdMsg->mtype;
  memcpy(&RMsg1.CtpMsg, &pRcvdMsg->CtpMsg, sizeof(pRcvdMsg->CtpMsg)); 
  RMsg1.CtpMsg.msg.RemOam = pRcvdMsg->CtpMsg.msg.RemOam;
  pQMsg = (CTP_Q_OAM_MSG *)&RMsg1;
#else
  pRMsg = (CTP_Q_OAM_MSG *)pMsg;
#endif
#if 0
  PRTV(GN1,Read message from socket of size,size);
  util_prt_msg((CTP_Q_MSG *)pRMsg);
#endif
#ifdef LINUX64 
  if( (pQMsg->CtpMsg.MsgType == CTPMSGTYPE_REM_OAM) &&
      (size >= 102) ) {
    if( (pQMsg->CtpMsg.OrigTask == CTP_TASK) &&
	(pQMsg->CtpMsg.DestTask == CTP_TASK) &&
	(pQMsg->CtpMsg.Status   == SUCCESS ) ){
      pQMsg->mtype			= 3;	// reserved and fixed
      pQMsg->CtpMsg.MsgType		= CTPMSGTYPE_REM_OAM;
      pQMsg->CtpMsg.DestTaskQid	= Ctp.Task[CTP_TASK].Qid;
#else
  if( (pRMsg->CtpMsg.MsgType == CTPMSGTYPE_REM_OAM) &&
      (size >= 102) ) {
    if( (pRMsg->CtpMsg.OrigTask == CTP_TASK) &&
	(pRMsg->CtpMsg.DestTask == CTP_TASK) &&
	(pRMsg->CtpMsg.Status   == SUCCESS ) ){
      pRMsg->mtype			= 3;	// reserved and fixed
      pRMsg->CtpMsg.MsgType		= CTPMSGTYPE_REM_OAM;
      pRMsg->CtpMsg.DestTaskQid	= Ctp.Task[CTP_TASK].Qid;
#endif
      // Add timestamp before sending to the ctp daemon
      gettimeofday (&now, NULL);
      while (now.tv_usec < 0)
      {
	now.tv_usec += 1000000;
	now.tv_sec--;
      }
      while (now.tv_usec >= 1000000)
      {
	now.tv_usec -= 1000000;
	now.tv_sec++;
      }
#ifdef LINUX64 
      pQMsg->CtpMsg.msg.RemOam.Arrive = (u32)(now.tv_usec+now.tv_sec*1000000);
      ctp_send_msg_via_ipc( (CTP_Q_MSG *)pQMsg ); // fwd msg to CTP TASK
#else
      pRMsg->CtpMsg.msg.RemOam.Arrive = (u32)(now.tv_usec+now.tv_sec*1000000);
      ctp_send_msg_via_ipc( (CTP_Q_MSG *)pRMsg ); // fwd msg to CTP TASK
#endif

    }
#ifdef LINUX64 
  } else if( (pQMsg->CtpMsg.MsgType == CTPMSGTYPE_REM_VC_OAM) &&
      (size >= 44) ) {
      pQMsg->mtype			= 3;	// reserved and fixed
      pQMsg->CtpMsg.MsgType		= CTPMSGTYPE_REM_VC_OAM;
      pQMsg->CtpMsg.DestTaskQid	= Ctp.Task[CTP_TASK].Qid; // PR 1411098 Fix
      ctp_send_msg_via_ipc( (CTP_Q_MSG *)pQMsg ); // fwd msg to CTP TASK
  } else if( (pQMsg->CtpMsg.MsgType == CTPMSGTYPE_RDNT_LINK_OAM ) &&
      (size >= 102) ) {
      pQMsg->mtype			= 3;	// reserved and fixed
      pQMsg->CtpMsg.MsgType		= CTPMSGTYPE_RDNT_LINK_OAM;
      pQMsg->CtpMsg.DestTaskQid	= Ctp.Task[CTP_TASK].Qid; // PR 1411098 Fix
      ctp_send_msg_via_ipc( (CTP_Q_MSG *)pQMsg ); // fwd msg to CTP TASK
  }
#else
  } else if( (pRMsg->CtpMsg.MsgType == CTPMSGTYPE_REM_VC_OAM) &&
      (size >= 44) ) {
      pRMsg->mtype			= 3;	// reserved and fixed
      pRMsg->CtpMsg.MsgType		= CTPMSGTYPE_REM_VC_OAM;
      pRMsg->CtpMsg.DestTaskQid	= Ctp.Task[CTP_TASK].Qid; // PR 1411098 Fix
      ctp_send_msg_via_ipc( (CTP_Q_MSG *)pRMsg ); // fwd msg to CTP TASK
  } else if( (pRMsg->CtpMsg.MsgType == CTPMSGTYPE_RDNT_LINK_OAM ) &&
      (size >= 102) ) {
      pRMsg->mtype			= 3;	// reserved and fixed
      pRMsg->CtpMsg.MsgType		= CTPMSGTYPE_RDNT_LINK_OAM;
      pRMsg->CtpMsg.DestTaskQid	= Ctp.Task[CTP_TASK].Qid; // PR 1411098 Fix
      ctp_send_msg_via_ipc( (CTP_Q_MSG *)pRMsg ); // fwd msg to CTP TASK
  }
#endif
  return;
}
//--------------------------------------------------------------------------
int ctp_net_daemon()
{
  char			TmpMsg[CTP_MAX_PKT_SIZE];
  int			status;
  static fd_set		socks;
  int readsocks, highSock;
  FUNC_PRT(ctp_net_daemon, PF_START, -1);

  openlog("ctp_netd",0,LOG_DAEMON);
  PRT(EVE,CTP Net Daemon started up);
  StayInProgram = YES;
  // build socket set
  FD_ZERO(&socks);
  FD_SET(pSysInfo->RxSock, &socks);
  FD_SET(pSysInfo->RxSock6, &socks);
  if(pSysInfo->RxSock > pSysInfo->RxSock6)
    highSock = pSysInfo->RxSock;
  else
    highSock = pSysInfo->RxSock6;
  while( StayInProgram == YES )
  {
    readsocks = select(highSock+1, &socks, (fd_set *) 0,
      (fd_set *) 0, NULL);
    if((readsocks < 0)||(readsocks > 2)) {
      PRT(EVE,Error select sockets - killing daemon);
      return(FAILURE);
    }
    if(FD_ISSET(pSysInfo->RxSock, &socks)){
      status = recv(pSysInfo->RxSock, (char *)&TmpMsg, CTP_MAX_PKT_SIZE,0);
      if(status < 0) {
        PRT(EVE,Error reading datagram - killing daemon);
        return(FAILURE);
      } else {
        ctp_proc_sock_data(TmpMsg, status);
      }
    }
    if(FD_ISSET(pSysInfo->RxSock6, &socks)){
      status = recv(pSysInfo->RxSock6, (char *)&TmpMsg, CTP_MAX_PKT_SIZE,0);
      if(status < 0) {
        PRT(EVE,Error reading datagram - killing daemon);
        return(FAILURE);
      } else {
        ctp_proc_sock_data(TmpMsg, status);
      }
    }
    FD_SET(pSysInfo->RxSock, &socks);
    FD_SET(pSysInfo->RxSock6, &socks);
  }
  PRT(EVE,Exiting Net Task);
  return(SUCCESS);
}

//--------------------------------------------------------------------------
// This routine is executed continuously by the TIMER task. It's only
// function is to send a timer message to the CTP task every scrub
// interval.
//--------------------------------------------------------------------------
void ctp_timer_daemon(void)
{
  CTP_Q_MSG		TMsg;
  int			tmp;
  FUNC_PRT(ctp_timer_daemon, PF_START, -1);

  openlog("ctp_timed",0,LOG_DAEMON);
  //--- set static fields in OAM message ---
  TMsg.mtype			= 2;			// reserved and fixed
  TMsg.CtpMsg.MsgType		= CTPMSGTYPE_TIMER;
  TMsg.CtpMsg.OrigTask		= CTP_TIMER_TASK;
  TMsg.CtpMsg.OrigNode		= *((CTP_NODE *)&Ctp.LocNode);
  TMsg.CtpMsg.OrigTaskQid	= Ctp.Task[CTP_TIMER_TASK].Qid;
  TMsg.CtpMsg.DestTask		= CTP_TASK;
  TMsg.CtpMsg.DestNode		= *((CTP_NODE *)&Ctp.LocNode);
  TMsg.CtpMsg.DestTaskQid	= Ctp.Task[CTP_TASK].Qid;
  TMsg.CtpMsg.SubType		= REQUEST;
  TMsg.CtpMsg.Status		= SUCCESS;
  TMsg.CtpMsg.Ident		= 0;

  TMsg.CtpMsg.msg.Timer.SeqNum	= 0;

  tmp = CTP_SCRUB_PERIOD;
  PRTDV(EVE,CTP Timer Task started w/ tick, tmp);
  sleep(2);		// give some time for network connections to open

  while(1)
  {
    ctp_send_msg( &TMsg );
    //PRT(GEN,Sent timer message to CTP task);		// Generates 1 msg/s
    TMsg.CtpMsg.msg.Timer.SeqNum++;
    sleep(CTP_SCRUB_PERIOD);
  }
}

