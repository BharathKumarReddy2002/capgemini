//-------------------------------------------------------------------------
//--- if speed or mtu are 0, this implies that they are unknown (eg for
//    a virtual ip attached to the loopback).
int ctp_nid_add_ip( u8 index, u8 type, char *name, CTP_NODE_STORAGE *pAddNode, int speed, int mtu )
{
  int	i = 0, found=0;
  char	prtBuf[200], ip_str[46];
  struct CtpNidInfo *iface;
  FUNC_PRT(ctp_nid_add_ip, PF_START, -1);

  if(pAddNode->Type == CTP_IPV4) {
    util_ip_string(pAddNode->v4, ip_str);
  } else if (pAddNode->Type == CTP_IPV6) {
    inet_ntop(AF_INET6, &pAddNode->v6, ip_str, 46);
  }

  //--- Look for ip saved already, if found update speed & mtu
  for( i = 0; i < CTP_MAX_NID; i++ ) {
    iface = &(pSysInfo->interface[i]);
    if( iface->if_index == index) {
      if( iface->type == CTP_IF_TYPE_VIP ) {
	//--- Virtual IPs all have same index, must also look for name
	//    match.
	if( !strncmp(name, iface->name, 10) ) {	found = 1; }
      } else {
	found = 1;
      }
      if( found ) {
	if(pAddNode->Type == CTP_IPV6) {
	  iface->addr_store.v6 = pAddNode->v6;
	} else if(pAddNode->Type == CTP_IPV4) {
	  iface->addr_store.v4 = pAddNode->v4;
	}
        iface->addr_store.Type   = pAddNode->Type;
	iface->speed = speed;
	iface->mtu = mtu;
	sprintf(prtBuf, "Updated interface %s in location %d, w/ index %d, ip %s speed %d and mtu %d",
	    iface->name, i, iface->if_index, ip_str, iface->speed, iface->mtu);
	PRTS(EVE,ctp_nid_add_ip,prtBuf);
#if 0	// Testing devices with both ipv4 & ipv6 addresses.
	{
	  char Buf[46];
	  CTP_NODE_STORAGE *pNode;
	  pNode = &iface->addr_store;
	  util_ip_string(pNode->v4,Buf);
	  PRTS(MIN,ctp_nid_add_ip update with ipv4 addr,Buf);
	  inet_ntop(AF_INET6, &pNode->v6,Buf, 46);
	  PRTS(MIN,ctp_nid_add_ip update with ipv6 addr,Buf);
	}
#endif
      }
    }
  }

  if( !found ) {
    i = 0;
    while( ( i < CTP_MAX_NID) &&
	( pSysInfo->interface[i].if_index != 0 ) ) { i++; }
    iface = &(pSysInfo->interface[i]);
    bzero(iface, sizeof(struct CtpNidInfo));
    iface->if_index = index;
    iface->type  = type;
    iface->speed = speed;
    iface->mtu = mtu;
    iface->addr_store.Type   = pAddNode->Type;
    if(pAddNode->Type == CTP_IPV4) {
      iface->addr_store.v4 = pAddNode->v4;
      sprintf( iface->name, "%s", name);
    }
    else if (pAddNode->Type == CTP_IPV6) {
      iface->addr_store.v6 = pAddNode->v6;
      sprintf( iface->name , "%s", if_indextoname(index, name));
    }
    sprintf(prtBuf, "Added interface %s in location %d, w/ index %d, ip %s speed %d and mtu %d",
	iface->name, i, iface->if_index, ip_str, iface->speed, iface->mtu);
  }

  PRTS(EVE,ctp_nid_add_ip,prtBuf);

  return found;
}

//-------------------------------------------------------------------------
int ctp_build_nid_req( CTP_NL_REQ *pReq, int af, int msg_type )
{
  FUNC_PRT(ctp_build_nid_req, PF_START, -1);

  bzero(pReq, sizeof(CTP_NL_REQ));
  pReq->nlh.nlmsg_len   = NLMSG_LENGTH(sizeof(struct ifaddrmsg));
  pReq->nlh.nlmsg_flags = NLM_F_REQUEST | NLM_F_DUMP;
  pReq->nlh.nlmsg_type  = RTM_GETADDR;
  pReq->msg.ifa_family  = af;
  if( af == AF_INET ) {
    pReq->msg.ifa_prefixlen =  24;
  } else if( af == AF_INET6 ) {
    pReq->msg.ifa_prefixlen = 128;
  } else {
    PRTDV(MIN,Cannot build msg for unknown address family, af);
    return FAILURE;
  }
  return SUCCESS;
}

