int add_sys_unusable_reason(int reason)
{
  int new_reason = reason;
  int ptr = 0;
  FUNC_PRT( add_sys_unusable_reason , PF_MISC, -1);

  // If a bad reason is passed...
  if( reason >= CTP_SYS_UNUSABLE_LAST ) {
    reason = CTP_SYS_UNUSABLE_UNKNOWN;
  }

  while( pSysInfo->SystemUnusableReasons[ptr] != 0 ) ptr++;

  if( ptr >= (MAX_SYS_UNUSABLE_REASONS - 2) ) {
    PRT(MAJ,!!!!! Too many system unusable reasons !!!!!);
    return FAILURE;
  } else {
    pSysInfo->SystemUnusableReasons[ptr] = new_reason;
  }
  return SUCCESS;
}

int chk_sys_unusable_fpga( void )
{
  int need_fpga_upgrade = 0;
  int ptr = 0;
  FUNC_PRT( chk_sys_unusable_fpga , PF_MISC, -1);

  while( pSysInfo->SystemUnusableReasons[ptr] != 0 ) {
    if( 
      ( pSysInfo->SystemUnusableReasons[ptr] == CTP_SYS_UNUSABLE_WINMON_VER_PROB ) ||
      ( pSysInfo->SystemUnusableReasons[ptr] == CTP_SYS_UNUSABLE_FPGA_VERS ) ) {
      need_fpga_upgrade = 1;
    }
    ptr++;
  }
  return need_fpga_upgrade;
}

