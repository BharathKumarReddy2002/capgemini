void ctp_check_load_winmon()
{
  int Card;
  unsigned int wddi_ver, win_ver;
  char tmpbuf[100];
  FUNC_PRT(ctp_check_load_winmon, PF_START, -1);

  sprintf(tmpbuf, "/usr/sbin/load_winmon -v > /tmp/win_ver");
  if(acorn_system(tmpbuf)) {
    PRTS(MAJ,,"@@@ load_winmon check error\n");
    pSysInfo->SystemUnusable++;
    add_sys_unusable_reason(CTP_SYS_UNUSABLE_WINMON_VER_EXEC);
  } else {
    FILE *fptr;
    if((fptr = fopen("/tmp/win_ver", "r+")) != NULL){
      fscanf(fptr, "Version:\t%d.%d", &win_ver, &wddi_ver);
      fclose(fptr);
    } else {
      PRTS(MAJ,,"@@@ can't open win_ver file\n");
      pSysInfo->SystemUnusable++;
      add_sys_unusable_reason(CTP_SYS_UNUSABLE_WINMON_VER_MISSING);
    }
  }
  acorn_system("/bin/rm -f /tmp/win_ver");
  if((win_ver != CTP_REQUIRED_WINMON_REV) ||
    (wddi_ver != CTP_REQUIRED_WDDI_REV)){
    sprintf(tmpbuf,
      "@@@ Incorrect load_winmon Rev: Expected %d.%d and got %d.%d\n",
      CTP_REQUIRED_WINMON_REV,CTP_REQUIRED_WDDI_REV,
       win_ver,wddi_ver);
    PRTS(MAJ,,tmpbuf);
    pSysInfo->SystemUnusable++;
    add_sys_unusable_reason(CTP_SYS_UNUSABLE_WINMON_VER_PROB);
  }
  return;
}

int ctp_check_fpga( int Card) 
{
  unsigned int fpgaVer;
  char prtbuf[100];
  FUNC_PRT(ctp_check_fpga, PF_START, -1);
#ifdef SKIP_FPGA_VERSION_CHECK
  PRT(MAJ,@@@ Skipping FPGA version checking);
  return SUCCESS;
#endif
  if(SCC_CARD(Card)) {
        switch(CARDTYPE(Card)) {
	  case T1CARD:
            //CAP fix start - PR 1708024
	    if( pSysInfo->SysType == SYS_TYPE_CTP_2000 ) {
              if(pSysInfo->Card[Card].SubType == HW_SUBTYPE_CTP2000_IM_8P_T1E1_B){
                fpgaVer = CTP_REQUIRED_FPGA_REV_POWDERKEG_T1;
              } else {
	        fpgaVer = CTP_REQUIRED_FPGA_REV_T1;
              }
	    } else {
	      if(IS_ABRG(Card)) {
		if(pSysInfo->Card[Card].SubType == HW_SUBTYPE_CTP150_IM_T1E1_B){
		  fpgaVer = CTP_REQUIRED_FPGA_REV_CTP150_POWDERKEG_ABRG;
		} else {
		  fpgaVer = CTP_REQUIRED_FPGA_REV_CTP150_AUDIO_BR;
		}
	      } else {
		if(pSysInfo->Card[Card].SubType == HW_SUBTYPE_CTP150_IM_T1E1_B){
		  fpgaVer = CTP_REQUIRED_FPGA_REV_CTP150_POWDERKEG_T1E1;
		} else {
		  fpgaVer = CTP_REQUIRED_FPGA_REV_CTP150_T1E1;
		}
	      }
	    }
	    break;
	  case SCCARD:
	    if( pSysInfo->SysType == SYS_TYPE_CTP_2000 ) {
	      if(pSysInfo->Card[Card].SubType == HW_SUBTYPE_CTP2000_IM_8P_B){
		fpgaVer = CTP_REQUIRED_FPGA_REV_POWDERKEG_SER;
	      } else {
		fpgaVer = CTP_REQUIRED_FPGA_REV;
	      }
	    } else {
#ifdef XMC
              fpgaVer = CTP_REQUIRED_FPGA_REV_SUB_CTP150_SER;
#else 
	      if(pSysInfo->Card[Card].SubType == HW_SUBTYPE_CTP150_IM_SER_B){
		fpgaVer = CTP_REQUIRED_FPGA_REV_CTP150_POWDERKEG_SER;
	      } else {
		fpgaVer = CTP_REQUIRED_FPGA_REV_CTP150_SER;
	      }
#endif
	    }
	    break;
            //CAP fix end - PR 1708024
	  default:
	    sprintf(prtbuf, "@@@ Unsupported Card type: 0x%x\n",
	      (unsigned int)pSysInfo->Card[Card].Type);
	    PRTS(MAJ,,prtbuf);
	    return FAILURE;
	}
#ifndef NO_2000_FPGA_CHECK
    if( pSysInfo->Card[Card].FpgaRev != fpgaVer ) {
      sprintf(prtbuf, "@@@ Incorrect FPGA Rev: Expected 0x%x and got 0x%x\n",
        fpgaVer,  (unsigned int)pSysInfo->Card[Card].FpgaRev);
      PRTSC(MAJ,,prtbuf);
      return FAILURE;
    }
#endif
// Only on Nova serial card
    if( (CARDTYPE(Card) == SCCARD) && (pSysInfo->SysType == SYS_TYPE_CTP_2000)
       && (pSysInfo->Card[Card].PcaRev < 0x2 )) {
      fpga_clr_fcfg();
      fpga_set_glob_clk_div(1);
      fpga_send_fcfg(pSysInfo->Card[Card].BaseSccNum);
    }
  } else if( VOICE(Card) ) {
    unsigned int pldVer;
    switch (CARDTYPE(Card)) {
      case EMCARD:
	fpgaVer = CTP_REQUIRED_EM_FPGA;
	pldVer =  CTP_REQUIRED_EM_PLD;
	break;
      case FXSCRD:
	fpgaVer = CTP_REQUIRED_FXS_FPGA;
	pldVer =  CTP_REQUIRED_FXS_PLD;
	break;
      case FXOCRD:
	fpgaVer = CTP_REQUIRED_FXO_FPGA;
	pldVer =  CTP_REQUIRED_FXO_PLD;
	break;
      default:
	fpgaVer = 0;
	pldVer =  0;
	break;
    }
    if( pSysInfo->Card[Card].FpgaRev != fpgaVer ) {
      sprintf(prtbuf, "@@@ Incorrect FPGA Rev: Expected 0x%x and got 0x%x\n",
        fpgaVer,  (unsigned int)pSysInfo->Card[Card].FpgaRev);
      PRTSC(MAJ,,prtbuf);
      return FAILURE;
    }
    if( pSysInfo->Card[Card].PldRev != pldVer ) {
      sprintf(prtbuf, "@@@ Incorrect Pld Rev: Expected 0x%x and got 0x%x\n",
	pldVer,  (unsigned int)pSysInfo->Card[Card].PldRev);
      PRTSC(MAJ,,prtbuf);
      return FAILURE;
    }
  }
  return SUCCESS;
}
//---- NOTE: Differences in Port Internal Sate & Port State:
// Port State gets setup by here (ctp_check) & by CTPMSGTYPE_ST_CFG_PORT // messages!!
// Port Internal State gets setup by ctp_add_port!!
//--------------------------------------------------------------------------
int ctp_check()
{
  struct acrndrv_static_stat	nstat;
  int				status, Card, pNum, slot;
  int				TwoPort = 0;
  char				sccbuf[10],SccBuf[10],prtbuf[100];
  char				tmpbuf1[100], tmpbuf2[100];
  int				nova_cards_found = 0, scc_cards_found = 0;
  int				scc_ports = 0;		// Count of scc ports
  int				ports_on_card;
  u64				hdlc_ports;
  u32				hdlc_port_mask;
  struct acrndrv_command	ncmd;
  FILE 				*pCtpProcFile;
  u32				cardBitMask;
#ifdef VCTP
  int c_idx;
#endif
  FUNC_PRT(ctp_check, PF_START, -1);

  //--- Dump into logs the ctpd code version.
  sprintf(tmpbuf1,"");
  sprintf(tmpbuf2,"");
  if( strlen(CTP_EDIT) != 0 ) { sprintf(tmpbuf1,"R%s", CTP_EDIT); }
  if( strlen(CTP_RELEASE_XTRA) != 0 ) { sprintf(tmpbuf2,"%s", CTP_RELEASE_XTRA); }
  sprintf(prtbuf,"%s.%s%s%s\n",
      CTP_RELEASE, CTP_VERSION, tmpbuf1, tmpbuf2);
  PRTS(MIN,Code version, prtbuf);

  //----- ctp_init_sysinfo intializes SysInfo structure which
  //      then gets updated here.
  //
  //----- Scan to find cards present, ports present, etc.
  //      Require card 0 to be present & from ioctl set
  //      => SysType
  //      => PortsPerCard
  //      => CardsPerCpu
  //      From each card's qry, set
  //      => PldRevision
  //      => FpgsRevision
  //      => BaseSccNum
  //      => port -> scc number mapping
  //      => Card Type
  //      => Ports Available
  //
#ifdef TARGET
  PRTU8(GEN,CardsPerCpu initialized to , pSysInfo->CardsPerCpu);
  //----- assuming CardsPerCpu as 7 so if slot 0 is not scc card, the loop
  //    will still go on find other slots
  pSysInfo->CardsPerCpu = 7;
#ifdef WRL
  // Aricent PR 1491003 fix - Start
  pSysInfo->SysType = get_sys_type();
#else
  FILE 				*pCtpProcFile;
  u32				cardBitMask;
  // This info generated by card_readproc() func in driver
  pCtpProcFile = fopen("/proc/ctp/info", "r+");
  if(pCtpProcFile) {
    fscanf(pCtpProcFile, "%d %x\n", &pSysInfo->SysType, &cardBitMask);
    fclose(pCtpProcFile);
  }
  // Aricent PR 1491003 fix - End 
#endif
  switch( pSysInfo->SysType ) {
    case SYS_TYPE_CTP_2000:
      PRT(MAJ, **** Got ctp-2000 system **** );
      pSysInfo->PortsPerCard = 8;	// TODO - Deprecated, to REMOVE later
      break;
    case SYS_TYPE_CTP_150:
      PRT(MAJ, **** Got ctp-150 system **** );
      pSysInfo->PortsPerCard = 4;	// TODO - Deprecated, to REMOVE later
      break;
    case SYS_SUBTYPE_CTP_150:
      PRT(MAJ, **** Got ctp-151 system **** );//PR1422568
      pSysInfo->PortsPerCard = 4;	// TODO - Deprecated, to REMOVE later
      break;
    default:
      PRT(MAJ, !!!!! Got UNKNOWN system !!!!! );
      break;
  }
#ifdef VCTP
  for(c_idx = 0; c_idx < pSysInfo->CardsPerCpu; c_idx++) {
    Card = cardIndx[c_idx];
    sprintf(sccbuf,"scc%d", Card * pSysInfo->PortsPerCard);
    status = ioc_priv(sccbuf,SCC_GET_STATIC_STAT,&nstat);
    if( status == 0) pSysInfo->CardsPerCpu = nstat.CardsSupported;

    for(pNum=0;pNum<pSysInfo->PortsPerCard;pNum++) {	
      int p = Card*pSysInfo->PortsPerCard + pNum;
      ctp_init_port_state(Card, pNum, p);
    }
  }
#endif
  pSysInfo->nova_type = 0;
  if( pSysInfo->SysType == SYS_TYPE_CTP_2000 ) {
    sprintf(tmpbuf1,"/bin/grep Serverworks /proc/bus/pci/devices");
    if( !acorn_system_quiet(tmpbuf1) ) {
      PRT(MAJ, CTP2000 Chassis is PP310);
    } else {
    //Aricent Fix for PR 822013 - Start
      sprintf(tmpbuf1,"");
      sprintf(tmpbuf1,"/bin/grep 80860104 /proc/bus/pci/devices");
      if( !acorn_system_quiet(tmpbuf1) ){
       PRT(MAJ, CTP2000 Chassis is PP833);
       pSysInfo->nova_type = 2;
      }
   //Aricent  Fix for PR 822013 - End
      else {
       PRT(MAJ, CTP2000 Chassis is PP332);
       pSysInfo->nova_type = 1;
      }
    }  
  }
  
#ifndef VCTP
  for(Card=0;Card<pSysInfo->CardsPerCpu;Card++) {	// Must loop over CardsPerCpu here
#else
  for(c_idx = 0; c_idx<pSysInfo->CardsPerCpu; c_idx++) {
    Card = cardIndx[c_idx];
#endif
    sprintf(sccbuf,"scc%d", Card * pSysInfo->PortsPerCard);
    status = ioc_priv(sccbuf,SCC_GET_STATIC_STAT,&nstat);
    //--- Must get at least one card!
    if( status == 0) {	// Found a card
      //--- Warning, driver tells us which card this is in nstat.slot. Use
      //    nstat.slot as card index (not Card variable) in this loop (eg:
      //    pSysInfo->Card[slot].Type = ...)
      //    Also, nstat slot is unsigned char, be careful casting to int
      slot = nstat.slot & 0xff;

      if ( scc_cards_found == 0 ) {
        scc_cards_found ++;  
	//--- Set max_cards from 1st GET_STATIC_STAT ioctl
	pSysInfo->CardsPerCpu = nstat.CardsSupported;
	{
	  int temp = pSysInfo->CardsPerCpu;
	  PRTDV(GEN,Got cards supported by chassis, temp);
	}
	PRTDV(GEN,Got cards supported by chassis, pSysInfo->CardsPerCpu);

	// Set SysType from 1st ioctl
//	pSysInfo->SysType = nstat.SysType; // PR 1622220 - SysType value is already got from get_sys_type() above in this function. 
        if( nstat.PortsSupported <= 2 ) {	// 2 port box
          pSysInfo->PortsPerCard = 2;	// TODO - Deprecated, to REMOVE later
          TwoPort = 1;
          PRT(MAJ,Got CTP-1002);
        }

	//--- Set HDLC ports from 1st ioctl
	hdlc_ports = nstat.hdlc_ports;
	pSysInfo->hdlc_ports = nstat.hdlc_ports;
	sprintf(prtbuf,"Got hdlc_ports 0x%x passed from driver.",
	    (unsigned int)nstat.hdlc_ports);
	PRTS(EVE,,prtbuf);
      }

      if(nstat.card_type == HW_CPCI_T1E1) {
        pSysInfo->Card[slot].Type = T1CARD;
	pSysInfo->Card[Card].SubType = nstat.card_sub_type;
	PRTDV(MAJ, **** Got CTP2000 T1/E1 CARD **** for card, slot);
	card_found |= 1<<slot;    //Aricent PR 1079714 fix
      } else if(nstat.card_type == HW_PCIE_T1E1) {
        pSysInfo->Card[slot].Type = T1CARD;
	pSysInfo->Card[Card].SubType = nstat.card_sub_type;
	if( pSysInfo->Card[Card].SubType == HW_SUBTYPE_CTP150_IM_ABRG_A ||
