int ctp_request_bw(int Card, int pNum, int *pSpeed, int *pPps)
{
  CTP_PORT_DBASE	*pDbP = &Db.Card[Card].Port[pNum];
  CTP_PORT_STATE	*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  double		 tmp_speed;
  int 			 speed_bps, status;
  FUNC_PRT(ctp_request_bw, PF_PST, pNum);

  if( Ctp.Card[Card].Port[pNum].Diagnostics ) return(SUCCESS);

  calc_port_speed( Card, pNum, &tmp_speed );
  pPortIntSt->CheckedOutSpeed = tmp_speed;	// Save for release
  *pSpeed = (int)tmp_speed;
  speed_bps = (int)(1000 * tmp_speed);
  calc_pps( Card, pNum, (int)*pSpeed, pPps );
#if 0  // PR 1820351 Fix start
  {
    int pps = (int)*pPps;
    PRTDVP(GEN,Calculated PPS:,pps);
    PRTDVP(GEN,Calculated speed (bps):,speed_bps);
  } 
  #endif // PR 1820351 Fix end

  pPortSt->CheckedOutPps = *pPps;		// Save for display only
  status = ctp_request_kbps( Card, pNum, (int)*pSpeed, speed_bps);
  if(status){
    PRTP(MIN,Problem with BPS checkout);
    // By setting this to 0, we gaurantee that, if we end up doing an
    // unecessary BW release, it will release nothing, and not cause a BW
    // leak. The same goes for below (the other failure return)
    pPortIntSt->CheckedOutSpeed = (double)0.0;
  } else {
    status = ctp_request_pps( Card, pNum, (int)*pPps);
    if(status){
      PRTP(MIN,Problem with PPS checkout so returning BPS checkout);
      ctp_release_kbps( Card, pNum, (int)*pSpeed);
      pPortIntSt->CheckedOutSpeed = (double)0.0; // If we checkin, it's 0
    }
  }
  return(status);
}

//-------------------------------------------------------
int ctp_release_bw(int Card, int pNum)
{
  CTP_PORT_DBASE	*pDbP = &Db.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  double		 tmp_speed;
  int 			 pps, speed, speed_bps, status;
  FUNC_PRT(ctp_release_bw, PF_PST, pNum);

  if( Ctp.Card[Card].Port[pNum].Diagnostics ) return(SUCCESS);

  tmp_speed = (double)pPortIntSt->CheckedOutSpeed;
  speed = (int)tmp_speed;
  speed_bps = (int)(1000 * tmp_speed);
  calc_pps( Card, pNum, speed, &pps );
  status = ctp_release_kbps( Card, pNum, speed);
  status += ctp_release_pps( Card, pNum, pps);
  if(status){
    PRTP(MIN,Problem with BPS or PPS release);
  }
  return(status);
}

