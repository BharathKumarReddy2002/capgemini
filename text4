void winCntrsCheck(int bNum,WinBndlCntrs *wncntrs)
{
  FUNC_PRT(winCntrsCheck, PF_WIN, -1); 
  int Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
  int pNum = util_bndl_src_pNum(0, &Db.Bndl[bNum]);
  CTP_BNDL_STATE        *pBndlSt = &Ctp.Bndl[bNum];
  FLOW_CNTRS_CES Curr = wncntrs->curr_cntrs;
  FLOW_CNTRS_CES Prev = wncntrs->prev_cntrs;
  ces_tx cur_ces,prev_ces;
  
 //============================================================================
	// Ignore 1 sec OR
	//checking when user clear stats and prev has higher value than currrent	
 //=============================================================================
  if(Prev.rx.forward[1] == 0 || Prev.rx.forward[1] > Curr.rx.forward[1] ) { 
    bcopy(&(wncntrs->curr_cntrs),&(wncntrs->prev_cntrs),sizeof(FLOW_CNTRS_CES));		
    return ;
  }

  if(CES_CNTRS_CHECK(Curr.tx.forward[1]- Prev.tx.forward[1],Curr.rx.forward[1] - Prev.rx.forward[1])) {
    bcopy(&Curr.tx,&cur_ces,sizeof(ces_tx));
    bcopy(&Prev.tx,&prev_ces,sizeof(ces_tx));
    if(!memcmp( (((int *)&cur_ces)+2), (((int *)&prev_ces)+2),sizeof(ces_tx)-8)) {//compare FLOW_CNTRS_CES except first one
      if(pBndlSt->Bndl.ctp.InSyncCntr < CES_SYNC_COUNTER)  //don't want to increase all the time
         pBndlSt->Bndl.ctp.InSyncCntr++;
      
      pBndlSt->Bndl.ctp.OutSyncCntr = 0; //Aricent PR843773 Fix
    } else {
      if(pBndlSt->Bndl.ctp.OutSyncCntr < CES_SYNC_COUNTER) //don't want to increase all the time
         pBndlSt->Bndl.ctp.OutSyncCntr++;
 
      pBndlSt->Bndl.ctp.InSyncCntr = 0; //Aricent PR843773 Fix
    }
  } else {
    if(pBndlSt->Bndl.ctp.OutSyncCntr < CES_SYNC_COUNTER) //don't want to increase all the time
      pBndlSt->Bndl.ctp.OutSyncCntr++;
 
      pBndlSt->Bndl.ctp.InSyncCntr = 0; //Aricent PR843773 Fix
  }
  bcopy(&(wncntrs->curr_cntrs),&(wncntrs->prev_cntrs),sizeof(FLOW_CNTRS_CES));
}

