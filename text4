//========================================================================
// This function used to set idle channel output on Dallas chip
// Moved from ctp_adt.c
// enable : 1 enable idle pattern 0x7f
// enable : 0 disable idle pattern
// enable : 2 enable idle pattern 0xff
void ctp_enable_Dallas_idle(int bNum, int enable)
{
  CTP_BNDL_DBASE * pBndlDb = &Db.Bndl[bNum];
  unsigned int chanmask=0;
  int card, pNum;
  char SccBuf[10], sNum = 0;
  struct acrndrv_command	ncmd;
//Aricent PR-703766 start.
  card=pBndlDb->Bndl.wp_bndl.SrcInfo[0].Card;
  pNum=pBndlDb->Bndl.wp_bndl.SrcInfo[0].pNum;
  CTP_PORT_DBASE * pDbP = &Db.Card[card].Port[pNum];
//Aricent PR-703766 end.
  FUNC_PRT(ctp_enable_Dallas_idle, PF_H110, -1);
  if(pBndlDb->Type == CTP_BNDL_TYPE_VC) {
    card=pBndlDb->Bndl.vc_bndl.vc_chan[0].SrcInfo.Card;
    pNum=pBndlDb->Bndl.vc_bndl.vc_chan[0].SrcInfo.pNum;
    while( pBndlDb->Bndl.vc_bndl.vc_chan[sNum].SrcInfo.Used ) {
      chanmask |= 1<<pBndlDb->Bndl.vc_bndl.vc_chan[sNum].SrcInfo.Chan;
      sNum++;
      if(sNum == CTP_MAX_CHAN_PER_VCOMP) break;
    }
  } else {
    card=pBndlDb->Bndl.wp_bndl.SrcInfo[0].Card;
    pNum=pBndlDb->Bndl.wp_bndl.SrcInfo[0].pNum;
    chanmask = pBndlDb->Bndl.wp_bndl.tsBitMask;
  }  
  if(!IS_T1E1(card)) return;
   
//Aricent fix for PR-661077
  sprintf(SccBuf, "scc%d", pSysInfo->Card[card].BaseSccNum+pNum);
  
  ncmd.CmdType = SCC_CMD_SET_DALLAS_IDLE;
  ncmd.CmdObj = pNum;
  ncmd.CmdObj2 = chanmask;
  ncmd.CmdObj3 = enable;

//Aricent fix for PR-661077
  if(pBndlDb->Type == CTP_BNDL_TYPE_VC)
    ncmd.CmdObj4 = 0;
//Aricent PR-703766 start.
  else {
/* CmdObj6 with value '1', indecate bundle level signaling is on.
 * CmdObj6 with value '0', indecate bundle level signaling is off.
 * CmdObj4 with value '2', indecate t1 & port level signaling on.
 * CmdObj4 with value '1', indecate t1 & port level signaling off , or e1.
*/
    if ((!(pDbP->DcardCfg1 & T1E1_MSK_E1)) && (pDbP->DcardCfg1 & T1E1_MSK_E1_CAS) && (pDbP->DcardType == DCARD_T1E1)) { //PR 1524860
      ncmd.CmdObj6 = !(pBndlDb->Bndl.wp_bndl.CfgFlags & CFG_BNDL_FLAG_T1_MSK_BNDL_SIG); //Aricent PR 1478968 fix
      ncmd.CmdObj4 = 2;
    } else {
      ncmd.CmdObj4 = 1;
      ncmd.CmdObj6 = (pDbP->DcardCfg1 & T1E1_MSK_E1_CAS)?1:0;
    }
  }
//Aricent PR-703766 end.

  ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
  return;
}

void ctp_check_ipmi_ps(int startup) 
{
  FILE *fptr;
  int slot = 0, ipmi_timeout = 0;
  char PrtBuf[150];
  FUNC_PRT(ctp_check_ipmi_ps, PF_TRAP, -1);

  pSysInfo->Chassis.ipmi_in_process = 1;
  if(startup) {
    // This is used to determine if the chassis is ipmi capable. 
    // rely on the file generated by AcornSysMon. here we are 
    // stuck for upto 2 mins. when timeout declare it is not ipmi
    // capable.
    while ( ipmi_timeout ++ < 120 ) {
      if((fptr = fopen("/tmp/tmp_ipmi", "r+")) != NULL){
	fseek(fptr, 0, SEEK_END);
	if(ftell(fptr) < 10) {
	// This file is empty indication of no IPMI capable 
	// powersupply is present in the chassis.
	  pSysInfo->Chassis.ipmi_ps_capable = 0;	
	  // Assume power not present	
	  pSysInfo->Chassis.ipmi_ps_present = 0;
	} else {
	  pSysInfo->Chassis.ipmi_ps_capable = 1;
	  // Assume power to be present	
	  pSysInfo->Chassis.ipmi_ps_present = 1;
	}
	sprintf(PrtBuf, "System is ipmi %s", 
	  pSysInfo->Chassis.ipmi_ps_capable?"capable":"incapable");
	R_PRTS(MIN,,PrtBuf);
	fclose(fptr);  
        pSysInfo->Chassis.ipmi_in_process = 0;
	return;
      }
      sleep(1);
    }  
  } else if(pSysInfo->Chassis.ipmi_ps_capable) { 	
    char TstCmd[100];	
    pSysInfo->Chassis.ps_ok = 1;
    for( slot = 0 ; slot < 2; slot ++ ) {
      int ipmb_addr = slot?0x54:0x52;    
#ifdef WRL
      sprintf(TstCmd,"/usr/bin/ipmitool -t 0x%x sdr > /var/log/ipmi_status", ipmb_addr);
#else
      sprintf(TstCmd,"/sbin/ipmitool -t 0x%x sdr > /var/log/ipmi_status", ipmb_addr);
#endif
      acorn_system_quiet(TstCmd);
      if((fptr = fopen("/var/log/ipmi_status", "r")) != NULL ) {
        char tmpStr[128];
	while ( fgets ( tmpStr, 128, fptr ) != NULL ) {
	  if(strstr(tmpStr, "ok") == NULL ) {
	    pSysInfo->Chassis.ps_ok = 0;
	    break;
	  }	
	}	      
	fclose(fptr);
	if(pSysInfo->Chassis.ps_ok == 0 ) break;
      }
    }  
    sprintf(PrtBuf, "IPMI power supplies are %s", 
      pSysInfo->Chassis.ps_ok?"ok":"fault");
    R_PRTS(MIN,,PrtBuf);
    // when this function is called, there is problem reported via IO pin
    // if power supply is determined to be ok, then fans must be bad.
    pSysInfo->Chassis.fans_ok = pSysInfo->Chassis.ps_ok? 0:1;
  }	  	
  pSysInfo->Chassis.ipmi_in_process = 0; // finished processing.
}

void ctp2000_proc_ps_fans(void) 
{
  u32 CtrlStatusReg = CTP_NOVA_DEG_REG;
  u8 val, fans_ok=1;
  char PrtBuf[150];
  int ChildPid;
  char tmpbuf[100], temp[5]; // Aricent PR 1236049 Fix
  FILE *fptr;
  int  num;// Aricent PR 1356307 fix  
  FUNC_PRT(ctp2000_proc_ps_fans, PF_TRAP, -1);
  
  // if ipmi is in process, just return, wait for its complete.
  if(pSysInfo->Chassis.ipmi_in_process) return;
  
  // Check IO pin get FAIL/DEG status.
  // Aricent PR 1236049 Fix - Start
  sprintf(tmpbuf,"/bin/grep ata_piix /proc/bus/pci/devices | wc -l | awk '{print $1}'");
  fptr = popen(tmpbuf,"r");
  while(fgets(temp, sizeof(temp), fptr) != NULL) {
    break;
  }
  pclose(fptr);
//  if( !acorn_system_quiet(tmpbuf) ) CtrlStatusReg = CTP_NOVA_PP833_DEG_REG;
  if(pSysInfo->nova_type == 1) CtrlStatusReg ++;
  else if(temp) CtrlStatusReg = CTP_NOVA_PP833_DEG_REG;
  // Aricent PR 1236049 Fix - End
  ioperm(CtrlStatusReg, 1, 3);
  val = inb(CtrlStatusReg);
  // Aricent PR 1236049 Fix - Start
  if( CtrlStatusReg == CTP_NOVA_PP833_DEG_REG ) {
    if( val & (CTP_NOVA_PP833_DEG_BIT | CTP_NOVA_PP833_FAIL_BIT) ) { fans_ok = 0; }
  } else if( val & (CTP_NOVA_DEG_BIT | CTP_NOVA_FAIL_BIT) ) { fans_ok = 0; }
  // Aricent PR 1236049 Fix - End
  
  // on ipmi dc chassis
  if(pSysInfo->Chassis.ipmi_ps_capable) {
    if( fans_ok == 0 ) {
     // reported problem.	    
      if( pSysInfo->Chassis.ps_ok & pSysInfo->Chassis.fans_ok ) {	    
	// check IPMI power supply first.      
        ChildPid = fork();
        if(ChildPid == 0) {
      // in Child process, run the ipmitool to detect problem.
          ctp_check_ipmi_ps(0);
	  exit(0);
        }
      } else if(!pSysInfo->Chassis.ps_failed_once){
	// send out trap only once.      
        sprintf(PrtBuf,"%s status change to Fault%s.\n", 
          pSysInfo->Chassis.ps_ok?"Fan":"Power supply",
          Ctp.Snmp.TrapAble?" sending trap":"" );
        R_PRTS(EVE,,PrtBuf);
        if( Ctp.Snmp.TrapAble ) {
        //--- Trap sent, update SysInfo
	  int  Type = pSysInfo->Chassis.ps_ok? TRAP_HW_FAN: TRAP_HW_PS;
          // Aricent PR 1356307 fix - Start
          if ( Type == TRAP_HW_FAN){
          num = trap_number("TRAP_HW_FAN");
          if (trap_bitmap & (1 << (num - 1))){
            ctp_send_trap( 0,0, Type, fans_ok);
          }
          }
          else if ( Type == TRAP_HW_PS) {
          num = trap_number("TRAP_HW_PS");
          if (trap_bitmap & (1 << (num - 1))){
            ctp_send_trap( 0,0, Type, fans_ok);
          }
         }
         // Aricent PR 1356307 fix - End
        }
	pSysInfo->Chassis.ps_failed_once = 1;
      }
    } else if (!( pSysInfo->Chassis.ps_ok & pSysInfo->Chassis.fans_ok )) {
      // problem cleared. send out trap immediately, no need to query ipmi	    
      sprintf(PrtBuf,"%s status change to OK%s.\n", 
        pSysInfo->Chassis.ps_ok?"Fan":"Power supply",
        Ctp.Snmp.TrapAble?" sending trap":"" );
      R_PRTS(EVE,,PrtBuf);
      if( Ctp.Snmp.TrapAble ) {
  //--- Trap sent, update SysInfo
 	int  Type = pSysInfo->Chassis.ps_ok? TRAP_HW_FAN: TRAP_HW_PS;
        // Aricent PR 1356307 fix - Start
        if ( Type == TRAP_HW_FAN){
         num = trap_number("TRAP_HW_FAN");
         if (trap_bitmap & (1 << (num - 1))){
           ctp_send_trap( 0,0, Type, fans_ok);
         }
        }
        else if ( Type == TRAP_HW_PS){
         num = trap_number("TRAP_HW_PS");
          if (trap_bitmap & (1 << (num - 1))){
            ctp_send_trap( 0,0, Type, fans_ok);
         }
       }
       // Aricent PR 1356307 fix - End
      }
      // reset fields
      pSysInfo->Chassis.ps_ok = pSysInfo->Chassis.fans_ok = 1;
      pSysInfo->Chassis.ps_failed_once = 0;
    }
  } else if(fans_ok != pSysInfo->Chassis.fans_ok) {
    // this is the old way of generating traps for fan and/or power supply	  
    sprintf(PrtBuf,"Fan/Power supply status change to %s%s.\n", 
      fans_ok?"OK":"Fault", Ctp.Snmp.TrapAble?" sending trap":"" );
    R_PRTS(EVE,,PrtBuf);
    if( Ctp.Snmp.TrapAble ) {
  //--- Trap sent, update SysInfo
      // Aricent PR 1356307 fix - Start
      num = trap_number("TRAP_HW_FAN");
      if (trap_bitmap & (1 << (num - 1))){
        ctp_send_trap( 0,0, TRAP_HW_FAN, fans_ok);
      }
     // Aricent PR 1356307 fix - End
    }
    pSysInfo->Chassis.fans_ok = fans_ok;
    PRTDV(GEN,CTP-2000 chassis fans, fans_ok);
  }
}

