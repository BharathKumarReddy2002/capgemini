//--------------------------------------------------------------------------
int initSemaphore( int semkey )
{
  int id;  /* Internal identifier of the semaphore. */
  int			sem_val;
  unsigned short	short_pid;

  union semun {
    int val;
    struct semid_ds *buf;
    ushort * array;
  } argument;

  FUNC_PRT(initSemaphore, PF_IPC, -1);

  short_pid = getpid() & 0x7fff;		// generate short PID
  //PRTDV(OFF,PID,short_pid);

  id = semget(semkey, 1, 0666 | IPC_CREAT );
  if(id < 0) {
    PRT(MAJ,Unable to obtain semaphore);
    return(-1);
  //} else {
    //PRTDV(EVE,Got ID for semaphore key,semkey);
  }

  argument.val = 0;
  sem_val = semctl(id, 0, SETVAL, argument);
  if( sem_val) {
    PRT(MAJ,Unable to access semaphore);
    return(-1);
  }
  sem_val = semctl(id, 0, GETVAL, argument);
  if( sem_val != 0 ) {
    PRT(MAJ,Unable to clear semaphore);
    return(-1);
  }
  return(0);
}

int ctp_scan_scc_dcard( int Card ) 
{
  int pNum;
  int sccNum;
  for(pNum=0;pNum<pSysInfo->Card[Card].PortsOnCard;pNum++) {
    // PR 1180788 start - Set redundancy mode off for DCARD access
    sccNum = Ctp.Card[Card].Port[pNum].SccNum;
    fpga_clr_fcfg();
    fpga_set_redundant_mode(pNum,0);		// Rdnt mode [2]
    fpga_set_redundant_cts_ctrl(pNum,0);	// Rdnt mode [1]
    fpga_set_redundant_mstr(pNum,0);		// Rdnt mode [0]
    fpga_send_fcfg(sccNum);
    // PR 1180788 end
    // Clean up the structure first	  
    memset(&Dcard.Card[Card].Info[pNum], 0, sizeof(CTP_DCARD_INFO));
    if (Ctp.Card[Card].Port[pNum].Available == YES) {
      if(IS_T1E1(Card)) {
     /* Here we fake T1E1 Daughter card */
        Dcard.Card[Card].Info[pNum].Present = YES;
	Dcard.Card[Card].Info[pNum].Type = DCARD_T1E1;
	Dcard.Card[Card].Info[pNum].HwRev = 0x1;
	Dcard.Card[Card].Info[pNum].FwRev = CTP_DCARD_PLD_REV_T1E1;
	continue;
      } else {
	dcard_get_info( Card, pNum,
	    &Dcard.Card[Card].Info[pNum].Type,
	    &Dcard.Card[Card].Info[pNum].HwRev,
	    &Dcard.Card[Card].Info[pNum].FwRev );
	if( (Dcard.Card[Card].Info[pNum].Type == DCARD_IRIG) ||
	    (Dcard.Card[Card].Info[pNum].Type == DCARD_MS) ) {
	  Dcard.Card[Card].Info[pNum].HwRev &= 0x1f;
	}
      }

      if( (Dcard.Card[Card].Info[pNum].Type == DCARD_NONE) ||
        (Dcard.Card[Card].Info[pNum].Type >= DCARD_MAX) ) {
	Dcard.Card[Card].Info[pNum].Present = NO;
	Dcard.Card[Card].Info[pNum].Type = DCARD_NONE;
	Dcard.Card[Card].Info[pNum].HwRev = 0x0;
	Dcard.Card[Card].Info[pNum].FwRev = 0x0;
      } else {
	//PRTDV(OFF,Found Daughter card on port,i);
	Dcard.Card[Card].Info[pNum].Present = YES;
	// We don't support these older DCARD types on the CTP150 any more.
	// But setting this ifdef to 0 will allow
#if 1
	if( (((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) &&
	    (pSysInfo->Card[Card].Type == SCCARD) &&
	    ( (Dcard.Card[Card].Info[pNum].Type == DCARD_T1E1) ||
	      (Dcard.Card[Card].Info[pNum].Type == DCARD_IRIG) ||
	      (Dcard.Card[Card].Info[pNum].Type == DCARD_4WTO)
	    )) || ((pSysInfo->SysType == SYS_TYPE_CTP_2000) && (pSysInfo->Card[Card].Type == SCCARD) &&
            (Dcard.Card[Card].Info[pNum].Type == DCARD_T1E1))) {    // Aricent PR 1567520 fix
	  pSysInfo->SystemUnusable++;
	  add_sys_unusable_reason(CTP_SYS_UNUSABLE_BAD_DCARD);    // Aricent PR 1567520 fix
	}
#endif
      }
    }
  }
  return SUCCESS;   
}

//--------------------------------------------------------------------------
void ctp_scan_hw( void )
{
  int	Card, pNum, sccNum;    //Aricent PR 947222 and PR 1010274 fix
  int   i, has_scc=0, need_h110 = 0, h110_capable = 0, found_cards = 0;
  int	first_t1 = -1, first_scc = -1, clk_rtm_hub_slot = -1;
  int	need_mLead_proc = 1;
  char	 Buf[200];
  int	scc_capable = 0;	/*--- Aricent PR 1089541 fix ---*/
#ifdef VCTP
  int c_idx;
#endif
  // Only needed with winpot u32	read_val;

  FUNC_PRT(ctp_scan_hw, PF_START, -1);

  //--------- Set all port interfaces for Daughter card check ---------
  for(Card=0; Card<CTP_MAX_CARDS;Card++) {
    if( IS_SER(Card) ) {		// Aricent PR-947222 Only search for dcards on scc cards
      for(pNum=0;pNum<pSysInfo->Card[Card].PortsOnCard;pNum++) {
	sccNum = Ctp.Card[Card].Port[pNum].SccNum;
	//--- DCARD reset activate ( PR 974139 )
	fpga_clr_fcfg();
	fpga_set_sig_reg(pNum,0);			// Reset entire register
	fpga_set_signals_inactive(pNum);		// Signaling leads inactive
	fpga_set_if_dce(pNum);				// Daughter card reset
	fpga_send_fcfg(sccNum);
	//--- DCARD reset release
	fpga_clr_fcfg();
	fpga_set_if_dcard(pNum);			// Daughter card unreset
	fpga_send_fcfg(sccNum);
      }
    }
  }

  // IRIG-B DCARDs need time for FPGA to load. The LFXP3 FPGA needs a max
  // of 1.7 ms to load from flash, so we wait a sufficient 5 ms.
  usleep(5000);

  //--------- Gather data on port daughter cards, if any ---------
  for(Card=0; Card<CTP_MAX_CARDS;Card++) ctp_scan_scc_dcard(Card);

  //--- Figure out Clocking and H110 for CTP2000 system
  if( pSysInfo->SysType == SYS_TYPE_CTP_2000 ) {
    int first_vcc= -1;
#ifndef VCTP
    for(Card=0;Card<pSysInfo->CardsPerCpu;Card++) {
#else
    int c_idx;
    for(c_idx = 0; c_idx<pSysInfo->CardsPerCpu; c_idx++) {
      Card = cardIndx[c_idx];
#endif
      int	cType = CARDTYPE(Card);
      switch( cType ) {
	//----------
	case SCCARD:
	  found_cards++;
	  has_scc = pSysInfo->Clk.has_scc = 1;
          /*--- Aricent PR 1089541 fix : Start ---*/
	  if (Card == 0)
	    scc_capable = 1;
          /*--- Aricent PR 1089541 fix : End ---*/
	  if( first_scc == -1 ) {
	    first_scc = pSysInfo->Clk.first_scc = Card;
	  }
	  clk_rtm_get_info( Card );
	  if (pSysInfo->Card[Card].ClkRtm == HUB_CLK_RTM) {
	    if( clk_rtm_hub_slot == -1 ) {
	      // We only get upset if the *first* Hub RTM we find is not in
	      // slot 0. Otherwise, additional hub cards are OK to use as spoke
	      // cards, since they behave very much like spoke cards (with
	      // extra unused interfaces...).
	      if( Card > 0 ) {
		sprintf(Buf,"@@@ HUB Clock RTM found in non-zero slot 0x%x\n",Card);
		PRTSC(MAJ,,Buf);
		pSysInfo->SystemUnusable++;
		add_sys_unusable_reason(CTP_SYS_UNUSABLE_CLK_HUB_SLOT);
	      } else {
		clk_rtm_hub_slot = pSysInfo->Clk.clk_rtm_hub_slot = Card;
	      }
	    }
	  }
	  break;
	case T1CARD:
	  found_cards++;
	  h110_capable++;
	  has_scc = pSysInfo->Clk.has_scc = 1;
          /*--- Aricent PR 1089541 fix : Start ---*/
	  if (Card == 0)
	    scc_capable = 1;
          /*--- Aricent PR 1089541 fix : End ---*/
	  if( first_scc == -1 ) {
	    first_scc = pSysInfo->Clk.first_scc = Card;
	  }
	  if( IS_T1E1(Card) ) {		// Inside if(CTP_2000) block ....
	    if( first_t1 == -1 ) {
	      first_t1 = pSysInfo->Clk.first_t1 = Card;
	    }
	  }
	  clk_rtm_get_info( Card );
	  if (pSysInfo->Card[Card].ClkRtm == HUB_CLK_RTM) {
	    if( clk_rtm_hub_slot == -1 ) {
	      // We only get upset if the *first* Hub RTM we find is not in
	      // slot 0. Otherwise, additional hub cards are OK to use as spoke
	      // cards, since they behave very much like spoke cards (with
	      // extra unused interfaces...).
	      if( Card > 0 ) {
		sprintf(Buf,"@@@ HUB Clock RTM found in non-zero slot 0x%x\n",Card);
		PRTSC(MAJ,,Buf);
		pSysInfo->SystemUnusable++;
		add_sys_unusable_reason(CTP_SYS_UNUSABLE_CLK_HUB_SLOT);
	      } else {
		clk_rtm_hub_slot = pSysInfo->Clk.clk_rtm_hub_slot = Card;
	      }
	    }
	  }
	  break;
	  //----------
	case VCCARD:
	  if(first_vcc == -1) first_vcc = Card;
	case EMCARD:
	case FXSCRD:
	case FXOCRD:
	  found_cards++;
	  h110_capable++;
	  need_h110 = pSysInfo->Clk.need_h110 = 1;
	  break;
	case NOCARD:
	  break;
	default:
	  found_cards++;
	  PRTDVC(MAJ,@@@ Unexpected card type,cType);
	  pSysInfo->SystemUnusable++;
	  add_sys_unusable_reason(CTP_SYS_UNUSABLE_BAD_CARD_TYPE);
	  break;
      }
    }
    /* 
     * Aricent PR 1089541 fix start :Check if T1E1/Serial card is present at slot-0
     * If not, then set system unusable.
     */
    if(!scc_capable) {
      pSysInfo->SystemUnusable++;
      add_sys_unusable_reason(CTP_SYS_UNUSABLE_NO_T1E1_SE_IN_SLOT0);
    }
    /*--- Aricent PR 1089541 fix : End ---*/
    //----- This will set up node as h110 if there are only T1E1 cards
    if( h110_capable == found_cards ) {
      need_h110 = pSysInfo->Clk.need_h110 = 1;
    }
    if( need_h110 ) {
      if( clk_rtm_hub_slot < 0 ) {
	if( h110_capable != found_cards ) {
	  // Apparently we have cards that are not capable of interfacing to
	  // the H.110 bus at 8M, and no hub card is available for clock
	  // distro. Don't prevent the node from coming up, but at least let
	  // the user know there is a problem.
	  PRT(MIN,No Hub card found - Cards will free run...);
	}
      }
      if( clk_rtm_hub_slot > 0 ) {
	PRTVC(MAJ,ERROR: Hub card in bad slot,Card);
      }
    }
    // When we need H110 but there is no T1 card in the chassis
    // Then there should be at least one voice compression card
    // which will be the H.110 master
    // Aricent PR 1137814 and 1142792 Fix - Start
    if((need_h110) && (first_t1 == -1)){
      if( (first_vcc > 0) && (ctp_cfg_vcc_h110_m(first_vcc) != SUCCESS) ) {
        // Aricent PR 1137814 and 1142792 Fix - End
        pSysInfo->SystemUnusable++;
        add_sys_unusable_reason(CTP_SYS_UNUSABLE_VC_CARD_INIT_ERR);
      }
    }
  }

  PRTDV(GEN,CLK: has_scc, has_scc);
  PRTDV(GEN,CLK: need_h110, need_h110);
  PRTDV(GEN,CLK: clk_rtm_hub_slot, clk_rtm_hub_slot);
  PRTDV(GEN,CLK: first_t1, first_t1);
  PRTDV(GEN,CLK: first_scc, first_scc);

  ctp_cfg_node_clks( 1 , -1 );

  //--------- port level ---------
  for(Card=0; Card<CTP_MAX_CARDS;Card++) {
    if( IS_SER(Card) ) {           // Aricent PR-947222
      for(pNum=0;pNum<pSysInfo->Card[Card].PortsOnCard;pNum++) {
	if (Ctp.Card[Card].Port[pNum].Available == YES) {
	  sccNum = Ctp.Card[Card].Port[pNum].SccNum;
	  fpga_clr_fcfg();
	  fpga_set_sig_reg(pNum,0);			// Reset entire register
	  fpga_set_signals_inactive(pNum);		// Signaling leads inactive
	  fpga_set_if_disable(Card,pNum);		// Tristated I/F //CAP PR 1734636
	  fpga_send_fcfg(sccNum);
	}
      }
    }
    if(IS_T1E1_2000(Card)) {
      ctp_t1e1_proc_sigs(Card);		//TODO: gw - Is this the best place???
    }
  }
  // Aricent Pr-947222 and PR 1010274 fix Start
  if(IS_T1E1_2000(0)) {
    ctp_t1e1_proc_h110_sigs(0);  //this will be called only when T1E1 card is in slot 0
  }
  // Aricent Pr-947222 End 

#ifndef TARGET
  for(i=1;i<2;i++) {
    Dcard.Card[0].Info[i].Present = YES;
    Dcard.Card[0].Info[i].Type = DCARD_4WTO;
    Dcard.Card[0].Info[i].HwRev = 0x1;
    Dcard.Card[0].Info[i].FwRev = 0x2;		// So that upgrades don't abort
  }
  for(i=2;i<3;i++) {
    Dcard.Card[0].Info[i].Present = YES;
    Dcard.Card[0].Info[i].Type = DCARD_T1E1;
    Dcard.Card[0].Info[i].HwRev = 0x1;
    Dcard.Card[0].Info[i].FwRev = 0x2;
  }
#endif // not TARGET

#ifdef DBG_FAKE_4WTO
  for(i=0;i<1;i++) {
    Dcard.Card[0].Info[i].Present = YES;
    Dcard.Card[0].Info[i].Type = DCARD_4WTO;
    Dcard.Card[0].Info[i].HwRev = 0x1;
    Dcard.Card[0].Info[i].FwRev = 0x2;		// So that upgrades don't abort
  }
#endif

#ifdef DBG_FAKE_T1E1
  for(i=1;i<2;i++) {
    if( Dcard.Card[0].Info[i].Present == NO ) {
      Dcard.Card[0].Info[i].Present = YES;
      Dcard.Card[0].Info[i].Type = DCARD_T1E1;
      Dcard.Card[0].Info[i].HwRev = 0x1;
      Dcard.Card[0].Info[i].FwRev = 0x3;
    }
  }
#endif

#ifdef DBG_FAKE_IRIG
  // Just on card 0 port 4. Only add them if there isn't one there already
  for(i=4;i<5;i++) {
    if( Dcard.Card[0].Info[i].Present == NO ) {
      Dcard.Card[0].Info[i].Present = YES;
      Dcard.Card[0].Info[i].Type = DCARD_IRIG;
      Dcard.Card[0].Info[i].HwRev = 0x0;
      Dcard.Card[0].Info[i].FwRev = 0x0;
    }
  }
#endif

}

int ctp_init_hub_rtm( int Card ) 
{
  int	Dev = I2C_ADR_CLKRTM;
  int Cfg=0x1a;
  FUNC_PRT(ctp_init_hub_rtm, PF_REF, -1);
  ctp_i2c_write(Card,Dev,0x0e,0x61); // Auto-Off,DIV is byp of P5 clk
  ctp_i2c_write(Card,Dev,0x03,0x00); // Get P5 Clk from Front Card
  ctp_i2c_write(Card,Dev,0x0d,0x05); // Initialize T1 register
  ctp_i2c_write(Card,Dev,0x0c,0x32); // Initialize T1 register
  ctp_i2c_write(Card,Dev,0x05,Cfg); // Drive out RJ45 #0
  ctp_i2c_write(Card,Dev,0x06,Cfg); // Drive out RJ45 #1
  ctp_i2c_write(Card,Dev,0x07,Cfg); // Drive out RJ45 #2
  ctp_i2c_write(Card,Dev,0x08,Cfg); // Drive out RJ45 #3
  ctp_i2c_write(Card,Dev,0x09,Cfg); // Drive out RJ45 #4
  ctp_i2c_write(Card,Dev,0x0a,Cfg); // Drive out RJ45 #5
}	

int ctp_cfg_hub_slot_clk( int Card)
{
  int ref_port = 0, found_extref = 0, div = 0; 
  int	Dev = I2C_ADR_CLKRTM;
  FUNC_PRT(ctp_cfg_hub_slot_clk, PF_REF, -1);
  //--- Configure Hub RTM to output clocks
  // Now that we have a dbase, we need to check what the
  // config is before touching the H/W. If we have an
  // external reference, we need to set the main card to have
  // P5 as an input to bring the reference in. Then we need
  // to divide it down on the hub PLD to create 32K to send
  // to the other spoke cards. We don't want to mess with the
  // other settings (i.e. fpga_set_ref_sel ) since that is
  // handled by the reference routines.
  //
  // If we are using an external reference, set P5 connection as input.
  // Otherwise, this is likely a hub card that needs to get clk from
  // front card through P5 to distribute to spoke cards
  // this is where we will configure the RTM (BITS, TTL, etc...)
  
  for ( ref_port = 0; ref_port < CTP_MAX_REFS_PER_NODE; ref_port++ ) {
    if( Db.Node[0].ref[ref_port].Port == CTP_REF_EXTERNAL ) {
      found_extref = 1;	
      div = Db.Node[0].ref[ref_port].Div;
      PRTU8(MIN, Found external reference port, Db.Node[0].ref[ref_port].ext_ref_port);
      break;
    }   
  }

  if( found_extref ){
    int ref_src;	
    fpga_set_ref_ext_sel(REF_EXT_P5);	// ...from P5
    switch(Db.Node[0].ref[ref_port].ext_ref_port) {
      case CTP_EXT_REF_DB25:
        ref_src = 0;
        break;
      case CTP_EXT_REF_TTL:
        ref_src = 0x19;
        break;
      case CTP_EXT_REF_T1:
        ref_src = 0x1b;
      // In case of E1, the dco need to send e1 frequency out
        if(div != CTP_REF_1544_FLAG ) {
  	  fpga_set_dco_e1(Card,1);
	  Ctp.Node[0].spoke_rtm_e1_input = 1;
	}	
	break;
    }
    ctp_i2c_write(0,Dev,0x03,ref_src); // P5 source.
  }  
  if( Db.Node[0].ref_out ) {
    fpga_set_ref_p5_out_enable(1);
    PRTC(EVE,Configured serial ext ref port as output);
  } else {
    fpga_set_ref_p5_out_enable(0);
    PRTC(EVE,Configured serial ext ref port as input);
  }
}

//-------------------------------------------------------------------------
int ctp_cfg_node_clks( int StartUp, int cfgCard )
{
  int	Card, pNum;
  int	need_proc_vb_msg = 0;
  int   need_h110_master = 1;
  int	lev = StartUp ? MIN : GEN;
  int	Dev = I2C_ADR_CLKRTM;
  char	Buf[200];
  FUNC_PRT(ctp_cfg_node_clks, PF_REF, -1);
  //========= Initial hardware configuration ===========
  //----- Clock configuration -----
  // The philosphy here is to do a clock setup the best it can with the
  // situation it has been dealt. Rather than get upset and make the system
  // unusable if anything looks awry, it just does the best it can. The one
  // exception is if a Hub RTM is detected, and it is not in slot 0.
  // ---
  // For SCC cards (cards which would have liked to use the H.110 bus for
  // passing nodal synchronization clock) if the need_H110 flag is active,
  // then we need to make sure that these SCC cards do not try to drive the
  // H.110 with a 32K clock. With need_H110 active, the Hub card will be
  // set to drive 32K out P5 and out all the hub RJ ports. Spoke cards will
  // just be configured to accept 32K in P5 (no config of spoke RTMs needed
  // since they will automatically route clocks to P5). Also, the
  // designated H110 card (T1E1 card) will be configured to drive the H.110
  // clocks. If need_H110 is not set, then it is OK to use the H.110 bus
  // for clock distribution, and the lowest numbered SCC Card is set to
  // drive the clock out to the other cards.
  //--------- card level ---------
  PRTDV(lev,Reconfig Clocks - StartUp:,StartUp);
  if(cfgCard < 0 ) // Not for hotplug
    Ctp.Node[0].spoke_rtm_e1_input = 0;	  // Initialize the e1 input from RTM
#ifndef VCTP
  for(Card=0;Card<pSysInfo->CardsPerCpu;Card++) {
#else
    int c_idx;
    for(c_idx = 0; c_idx<pSysInfo->CardsPerCpu; c_idx++) {
      Card = cardIndx[c_idx];
#endif
    // In case of hotswap, we only need to visit one card configuration. 
    // otherwise the whole node need to be configured again.	  
    if((cfgCard >= 0) && Card != cfgCard) continue; 
    if( pSysInfo->SysType == SYS_TYPE_CTP_2000 ) {
      if( SCC_CARD(Card) ) {
	fpga_clr_fcfg();
	fpga_set_ref_p3_out_enable(0);	// Always turn off P3 output
        fpga_set_dco_e1(Card,0); // set the dco frequency to 1.544Mhz until T1E1 RTM BITS input enabled.
	if( pSysInfo->Clk.need_h110 ) {
	  fpga_set_ref_p4_out_enable(0);	// No cards drive 32K to H.110
	  if( pSysInfo->Clk.clk_rtm_hub_slot >= 0 ) {	// If hub card found
            //========== Card 0 with Hub RTM ==========  
	    if( pSysInfo->Clk.clk_rtm_hub_slot == Card ) {	// If this is a hub card
	      if( StartUp ) {
		// If no dbase is availabe yet (during startup), we want to
		// set the "main card" to center frequency and distribute
		// it to other cards as a 32K reference going out P5
		//--- set to center VCO frequency
		fpga_set_ref_fixed( CTP_PHDET_SPAN >> 1 );
		fpga_set_ref_fixed_period(CTP_PHDET_GEN_SPAN);
		fpga_set_ref_sel(CTP_REF_FIXED);	// Fixed setting
		//---
		if( IS_T1E1(Card) ) {		// Inside if(CTP_2000) block ...
		  ctp_card_h110_m( Card );	// Drive H.110 clock (8M)
		  pSysInfo->H110_InUse = 1;	// Declare mastership
		  sprintf(Buf,"T1E1   Hub slot with H.110 on (H110 mstr)");
		  PRTSC(lev,,Buf);
		} else {
		  sprintf(Buf,"Serl   Hub slot with H.110 on");
		  PRTSC(lev,,Buf);
		}
		//--- Configure Hub RTM to output clocks
                ctp_init_hub_rtm( Card );
		sprintf(Buf,"Configure Hub RTM to drive outputs");
		PRTSC(lev,,Buf);
	      } else {	// Dbase is available
		if( IS_T1E1(Card) ) {		// Inside if(CTP_2000) block ...
		  sprintf(Buf,"T1E1   Hub slot with H.110 on (H110 mstr)");
		  PRTSC(lev,,Buf);
		} else {
		  sprintf(Buf,"Serl   Hub slot with H.110 on");
		  PRTSC(lev,,Buf);
		}
		ctp_cfg_hub_slot_clk(Card);
	      }
	    //========== Card X with Spoke RTM ==========  
	    } else { // *not* Hub slot
	      fpga_set_ref_p5_out_enable(0);	// Input clock comes from Hub RTM
	      if( IS_T1E1(Card) ) {		// Inside if(CTP_2000) block ...
		if( Card == pSysInfo->Clk.first_t1 ) {
		  fpga_set_ref_ext_sel(REF_EXT_P5);	// ...from P5
                  fpga_set_ref_t1(1);
		  if( StartUp ) {
		    ctp_card_h110_m( Card );
		    pSysInfo->H110_InUse = 1;
		  }
		  sprintf(Buf,"T1E1 Spoke slot with H.110 on (H110 primary)");
		  PRTSC(lev,,Buf);
		} else {
		  fpga_set_ref_ext_sel(REF_EXT_H110);	// ...from H.110 controller
                  fpga_set_ref_t1(0);
		  sprintf(Buf,"T1E1 NoRtm slot with H.110 on (H110 client)");
		  PRTSC(lev,,Buf);
		}
	      } else { // *not* T1E1 card  
		fpga_set_ref_ext_sel(REF_EXT_P5);	// ...from P5
		sprintf(Buf,"Serl Spoke slot with H.110 on");
		PRTSC(lev,,Buf);
		//Aricent PR 1234113 fix - Start
                // Only serial cards will have spoke RTMs, so we program the spoke RTM here.
		ctp_i2c_write(Card,Dev,0x3,0x13); // Input from RJ45 port 0
		ctp_i2c_write(Card,Dev,0xe,0x21); // Disable Auto
		// If using E1 BITS set ref to 2.048 Mhz (PR-1234113)
		if(Ctp.Node[0].spoke_rtm_e1_input) {
		  fpga_set_ref_t1(0);
		  fpga_set_pll_div(32);
		} else {
		  fpga_set_ref_t1(1);
		  fpga_set_pll_div(1);	// not used, something benign
		}
                //Aricent PR 1234113 fix - End
	      }
	    }
	  } else { // No Hub card found in node which needs H.110
	    // If no hub RTM is found on a node with the H.110 bus running,
	    // we need to set all serial cards and the first T1E1 card to
	    // free run. Any addtitional T1E1 cards can lock to the 8M
	    // H.110 clock of the master T1E1
	    fpga_set_ref_p5_out_enable(0);	// Input 32K from RTM
            fpga_set_ref_t1(0);
	    if( IS_T1E1(Card) ) {		// Inside if(CTP_2000) block ...
	      if( Card == pSysInfo->Clk.first_t1 ) {
		//--- set to center VCO frequency
		fpga_set_ref_fixed( CTP_PHDET_SPAN >> 1 );
		fpga_set_ref_fixed_period(CTP_PHDET_GEN_SPAN);
		fpga_set_ref_sel(CTP_REF_FIXED);	// Fixed setting
		fpga_set_ref_ext_sel(REF_EXT_P5);	// Ref from P5 (?)
		if( StartUp ) {
		  ctp_card_h110_m( Card );	// Drive H.110 clock (8M)
		  pSysInfo->H110_InUse = 1;	// Declare mastership
		}
		sprintf(Buf,"T1E1 !Hub! slot with H.110 on (H.110 primary)");
		PRTSC(lev,,Buf);
	      } else {
		fpga_set_ref_ext_sel(REF_EXT_H110);	// ...from H.110 controller
		sprintf(Buf,"T1E1 !Hub! slot with H.110 on (H.110 client)");
		PRTSC(lev,,Buf);
	      }
	    } else {
	      //--- set to center VCO frequency
	      fpga_set_ref_fixed( CTP_PHDET_SPAN >> 1 );
	      fpga_set_ref_fixed_period(CTP_PHDET_GEN_SPAN);
	      fpga_set_ref_sel(CTP_REF_FIXED);	// Fixed setting
	      fpga_set_ref_ext_sel(REF_EXT_P5);	// Ref from P5 (?)
	      sprintf(Buf,"Serl !Hub! slot with H.110 on");
	      PRTSC(lev,,Buf);
	    }
	  }
	} else { // *no* H.110 in use
	  if( Card == pSysInfo->Clk.first_scc ) {
	    fpga_set_ref_p4_out_enable(1);	// drive 32K to H.110
	    fpga_set_ref_ext_sel(REF_EXT_P5);	// Ext ref from P5
	    //--- set to center VCO frequency
	    fpga_set_ref_fixed( CTP_PHDET_SPAN >> 1 );
	    fpga_set_ref_fixed_period(CTP_PHDET_GEN_SPAN);
	    fpga_set_ref_sel(CTP_REF_FIXED);	// Fixed setting
	    //---
	    sprintf(Buf,"Primary slot *without* H.110 on");
	    PRTSC(lev,,Buf);
	    if( pSysInfo->Clk.clk_rtm_hub_slot == Card ) {	// If this is a hub card
	      // this is where we will configure the RTM (BITS, TTL, etc...)
	      if(StartUp) ctp_init_hub_rtm( Card ); 
	      ctp_cfg_hub_slot_clk(Card);
	    } else {
	      // PR 701893
	      // The clock RTM is not a hub, but a spoke or passive RTM
	      if( Db.Node[0].ref_out ) {
		fpga_set_ref_p5_out_enable(1);
		PRTC(EVE,Configured serial ext ref port as output);
	      } else {
		fpga_set_ref_p5_out_enable(0);
		PRTC(EVE,Configured serial ext ref port as input);
	      }
	    }
	  } else {
	    sprintf(Buf,"Client  slot *without* H.110 on");
	    PRTSC(lev,,Buf);
	    fpga_set_ref_p4_out_enable(0);	// Input 32K from H.110
	    fpga_set_ref_ext_sel(REF_EXT_P4);	// ...from H.110 32K
            fpga_set_ref_t1(0);
	  }
	}

	fpga_send_fcfg(pSysInfo->Card[Card].BaseSccNum);

      } else {
	//--- Not an scc card
	// Since this function can be called many times, this part that
	// configures the analog voice cards should only be called once at
	// startup (it creates processes for signal lead handling that
	// should only be spawned once. This routine is called at startup
	// (StartUp == 1), so we check for that here.
	// The need_h110_master variable is initialized active if there are
	// no T1E1 cards detected in the node, so the first found analog
	// card will drive the clock. It will then clear the flag so that
	// additional voice cards know to be H.110 slaves.
	if( VOICE(Card) && StartUp) {
	  need_proc_vb_msg = 1;
	  sprintf(Buf,"Voice      slot with H.110 on (H.110 client)");
	  PRTSC(lev,,Buf);

	  ctp_vb_cfg_h110_clks(Card);
	  for(pNum=0;pNum<pSysInfo->Card[Card].PortsOnCard;pNum++) {
	    // Attach port to assigned H110 backplane ts
	    ctp_vb_port_h110_conn(Card,pNum,1,0);
	    // Mute port to start
	    ctp_vb_port_mute(Card,pNum);
	  }
	}
      }
    } else if( (pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150) ) {	// CTP150 
      if( Card == 0 ) {

	//--- This gets rerun when node references are reconfigured (w/startup = 0)
	//TODO: If we are using external reference on gluon_t1e1:
	//      else complain that the rate is not supported!
	//TODO: Manage intercard references.......
	if(CARDTYPE(Card)) {
	  int ref, t1 = 1;
	  PRTC(GEN,Set ext ref sel to ext card ref);
	  fpga_clr_fcfg();
	  fpga_set_ref_ext_sel(REF_EXT_P5);	// Ext ref from P5( ext ref on card).
	  fpga_send_fcfg(pSysInfo->Card[Card].BaseSccNum);

	  if( IS_T1E1(Card) ) {
            int ext_ref_act = 0;
	    //--- Figure out if ext ref is enabled & if so if it is configured
	    //    for T1 or E1. Default to T1 if we can't find ext ref.
	    for(ref=0; ref<CTP_MAX_REFS_PER_NODE; ref++) {
	      if(Db.Node[Card].ref[ref].Port == CTP_REF_EXTERNAL){
		  if(Db.Node[Card].ref[ref].Div == 64) t1 = 0;	// Is E1!!
		  ext_ref_act = 1;
	      }
	    }
	    // if speed = 1544 cfg Dallas for T1
	    // if speed = 2048 cfg Dallas for E1
	    ctp_set_ex_ref_t1e1_rate( Card, t1, ext_ref_act);
	    if( t1 ) { 
	      PRTC(EVE,Configured Dallas on ext ref for T1);
	    } else {
	      PRTC(EVE,Configured Dallas on ext ref for E1);
	    }
	  } 
	  else if( IS_SER(Card) ) {
	    fpga_clr_fcfg();
	    if( Db.Node[0].ref_out ) {
	      fpga_set_ref_p5_out_enable(1);
	      PRTC(EVE,Configured serial ext ref port as output);
	    } else {
	      fpga_set_ref_p5_out_enable(0);
	      PRTC(EVE,Configured serial ext ref port as input);
	    }
	    fpga_send_fcfg(pSysInfo->Card[Card].BaseSccNum);
	  }
	}
      }
    } 
  }

  if( need_proc_vb_msg ) {
    int tmp;
    //--- Open msg queue to board
    PRT(DBG,Starting ctp_proc_vb_msg);
    vbosCreateTask("processVBMsg", 0, 0, 0x8000,
	(VBFUNCPTR)ctp_proc_vb_msg, &tmp);
    need_proc_vb_msg = 0;
  }

  //dump_clk_reg_cfg();
}


