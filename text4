void ctp_vc_proc_tx_sigs(int bNum, int sNum, u8 sigs, u8 hChan)
{
  CTP_BNDL_STATE * pBndlSt = &Ctp.Bndl[bNum];
  int Card=0 ;	// Must be VCOMP bundle!
  int pNum=0 ;	// Must be VCOMP bundle!
  int Chan=0 ;	// Must be VCOMP bundle!
  char PrtStr[80];
  int tsigs = (int)sigs;
  FUNC_PRT(ctp_vc_proc_tx_sigs, PF_VSIG, -1);
 
  // Aricent PR-947222 Start
  if( CTP_BNDL_TYPE_WP == Db.Bndl[bNum].Type ) {
   Card = util_bndl_src_card( 0, &Db.Bndl[bNum]);
   pNum = GetBndlPort(bNum, hChan); //Aricent PR-1017820
  } else {
   // Aricent PR-947222 End
   Card = pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Card ;	// Must be VCOMP bundle!
   pNum = pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].pNum ;	// Must be VCOMP bundle!
   Chan = pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Chan ;	// Must be VCOMP bundle!
  }
  PRTVB(GN3,ctp_vc_proc_tx_sigs with sigs, tsigs);
  //--- Figure out if we need change output based on incoming signals....
  switch (CARDTYPE(Card) ) {
    case T1CARD:
      //--- If changed, set out sigs
      if(pBndlSt->Bndl.vc_bndl.alarmStatus) {
      // In alarm status we don't set the signaling  //
      } else if( VC_SIGS_OUT(Card,pNum,Chan) != sigs ) {
	u8 old_sigs = VC_SIGS_OUT(Card,pNum,Chan);
	u8 old_rx_sigs, old_tx_sigs, new_rx_sigs, new_tx_sigs;
	old_rx_sigs = VC_SIGS_IN(Card,pNum,Chan);
	old_tx_sigs = VC_SIGS_OUT(Card,pNum,Chan);
	sprintf(PrtStr,"Chan %d old sigs 0x%x new 0x%x.\n",Chan,old_sigs,sigs);
	PRTSP(GN2,Tx Sig ch req on,PrtStr);
	pVcSigs->Card[Card].Port[pNum].Chan[Chan] =
	  ((sigs & 0xf) << 4) | (pVcSigs->Card[Card].Port[pNum].Chan[Chan] & 0xf);
	ctp_t1_port_cfg_sigs(Card,pNum,Chan,sigs);
	new_rx_sigs = VC_SIGS_IN(Card,pNum,Chan);
	new_tx_sigs = VC_SIGS_OUT(Card,pNum,Chan);
	sprintf(PrtStr,"Chan %d ToNet: 0x%1x -> 0x%1x FrmNet: 0x%1x -> 0x%1x.\n",
	    Chan, old_tx_sigs, new_tx_sigs, old_rx_sigs, new_rx_sigs);
	PRTSP(EVE,T1E1 Tx Sig Ch,PrtStr);
      } else {
	u8 old_sigs = VC_SIGS_OUT(Card,pNum,Chan);
	sprintf(PrtStr,"Chan %d old sigs 0x%x new 0x%x.\n",Chan,old_sigs,sigs);
	PRTSP(GN3,NO Tx sig ch req on,PrtStr);
      }
      break;
    case EMCARD:
      if( VC_SIGS_OUT(Card,pNum,Chan) != sigs ) {
	u8 old_sigs = VC_SIGS_OUT(Card,pNum,Chan);
	sprintf(PrtStr,"old sigs 0x%x new 0x%x.\n",old_sigs,sigs);
	PRTSP(GN2,Sig ch req,PrtStr);
	if( ((sigs & 0xc) == 0x8) ||
	    ((sigs & 0xc) == 0x4) ) {
	  PRTU8P(MIN,Do not know how to process signaling passed, sigs);
	  break;
	} else {
	  //--- Save the state
	  pVcSigs->Card[Card].Port[pNum].Chan[0] =
	    ((sigs & 0xf) <<4) | (pVcSigs->Card[Card].Port[pNum].Chan[0] & 0xf);
	  PRTU8P(GN1,Signaling saved as,pVcSigs->Card[Card].Port[pNum].Chan[0]);
	  ctp_vb_port_cfg_sigs( Card, pNum, sigs, bNum, sNum );
	}
      } else {
	u8 old_sigs = VC_SIGS_OUT(Card,pNum,Chan);
	sprintf(PrtStr,"old sigs 0x%x new 0x%x.\n",old_sigs,sigs);
	PRTSP(GN1,NO Tx sig ch req,PrtStr);
      }
      break;
    case FXOCRD:
      {
	int loopStart = GROUND_START(Card,pNum) ? 0 : 1;

	if( (sigs & 0xc) == 0x8 ) {
	  PRTVP(MIN,Do not know how to process Tx signaling passed, tsigs);
	  break;
	}

	if( loopStart ) {
	  // Mike - PR 1597669 fix Start
	  u8 event = CTP_VP_EVENT_SIG_CHG;
	  u8 event_val = sigs;
	  voice_state_machine((u8)bNum,(u8)Card,(u8)pNum,(u8)event,(u8)event_val,(u8)sNum);
	  // Mike - PR 1597669 fix End
	} else { //--- Ground start
	  int OldAB     = ((VC_SIGS_OUT(Card,pNum,0) >> 2) & 0x3);
	  int NewAB     = ((sigs >> 2) & 0x3);
	  u8 OldRxSigs  = VC_SIGS_IN(Card,pNum,0);
	  if( OldAB != NewAB ) {
	    int change = (ctp_vb_port_cfg_sigs( Card, pNum, sigs, bNum, sNum ) == SUCCESS) ? 1 : 0;
	    PRTVP(GEN,Ground start sig change old, OldAB);
	    PRTVP(GEN,Ground start sig change new, NewAB);
	    if( change ) {
	      u8 old_rx_sigs, old_tx_sigs, new_rx_sigs, new_tx_sigs;
	      old_rx_sigs = VC_SIGS_IN(Card,pNum,0);
	      old_tx_sigs = VC_SIGS_OUT(Card,pNum,0);
	      //--- Save the state
	      pVcSigs->Card[Card].Port[pNum].Chan[0] = (NewAB << 6) | 	// Move to Tx AB location
		(NewAB << 4) |	// Reproduce in Tx CD
		(OldRxSigs & 0xf); // Save old rx signaling
	      PRTU8P(GN1,Signaling saved as,pVcSigs->Card[Card].Port[pNum].Chan[0]);
	      if( (NewAB == 0x3) && (OldAB == 0x1) ) {
		int OutSigs = VC_SIGS_OUT(Card,pNum,0);
		//---
		PRTP(GN2,Sending sig change OAM for gs ring stop);
		pVcSigs->Card[Card].Port[pNum].Chan[0] =  (OutSigs<<4) | 0x5;
               // Aricent PR-947222 Start 
               if( CTP_BNDL_TYPE_WP == Db.Bndl[bNum].Type )
                ctp_set_vc_sig(bNum, Card, pNum, 0);
               // Aricent PR-947222 End
	       else ctp_vc_send_sig_ch_oam( bNum, Card, pNum, 0, sNum);	//XXX Needed?????
	      }
	      new_rx_sigs = VC_SIGS_IN(Card,pNum,0);
	      new_tx_sigs = VC_SIGS_OUT(Card,pNum,0);
	      sprintf(PrtStr,"ToNet: 0x%1x -> 0x%1x FrmNet: 0x%1x -> 0x%1x.\n",
		  old_tx_sigs, new_tx_sigs, old_rx_sigs, new_rx_sigs);
	      PRTSP(EVE,Groundstart Sig Ch,PrtStr);
	    }
	  }
	}	// end: ground start
      }
      break;
    case FXSCRD:
      {
	int loopStart = GROUND_START(Card,pNum) ? 0 : 1;

	if( (sigs & 0xc) == 0x8 ) {
	  PRTVP(MIN,Do not know how to process signaling passed, tsigs);
	  break;
	}

	if( loopStart ) {
	  u8  new_a_bit = sigs & 0x8;
	  u8  new_b_bit = sigs & 0x4;
	  u8  old_b_bit = VC_SIGS_OUT(Card,pNum,0) & 0x4;
	  u8 old_rx_sigs, old_tx_sigs, new_rx_sigs, new_tx_sigs;
	  old_rx_sigs = VC_SIGS_IN(Card,pNum,0);
	  old_tx_sigs = VC_SIGS_OUT(Card,pNum,0);
	  { // Mike - PR 1597669 fix Start
	    u8 event = CTP_VP_EVENT_SIG_CHG;
	    u8 event_val = sigs;
	    voice_state_machine((u8)bNum,(u8)Card,(u8)pNum,(u8)event,(u8)event_val,(u8)sNum);
	  } // Mike - PR 1597669 fix End
	} else {	//--- Ground start
	  int OldAB     = ((VC_SIGS_OUT(Card,pNum,0) >> 2) & 0x3);
	  int NewAB     = ((sigs >> 2) & 0x3);
	  u8 OldRxSigs  = VC_SIGS_IN(Card,pNum,0);
	  if( OldAB != NewAB ) {
	    int change = (ctp_vb_port_cfg_sigs( Card, pNum, sigs, bNum, sNum ) == SUCCESS) ? 1 : 0;
	    PRTVP(GEN,Ground start sig change old, OldAB);
	    PRTVP(GEN,Ground start sig change new, NewAB);
	    if( change ) {
	      //--- Save the state
	      pVcSigs->Card[Card].Port[pNum].Chan[0] = (NewAB << 6) | 	// Move to Tx AB location
		(NewAB << 4) |	// Reproduce in Tx CD
		(OldRxSigs & 0xf); // Save old rx signaling
	      PRTU8P(GN1,Signaling saved as,pVcSigs->Card[Card].Port[pNum].Chan[0]);
	      if( (NewAB == 0x3) && (OldAB == 0x1) ) {
		int OutSigs = VC_SIGS_OUT(Card,pNum,0);
		//---
		PRTP(GEN,Sending sig change OAM for gs onHook);
		pVcSigs->Card[Card].Port[pNum].Chan[0] =  (OutSigs<<4) | 0x5;
                // Aricent PR-947222 Start 
                if( CTP_BNDL_TYPE_WP == Db.Bndl[bNum].Type )
                 ctp_set_vc_sig(bNum, Card, pNum, 0);
                // Aricent PR-947222 End
		else ctp_vc_send_sig_ch_oam( bNum, Card, pNum, 0, sNum);
	      }
	    }
	  }
	}
      }
      break;
    default:
      PRTP(MIN,Called to process TX sigs on unsupported HW);
      break;
  }
}

void ctp_vc_set_t1e1_alarm(int bNum, int alarm) 
{
    CTP_BNDL_STATE * pBndlSt = &Ctp.Bndl[bNum];
    int Card  = pBndlSt->Bndl.vc_bndl.StSrcInfo[0].Card;
    int pNum  = pBndlSt->Bndl.vc_bndl.StSrcInfo[0].pNum;
    char pBuf[80];
    FUNC_PRT(ctp_vc_set_t1e1_alarm, PF_VSIG, -1);
    if( IS_T1E1_2000(Card)) {
      char SccBuf[40];
      CTP_VC_SIG_PORT_STATE port_sigs;
     //--- Copy port sigs from shared memory
      memcpy( &port_sigs,
	      &pVcSigs->Card[Card].Port[pNum],
	      sizeof(CTP_VC_SIG_PORT_STATE));
      sprintf(pBuf, "alarm %d, card %d, port %d \n", alarm, Card, pNum);
      PRTS(EVE, , pBuf);
      sprintf(SccBuf,"scc%d",Ctp.Card[Card].Port[pNum].SccNum);
      if( alarm ) {
	int sn=0;
	for( sn=0; sn<CTP_MAX_CHAN_PER_VCOMP; sn++) {
	  if(  pBndlSt->Bndl.vc_bndl.StSrcInfo[sn].Used ) {
	    //--- Set all channels in bundle to 0xff.
	    int ch = pBndlSt->Bndl.vc_bndl.StSrcInfo[sn].Chan;
	    port_sigs.Chan[ch]= 0xff;
	  }
	}
        ctp_enable_Dallas_idle(bNum, 2);
      } else ctp_enable_Dallas_idle(bNum, 0);
      ioc_priv(SccBuf, SCC_SET_T1_SIGS, &port_sigs);  
   }
}

void ctp_proc_msg_rdnt_rem_oam(CTP_Q_MSG * pMsg)
{
  CTP_Q_OAM_MSG * pRxMsg = (CTP_Q_OAM_MSG *)pMsg;
  CTP_PORT_DBASE	*pDbP;
  u32 MsgRemCard, MsgRemPort, MsgRemCardPort, MsgRemPortActive;
  u32 MsgLocCard, MsgLocPort, MsgLocCardPort;
  u32 RemCard, RemPort;
  char	PrtBuf[150];
  FUNC_PRT(ctp_proc_msg_rdnt_rem_oam, PF_IPC, -1);

  MsgLocCardPort = pRxMsg->CtpMsg.msg.RemRdntOam.LocCardPort;
  MsgRemCardPort = pRxMsg->CtpMsg.msg.RemRdntOam.RemCardPort;
  MsgRemPortActive = pRxMsg->CtpMsg.msg.RemRdntOam.Active;

  getMaskVal(&MsgLocCardPort,16,CFG_RDNT_CARD_MASK,&MsgLocCard);
  getMaskVal(&MsgLocCardPort,16,CFG_RDNT_PORT_MASK,&MsgLocPort);
  getMaskVal(&MsgRemCardPort,16,CFG_RDNT_CARD_MASK,&MsgRemCard);
  getMaskVal(&MsgRemCardPort,16,CFG_RDNT_PORT_MASK,&MsgRemPort);

  PRTV(GN3,ctp_proc_msg_rdnt_rem_oam for CardPort, MsgRemCardPort);

  pDbP = (CTP_PORT_DBASE *)&Db.Card[MsgRemCard].Port[MsgRemPort];

  if( pDbP->RdntConfig & CFG_RDNT_MODE_MASK ) {
    if( pDbP->RdntConfig & CFG_RDNT_FLAG_SW_LINK ) {
      getMaskVal(&pDbP->RdntPort,16,CFG_RDNT_CARD_MASK,&RemCard);
      getMaskVal(&pDbP->RdntPort,16,CFG_RDNT_PORT_MASK,&RemPort);
      if( (MsgLocCard != RemCard) || (MsgLocPort != RemPort) ) {
	PRTV(MIN,Rcvd Rdnt OAM from link partner - port mismatch, MsgRemCardPort);
      } else {
	u32 temp;
	CTP_PORT_INT_STATE	*pPortIntSt;
	CTP_PORT_STATE		*pPortSt;
	pPortIntSt = (CTP_PORT_INT_STATE *)&Ctp.Card[MsgRemCard].PortInt[MsgRemPort];
	pPortSt = (CTP_PORT_STATE *)&Ctp.Card[MsgRemCard].Port[MsgRemPort];
	if( MsgRemPortActive ) { pPortSt->RdntActiveCnt = 8; } 
	else {                   pPortSt->RdntActiveCnt = 4; }
	temp = pPortSt->RdntActiveCnt;
	PRTV(GN3,Rcvd Rdnt OAM from link partner - Cnt:, temp);
      }
    } else {
      PRTV(MIN,Rcvd Rdnt OAM from link partner - local not S/W link type, MsgRemCardPort);
    }
  } else {
    PRTV(MIN,Rcvd Rdnt OAM from link partner - local not redundant, MsgRemCardPort);
  }
}

void ctp_vc_proc_msg_rem_oam(CTP_Q_MSG * pMsg)
{
  CTP_Q_VC_OAM_MSG * pAllMsg = (CTP_Q_VC_OAM_MSG *)pMsg;
  int locCid = pAllMsg->CtpMsg.msg.RemVcOam.cid;
  int bNum;
  char	PrtBuf[150];
  FUNC_PRT(ctp_vc_proc_msg_rem_oam, PF_VSIG, -1);

  PRTDV(GN2,ctp_vc_proc_msg_rem_oam function enter for local cid, locCid);

  //--- bundle checks:
  bNum = pSysInfo->LocCid[locCid].bNum;
  if( ((bNum >=0) && (bNum < CTP_MAX_BNDLS)) &&			// Valid bNum
      ((Ctp.Bndl[bNum].Type == CTP_BNDL_TYPE_VC)) && 		// VCOMP bundle
      (Ctp.Bndl[bNum].State == CTP_PORT_STATE_RUNNING) &&       // Running
      (Ctp.Bndl[bNum].Bndl.vc_bndl.oam )) {			// OAM signaling enabled
    CTP_BNDL_STATE * pBndlSt = &Ctp.Bndl[bNum];

    PRTB(GN2,Processing CTPMSGTYPE_REM_VC_OAM for VCOMP bundle);

    if( pAllMsg->CtpMsg.msg.RemVcOam.type == CTP_VC_OAM_TYPE_ALL ) {
      int sNum;
      int numSrc = pAllMsg->CtpMsg.msg.RemVcOam.numVCh;
      int Card  = pBndlSt->Bndl.vc_bndl.StSrcInfo[0].Card;
      //--- Signaling OAM
      PRTU8B(GN3,VC_OAM num channels, numSrc);

      // Only process signaling if it is enabled...
      if (Ctp.Bndl[bNum].Bndl.vc_bndl.sig) { 
	//--- Check signaling on all channels....
	for( sNum=0; sNum < numSrc; sNum++ ) {
	  if( (sNum < CTP_MAX_CHAN_PER_VCOMP) &&
	      (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Used) ) {
	    u8  sigs = pAllMsg->CtpMsg.msg.RemVcOam.Sigs[sNum] & 0xf;
	    //--- Process the channel
	    if(!pAllMsg->CtpMsg.msg.RemVcOam.alarm) 
  	      ctp_vc_proc_tx_sigs(bNum,sNum,sigs,0); //Aricent PR-1017820
	  } else {
	    break;
	  }
	}
      }
      if(IS_T1E1_2000(Card)){
        int preAlarm = pBndlSt->Bndl.vc_bndl.alarmStatus;
        if(pAllMsg->CtpMsg.msg.RemVcOam.version > 1) {
      //--- Added in version 2 the alarm processing
          if(pAllMsg->CtpMsg.msg.RemVcOam.alarm) 
            pBndlSt->Bndl.vc_bndl.alarmStatus |= CTP_VC_ALRM_STATUS_PORT;
          else  pBndlSt->Bndl.vc_bndl.alarmStatus &= ~CTP_VC_ALRM_STATUS_PORT;
        } 
        if(pBndlSt->Bndl.vc_bndl.alarmStatus & CTP_VC_ALRM_STATUS_NETWORK){
      //--- In network outage condition....
          if(pBndlSt->Bndl.vc_bndl.timeoutCnt++ > NETWORK_ALRM_CLR_TIMEOUT){
        //--- Clear alarm and timeout cnt....
            pBndlSt->Bndl.vc_bndl.alarmStatus &= ~CTP_VC_ALRM_STATUS_NETWORK;
            pBndlSt->Bndl.vc_bndl.timeoutCnt = 0;
          }
        } else 
      //--- Clear timeout cnt....
          pBndlSt->Bndl.vc_bndl.timeoutCnt = 0;
        //--- Any alarm condition change? 
        if(preAlarm) {
          if(!pBndlSt->Bndl.vc_bndl.alarmStatus) {
        //--- Clear alarm
            ctp_vc_set_t1e1_alarm(bNum, 0);
          }
        } else if (pBndlSt->Bndl.vc_bndl.alarmStatus) {
        //--- Set alarm
            ctp_vc_set_t1e1_alarm(bNum, 1);
        }
      }
    } else if( pAllMsg->CtpMsg.msg.RemVcOam.type == CTP_VC_OAM_TYPE_ALRM ) {
      //--- Deal with alarm change....
      CTP_Q_VC_SIG_MSG * pChMsg = (CTP_Q_VC_SIG_MSG *)pMsg;
      int sNum = pChMsg->CtpMsg.msg.RemVcSig.chan;
      int Card  = pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Card;
      int pNum  = pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].pNum;
      if( IS_T1E1_2000(Card) &&
	  (sNum < CTP_MAX_CHAN_PER_VCOMP) &&
	  (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Used) ) {
	int alarm = pChMsg->CtpMsg.msg.RemVcSig.Sigs;
	char SccBuf[40];
	CTP_VC_SIG_PORT_STATE port_sigs;
	//--- Copy port sigs from shared memory
	memcpy( &port_sigs,
	        &pVcSigs->Card[Card].Port[pNum],
		sizeof(CTP_VC_SIG_PORT_STATE));
	sprintf(SccBuf,"scc%d",Ctp.Card[Card].Port[pNum].SccNum);
	if( alarm ) {
	  int sn=0;
	  for( sn=0; sn<CTP_MAX_CHAN_PER_VCOMP; sn++) {
	    if(  pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Used ) {
	      //--- Set all channels in bundle to 0xff.
	      int ch = pBndlSt->Bndl.vc_bndl.StSrcInfo[sn].Chan;
	      port_sigs.Chan[ch]= 0xff;
	    }
	  }
	} else {
	  //--- clear alarm, use sigs already copied to port_sigs
	}
	ioc_priv(SccBuf, SCC_SET_T1_SIGS, &port_sigs);
      }
    } else if( pAllMsg->CtpMsg.msg.RemVcOam.type == CTP_VC_OAM_TYPE_CHNG ) {
      //--- Signaling change OAM
      CTP_Q_VC_SIG_MSG * pChMsg = (CTP_Q_VC_SIG_MSG *)pMsg;
      int sNum = pChMsg->CtpMsg.msg.RemVcSig.chan;
      if( (sNum < CTP_MAX_CHAN_PER_VCOMP) &&
	  (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Used) ) {
	int Card = pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Card;
	int pNum = pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].pNum;
	int Chan = pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Chan;
	u8  sigs = pChMsg->CtpMsg.msg.RemVcSig.Sigs & 0xf;

	sprintf(PrtBuf,"BNDL %d got VC_OAM sig change 0x%x", bNum, sigs);
	PRTSP(GN1,**** ,PrtBuf);

	//--- Process the channel
	ctp_vc_proc_tx_sigs(bNum,sNum,sigs,0); //Aricent PR-1017820

      }
    } else {
      PRTB(MIN,Unknown CTP_VC_OAM_TYPE);
    }
  }	// End of bundle checks passed
}

void ctp_vc_proc_bndl( int bNum )
{
  CTP_BNDL_STATE * pBndlSt = &Ctp.Bndl[bNum];
  CTP_BNDL_DBASE * pBndlDb = &Db.Bndl[bNum]; //Aricent PR-947222
  int sNum = 0, Card, pNum; 
  FUNC_PRT(ctp_vc_proc_bndl, PF_VSIG, -1);

  PRTB(GN3,Processing bundle);

  //--- VComp bundles with FXS/FXO
  while( (sNum < CTP_MAX_CHAN_PER_VCOMP) &&
      ((Db.Bndl[bNum].Type == CTP_BNDL_TYPE_WP)? // Aricent PR-947222
       (pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].Used): // // Aricent PR-947222
      (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Used))) {
   //Aricent Pr-947222 Start
    if( Db.Bndl[bNum].Type == CTP_BNDL_TYPE_WP){
      pNum = pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].pNum;
      Card = pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].Card;
    } // Aricent PR-947222 End
    else {
    pNum = pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].pNum;
    Card = pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Card;
   }
    if( CARDTYPE(Card) == FXOCRD ) {
      int loopStart = GROUND_START(Card,pNum) ? 0 : 1;
      int Ring = (int)RING_ON(Card,pNum);
      PRTU8P(GN3,Processing port with loopStart, loopStart);
      PRTU8P(GN3,Processing port with Ring state, Ring);
      if( Ring  && loopStart ) {
	// Mike - PR 1597669 fix Start
	u8 event = CTP_VP_EVENT_ONE_SEC;
	u8 event_val = 0;
	PRTP(GN2,FXO/loopstart one second processing);
	voice_state_machine((u8)bNum,(u8)Card,(u8)pNum,(u8)event,(u8)event_val,(u8)sNum);
	// Mike - PR 1597669 fix End
      }
    } else if( CARDTYPE(Card) == FXSCRD ) {
      int loopStart = GROUND_START(Card,pNum) ? 0 : 1;
      int Ring = (int)RING_ON(Card,pNum);
      if( loopStart ) {
	if(PLAR_PORT(Card,pNum) ) { // Mike - PR 1597669 fix Start
	  u8 event = CTP_VP_EVENT_ONE_SEC;
	  u8 event_val = 0;
	  PRTP(GN2,FXS/loopstart/PLAR one second processing);
	  voice_state_machine((u8)bNum,(u8)Card,(u8)pNum,(u8)event,(u8)event_val,(u8)sNum);
	} // Mike - PR 1597669 fix End
      }
    }
    sNum++;
  }

  if( pBndlSt->Bndl.vc_bndl.oam ) {
    //--- Send signaling (and/or alarm) OAM
    ctp_vc_send_oam( bNum );
    //--- vc alarm timer processing
    Card = pBndlSt->Bndl.vc_bndl.StSrcInfo[0].Card;
    if(IS_T1E1_2000(Card)){
      if(!(pBndlSt->Bndl.vc_bndl.alarmStatus & CTP_VC_ALRM_STATUS_NETWORK))
        if(pBndlSt->Bndl.vc_bndl.timeoutCnt++ > NETWORK_ALRM_SET_TIMEOUT){
          //--- clear timeoutCnt ..
          pBndlSt->Bndl.vc_bndl.timeoutCnt = 0;
          if(!pBndlSt->Bndl.vc_bndl.alarmStatus){
              ctp_vc_set_t1e1_alarm(bNum, 1);
          }
	  //--- set alarm status 
          pBndlSt->Bndl.vc_bndl.alarmStatus |=  CTP_VC_ALRM_STATUS_NETWORK;
        }
    }
  }
}

