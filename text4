void ctp_t1e1_proc_sigs (int Card) {
  int pid = fork();
  FUNC_PRT(ctp_t1e1_proc_sigs, PF_VSIG, -1);
  if (pid == 0) {
    //--- child- watch over sigs on this card
    char dev_name[80];
    int fd;

    sprintf(dev_name,"/dev/sigdev%d", Card);
    PRTSC(GEN,Opening,dev_name);
    fd = open(dev_name,O_RDONLY);
    if (fd == -1) {
      PRTC(MIN,Problems opening sigdev);
    } else {
      int status;
      char buff[100];
      CTP_Q_MSG		TMsg;

      PRTSC(GEN,Successfully opened, dev_name);

      //--- set static fields in OAM message ---
      TMsg.mtype			= 4;			// reserved and fixed
      TMsg.CtpMsg.MsgType		= CTPMSGTYPE_SIG_CHANGE;

      while (1) {
        status = read(fd, buff, 100);
	if (status>0) {
	  char pbuff[100];
	  int  c,p,ch,s;
	  int n = sscanf(buff,"Card %d port %d chan %d rx sig 0x%x",&c,&p,&ch,&s);
	  PRTSC(GEN,Read, buff);
	  if( n == 4) {
	    sprintf(pbuff,"Card %d port %d chan %d rx sig change to 0x%x",c,p,ch,s);
	    PRTSC(GEN,Got, pbuff);

	    TMsg.CtpMsg.DestTaskQid	= Ctp.Task[CTP_TASK].Qid;
	    TMsg.CtpMsg.OrigTask = c;	// Send card here
	    TMsg.CtpMsg.SubType  = p;	// Send pNum here
	    TMsg.CtpMsg.Ident    = ch;	// Send Chan here!
	    TMsg.CtpMsg.Status   = s;	// Send signaling here
	    ctp_send_msg( &TMsg );
	  }
	} else {
	  PRTSC(MIN,Problems reading,dev_name);
	  exit;
	}
      }
    }


  } else {
    //--- parent
    Ctp.Task[CTP_CARD0_SIG+Card].Pid = pid;
    return;
  }
}

