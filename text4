//-------------------------------------------
// This is the bundle state machine routine, which controls the operation of
// each bundle on the node. It receives events that help it decide what to do
// with the bundle. Here is a list of possible significant events:
// CTP_PORT_EVENT_DB_ACTIVE	- Bundle dbase state set to active
// CTP_PORT_EVENT_DB_DISABLED	- Bundle dbase state set to disabled
// CTP_PORT_EVENT_TIMER		- Received timer message from timer daemon
// TBD Currently only gluon CESoPSN bundle goes through this machine
//-------------------------------------------
#define	PRT_BREASON    util_prt_breason(bNum,pBndlSt->StReason);
#define	NEW_BNDL_STATE(A)  pBndlSt->State = A; \
		      util_prt_bsc(bNum,CurState,pBndlSt->State);
		      
int ctp_bndl_state_machine(int bNum, int Event)
{
  CTP_BNDL_STATE	*pBndlSt = &Ctp.Bndl[bNum];
  CTP_BNDL_CNTRS	*pBndlCntrs = &Ctp.Bndl_cnt[bNum];
  int Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
  int pNum = util_bndl_src_pNum(0, &Db.Bndl[bNum]);
  //Aricent PR 880784 fix - Start
  CTP_PORT_DBASE        *pDbP = &Db.Card[Card].Port[pNum];
  CTP_PORT_STATE        *pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_BNDL_DBASE        *pDbB = &Db.Bndl[bNum];
  double                 TtFreq;
  //Aricent PR 880784 fix - End
  int bType = pDbB->Type;
  u32			 restart_flag = Ctp.Bndl_cnt[bNum].Bndl.ctp.Current.Buffer.restart_flag;
  u32                    Acc, Freq;
  int			 Ret;
  char			 CmdStr[140];
  int			 status;
  int			 CurState = pBndlSt->State;
  short                  AddBun;
  int                    num;// Aricent PR 1356307 fix 
  FUNC_PRT(ctp_bndl_state_machine, PF_BNDL, bNum);

  //--- What we have hot swap, do we have to check for change in
  //    availability & transition to NOT_PRSNT??
  //util_prt_pev(Port,Card,pNum,Event,pPortSt->State);

  switch(pBndlSt->State) {
    //==============================================
    case CTP_PORT_STATE_NOT_CFG: // (DISABLD)
      //-----------------------------
      if( Event == CTP_PORT_EVENT_DB_ACTIVE ) {
        if ((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150) ||
             (pSysInfo->SysType == SYS_TYPE_CTP_2000 )) { // Aricent PR-799637 and PR-947222
           pBndlSt->StReason = ctp_chk_port_cfg(Card, pNum);
           if( pBndlSt->StReason ) {
             NEW_BNDL_STATE(CTP_PORT_STATE_CFG_FAIL);		// ??
             PRT_BREASON;
	   } else if(bType ==  CTP_BNDL_TYPE_WP) {
              if(pDbP->rx_sel != CTP_CLK_SEL_TT || IS_T1E1(Card)) { //Aricent PR 880784 fix
   	         int SatPort = bNum+56;
	         //--- Go right to InSync & wait for driver to go running.
	         PRTB(FNC,CTP processing CESoPSN bundle);
     		 pDbB->Bndl.wp_bndl.cbc_num = free_cbc_devnum(Card, pNum, bNum); //Aricent PR-947222
	         status = ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_UP );
	         if( status == SUCCESS ) {
	           usleep(1000);				// Sleep in usec
	           status = ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_START);
	           if( status == SUCCESS ) {
		      // Aricent PR-947222 Start
                    //Aricent PR 1290128 fix- Start
                    if(pDbB->RemAdCid.Node.Type == CTP_IPV6) {
                       sprintf(CmdStr,
                           "/sbin/ifconfig cbc%d inet6 add ::172.1.%d.100/120",
                           pDbB->Bndl.wp_bndl.cbc_num, SatPort);
                     } else {
                      sprintf(CmdStr,
                        "/sbin/ifconfig cbc%d 172.0.1.%d pointopoint 172.0.1.%d",
                      pDbB->Bndl.wp_bndl.cbc_num, (SatPort + 120), SatPort);
                      }
                      //Aricent PR 1290128 fix -End
		      // Aricent PR-947222 End 
		      Ret = acorn_system(CmdStr);
		      PRTB(GEN,Just did ifconfig cbc ptp);
	  	      NEW_BNDL_STATE(CTP_PORT_STATE_IN_SYNC);		// ??
	           } else {
	              PRTB(MAJ,Problem with driver start);
	              ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_STOP);
	              ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_DOWN);
	              NEW_BNDL_STATE(CTP_PORT_STATE_CFG_FAIL);		// ??
	           }
	        } else {
	           PRTP(MAJ,Problem with driver UP);
	           ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_DOWN);
	           NEW_BNDL_STATE(CTP_PORT_STATE_CFG_FAIL);		// ??
	        }
             } else {
                 //Aricent PR 880784 fix -Start
                 NEW_BNDL_STATE(CTP_PORT_STATE_EVAL);
                 pBndlSt->Bndl.ctp.OutSyncCntr = CTP_EVAL_WAIT_CNT;
                 //Aricent PR 880784 fix - End
             }
          }
         }
      }
      break;
    //==============================================
    case CTP_PORT_STATE_IN_SYNC:
      //-----------------------------
      if(Event == CTP_PORT_EVENT_TIMER) {
           //Aricent PR 880784 fix - Start
           if( ( (pDbP->rt_sel == CTP_CLK_SEL_TT) ||
                   (pDbP->tx_sel == CTP_CLK_SEL_TT) ||
                   (pDbP->st_sel == CTP_CLK_SEL_TT) ||
                   (pDbP->rf_sel == CTP_CLK_SEL_TT) ||
                   (pDbP->rx_sel == CTP_CLK_SEL_TT) ) &&
                 (ctp_qualify_tt(Card, pNum) == FAILURE) ) {
             //--- Send port to TT_FAIL
             ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_STOP );
             ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_DOWN );
             NEW_BNDL_STATE(CTP_PORT_STATE_TT_FAIL);                    // 41
             pBndlSt->Bndl.ctp.OutSyncCntr = CTP_FAIL_RETRY_CNT;
             // Aricent PR 880784 fix - End
           } else if (restart_flag == 0) {
	      // All other ports goto RUNNING when restart_flag is clear
              ctp_wp_h110_intr(bNum, 1); //enabling interrupt Aricent PR-1017820
	      NEW_BNDL_STATE(CTP_PORT_STATE_RUNNING);			// 19
	      // Aricent PR 1356307 fix - Start
              num = trap_number("TRAP_PT_STCHG");
              if (trap_bitmap & (1 << (num - 1))){
                ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_RUNNING);
              }
              // Aricent PR 1356307 fix - End 
	   }
      } else if ( Event == CTP_PORT_EVENT_DB_DISABLED ) {
	    ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_STOP);
	    ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_DOWN);
	    NEW_BNDL_STATE(CTP_PORT_STATE_NOT_CFG);	//Aricent PR-799637
       }
      break;
    //==============================================
    case CTP_PORT_STATE_RUNNING:
      //-----------------------------
      if( Event == CTP_PORT_EVENT_TIMER ) {
           PRTB(FNC,Hit CTP_PORT_EVENT_TIMER in bndl state machine for CESoPSN bndl);
           // Aricent PR 880784 fix - Start
           if( ( (pDbP->rt_sel == CTP_CLK_SEL_TT) ||
                   (pDbP->tx_sel == CTP_CLK_SEL_TT) ||
                   (pDbP->st_sel == CTP_CLK_SEL_TT) ||
                   (pDbP->rf_sel == CTP_CLK_SEL_TT) ||
                   (pDbP->rx_sel == CTP_CLK_SEL_TT) ) && 
                 (ctp_qualify_tt(Card, pNum) == FAILURE) ) {
             //--- Send port to TT_FAIL
             ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_STOP );
             ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_DOWN );
             NEW_BNDL_STATE(CTP_PORT_STATE_TT_FAIL);                    // 41
             pBndlSt->Bndl.ctp.OutSyncCntr = CTP_FAIL_RETRY_CNT;
           } // Aricent PR 880784 fix - End
           else {
	     pBndlSt->Bndl.ctp.OutSyncCntr = 5;
	     if( restart_flag == 1 ) {
	       // check for restart flag & send to InSYNC if it is lit
	       NEW_BNDL_STATE(CTP_PORT_STATE_IN_SYNC);			// 28
	       // Aricent PR 1356307 fix - Start
               num = trap_number("TRAP_PT_STCHG");
               if (trap_bitmap & (1 << (num - 1))){
                 ctp_send_trap(Card,pNum,TRAP_PT_STCHG,CTP_PORT_STATE_IN_SYNC);
               }
              // Aricent PR 1356307 fix - End
	     }
          }
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_DB_DISABLED ) {
           ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_STOP);
	   ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_DOWN);
	NEW_BNDL_STATE(CTP_PORT_STATE_NOT_CFG); // Aricent PR-799637
      }
      break;
    //==============================================
    case CTP_PORT_STATE_CFG_FAIL:
      //-----------------------------
      if( (Event == CTP_PORT_EVENT_TIMER) &&
	  (pBndlSt->Bndl.ctp.OutSyncCntr <= 0) ) {
	pBndlSt->StReason = ctp_chk_port_cfg(Card, pNum);
	if( !pBndlSt->StReason ) {
	    if( ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_UP) == SUCCESS ) {
	      NEW_BNDL_STATE(CTP_PORT_STATE_IN_SYNC);			// 32
	    } else {
	      PRTB(MAJ,Problem with driver UP);
	      ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_DOWN);
	      pBndlSt->Bndl.ctp.OutSyncCntr = CTP_FAIL_RETRY_CNT;
	    }
	} else {
	  PRT_BREASON;
	}
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_DB_DISABLED ) {
	pBndlSt->StReason = CTP_PORT_STATE_REASON_NONE;
	NEW_BNDL_STATE(CTP_PORT_STATE_NOT_CFG);			// 34
      }
      break;
    //==============================================
    //Aricent PR 880784 fix - Start
    case CTP_PORT_STATE_EVAL:
       // ----------------------------
      if( (Event == CTP_PORT_EVENT_TIMER ) && 
          (pBndlSt->Bndl.ctp.OutSyncCntr <= 0)) {
        if( (pPortSt->LocMeasFreqAcc & 0x100) == 0 ) {
            Freq = pPortSt->LocMeasFreq;
            Acc  = pPortSt->LocMeasFreqAcc;
            TtFreq = (double)Freq/((double)Acc*500);
            set_nom_ctr_freq(Card,pNum);
            if( (ctp_qualify_tt(Card, pNum) == SUCCESS) &&
                (ctp_check_netbound_pps(Card, pNum) == SUCCESS)) {
                pDbB->Bndl.wp_bndl.cbc_num = Card*CTP_CBC_CARD_OFFSET + pDbB->Bndl.wp_bndl.srcBundle; //PR 1524860 fix
                status = ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_UP );
                if( status == SUCCESS ) {
                   usleep(1000);
                   status = ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_START);
                   if( status == SUCCESS ) {
                      int SatPort = bNum+56;
                     //Aricent PR 1290128 fix -Start
                     if(pDbB->RemAdCid.Node.Type == CTP_IPV6) {
                        sprintf(CmdStr,
                            "/sbin/ifconfig cbc%d inet6 add ::172.1.%d.100/120",
                            Card*CTP_CBC_CARD_OFFSET + pDbB->Bndl.wp_bndl.srcBundle, SatPort);
                      } else {
                      sprintf(CmdStr,
                         "/sbin/ifconfig cbc%d 172.0.1.%d pointopoint 172.0.1.%d",
                      Card*CTP_CBC_CARD_OFFSET + pDbB->Bndl.wp_bndl.srcBundle, (SatPort + 120), SatPort);     // PR-947222
                      }
                      //Aricent PR 1290128 fix -End
                      Ret = acorn_system(CmdStr);
                      PRTB(GEN,Just did ifconfig cbc ptp);
                      NEW_BNDL_STATE(CTP_PORT_STATE_IN_SYNC);
                   } else {
                      PRTB(MAJ,Problem with driver start);
                      ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_STOP);
                      ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_DOWN);
                      NEW_BNDL_STATE(CTP_PORT_STATE_CFG_FAIL);          // ??
                   }
                } else {
                   PRTP(MAJ,Problem with driver UP);
                   ctp_cfg_cs_bndl(bNum, CTP_PORT_CMD_DOWN);
                   NEW_BNDL_STATE(CTP_PORT_STATE_CFG_FAIL);             // ??
                }
            } else {
               NEW_BNDL_STATE(CTP_PORT_STATE_TT_FAIL);          // 25
               pBndlSt->Bndl.ctp.OutSyncCntr = CTP_FAIL_RETRY_CNT;
            } 
         }
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_DB_DISABLED ) {
        NEW_BNDL_STATE(CTP_PORT_STATE_NOT_CFG);                             // 36
      }
      break;
    //==============================================
    case CTP_PORT_STATE_TT_FAIL:
      //-----------------------------
      if( (Event == CTP_PORT_EVENT_TIMER) &&
          (pBndlSt->Bndl.ctp.OutSyncCntr <= 0) ) {
        NEW_BNDL_STATE(CTP_PORT_STATE_EVAL);                         // 35
        pBndlSt->Bndl.ctp.OutSyncCntr = CTP_EVAL_WAIT_CNT;    // Wait for TT
      }
      //-----------------------------
      else if( Event == CTP_PORT_EVENT_DB_DISABLED ) {
        NEW_BNDL_STATE(CTP_PORT_STATE_NOT_CFG);          	            // 36
      }
      break;
    //==============================================
    //Aricent PR 880784 fix - End
    default:
      PRTVB(MAJ,Bad State,pBndlSt->State);
      NEW_BNDL_STATE(CTP_PORT_STATE_NOT_CFG);
      break;
  }

  if( (Event == CTP_PORT_EVENT_TIMER) && (pSysInfo->SysType != SYS_TYPE_CTP_2000)) {
    // decrement sync loss counter. It triggers events when it reaches 0.
    // Do not let continue it decrementing, however. Freeze it at 0.
    pBndlSt->Bndl.ctp.OutSyncCntr--;
    if( pBndlSt->Bndl.ctp.OutSyncCntr < 0 ) pBndlSt->Bndl.ctp.OutSyncCntr = 0;
  }
  return(SUCCESS);
}

//========================================================================
// This function used to enble/disable Dallas LIU output (for redundancy)
// enable : 1 enable Tx output drive
