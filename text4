int ctp_vc_bndl_act(int bNum,int activate) {
  int dsp_card = Db.Bndl[bNum].Card;	// TODO This is supposed to be the card with the dsp,
  					// but it has never been configured and may be
					// dynamically set in the end!
  char PrtBuf[80];
  int  stat = SUCCESS;
  int  sNum;				// These are for sources of voice channels!
  int  cNum = 0;			// Number of voice channels in bundle
  int	speed, pps;
  // Get the first port from SRC_INFO port list
  int Card = Db.Bndl[bNum].Bndl.vc_bndl.vc_chan[0].SrcInfo.Card;
  int pNum = Db.Bndl[bNum].Bndl.vc_bndl.vc_chan[0].SrcInfo.pNum;
  CTP_BNDL_CNTRS        *pBndlCnt   = &Ctp.Bndl_cnt[bNum];//Aricent PR 704072 
  CTP_BNDL_STATE * pBndlSt = &Ctp.Bndl[bNum];
  CTP_BNDL_DBASE * pBndlDb = &Db.Bndl[bNum];
  int ground_start = 0;
  //Start Aricent PR 721069 - Last counter clear status is dashed out in bundle query
  struct timeval  now;
  //End Aricent PR 721069 - Last counter clear status is dashed out in bundle query
  
  FUNC_PRT(ctp_vc_bndl_act, PF_BNDL, -1);

  if( activate ) {
    if(pBndlDb->Bndl.vc_bndl.PktProtect) {
      if( ctp_request_pps(Card,pNum,2*CTP_VC_BNDL_PPS) ) return;
    }
    else {
      if( ctp_request_pps(Card,pNum,CTP_VC_BNDL_PPS) ) return;
    }
  }
  else {
    if(pBndlSt->State == CTP_PORT_STATE_RUNNING) {
      if(pBndlDb->Bndl.vc_bndl.PktProtect)
        ctp_release_pps(Card, pNum, 2*CTP_VC_BNDL_PPS);
      else
        ctp_release_pps(Card, pNum, CTP_VC_BNDL_PPS);
    }
  }

  if( activate ) {
    CTP_NODE_STORAGE junk;
    int Cid = pBndlDb->RemAdCid.Cid;
    PRTB(MIN,Activating VCOMP bundle);
    // TODO - eventually check all the ports in the bundle
    if( ctp_verify_dbase_and_hw(Card,pNum) ) return(FAILURE);
    //--- Check the CID is unused
    if( (pSysInfo->LocCid[Cid].Card == ~0) &&
	(pSysInfo->LocCid[Cid].pNum == ~0) &&
	(pSysInfo->LocCid[Cid].bNum == ~0) )  {
      //--- Configure & Bring up ports  ???
      sNum = 0;
      pBndlSt->Bndl.vc_bndl.sig = 0;
      pBndlSt->Bndl.vc_bndl.oam = 0;
      if(ctp_cfg_dsp(bNum)!=SUCCESS) {
        pBndlSt->StReason = CTP_PORT_STATE_REASON_DSPFAIL;
        return FAILURE;
      }
      pSysInfo->LocCid[Cid].bNum = bNum;
      while( pBndlDb->Bndl.vc_bndl.vc_chan[sNum].SrcInfo.Used ) {
	int src_Card = pBndlDb->Bndl.vc_bndl.vc_chan[sNum].SrcInfo.Card;
	int src_pNum = pBndlDb->Bndl.vc_bndl.vc_chan[sNum].SrcInfo.pNum;
	int src_Chan = pBndlDb->Bndl.vc_bndl.vc_chan[sNum].SrcInfo.Chan;

	//--- Copy src info into Bundle state
	pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Card = src_Card;
	pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].pNum = src_pNum;
	pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Chan = src_Chan;
	pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Used = 1;

	if( sNum == 0) {
	  //--- Use this as the card/port in LocCid structure...
	  pSysInfo->LocCid[Cid].Card = src_Card;
	  pSysInfo->LocCid[Cid].pNum = src_pNum;
	}
    //Sets the Packet Protection option in vcb driver
    ctp_vb_port_pkt_prot(pBndlSt,pBndlDb->Bndl.vc_bndl.PktProtect,Cid);

	if( VOICE(src_Card) ) {
	  u8 rxGain = Db.Card[src_Card].Port[src_pNum].rxGain;
	  u8 txGain = Db.Card[src_Card].Port[src_pNum].txGain;

	  //--- Set companding
	  switch (pBndlDb->Bndl.vc_bndl.Companding) {
	    case VCB_COMPANDING_ULAW:
	      ctp_vb_cfg_companding(src_Card, src_pNum, CTP_VP_MU_LAW);
	      break;
	    case VCB_COMPANDING_ALAW:
	      ctp_vb_cfg_companding(src_Card, src_pNum, CTP_VP_A_LAW_EVEN);
	      break;
	    default:
	      PRT(MIN,Unsupported companding on voice port);
	      return FAILURE;
	      break;
	  }

	  //--- Set Tx & Rx gain
	  ctp_vb_cfg_gain( src_Card, src_pNum, rxGain, CTPCMDTYPE_PORT_VP_RX_GAIN_CFG);
	  ctp_vb_cfg_gain( src_Card, src_pNum, txGain, CTPCMDTYPE_PORT_VP_TX_GAIN_CFG);

	  if( (CARDTYPE(src_Card) == FXSCRD) ||
	      (CARDTYPE(src_Card) == FXOCRD) ) {
	    //--- Loop/Ground start from Dbase
	    GROUND_START(src_Card,src_pNum) = (Db.Card[src_Card].Port[src_pNum].vp_flags & CFG_VP_FLAG_GND) ? 1 : 0;
	    if(GROUND_START(src_Card,src_pNum)) PRTDVP(GN2,Added ground start port to bundle, bNum);

	    //--- PLAR
	    if( (CARDTYPE(src_Card) == FXSCRD) &&
		(!GROUND_START(src_Card,src_pNum)) &&		//--- PLAR loop start only!
		(Db.Card[src_Card].Port[src_pNum].vp_flags & CFG_VP_FLAG_PLAR) ) {
	      PLAR_PORT(src_Card,src_pNum) = 1;
	    } else {
	      PLAR_PORT(src_Card,src_pNum) = 0;
	    }

	    // Mike - PR 1597669 fix Start
	    // Init state onhook, but after setting PLAR config
	    voice_state_machine((u8)bNum,(u8)Card,(u8)pNum,(u8)CTP_VP_EVENT_ONHOOK,(u8)0,(u8)sNum);
	    // Init net-bound signaling to idle (toggle on/off/on to flush)
	    VC_SIGS_OUT_CLR_A_BIT(Card,pNum);	// On Hook
	    VC_SIGS_OUT_SET_B_BIT(Card,pNum);	// Ring Off
	    send_net_bound_vc_sig_change(Card,pNum,0x00,bNum,sNum);
	    VC_SIGS_OUT_SET_A_BIT(Card,pNum);	// Off Hook
	    send_net_bound_vc_sig_change(Card,pNum,0x00,bNum,sNum);
	    VC_SIGS_OUT_CLR_A_BIT(Card,pNum);	// On Hook
	    send_net_bound_vc_sig_change(Card,pNum,0x00,bNum,sNum);
	    // Mike - PR 1597669 fix End
	  }

	  //--- Get intitial signaling state
	  ctp_vb_port_init_sigs( src_Card, src_pNum, bNum, sNum );

	  if( (pSysInfo->Card[src_Card].Type == FXSCRD) ||
	      (pSysInfo->Card[src_Card].Type == FXOCRD) ) {
	    //--- Configure card for loop/ground start LAST
	    ctp_vb_cfg_start(src_Card,src_pNum);
	  }

	  //--- Bump fxs in case it was grounded & in power failsafe state.
	  if (pSysInfo->Card[src_Card].Type == FXSCRD) ctp_vb_fxs_bump(src_Card, src_pNum);

	  //--- Set OAM signaling state on
	  if(!(pBndlDb->Bndl.vc_bndl.vc_chan[0].flags & CFG_VCC_PM_TAIL)) {
	    pBndlSt->Bndl.vc_bndl.sig = 1;
	    pBndlSt->Bndl.vc_bndl.oam = 1;
	  }
	} else if( IS_T1E1_2000(src_Card) ) {
	  //--- Set OAM signaling state on in any case (needed for alarms)
	  pBndlSt->Bndl.vc_bndl.oam = 1;
	  //--- Now decide if we want to process signaling OAMs also
	  if( (Db.Card[src_Card].Port[src_pNum].DcardCfg1 & T1E1_MSK_E1_CAS) 
	  	&& !(pBndlDb->Bndl.vc_bndl.vc_chan[0].flags & CFG_VCC_PM_TAIL) ) {
  	    pBndlSt->Bndl.vc_bndl.sig = 1;
	  }

	  //--- Set signaling on chan to zero
	  if( Db.Card[src_Card].Port[src_pNum].DcardCfg1 & T1E1_MSK_E1 ) {
	    if( (src_Chan != 0) && (src_Chan != 16) ) {
	      ctp_t1_port_cfg_sigs( src_Card, src_pNum, src_Chan, 0x0);
	    }
	  } else if( src_Chan < 24 ) {
	    ctp_t1_port_cfg_sigs( src_Card, src_pNum, src_Chan, 0x0);
	  }
	} else {
	  if( !IS_T1E1_2000(src_Card) ) { PRTP(MIN,Unsupported source card type); }
	}

	sNum++;
      }

      PRTU8P(DBG,Before opening socket sigs,pVcSigs->Card[Card].Port[pNum].Chan[0]);
      if( pBndlSt->Bndl.vc_bndl.oam ) {
        int flag=0;
	//--- Open VC_OAM socket, no VIPs...
	memcpy(&pBndlSt->Conn.Node, &pBndlDb->RemAdCid.Node, sizeof(CTP_NODE_STORAGE));
	/* If it is hairpinned(destination address is 172.0.3.x), then send oam to itself */
	if((pBndlSt->Conn.Node.v4 & 0xffffff00) == 0xac000300) {
          pBndlSt->Conn.Node.v4 = 0x7f000001;
          PRTP(MIN, Signal OAM sent to self);
        }
        if(pBndlSt->Conn.Node.Type == CTP_IPV6) flag |= CON_FLAG_USE_IPV6;
        pBndlSt->Conn.Tos = pBndlDb->oam_svc_type;
	if( ctp_con_rem_node(&pBndlSt->Conn, flag, junk) ) PRTB(MIN,ERROR opening socket);
      }
      PRTU8P(DBG,After opening socket sigs,pVcSigs->Card[Card].Port[pNum].Chan[0]);

      // Set port mirroring
      if(pBndlDb->port_mirror_rx.numTail) {
        ctp_pm_tail_cfg(bNum, 0, 1, 1);
      }
      if (pBndlDb->port_mirror_tx.numTail) {
        ctp_pm_tail_cfg(bNum, 0, 1, 0);
      }
      //--- Activate
      if( stat == FAILURE ) {
	//--- Clean up
	ctp_release_bw(Card, pNum);	// failure, so release checked out BW
      } else {
	//--- Setup bundle state
	pBndlSt->State = CTP_PORT_STATE_RUNNING;	// Send directly to running!
	pBndlSt->Type  = CTP_BNDL_TYPE_VC;
	memcpy(&pBndlSt->RemAdCid, &pBndlDb->RemAdCid, sizeof(CTP_NC) );
	pBndlSt->TicksPerPkt = 0x8000; // The unit is already milliseconds and the clock tick is 32.768K.
        pBndlSt->Bndl.vc_bndl.alarmStatus = 0;
        pBndlSt->Bndl.vc_bndl.timeoutCnt = 0;
    //Start Aricent PR 721069 - Last counter clear status is dashed out in bundle query
    //Clear Bundle timer counter
    gettimeofday(&now,NULL);
    pBndlCnt->Bndl.vc_cntrs.TimeLastClr = now.tv_sec;
    //End Aricent PR 721069 - Last counter clear status is dashed out in bundle query
      }
    } else {
      stat = FAILURE;
      PRTDVB(MIN,Problems bringing up bundle - CID in use, Cid);
      ctp_release_bw(Card, pNum);	// failure, so release checked out BW
    }
  } else {
    if( pSysInfo->LocCid[pBndlSt->RemAdCid.Cid].bNum != bNum ) {
      PRT(DBG,Do not clear out loccid info - belongs to another bundle);
    } else if( pSysInfo->LocCid[pBndlSt->RemAdCid.Cid].bNum == ~0 ) {
      PRT(DBG,Do not clear out loccid info - already clear);	// ctp_verify_dbase_and_hw failed??
    } else {
      PRTB(MIN,Disabling VCOMP bundle);
      PRTU8B(DBG,Clear out loccid info for CID,pBndlSt->RemAdCid.Cid);
      //--- Remove CID from SysInfo
      pSysInfo->LocCid[pBndlSt->RemAdCid.Cid].Card = ~0;
      pSysInfo->LocCid[pBndlSt->RemAdCid.Cid].pNum = ~0;
      pSysInfo->LocCid[pBndlSt->RemAdCid.Cid].bNum = ~0;

      if( pBndlSt->Bndl.vc_bndl.oam ) {
	//--- Close socket for OAM/Signaling ???
	ctp_discon_rem_node(&pBndlSt->Conn);
      }

      //--- If voice ports, mute (ie minimize gains)
      if( VOICE(Card) ) {
	sNum = 0;
	while( pBndlDb->Bndl.vc_bndl.vc_chan[sNum].SrcInfo.Used ) {
	  int src_Card = pBndlDb->Bndl.vc_bndl.vc_chan[sNum].SrcInfo.Card;
	  int src_pNum = pBndlDb->Bndl.vc_bndl.vc_chan[sNum].SrcInfo.pNum;
	  ctp_vb_port_mute(src_Card, src_pNum);
	  sNum++;
	}
      }
 
     //Aricent PR 704072 start
      ctp_get_dsp_bndl_cntrs(bNum, pBndlCnt, 1);
      memset(&Ctp.Bndl_cnt[bNum].Bndl.vc_cntrs,0,sizeof(CTP_BNDL_CNTRS));
    //Aricent PR 704072 End
      //--- Disable T1E1 ports???

      //--- release dsp resource ???
      ctp_delete_dsp(bNum);
      //--- Clear bundle state
      pBndlSt->State = CTP_PORT_STATE_NOT_CFG;
      pBndlSt->Type  = CTP_BNDL_TYPE_NONE;
      bzero(&pBndlSt->RemAdCid, sizeof(CTP_NC));
      bzero(&pBndlSt->Bndl.vc_bndl.StSrcInfo[0], CTP_MAX_CHAN_PER_VCOMP*sizeof(CTP_ST_SRC_INFO));
      bzero(&Ctp.Bndl[bNum], sizeof(CTP_BNDL_STATE)); //Aricent PR-996102 
      pBndlSt->Bndl.vc_bndl.numVCh = 0;
      // Set port mirroring
      if(pBndlDb->port_mirror_rx.numTail) {
	ctp_pm_tail_cfg(bNum, 0, 0, 1);
      }
      if (pBndlDb->port_mirror_tx.numTail) {
	ctp_pm_tail_cfg(bNum, 0, 0, 0);
      }
    }
  }
  //--- Manage H.110 connections (all_vcomp vs flex vcomp)
  ctp_vc_bndl_h110_conn(bNum, activate);
  return(stat);
}

// Aricent PR-947222 Start
int cesopsn_h110_cfg(int Card, int pNum, int bNum)
{
 CTP_BNDL_STATE * pBndlSt = &Ctp.Bndl[bNum];
 CTP_BNDL_DBASE * pBndlDb = &Db.Bndl[bNum];
 CTP_PORT_DBASE * pDbP = &Db.Card[Card].Port[pNum];
 int sNum=0;
 FUNC_PRT(cesopsn_h110_cfg, PF_BNDL, -1);
 while( pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].Used ) {
  int src_Card = pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].Card;
  int src_pNum = pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].pNum;
  int src_Chan = pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].Chan;

  if( VOICE(src_Card) ) {
   u8 rxGain = Db.Card[src_Card].Port[src_pNum].rxGain;
   u8 txGain = Db.Card[src_Card].Port[src_pNum].txGain;
   //--- Set companding
   switch (pDbP->Companding) {
    case VCB_COMPANDING_ULAW:
     ctp_vb_cfg_companding(src_Card, src_pNum, CTP_VP_MU_LAW);
     break;
    case VCB_COMPANDING_ALAW:
     ctp_vb_cfg_companding(src_Card, src_pNum, CTP_VP_A_LAW_EVEN);
     break;
    default:
     PRT(MIN,Unsupported companding on voice port);
     return FAILURE;
     break;
   }

   // Aricent PR 1137814 and 1142792 Fix
   ctp_vb_cfg_gain( src_Card, src_pNum, rxGain, CTPCMDTYPE_PORT_VP_RX_GAIN_CFG);
   ctp_vb_cfg_gain( src_Card, src_pNum, txGain, CTPCMDTYPE_PORT_VP_TX_GAIN_CFG);
   if( (CARDTYPE(src_Card) == FXSCRD) ||
       (CARDTYPE(src_Card) == FXOCRD) ) {
       //--- Loop/Ground start from Dbase
       GROUND_START(src_Card,src_pNum) = (Db.Card[src_Card].Port[src_pNum].vp_flags & CFG_VP_FLAG_GND) ? 1 : 0;
       if(GROUND_START(src_Card,src_pNum)) PRTDVP(GN2,Added ground start port to bundle, bNum);

   //--- PLAR
    if( (CARDTYPE(src_Card) == FXSCRD) &&
       (!GROUND_START(src_Card,src_pNum)) &&           //--- PLAR loop start only!
       (Db.Card[src_Card].Port[src_pNum].vp_flags & CFG_VP_FLAG_PLAR) ) {
        PLAR_PORT(src_Card,src_pNum) = 1;
    } else {
     PLAR_PORT(src_Card,src_pNum) = 0;
    }
    // Mike - PR 1597669 fix Start
    // Init state onhook, but after setting PLAR config
    voice_state_machine((u8)bNum,(u8)Card,(u8)pNum,(u8)CTP_VP_EVENT_ONHOOK,(u8)0,(u8)sNum);
    // Init net-bound signaling to idle (toggle on/off/on to flush)
    VC_SIGS_OUT_CLR_A_BIT(Card,pNum);	// On Hook
    VC_SIGS_OUT_SET_B_BIT(Card,pNum);	// Ring Off
    send_net_bound_vc_sig_change(Card,pNum,0x00,bNum,sNum);
    VC_SIGS_OUT_SET_A_BIT(Card,pNum);	// Off Hook
    send_net_bound_vc_sig_change(Card,pNum,0x00,bNum,sNum);
    VC_SIGS_OUT_CLR_A_BIT(Card,pNum);	// On Hook
    send_net_bound_vc_sig_change(Card,pNum,0x00,bNum,sNum);
    // Mike - PR 1597669 fix End
   }

  //--- Get intitial signaling state
  ctp_vb_port_init_sigs( src_Card, src_pNum, bNum, sNum );
  if( (pSysInfo->Card[src_Card].Type == FXSCRD) ||
      (pSysInfo->Card[src_Card].Type == FXOCRD) ) {
      //--- Configure card for loop/ground start LAST
      ctp_vb_cfg_start(src_Card,src_pNum);
  }
  //--- Bump fxs in case it was grounded & in power failsafe state.
  if (pSysInfo->Card[src_Card].Type == FXSCRD) ctp_vb_fxs_bump(src_Card, src_pNum);
  pBndlSt->Bndl.ctp.sig=1;
  }else if( IS_T1E1_2000(src_Card) ) {
   pBndlSt->Bndl.ctp.sig=1;
   pBndlSt->Bndl.ctp.oam=1;
   //--- Set signaling on chan to zero
   if( Db.Card[src_Card].Port[src_pNum].DcardCfg1 & T1E1_MSK_E1 ) {
    if( (src_Chan != 0) && (src_Chan != 16) ) {
     ctp_t1_port_cfg_sigs( src_Card, src_pNum, src_Chan, 0x0);
     }
   } else if( src_Chan < 24 ) {
     ctp_t1_port_cfg_sigs( src_Card, src_pNum, src_Chan, 0x0);
   }
 }
  sNum++;
 }
 pBndlSt->Bndl.ctp.alarmStatus = 0;
 pBndlSt->Bndl.ctp.timeoutCnt = 0;

}
// Aricent PR-947222 End

int ctp_wp_bndl_h110_conn(int bNum,int activate) {
  int Card, pNum, sNum;
  int chan_cnt=0;
  int status;
  char SccBuf[10];
  char prtbuf[100];
  struct acrndrv_command ncmd;
  FUNC_PRT(ctp_wp_bndl_h110_conn, PF_MISC, -1);
  // Aricent PR-947222 Start

  memset(&ncmd, 0, sizeof(struct acrndrv_command));
  for(sNum=0; sNum<CTP_MAX_CHAN_PER_VCOMP;sNum++) {
   if(Db.Bndl[bNum].Bndl.wp_bndl.SrcInfo[sNum].Used) {
    Card = Db.Bndl[bNum].Bndl.wp_bndl.SrcInfo[sNum].Card;
    pNum = Db.Bndl[bNum].Bndl.wp_bndl.SrcInfo[sNum].pNum;
    if(VOICE(Card)) {
     ncmd.CmdObj  = Card;
     ncmd.CmdObj2 |= 1 << pNum;
     ncmd.CmdObj4 = 1;
     ncmd.CmdObj6 = ++chan_cnt; // number of channels 
     ncmd.CmdObj5[pNum]=GetH110Chan(bNum, pNum); //Assign H110 Chan according to port
     sprintf(SccBuf, "cbc%d",  Db.Bndl[bNum].Bndl.wp_bndl.cbc_num);
    }
   }
  }
  ncmd.CmdType = SCC_CMD_ZARLINK_PORT_CONN;
  status = ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
  BAILTESTmP(status,Cant IOCTL scc);
  return 0; //Aricent PR-947222
}

