    } else {
      Ctp.Node[Card].VcxoPpmRange = CTP_2000_VCXO_PPM_RANGE;
    }
    PRTU16C(EVE,No Valid VcxoPpmRange value - set to,
	Ctp.Node[Card].VcxoPpmRange);
  }
}

//--------------------------------------------------------------------------
// This routine writes the VCXO PPM Range setting to the EEPROM. It also
// updates the node state so that the PLL routines know about it.
//--------------------------------------------------------------------------
void ctp_set_vcxo_ppm_range ( int Card, u16 PpmValue )
{
  char				SccBuf[40];
  struct acrndrv_command	ncmd;
  FUNC_PRT(ctp_set_vcxo_ppm_range, PF_REF, -1);

  if ((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) {
#ifndef XMC	// Skip write for now
    char cmd_str[200];
    sprintf(cmd_str,"/acorn/bin/smbutil -q -F CTP_PPM_R -c %d -w %d\n",Card, PpmValue);
    PRTSC(GEN,running cmd,cmd_str);
    acorn_system(cmd_str);
#endif // XMC
  } else if( pSysInfo->SysType == SYS_TYPE_CTP_2000 ) {
    if( !((pSysInfo->Card[Card].SubType == HW_SUBTYPE_CTP2000_IM_8P_T1E1_B) ||
         (pSysInfo->Card[Card].SubType == HW_SUBTYPE_CTP2000_IM_8P_B)) ) { //For ctp2k old cards PR-1739392

    //PRTU16C(OFF,Setting VCXO range value,PpmValue);
      sprintf(SccBuf,"scc%d",pSysInfo->Card[Card].BaseSccNum);
      ncmd.CmdType = SCC_CMD_WRITE_EEPROM;
      ncmd.CmdObj = 19;				// Value is a u16 at 18/19
      ncmd.CmdObj2 = PpmValue & 0xff;
      ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);

      usleep(200000);				// wait 200 ms

      ncmd.CmdObj = 18;				// Location 18 holds the MSB
      ncmd.CmdObj2 = (PpmValue >> 8) & 0xff;
      ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
    } else { //For ctp2k-new cards PR-1739392 start
      //PRTU16C(OFF,Setting VCXO range value,PpmValue);
      sprintf(SccBuf,"scc%d",pSysInfo->Card[Card].BaseSccNum);
      ncmd.CmdType = SCC_CMD_WRITE_EEPROM;
      ncmd.CmdObj = CTP_PPM_OFFSET+1;
      ncmd.CmdObj2 = PpmValue & 0xff;
      ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);

      usleep(200000);                           // wait 200 ms

      ncmd.CmdObj = CTP_PPM_OFFSET;
      ncmd.CmdObj2 = (PpmValue >> 8) & 0xff;
      ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
    } //CAP PR-1739392 End
  }


  Ctp.Node[Card].VcxoPpmRange = PpmValue;	// Make available for use
  if( (Ctp.Node[Card].VcxoPpmRange & 0x8000) == 0 ) {
    PRTU16C(EVE,Valid VcxoPpmRange value,Ctp.Node[Card].VcxoPpmRange);
  }
}

//--------------------------------------------------------------------------
int ctp_qualify_tt( int Card, int pNum )
{
  //--- If port is TT frequency is off by more than 6.25%, turn OFF
  //rx_sel so we don't feed bad data into packer.
  int Freq = Ctp.Card[Card].Port[pNum].LocMeasFreq;
  int Acc  = Ctp.Card[Card].Port[pNum].LocMeasFreqAcc;
  int measured_tt = (int)((double)Freq*1000/((double)Acc*500));
  int last_tt  = Ctp.Card[Card].PortInt[pNum].Last_Tt;
  int Port = Card*pSysInfo->Card[Card].PortsOnCard + pNum;     //TODO Fix snmp for card/port
  CTP_PORT_DBASE *pDbP = (CTP_PORT_DBASE *)&Db.Card[Card].Port[pNum];
  double speed;
  int  speed_bps, range_bps, rtn=SUCCESS;
  char PrtBuf[80];
  int num;// Aricent PR 1356307 fix
  FUNC_PRT(ctp_qualify_tt, PF_MISC, -1);

  // Voice card will always have qualified clock
  if( VOICE(Card) ) return SUCCESS;     //Aricent PR-947222 fix

  // T1E1 card does not have a separate "ext clock", but we can use LOS as
  // a way to qualify the presence of an incoming signal (i.e. clock)
  if( IS_T1E1(Card) ) {
    if( (pDbP->CfgFlags & CFG_PORT_FLAG_T1_LOS_CHECK) &&
	(Ctp.Card[Card].Port[pNum].t1State & T1_ALARM_LOS) ) { return FAILURE; }
    return SUCCESS;     
  }

  speed = util_get_exp_tt( &Db.Card[Card].Port[pNum] );
  speed_bps = (int)(speed * 1000);
  range_bps = speed_bps >> 4;	// Speed/16
  PRTFV(FNC,Got synth freq bps, speed_bps);

  if( ! (pDbP->CfgFlags & CFG_PORT_FLAG_NO_TTCHECK) ) {
    // if no HiTTCheck flag then check the freqency low boundary.
    if( ( measured_tt < (speed_bps - range_bps) ) &&
      (!(pDbP->CfgFlags & CFG_PORT_FLAG_HI_TTCHECK))) {	// Too slow
      rtn = FAILURE;
    }
    // check the freqency high boundary.
    else if( measured_tt > (speed_bps + range_bps) )	// Too Fast
      rtn = FAILURE;
    // check if TT clock is there.    
    else if( measured_tt == 0 )				// no clock
      rtn = FAILURE;
  }

  // PR 579006
  if( pDbP->CfgFlags & CFG_PORT_FLAG_TT_SUBSTITUTE ) {
    CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
    CTP_PORT_STATE  *pPortSt = &Ctp.Card[Card].Port[pNum];
    int temp;
    if( rtn == FAILURE ) {
      rtn = SUCCESS;	// Fake out port state machine
      if( pPortIntSt->TtSubstituteActive == NO ) {
	pPortIntSt->TtSubstituteActive = YES;
	// Change net-bound clocks to DDS
	fpga_clr_fcfg();
	fpga_set_rx_fifo_clk( pNum, (u32)CTP_CLK_SEL_DDS);
	fpga_set_rx_scc_clk(  pNum, (u32)CTP_CLK_SEL_DDS);
	fpga_send_fcfg(pPortSt->SccNum);
	PRTP(MIN,TT bad - Substitute DDS for port clocks);
      } else {
	PRTP(GEN,TT still bad - DDS used for port clocks);
      }
    // Incoming TT is good again
    } else {
      if( pPortIntSt->TtSubstituteActive > 0 ) {
	pPortIntSt->TtSubstituteActive = NO;
	// Change net-bound clocks back to normal Port config
        ctp_cfg_port(Card, pNum, CTP_PORT_CMD_CFG_CLKS);
	PRTP(MIN,TT good again - Set port clocks back to original);
      }
    }
  }

  if(rtn == FAILURE) {
    sprintf(PrtBuf,"Measured TT %d, cfg speed %d, range +-%d bps.\n",
	measured_tt, speed_bps, range_bps);
    PRTSP(MIN,TT disqualified-,PrtBuf);
  } else {
    sprintf(PrtBuf,"Measured TT %d, cfg speed %d, max %d bps.\n",
	measured_tt, speed_bps, speed_bps + range_bps);
    PRTSP(GEN,TT qualified-,PrtBuf);
  }

  //---- Check if TT went to zero and, if so, generate snmptrap
  if( (last_tt != 0) && (measured_tt == 0) ) {
   // Aricent PR 1356307 fix - Start
   num = trap_number("TRAP_PT_TT_BAD");
   if (trap_bitmap & (1 << (num - 1))){
     ctp_send_trap(Card, pNum,TRAP_PT_TT_BAD,measured_tt);
   }
   // Aricent PR 1356307 fix - End
  }
  Ctp.Card[Card].PortInt[pNum].Last_Tt = measured_tt;
  return(rtn);
}

//-------------------------------------------------------------------------
// This function check chassis fan/power supply/temperatures for failure
// and sends a trap if a change is status is found.
//-------------------------------------------------------------------------
void ctp_chk_chassis( )
{
  char	CmdStr[150];
  int	fans_ok = 1, ps_ok = 1, temp_ok = 1, is_ctp151 = 255;
  char	PrtBuf[100];
  int   num;  // Aricent PR 1356307 fix
  FUNC_PRT(ctp_chk_chassis, PF_TRAP, -1);

  if( (pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150) ) {	// ctp150
    sprintf(CmdStr, "/acorn/perl/scripts/sensors_pwr_fan.pl -S >/dev/null 2>&1 < /dev/null");
    if( 0 == acorn_system_quiet(CmdStr) ) { is_ctp151 = 0; }
    //--- Fans acorn.2.1.17.1.1
    if( 0 == is_ctp151 ) { //CTP151
      sprintf(CmdStr, "/acorn/perl/scripts/sensors_pwr_fan.pl -f >/dev/null 2>&1 < /dev/null");
    }
    else {
      if( pSysInfo->Chassis.fans_ok ) {
        sprintf(CmdStr, "/acorn/perl/scripts/snmpAcorn.pl -t .%s.%s ",
	    CTP_TRAP_BASE, CTP_TRAP_QRY_FANS);
      } else {	// Use -T to indicate no logging!
        sprintf(CmdStr, "/acorn/perl/scripts/snmpAcorn.pl -T .%s.%s ",
	    CTP_TRAP_BASE, CTP_TRAP_QRY_FANS);
      }
    }
    if( acorn_system_quiet(CmdStr) ) { fans_ok = 0; }
    PRTDV(GN2,Got snmpAcorn -t fans give fans_ok, fans_ok);
    if( (fans_ok != pSysInfo->Chassis.fans_ok) ||
	(!fans_ok && pSysInfo->Chassis.fans_failed_once) ) {
      int wait_for_second_time = 0;

      if( !fans_ok && pSysInfo->Chassis.fans_ok && Ctp.Snmp.TrapAble ) { wait_for_second_time = 1; }

      if( wait_for_second_time ) {
	sprintf(PrtBuf,"Fan status change to %s. Waiting for second consecutive failure to send trap.\n", fans_ok?"OK":"Fault");
	R_PRTS(EVE,,PrtBuf);
	pSysInfo->Chassis.fans_failed_once = 1;
      } else {
	sprintf(PrtBuf,"Fan status change to %s%s.\n", fans_ok?"OK":"Fault",
	    					      Ctp.Snmp.TrapAble?" sending trap":"" );
	R_PRTS(EVE,,PrtBuf);
	if( Ctp.Snmp.TrapAble ) {
	  //--- Trap sent, update SysInfo
          // Aricent PR 1356307 fix - Start
          num = trap_number("TRAP_HW_FAN");
          if (trap_bitmap & (1 << (num - 1))){
            ctp_send_trap( 0,0, TRAP_HW_FAN, fans_ok);
           }
         // Aricent PR 1356307 fix - End
	}
	pSysInfo->Chassis.fans_failed_once = 0;
      }
      pSysInfo->Chassis.fans_ok = fans_ok;
    }

    if( 0 == is_ctp151 ) { //CTP151
      sprintf(CmdStr, "/acorn/perl/scripts/sensors_pwr_fan.pl -p >/dev/null 2>&1 < /dev/null");
    }
    else {
      //--- Power supply acorn.2.1.17.1.1
      if( pSysInfo->Chassis.ps_ok ) {
        sprintf(CmdStr, "/acorn/perl/scripts/snmpAcorn.pl -t .%s.%s",
	    CTP_TRAP_BASE, CTP_TRAP_QRY_PS);
      } else {	// Use -T to indicate no logging!
        sprintf(CmdStr, "/acorn/perl/scripts/snmpAcorn.pl -T .%s.%s",
  	    CTP_TRAP_BASE, CTP_TRAP_QRY_PS);
      }
    }
    if( acorn_system_quiet(CmdStr) ) { ps_ok = 0; }
    PRTDV(GN2,Got snmpAcorn -t ps give ps_ok, ps_ok);
    if( (ps_ok != pSysInfo->Chassis.ps_ok) ||
	(!ps_ok && pSysInfo->Chassis.ps_failed_once) ) {
      int wait_for_second_time = 0;

      if( !ps_ok && pSysInfo->Chassis.ps_ok && Ctp.Snmp.TrapAble ) { wait_for_second_time = 1; }

      if( wait_for_second_time ) {
	sprintf(PrtBuf,"Power supply change to %s. Waiting for second consecutive failure to send trap.\n", ps_ok?"OK":"Fault");
	R_PRTS(EVE,,PrtBuf);
	pSysInfo->Chassis.ps_failed_once = 1;
      } else {
	sprintf(PrtBuf,"Power supply change to %s%s.\n", ps_ok?"OK":"Fault",
	    					      Ctp.Snmp.TrapAble?" sending trap":"" );
	R_PRTS(EVE,,PrtBuf);
	if( Ctp.Snmp.TrapAble ) {
	  //--- Trap sent, update SysInfo
          // Aricent PR 1356307 fix - Start
          num = trap_number("TRAP_HW_PS");
          if (trap_bitmap & (1 << (num - 1))){
            ctp_send_trap( 0,0, TRAP_HW_PS, ps_ok);
          }
         // Aricent PR 1356307 fix - End
	}
	pSysInfo->Chassis.ps_failed_once = 0;
      }
      pSysInfo->Chassis.ps_ok = ps_ok;
    }

    if( 0 == is_ctp151 ) { //CTP151
      sprintf(CmdStr, "/acorn/perl/scripts/sensors_pwr_fan.pl -t >/dev/null 2>&1 < /dev/null");
    }
    else {
      //--- Temperatures acorn.2.1.19.1.1
      if( pSysInfo->Chassis.temp_ok ) {
        sprintf(CmdStr, "/acorn/perl/scripts/snmpAcorn.pl -t .%s.%s",
	    CTP_TRAP_BASE, CTP_TRAP_QRY_TEMP);
      } else {	// Use -T to indicate no logging!
        sprintf(CmdStr, "/acorn/perl/scripts/snmpAcorn.pl -T .%s.%s",
	    CTP_TRAP_BASE, CTP_TRAP_QRY_TEMP);
      }
    }
    if( acorn_system_quiet(CmdStr) ) { temp_ok = 0; }
    PRTDV(GN2,Got snmpAcorn -t temp give temp_ok, temp_ok);
    if( (temp_ok != pSysInfo->Chassis.temp_ok) ||
	(!temp_ok && pSysInfo->Chassis.temp_failed_once) ) {
      int wait_for_second_time = 0;

      if( !temp_ok && pSysInfo->Chassis.temp_ok && Ctp.Snmp.TrapAble ) { wait_for_second_time = 1; }

      if( wait_for_second_time ) {
	sprintf(PrtBuf,"Temperature change to %s. Waiting for second consecutive failure to send trap.\n", temp_ok?"OK":"Fault");
	R_PRTS(EVE,,PrtBuf);
	pSysInfo->Chassis.temp_failed_once = 1;
      } else {
	sprintf(PrtBuf,"Temperature change to %s%s.\n", temp_ok?"OK":"Fault",
	    					      Ctp.Snmp.TrapAble?" sending trap":"" );
	R_PRTS(EVE,,PrtBuf);
	if( Ctp.Snmp.TrapAble ) {
	  //--- Trap sent, update SysInfo
          // Aricent PR 1356307 fix - Start
          num = trap_number("TRAP_HW_TEMP");
          if (trap_bitmap & (1 << (num - 1))){
            ctp_send_trap( 0,0, TRAP_HW_TEMP, temp_ok);
          }
         // Aricent PR 1356307 fix - End
	}
	pSysInfo->Chassis.temp_failed_once = 0;
      }
      pSysInfo->Chassis.temp_ok = temp_ok;
    }
  } else {	// Only degrade/fail pin support on nova!
    unsigned int val;
    int slot;
    if(pSysInfo->Chassis.ipmi_ps_capable) {
      char TstCmd[80];	
      sprintf(TstCmd,"/bin/grep MISSING /tmp/tmp_ipmi");
      PRTS (GN1,Running cmd, TstCmd);
      if( !acorn_system(TstCmd) ) {
        ps_ok = 0;
      };
      if( ps_ok != pSysInfo->Chassis.ipmi_ps_present ) { 
	sprintf(PrtBuf,"Power supply status change to %s%s.\n", ps_ok?"Present":"Missing",
	        Ctp.Snmp.TrapAble?" sending trap":"" );
	R_PRTS(MIN,,PrtBuf);
	if( Ctp.Snmp.TrapAble ) {
	      //--- Trap sent, update SysInfo
           // Aricent PR 1356307 fix - Start
           num = trap_number("TRAP_HW_PS_MISSING");
          if (trap_bitmap & (1 << (num - 1))){
            ctp_send_trap( 0,0, TRAP_HW_PS_MISSING, ps_ok);
          }
          // Aricent PR 1356307 fix - End	  
	}
        pSysInfo->Chassis.ipmi_ps_present = ps_ok;
      }
    }
    //--- Temperatures acorn.2.1.19.1.1
    if( pSysInfo->Chassis.temp_ok ) {
      int c = 0;
      //--- Look to see if any have gone too high
      while( c < CTP_MAX_CARDS ) {
	if( (pSysInfo->Card[c].Type) &&
	    (pSysInfo->Chassis.board_temp[c] > 60) ) {
	  temp_ok = 0;
	}
	c++;
      }
    } else {
      int c = 0;
      //--- Look to see if any have gone too high
      while( c < CTP_MAX_CARDS ) {
	if( (pSysInfo->Card[c].Type) &&
	    (pSysInfo->Chassis.board_temp[c] > 60) ) {
	  temp_ok = 0;
	}
	c++;
      }
    }
    if( (temp_ok != pSysInfo->Chassis.temp_ok) ||
	(!temp_ok && pSysInfo->Chassis.temp_failed_once) ) {
      int wait_for_second_time = 0;

      if( !temp_ok && pSysInfo->Chassis.temp_ok && Ctp.Snmp.TrapAble ) { wait_for_second_time = 1; }

      if( wait_for_second_time ) {
	sprintf(PrtBuf,"Temperature change to %s. Waiting for second consecutive failure to send trap.\n", temp_ok?"OK":"Fault");
	R_PRTS(EVE,,PrtBuf);
	pSysInfo->Chassis.temp_failed_once = 1;
      } else {
	sprintf(PrtBuf,"Temperature change to %s%s.\n", temp_ok?"OK":"Fault",
	    					      Ctp.Snmp.TrapAble?" sending trap":"" );
	R_PRTS(EVE,,PrtBuf);
	if( Ctp.Snmp.TrapAble ) {
	  //--- Trap sent, update SysInfo
           // Aricent PR 1356307 fix - Start
           num = trap_number("TRAP_HW_TEMP");
          if (trap_bitmap & (1 << (num - 1))){
            ctp_send_trap( 0,0, TRAP_HW_TEMP, temp_ok);
          }
         // Aricent PR 1356307 fix - End
	}
	pSysInfo->Chassis.temp_failed_once = 0;
      }
      pSysInfo->Chassis.temp_ok = temp_ok;
    }
  }
}

