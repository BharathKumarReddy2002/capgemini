      nrc.SendNrzPkts	= NO;
      status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      break;
    //============================================================
    case CTP_PORT_CMD_UNBLOCK_RX_PKTS:
      PRTSP(GN2,UNBLOCKING RX PKTS,SccBuf);
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      nrc.SendNrzPkts	= YES;
      status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      break;
    //============================================================
    case CTP_PORT_CMD_PROC_SER_LOOP:
      if(IS_T1E1(Card)) {
	ctp_proc_t1_loop(Card,pNum);
      } else {
        ctp_proc_ser_loop(Card,pNum);
      }
      break;
    //============================================================
    case CTP_PORT_CMD_PROC_BERT:
      if( !PBS(Card,pNum) && !FRAC_T1E1(Card, pNum) ) {
	if(ctp_bndl_type_wp(Card, pNum) || (IS_T1E1_2000(Card)&&(IS_H110(Card,pNum))))
	  ctp_proc_t1_bert( Card, pNum );
	else ctp_proc_bert_cfg( Card, pNum );
      }
      break;
    //============================================================
    case CTP_PORT_CMD_PKT_LOOP_SER:
      //--- ser driver loops pkts back to self ---
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      nrc.nrz_loop 	= YES;
      status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      break;
#endif      
    //============================================================
    default:
      PRTVB(MIN,Unexpected Cmd type,Cmd);
      break;
  }
  return(SUCCESS);
}

