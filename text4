// This function will take a signaling nibble, interpret it, and configure
// the Analog Voice port to do the right thing (Ring, offhook, onhook,
// etc...). This function is not called by new voice_state_machine() func
int ctp_vb_port_cfg_sigs( int Card, int pNum, u8 sigs, int bNum, int sNum)
{
  int status = SUCCESS;
  int loopStart = GROUND_START(Card,pNum) ? 0 : 1;
  char PrtBuf[100];
  int  isigs = (int)sigs;
  FUNC_PRT(ctp_vb_port_cfg_sigs, PF_VSIG, pNum);

  PRTVP(GN1,ctp_vb_port_cfg_sigs with sigs, isigs);
    switch(CARDTYPE(Card)) {
      case (EMCARD):
	//--- Check for allowable signaling
	if( ((sigs & 0xc) != 0xc) && ((sigs & 0xc) != 0x0 ) ) {
	  PRTU8P(MIN,Error signaling not allowed for port, sigs);
	  status = FAILURE;
	} else {
	  UINT_32 MLeadState;
	  UINT_16 ELeadState;
	  if( (sigs&0xc) == 0xc ) { ctp_vb_cmd(Card, pNum, CTP_VB_CMD_EM_OFF_HOOK); }	// E OFFHOOK
	  else                    { ctp_vb_cmd(Card, pNum, CTP_VB_CMD_EM_ON_HOOK); }	// E ONHOOK
	}
	break;
      case (FXSCRD):
	//--- Check for allowable signaling
	if( (sigs & 0xc) == 0x8 ) {
	  PRTU8P(MIN,Error signaling not allowed for port, sigs);
	} else {
	  if( loopStart ) {
#if 1
	    // This should only be called for "cmd port x diag dbg_vc_sig"
	    // additional processing for FXS loopstart when writing signaling to network
	    // We also generate events to the AV state machine.
	    if( (sigs & 0xc) == 0x0 ) {
	      if( !PLAR_PORT(Card,pNum) ||	
		  !RINGBACK_ON(Card,pNum) ) {
		PRTP(GN2,Ring on);
		ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_ON);
		{ // Mike - PR 1597669 fix Start
		  u8 event = CTP_VP_EVENT_RING; 
		  u8 event_val = 1;
		  voice_state_machine((u8)bNum,(u8)Card,(u8)pNum,(u8)event,(u8)event_val,(u8)sNum);
		} // Mike - PR 1597669 fix End
	      }
	    } else if( (sigs & 0xc) == 0x4 ) {
	      PRTP(GN2,Ring off);
	      ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
	      { // Mike - PR 1597669 fix Start
		u8 event = CTP_VP_EVENT_RING;
		u8 event_val = 0;
		voice_state_machine((u8)bNum,(u8)Card,(u8)pNum,(u8)event,(u8)event_val,(u8)sNum);
	      } // Mike - PR 1597669 fix End 
	    } else {	// 0xc!
	      PRTP(GN2,Ring off);
	      ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF); 
	      { // Mike - PR 1597669 fix Start
		u8 event = CTP_VP_EVENT_RING;
		u8 event_val = 0;
		voice_state_machine((u8)bNum,(u8)Card,(u8)pNum,(u8)event,(u8)event_val,(u8)sNum);
	      } // Mike - PR 1597669 fix End
	    }
#endif
	  } else {	// Ground start
	    int OldAB     = ((VC_SIGS_OUT(Card,pNum,0) >> 2) & 0x3);
	    int NewAB     = ((sigs >> 2) & 0x3);
	    //--- Look for allowed transitions:
	    switch(OldAB) {
	      case 0x3:	// Idle
		switch(NewAB) {
		  case 0x1:	// Tip grounded, No AC ringing
		    PRTVP(DBG,Nothing to do with sigs,NewAB);
		    break;
		  case 0x0:	// Tip grounded, AC ringing
		    status = ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_GND_TIP);
		    break;
		  default:
		    status = FAILURE;
		    PRTVP(MIN,Got unsupported gs sig transition from 0x3 to,NewAB);
		    break;
		}
		break;
	      case 0x1:	// Tip grounded, No AC ringing
		switch(NewAB) {
		  case 0x3:	// Idle
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
		    status = ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_GND_START);
		    status = ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_SENSE);
		    //--- Since FXS will not detect event when FXO goes
		    //    on-hook, we need to generate Rx sigs
		    //    and initiate sending of signaling change OAM
		    //    here.
		    pVcSigs->Card[Card].Port[pNum].Chan[0] &= 0xf0;	// Clear Rx sigs
		    pVcSigs->Card[Card].Port[pNum].Chan[0] |= 0x05;	// Set new Rx sigs
		    PRTP(EVE,Just set Rx sigs to 0x5);
		    if( (bNum >= 0) && (bNum < CTP_MAX_BNDLS) &&
			(sNum >= 0) && (sNum < CTP_MAX_CHAN_PER_VCOMP) ) {
	             // Aricent PR-947222 Start
                     if( CTP_BNDL_TYPE_WP == Db.Bndl[bNum].Type ) 
                      ctp_set_vc_sig(bNum, Card, pNum, 0);
	             // Aricent PR-947222 End 
		      else ctp_vc_send_sig_ch_oam( bNum, Card, pNum, 0, sNum);
		    }
		    break;
		  default:
		    status = FAILURE;
		    PRTVP(MIN,Got unsupported gs sig transition from 0x1 to,NewAB);
		    break;
		}
		break;
	      case 0x0:	// Tip grounded, AC ringing
		switch(NewAB) {
		  case 0x1:	// Tip grounded, No AC ringing
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_GND_TIP);
		    status = ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
		    break;
		  case 0x3:	// Idle
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_OFF);
		    status = ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_GND_START);
		    break;
		  default:
		    status = FAILURE;
		    PRTVP(MIN,Got unsupported gs sig transition from 0x0 to,NewAB);
		    break;
		}
		break;
	      default:
		status = FAILURE;
		PRTVP(MIN,Got unsupported old gs signaling, OldAB);
		break;
	    }
	  }
	}
	break;
      case (FXOCRD):
	//--- Check for allowable signaling
	if( (sigs & 0xc) == 0x8 ) {
	  PRTU8P(MIN,Error signaling not allowed for port, sigs);
	} else {
	  if(loopStart) {
#if 1
	    // This should only be called for "cmd port x diag dbg_vc_sig"
	    // additional processing for FXO loopstart when writing signaling to network
	    if( (sigs & 0xc) == 0x4 ) {
	      PRTP(EVE,Putting port on hook);
	      ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_ON_HOOK);
	    } else {	// 0xc !
	      PRTP(EVE,Taking port off hook);
	      ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_OFF_HOOK);
	    }
#endif
	  } else {	// Ground start
	    int OldAB     = ((VC_SIGS_OUT(Card,pNum,0) >> 2) & 0x3);
	    int NewAB     = ((sigs >> 2) & 0x3);
	    //--- Look for allowed transitions:
	    switch(OldAB) {
	      case 0x3:	// OffHook
		switch(NewAB) {
		  case 0x1:	// Idle
		    if(TIP_GROUND(Card,pNum)) {
		      PRTP(GEN,Going to idle with tip grounded);
		      ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_ON_HOOK);
		      status = ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_TIP_SENSE);
		    } else {
		      PRTP(GEN,Going to idle with tip ungrounded);
		      ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_LOOP_START);
		      ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_ON_HOOK);
		      status = ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_TIP_SENSE);
		    }
		    break;
		  default:
		    status = FAILURE;
		    PRTVP(MIN,Got unsupported gs sig transition from 0x3 to,NewAB);
		    break;
		}
		break;
	      case 0x1:	// Idle
		switch(NewAB) {
		  case 0x3:	// OffHook
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_RING_SENSE_OFF);
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_OFF_HOOK);
		    //--- Since FXO will not detect event when FXS turns
		    //    off the AC ring, we need to generate Rx sigs
		    //    and initiate sending of signaling change OAM
		    //    here.
		    pVcSigs->Card[Card].Port[pNum].Chan[0] &= 0xf0;	// Clear Rx sigs
		    pVcSigs->Card[Card].Port[pNum].Chan[0] |= 0x05;	// Set new Rx sigs
		    PRTP(EVE,Just set Rx sigs to 0x5);
		    if( (bNum >= 0) && (bNum < CTP_MAX_BNDLS) &&
			(sNum >= 0) && (sNum < CTP_MAX_CHAN_PER_VCOMP) ) {
                      // Aricent PR-947222 Start
                     if( CTP_BNDL_TYPE_WP == Db.Bndl[bNum].Type )
                      ctp_set_vc_sig(bNum, Card, pNum, 0);
                     // Aricent PR-947222 End
		     else ctp_vc_send_sig_ch_oam( bNum, Card, pNum, 0, sNum);
		    }
		    break;
		  case 0x0:	// Ring Grounded
		    status = ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_GND_RING);
		    break;
		  default:
		    status = FAILURE;
		    PRTVP(MIN,Got unsupported gs sig transition from 0x1 to,NewAB);
		    break;
		}
		break;
	      case 0x0:	// Ring grounded
		switch(NewAB) {
		  case 0x3:	// OffHoook
		    PRTP(EVE,Remove ground R lead);
		    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_RING_SENSE_OFF);
		    status = ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_OFF_HOOK);
		    break;
		  default:
		    status = FAILURE;
		    PRTVP(MIN,Got unsupported gs sig transition from 0x0 to,NewAB);
		    break;
		}
		break;
	      default:
		status = FAILURE;
		PRTVP(MIN,Got unsupported old gs signaling, OldAB);
		break;
	    }
	  }
	}
	break;
      default:
	PRTP(MIN,Error unsupported port type);
	break;
    }
  return(status);
}

int  ctp_vb_cfg_start(int Card, int pNum ) {
  int status = SUCCESS;
  int loopStart = GROUND_START(Card,pNum) ? 0 : 1;
  FUNC_PRT(ctp_vb_cfg_start, PF_MISC, pNum);

  if( VOICE(Card) ) {
    switch (CARDTYPE(Card)) {
      case EMCARD:
	break;
      case FXOCRD:
	{
	  if( loopStart ) {
	    PRTDVP(EVE,Setting loop start with message queue,hMsgQ);
	    ctp_vb_cmd(Card,pNum,CTP_VB_CMD_FXO_RING_SENSE);
	    ctp_vb_cmd(Card,pNum,CTP_VB_CMD_FXO_LOOP_START);
	  } else {
	    PRTDVP(EVE,Setting ground start with message queue,hMsgQ);
	    //Need next two lines, else we get tip gnd/tip open message
	    //pair with ver 43 if FXO init a call connect prior to
	    //FXS init call. (doesn't matter which side inits the hangup).
	    ctp_vb_cmd(Card,pNum,CTP_VB_CMD_FXO_LOOP_START);
	    ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_ON_HOOK);
	    ctp_vb_cmd(Card,pNum,CTP_VB_CMD_FXO_RING_SENSE_OFF);
	    ctp_vb_cmd(Card,pNum,CTP_VB_CMD_FXO_TIP_SENSE);
	    TIP_GROUND(Card,pNum) = 0;
	  }
	}
	break;
      case FXSCRD:
	{
	  if( loopStart ) {
	    PRTDVP(EVE,Setting loop start with message queue,hMsgQ);
	    status = ctp_vb_cmd(Card,pNum,CTP_VB_CMD_FXS_LOOP_START);
	    if( status == VB_OK ) PRTP(EVE,Success setting port to loop start);
	  } else {
	    PRTDVP(EVE,Setting ground start with message queue,hMsgQ);
	    status = ctp_vb_cmd(Card,pNum,CTP_VB_CMD_FXS_GND_START);
	    if( status == VB_OK ) PRTP(EVE,Success setting port to ground start);
	    ctp_vb_cmd(Card,pNum,CTP_VB_CMD_FXS_RING_SENSE);
	  }
	}
	break;
      default:
	PRTP(MIN,No support for configuring start protocol);
	status = FAILURE;
	break;
    }
  } else {
    PRTP(MIN,No support for configuring companding);
    status = FAILURE;	// Bad board handle.
  }
  return status;
}

int  ctp_vb_cfg_companding(int Card, int pNum, int cmd) {
  int status = SUCCESS;
  FUNC_PRT(ctp_vb_cfg_companding, PF_MISC, pNum);

  if( VOICE(Card) ) {
    VBHANDLE      hRes;

    status = ctp_wait_for_handle(Card,pNum);
    if( status == SUCCESS) {
      switch (CARDTYPE(Card)) {
	case EMCARD:
	  {
	    VBBOARDHANDLE hBoard = pSysInfo->Card[Card].hBoard;
	    hRes = vbOpenEx(hBoard, VB_CDXRES , pNum, 0, VBNO_HANDLE);
	    if( hRes != VBBAD_HANDLE ) {
	      switch (cmd) {
		case CTP_VP_MU_LAW:
		  status = cdxSetCfg( hRes, CDXEM_PCMFMT, CDXPCM_uLAW, VB_NULL, VB_NULL, VB_NULL, VB_NULL);
		  if( status != VB_OK) PRTDVP(MIN, Problem setting mu-law, status)
		  else                 PRTP(EVE,Success setting companding to mu-law);
		  break;
		case CTP_VP_A_LAW_EVEN:
		  status = cdxSetCfg( hRes, CDXEM_PCMFMT, CDXPCM_aLAW_EVENBIT, VB_NULL, VB_NULL, VB_NULL, VB_NULL);
		  if( status != VB_OK) PRTP(MIN, Problem setting a-law even bit)
		  else                 PRTP(EVE,Success setting companding to A-law);
		  break;
		case CTP_VP_A_LAW_NO_EVEN:
		  status = cdxSetCfg( hRes, CDXEM_PCMFMT, CDXPCM_aLAW_NOEVENBIT, VB_NULL, VB_NULL, VB_NULL, VB_NULL);
		  if( status != VB_OK) PRTP(MIN, Problem setting a-law no even bit);
		  break;
		default:
		  PRTDVP(MIN,Unknown companding format:, cmd);
		  status = FAILURE;
		  break;
	      }
	      vbClose(hRes);
	    } else {
	      PRTP(MIN,Bad CDXRES handle);
	      status = FAILURE;	// Could not open resource
	    }
	  }
	  break;
	case FXOCRD:
	  {
	    hRes = pVcSigs->Card[Card].hRes[pNum];
	    if( hRes != VBBAD_HANDLE ) {
	      switch (cmd) {
		case CTP_VP_MU_LAW:
		  status = lineSetMuLaw( hRes);
		  if( status != VB_OK) PRTDVP(MIN, Problem setting mu-law, status)
		  else                 PRTP(EVE,Success setting companding to mu-law);
		  break;
		case CTP_VP_A_LAW_EVEN:
		  status = lineSetALaw( hRes);
		  if( status != VB_OK) PRTDVP(MIN, Problem setting a-law, status)
		  else                 PRTP(EVE,Success setting companding to A-law);
		  break;
		default:
		  PRTDVP(MIN,Unknown or unsupported companding format:, cmd);
		  status = FAILURE;
		  break;
	      }
	    } else {
	      PRTP(MIN,Bad LINRES handle);
	      status = FAILURE;	// Could not open resource
	    }
	  }
	  break;
	case FXSCRD:
	  {
	    hRes = pVcSigs->Card[Card].hRes[pNum];
	    if( hRes != VBBAD_HANDLE ) {
	      switch (cmd) {
		case CTP_VP_MU_LAW:
		  status = ncoSetMuLaw( hRes);
		  if( status != VB_OK) PRTDVP(MIN, Problem setting mu-law, status)
		  else                 PRTP(EVE,Success setting companding to mu-law);
		  break;
		case CTP_VP_A_LAW_EVEN:
		  status = ncoSetALaw( hRes);
		  if( status != VB_OK) PRTDVP(MIN, Problem setting a-law, status)
		  else                 PRTP(EVE,Success setting companding to A-law);
		  break;
		default:
		  PRTDVP(MIN,Unknown or unsupported companding format:, cmd);
		  status = FAILURE;
		  break;
	      }
	    } else {
	      PRTP(MIN,Bad NCORES handle);
	      status = FAILURE;	// Could not open resource
	    }
	  }
	  break;
	default:
	  PRTP(MIN,No support for configuring companding);
	  status = FAILURE;
	  break;
      }
      ctp_release_handle(Card,pNum);
    } else {
      PRTP(MIN,could not access resource handle);
      status = FAILURE;	// Bad board handle.
    }
  } else {
    PRTP(MIN,No support for configuring companding);
    status = FAILURE;	// Bad board handle.
  }
  return status;
}

/*
 * Bump port in case fxs was grounded and went to power failsafe.
 */
void ctp_vb_fxs_bump(int Card, int pNum)
{
  FUNC_PRT(ctp_vb_fxs_bump, PF_MISC, pNum);

  if( CARDTYPE(Card) == FXSCRD ) {
    int status = ctp_wait_for_handle(Card,pNum);

    if( status == SUCCESS) {
      VBHANDLE      hRes;

      hRes = pVcSigs->Card[Card].hRes[pNum];

      //---
      ncoWriteCodecRegister(hRes,0x14,0);
      ncoWriteCodecRegister(hRes,0x1e,0);
      ncoWriteCodecRegister(hRes,0x1e,1);

      ctp_release_handle(Card,pNum);
    }
  } else {
    PRTP(MIN,ctp_vb_fxs_bump called for non-fxs port);
  }
}

/*
 * Set port gains to minimum
 */
void ctp_vb_port_mute(int Card, int pNum) {
  if( pSysInfo->Flags & SYSINFO_FLAG_NO_VP_MUTE ) {
    switch(CARDTYPE(Card)){
      case EMCARD:
	ctp_vb_cfg_gain( Card, pNum, CTP_EM_TX_GAIN_ZERO, CTPCMDTYPE_PORT_VP_TX_GAIN_CFG);
	ctp_vb_cfg_gain( Card, pNum, CTP_EM_RX_GAIN_ZERO, CTPCMDTYPE_PORT_VP_RX_GAIN_CFG);
	break;
      case FXSCRD:
	ctp_vb_cfg_gain( Card, pNum, CTP_FXS_TX_GAIN_ZERO, CTPCMDTYPE_PORT_VP_TX_GAIN_CFG);
	ctp_vb_cfg_gain( Card, pNum, CTP_FXS_RX_GAIN_ZERO, CTPCMDTYPE_PORT_VP_RX_GAIN_CFG);
	break;
      case FXOCRD:
      default:
	ctp_vb_cfg_gain( Card, pNum, CTP_FXO_TX_GAIN_ZERO, CTPCMDTYPE_PORT_VP_TX_GAIN_CFG);
	ctp_vb_cfg_gain( Card, pNum, CTP_FXO_RX_GAIN_ZERO, CTPCMDTYPE_PORT_VP_RX_GAIN_CFG);
	break;
    }

  } else {
    switch(CARDTYPE(Card)){
      case EMCARD:
	ctp_vb_cfg_gain( Card, pNum, 255, CTPCMDTYPE_PORT_VP_TX_GAIN_CFG);
	ctp_vb_cfg_gain( Card, pNum, 0, CTPCMDTYPE_PORT_VP_RX_GAIN_CFG);
	break;
      case FXSCRD:
      case FXOCRD:
      default:
	ctp_vb_cfg_gain( Card, pNum, 0, CTPCMDTYPE_PORT_VP_TX_GAIN_CFG);
	ctp_vb_cfg_gain( Card, pNum, 0, CTPCMDTYPE_PORT_VP_RX_GAIN_CFG);
	break;
    }
  }
}

/*
 *  Gain sent is integer.
 *  E&M ports take integer 0-255
 *  FXS & FXO take float which is (int passed)/100
 */
int  ctp_vb_cfg_gain(int Card, int pNum, int gain, int cmd) {
  int status = SUCCESS;
  FUNC_PRT(ctp_vb_cfg_gain, PF_MISC, pNum);

  if( VOICE(Card) ) {
    VBHANDLE      hRes;

    status = ctp_wait_for_handle(Card,pNum);
    if( status == SUCCESS) {
      switch (CARDTYPE(Card)) {
	case EMCARD:
	  {
	    VBBOARDHANDLE hBoard = pSysInfo->Card[Card].hBoard;
	    hRes = vbOpenEx(hBoard, VB_CDXRES , pNum, 0, VBNO_HANDLE);
	    if( hRes != VBBAD_HANDLE ) {
	      switch(cmd){
		case CTPCMDTYPE_PORT_VP_TX_GAIN_CFG:
		  PRTDVP(GEN,ctp_vb_cfg_gain for Tx,gain);
		  status = cdxSetCfg( hRes, CDXEM_RXGAIN, VB_NULL, VB_NULL, (u8)gain, (u8)gain, VB_NULL);
		  if( status != VB_OK) PRTP(MIN, Problem setting codec gain)
		  else                 PRTDVP(DBG,Set Tx Gain,gain);
		  break;
		case CTPCMDTYPE_PORT_VP_RX_GAIN_CFG:
		  PRTDVP(GEN,ctp_vb_cfg_gain for Rx,gain);
		  status = cdxSetCfg( hRes, CDXEM_TXGAIN, VB_NULL, VB_NULL, (u8)gain, (u8)gain, VB_NULL);
		  if( status != VB_OK) PRTP(MIN, Problem setting codec gain)
		  else                 PRTDVP(DBG,Set Rx Gain,gain);
		  break;
		default:
		  PRTDVP(MIN,Unknown or unsupported gain command:, cmd);
		  break;
	      }
	      vbClose(hRes);
	    } else {
	      PRTP(MIN,Bad CDXRES handle);
	      status = FAILURE;	// Could not open resource
	    }
	  }
	  break;
	case FXOCRD:
	  {
	    hRes = pVcSigs->Card[Card].hRes[pNum];
	    if( hRes != VBBAD_HANDLE ) {
	      double Gain = 0.0;
	      double VbGain = 0.0;
	      switch (cmd) {
		case CTPCMDTYPE_PORT_VP_RX_GAIN_CFG:
		  Gain = (gain-CTP_FXO_RX_GAIN_ZERO)/10.0;
		  VbGain = (gain-CTP_FXO_RX_GAIN_ZERO-CTP_FXO_RX_ZERO_OFF)/10.0;
		  PRTFVP(GEN,ctp_vb_cfg_gain for Rx,Gain);
		  PRTFVP(DBG,ctp_vb_cfg_gain for vbRx,VbGain);
		  status = lineSetAudioRxGain( hRes, VbGain);
		  if( status != VB_OK) PRTP(MIN, Problem setting Rx gain);
		  break;
		case CTPCMDTYPE_PORT_VP_TX_GAIN_CFG:
		  Gain = (gain-CTP_FXO_TX_GAIN_ZERO)/10.0;
		  VbGain = (gain-CTP_FXO_TX_GAIN_ZERO-CTP_FXO_TX_ZERO_OFF)/10.0;
		  PRTFVP(GEN,ctp_vb_cfg_gain for Tx,Gain);
		  PRTFVP(DBG,ctp_vb_cfg_gain for vbTx,VbGain);
		  status = lineSetAudioTxGain( hRes, VbGain);
		  if( status != VB_OK) PRTP(MIN, Problem setting Tx gain);
		  break;
		default:
		  PRTDVP(MIN,Unknown or unsupported gain command:, cmd);
		  break;
	      }
	    } else {
	      PRTP(MIN,Bad LINRES handle);
	      status = FAILURE;	// Could not open resource
	    }
	  }
	  break;
	case FXSCRD:
	  {
	    hRes = pVcSigs->Card[Card].hRes[pNum];
	    if( hRes != VBBAD_HANDLE ) {
	      double Gain   = 0.0;
	      double VbGain = 0.0;
	      switch (cmd) {
		case CTPCMDTYPE_PORT_VP_RX_GAIN_CFG:
		  Gain   = (gain-CTP_FXS_RX_GAIN_ZERO)/10.0;
		  PRTFVP(GEN,ctp_vb_cfg_gain for rx,Gain);
		  status = ncoSetAudioRxGain( hRes, Gain);
		  if( status != VB_OK) PRTP(MIN, Problem setting Rx gain);
		  break;
		case CTPCMDTYPE_PORT_VP_TX_GAIN_CFG:
		  Gain   = (gain-CTP_FXS_TX_GAIN_ZERO)/10.0;
		  VbGain = (gain-CTP_FXS_TX_GAIN_ZERO-CTP_FXS_TX_ZERO_OFF)/10.0;
		  PRTFVP(GEN,ctp_vb_cfg_gain for Tx,Gain);
		  PRTFVP(DBG,ctp_vb_cfg_gain for vbTx,VbGain);
		  status = ncoSetAudioTxGain( hRes, VbGain);
		  if( status != VB_OK) PRTP(MIN, Problem setting Tx gain);
		  break;
		default:
		  PRTDVP(MIN,Unknown or unsupported gain command:, cmd);
		  break;
	      }
	    } else {
	      PRTP(MIN,Bad NCORES handle);
	      status = FAILURE;	// Could not open resource
	    }
	  }
	  break;
	default:
	  PRTP(MIN,No support for configuring gains);
	  status = FAILURE;
	  break;
      }
      ctp_release_handle(Card,pNum);
    } else {
      PRTP(MIN,could not access resource handle);
      status = FAILURE;	// Bad board handle.
    }
  } else {
    PRTP(MIN,No support for setting codec gain);
    status = FAILURE;
  }
  return status;
}

int  ctp_vb_qry_cdx_gain(int Card, int pNum, int cmd) {
  int status = SUCCESS;
  u8 pcmFmt, loop, txGain, rxGain, timeSlot, Hybrid;
  FUNC_PRT(ctp_vb_qry_cdx_gain, PF_MISC, pNum);

#ifndef NEED_FXO_FXS_GAIN
  if( (CARDTYPE(Card) == FXOCRD) ||
      (CARDTYPE(Card) == FXSCRD) ) {
    return(status);
  }
#endif

  if( CARDTYPE(Card) == EMCARD ) {
    VBHANDLE      hRes;

    status = ctp_wait_for_handle(Card,pNum);
    if( status == SUCCESS ) {
      VBBOARDHANDLE hBoard = pSysInfo->Card[Card].hBoard;
      hRes = vbOpenEx(hBoard, VB_CDXRES , pNum, 0, VBNO_HANDLE);
      if( hRes != VBBAD_HANDLE ) {

	if( cmd == CTPCMDTYPE_PORT_VP_CDX_GAIN_QRY ) {
	  PRTP(GEN,ctp_vb_qry_cdx_gain for both rx and tx);
	  status = cdxGetTxGain(hRes, &txGain);
	  if( status != VB_OK) PRTP(MIN, Problem getting codec Tx gain);
	  PRTU8P(GEN,TxGain, txGain);
	  status = txGain;

	  status = cdxGetRxGain(hRes, &rxGain);
	  if( status != VB_OK) PRTP(MIN, Problem getting codec Rx gain);
	  PRTU8P(GEN,RxGain, rxGain);
	  //--- Rx gain Only gets dumpred to logs here !
	} else if( cmd == CTPCMDTYPE_PORT_VP_RX_GAIN_QRY ) {
	  PRTP(GEN,ctp_vb_qry_cdx_gain for rx);
	  status = cdxGetRxGain(hRes, &rxGain);
	  if( status != VB_OK) PRTP(MIN, Problem getting codec Rx gain);
	  PRTU8P(GEN,RxGain, rxGain);
	  status = rxGain;
	} else if( cmd == CTPCMDTYPE_PORT_VP_TX_GAIN_QRY ) {
	  PRTP(GEN,ctp_vb_qry_cdx_gain for tx);
	  status = cdxGetTxGain(hRes, &txGain);
	  if( status != VB_OK) PRTP(MIN, Problem getting codec Tx gain);
	  PRTU8P(GEN,TxGain, txGain);
	  status = txGain;
	}
	vbClose(hRes);
      } else {
      status = FAILURE;	// Could not open resource
      }
      ctp_release_handle(Card,pNum);
    } else {
      status = FAILURE;	// Could not get resource handle
    }
  } else {
    PRTP(MIN,No support for card type);
    status = FAILURE;
  }

  return status;
}

int  ctp_vb_cfg_loop(int Card, int pNum, int cmd) {
  int status = SUCCESS;
  FUNC_PRT(ctp_vb_cfg_loop, PF_MISC, pNum);

#ifndef NEED_FXO_FXS_LOOPS
  if( (CARDTYPE(Card) == FXOCRD) ||
      (CARDTYPE(Card) == FXSCRD) ) {
    return(status);
  }
#endif
  if( VOICE(Card) ) {
    VBHANDLE      hRes;

    status = ctp_wait_for_handle(Card,pNum);
    if( status == SUCCESS ) {
      VBBOARDHANDLE hBoard = pSysInfo->Card[Card].hBoard;

      switch(CARDTYPE(Card)) {
	case EMCARD:
	  hRes = vbOpenEx(hBoard, VB_CDXRES , pNum, 0, VBNO_HANDLE);
	  if( hRes != VBBAD_HANDLE ) {
	    switch (cmd) {
	      case CTP_VP_LOOP_N:
		status = cdxSetCfg( hRes, CDXEM_LOOPBACK, VB_NULL, CDXLB_NOLOOPBACK, VB_NULL, VB_NULL, VB_NULL);
		if( status != VB_OK) { PRTP(MIN, Problem setting loop OFF); }
		else                 { PRTP(GEN, All loops off); }
		break;
	      case CTP_VP_LOOP_D:
		status = cdxSetCfg( hRes, CDXEM_LOOPBACK, VB_NULL, CDXLB_DIGITAL_LB, VB_NULL, VB_NULL, VB_NULL);
		if( status != VB_OK) { PRTP(MIN, Problem setting digital loop); }
		else                 { PRTP(GEN, Set digital loop); }
		break;
	      case CTP_VP_LOOP_A:
		status = cdxSetCfg( hRes, CDXEM_LOOPBACK, VB_NULL, CDXLB_ANALOG_LB, VB_NULL, VB_NULL, VB_NULL);
		if( status != VB_OK) { PRTP(MIN, Problem setting analog loop); }
		else                 { PRTP(GEN, Set analog loop); }
		break;
	      default:
		PRTDVP(MIN,Unknown loop cmd:, cmd);
		status = FAILURE;
		break;
	    }
	    vbClose(hRes);
	  } else {
	    status = FAILURE;	// Could not open resource
	  }
	  break;
	case FXOCRD:
	  hRes = pVcSigs->Card[Card].hRes[pNum];
	  if( hRes != VBBAD_HANDLE ) {
	    switch (cmd) {
	      case CTP_VP_LOOP_N:
		status = lineDisableDigitalLoopBack( hRes );
		if( status != VB_OK) { PRTP(MIN, Problem setting loop OFF); }
		else                 { PRTP(GEN, All loops off); }
		break;
	      case CTP_VP_LOOP_D:
		status = lineEnableDigitalLoopBack( hRes );
		if( status != VB_OK) { PRTP(MIN, Problem setting digital loop); }
		else                 { PRTP(GEN, Set digital loop); }
		break;
	      case CTP_VP_LOOP_A:
	      default:
		PRTDVP(MIN,Unknown or unsupported loop cmd:, cmd);
		status = FAILURE;
		break;
	    }
	  } else {
	    PRTP(MIN,Bad LINRES handle);
	    status = FAILURE; // Could not open resource
	  }
	  break;
	case FXSCRD:
	  hRes = pVcSigs->Card[Card].hRes[pNum];
	  if( hRes != VBBAD_HANDLE ) {
	    switch (cmd) {
	      case CTP_VP_LOOP_N:
		status = ncoDisableDigitalLoopBack( hRes );
		if( status != VB_OK) { PRTP(MIN, Problem setting loop OFF); }
		else                 { PRTP(GEN, All loops off); }
		break;
	      case CTP_VP_LOOP_D:
		status = ncoEnableDigitalLoopBack( hRes );
		if( status != VB_OK) { PRTP(MIN, Problem setting digital loop); }
		else                 { PRTP(GEN, Set digital loop); }
		break;
	      case CTP_VP_LOOP_A:
	      default:
		PRTDVP(MIN,Unknown or unsupported loop cmd:, cmd);
		status = FAILURE;
		break;
	    }
	  } else {
	    PRTP(MIN,Bad NCORES handle);
	    status = FAILURE; // Could not open resource
	  }
	  break;
	default:
	  PRTP(MIN,No support for configuring port loops);
	  status = FAILURE;
	  break;

      }
      ctp_release_handle(Card,pNum);
    } else {
      status = FAILURE;	// Could not get resource handle
    }

  } else {
    PRTP(MIN,No support for loops);
    status = FAILURE;
  }
  return status;
}

// H.110 bus is 32 streams of 128 channels, which is 4096 total.
// Card 0 is allocated the first 4 streams, 2 for Rx, then 2 for Tx.
// Port 0 Rx/Tx uses the first channel of its first stream
void ctp_vb_port_h110_map( int Card, int pNum, int * pVbTsRx,int * pVbTsTx){

  int StRx = (4 * Card);	// 4 Streams per card
  int StTx = (4 * Card) + 2;	// Tx Streams are after Rx Streams
  int TsRx = pNum;
  int TsTx = pNum;

  // VoiceBoard numbers timeslots on backplane from 0 - 4096
  *pVbTsRx = (128 * StRx) + TsRx;
  *pVbTsTx = (128 * StTx) + TsTx;
}

//------------------------------------------------------------------- 
// This function maps an analog voice port to the H.110 bus, accessing the
// H.110 switches on both the voice card itself as well as the one on the
// T1 card.
// cmds:
// 	0 - Disconnect port RX/TX from H.110
// 	1 - Connect    port RX/TX to   H.110
// 	3 - Connect    port RX    to   H.110 (specified timeslot) (BPlane->Card)
// 	4 - Connect    port TX    to   H.110 (specified timeslot) (Card->BPlane)
// params:
// 	specified timeslot for commands 2/3
// It is worth pointing out that ctpd.c only call with cmd, and all the
// other commands are reserved for CTPCMDTYPE_PORT_H110 messages
//------------------------------------------------------------------- 

void ctp_vb_port_h110_conn( int Card, int pNum, int cmd, int param) {
  int 	pid = (int) getpid();
  VBHANDLE      hDev;
  int	status;
  FUNC_PRT(ctp_vb_port_h110_conn, PF_H110, pNum);

  PRTDVP(DBG,ctp_vb_port_h110_conn enter with pid,pid);

  status = ctp_wait_for_handle(Card,pNum);
  if( status == SUCCESS ) {
    hDev = (VBHANDLE)pVcSigs->Card[Card].hRes[pNum];
    if( hDev != VBBAD_HANDLE ) {
      int vbTsRx, vbTsTx;
      int stat;

      switch (cmd) {
	case 0:
	  stat = scDisconn(hDev, pNum, DIR_RX, 0);
	  if( stat == VB_OK ) { PRTP(EVE, port RX successfully disconnected from H110 stream); }
	  else                { PRTDVP(MIN, port RX COULD NOT disconnect from H110 stream status, stat); }
	  stat = scDisconn(hDev, pNum, DIR_TX, 0);
	  if( stat == VB_OK ) { PRTP(EVE, port TX successfully disconnected from H110 stream); }
	  else                { PRTDVP(MIN, port TX COULD NOT disconnect from H110 stream status, stat); }
	  break;
	case 1:
	  ctp_vb_port_h110_map( Card, pNum, &vbTsRx, &vbTsTx);
	  scDisconn(hDev, pNum, DIR_RX, 0);
	  stat = scConn(hDev, pNum, DIR_RX, vbTsRx, VBSC_FORCE);
	  if( stat == VB_OK ) { PRTDVP(GN2, port RX successfully connected to H110 timeslot, vbTsRx); }
	  else                { PRTDVP(MIN, port RX COULD NOT connect to H110 status, stat); }
	  scDisconn(hDev, pNum, DIR_TX, 0);
	  stat = scConn(hDev, pNum, DIR_TX, vbTsTx, VBSC_FORCE);
	  if( stat == VB_OK ) { PRTDVP(GN2, port TX successfully connected to H110 timeslot, vbTsTx); }
	  else                { PRTDVP(MIN, port TX COULD NOT connect to H110 status, stat); }
	  break;
	case 3:
	  scDisconn(hDev, pNum, DIR_RX, 0);
	  stat = scConn(hDev, pNum, DIR_RX, param, VBSC_FORCE);
	  if( stat == VB_OK ) { PRTDVP(EVE, port RX successfully connected to H110 timeslot, param); }
	  else                { PRTDVP(MIN, port RX COULD NOT connect to H110 status, stat); }
	  break;
	case 4:
	  scDisconn(hDev, pNum, DIR_TX, 0);
	  stat = scConn(hDev, pNum, DIR_TX, param, VBSC_FORCE);
	  if( stat == VB_OK ) { PRTDVP(EVE, port TX successfully connected to H110 timeslot, param); }
	  else                { PRTDVP(MIN, port TX COULD NOT connect to H110 status, stat); }
	  break;
	default:
	  break;
      }
    } else {
      PRTC(MIN,Cant connect voice card to H110- bad resource handle);
    }
    ctp_release_handle(Card,pNum);
  } else {
    PRTC(MIN,Cant connect voice card to H110- cannot access resource handle);
  }
}

int ctp_unmap_vb_slot ( int vb_slot ) {
  int Card;

  switch(pSysInfo->ChassisType) {
    case CTP_CHAS_TYPE_3_MONO:
      Card = 3 - vb_slot;
      break;
    case CTP_CHAS_TYPE_7:
      Card = 7 - vb_slot;
      break;
    case CTP_CHAS_TYPE_3:
    default:
      Card = vb_slot - 2;
      break;
  }

  return(Card);
}

int ctp_map_vb_slot ( int Card ) {
  int vb_slot;

  switch(pSysInfo->ChassisType) {
    case CTP_CHAS_TYPE_3_MONO:
      vb_slot = 3 - Card;
      break;
    case CTP_CHAS_TYPE_7:
      vb_slot = 7 - Card;
      break;
    case CTP_CHAS_TYPE_3:
    default:
      vb_slot = Card + 2;
      break;
  }

  return(vb_slot);
}

