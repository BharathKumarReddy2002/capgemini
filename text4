void ctp_cfg_if_mode_redundancy(int Card, int pNum, CTP_PORT_DBASE *pDbP) 
{
    int	sccNum = Ctp.Card[Card].Port[pNum].SccNum;
    char *fn = "ctp_cfg_if_mode_redundancy";
    short pf = PF_START;
    fpga_clr_fcfg();
    if( pDbP->RdntConfig & CFG_RDNT_MODE_MASK ) {
      int RdntMode,RdntSec;
      getMaskVal(&pDbP->RdntConfig,16,CFG_RDNT_MODE_MASK,&RdntMode);
      getMaskVal(&pDbP->RdntConfig,16,CFG_RDNT_FLAG_SECONDARY,&RdntSec);
      if( (Dcard.Card[Card].Info[pNum].Present == YES) &&    
    	(pDbP->if_mode == IF_MODE_DCARD) &&
    	(pDbP->DcardType == DCARD_MS) ) {
          PRT(MAJ,Configuring Port for DCARD redundancy);
	  fpga_invert_rdnt_if_en(pNum,1);
      }	
      else {
	  fpga_invert_rdnt_if_en(pNum,0);
      }
      if( pDbP->RdntConfig & CFG_RDNT_FLAG_SW_LINK ) {
	// SW Link: rdnt_mode[2:0] = 6/7
	fpga_set_redundant_mode(     pNum,1);	
	fpga_set_redundant_cts_ctrl( pNum,1); 
	fpga_set_redundant_mstr(     pNum,0); 	// This is the LOC active toggle
      } else {
	switch(RdntMode) {
	  //-----
	  case CFG_RDNT_MODE_XOR:
	    // HW Link/XOR/Pri&Sec: rdnt_mode[2:0] = 1 (XOR)
	    fpga_set_redundant_mode(     pNum,0);
	    fpga_set_redundant_cts_ctrl( pNum,0); 
	    fpga_set_redundant_mstr(     pNum,1);
	    break;
	    //-----
	  case CFG_RDNT_MODE_RVRT:
	    if( RdntSec ) {
	      // HW Link/Revert/Sec: rdnt_mode[2:0] = 1 (XOR)
	      fpga_set_redundant_mode(     pNum,0);
	      fpga_set_redundant_cts_ctrl( pNum,0); 
	      fpga_set_redundant_mstr(     pNum,1);
	    } else {
	      // HW Link/Revert/Pri: rdnt_mode[2:0] = 2 (RVRT)
	      fpga_set_redundant_mode(     pNum,0);
	      fpga_set_redundant_cts_ctrl( pNum,1); 
	      fpga_set_redundant_mstr(     pNum,0);
	    }
	    break;
	    //-----
	  case CFG_RDNT_MODE_NONRVRT:
	    // HW Link/NonRevert/Pri&Sec: rdnt_mode[2:0] = 3 (NORV)
	    fpga_set_redundant_mode(     pNum,0);
	    fpga_set_redundant_cts_ctrl( pNum,1); 
	    fpga_set_redundant_mstr(     pNum,1);
	    break;
	  case CFG_RDNT_MODE_SIG:
	    if( RdntSec ) {
	      // HW Link/Sig/Sec: rdnt_mode[2:0] = 4 (SIG)
	      fpga_set_redundant_mode(     pNum,1);
	      fpga_set_redundant_cts_ctrl( pNum,0); 
	      fpga_set_redundant_mstr(     pNum,0);
	    } else {
	      // HW Link/Sig/Pri: rdnt_mode[2:0] = 1 (XOR)
	      fpga_set_redundant_mode(     pNum,0);
	      fpga_set_redundant_cts_ctrl( pNum,0); 
	      fpga_set_redundant_mstr(     pNum,1);
	    }
	    break;
	    //-----
	  default:
	    PRTDVP(MIN,Illegal RndtMode,RdntMode);
	    break;
	}
      }
      //-----
      if( pDbP->RdntConfig & CFG_RDNT_FLAG_CTS_INV ) {
	fpga_set_redundant_cts_inv(pNum,1);
      } else { fpga_set_redundant_cts_inv(pNum,0); }
    } else {
      // Redundancy disabled
      fpga_set_redundant_mode(     pNum,0);
      fpga_set_redundant_cts_ctrl( pNum,0); 
      fpga_set_redundant_mstr(     pNum,0);
      fpga_set_redundant_cts_inv(  pNum,0);
      fpga_set_redundant_fast(     pNum,0);
    } // end redundancy configuration

    fpga_send_fcfg(sccNum);
}

