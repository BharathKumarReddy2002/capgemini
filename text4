    ncmd.CmdType = SCC_CMD_T1_LOOP;
    ncmd.CmdObj = pNum;
    ncmd.CmdObj2 = pPortSt->SerLoop;
    ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
  } else {
    PRT(MIN,Function call on non T1E1 card);
  }
  return;
}

//--------------------------------------------------------------------------
void ctp_proc_bert_cfg( int Card, int pNum )
{
  CTP_PORT_STATE		*pPortSt = &Ctp.Card[Card].Port[pNum];
  FUNC_PRT(ctp_proc_bert_cfg, PF_MISC, pNum);

//  if( !FRAC_T1E1(Card, pNum) ) {
    fpga_clr_fcfg();
    //+++++ Configure Tx BERT output +++++
    switch(pPortSt->TxBert) {
      case CTP_TX_BERT_OFF:
	fpga_set_tx_bert_clk(        pNum, 0 );		// don't care
	fpga_set_tx_bert_insert_net( pNum, INACTIVE_H );	// disable
        if(IS_SER(Card)) //Aricent PR-1024772
	fpga_set_tx_bert_insert_if(  pNum, INACTIVE_H );	// disable
	if(CARDTYPE(Card) == T1CARD) { // PR 1682233 - Needed for full circle BERT
	  u32 val = ctp_bndl_type_wp(Card, pNum) ? 1 : 0;		// Winpath or Packer to Framer
          if( IS_H110(Card, pNum) ) val = 3;
	  fpga_set_framer_txser_sel(Card, pNum,val);	// 0x24[21:20]
	}
	break;
      case CTP_TX_BERT_TO_NET:
	fpga_set_bert_pat(	     pNum, pPortSt->BertPat);
	fpga_set_tx_bert_clk(        pNum, 0 );		// from net
	fpga_set_tx_bert_insert_net( pNum, ACTIVE_H );
        if(IS_SER(Card)) //Aricent PR-1024772
	fpga_set_tx_bert_insert_if(  pNum, INACTIVE_H );	// disable
	break;
      case CTP_TX_BERT_TO_IF:
	fpga_set_bert_pat(	     pNum,pPortSt->BertPat);
	fpga_set_tx_bert_clk(        pNum, 1 );		// from i/f
	fpga_set_tx_bert_insert_net( pNum, INACTIVE_H );	// disable
        if(IS_SER(Card)) //Aricent PR-1024772
	fpga_set_tx_bert_insert_if(  pNum, ACTIVE_H );
	if(CARDTYPE(Card) == T1CARD) { // PR 1682233 - Needed for full circle BERT
	  fpga_set_framer_txser_sel(Card, pNum,(u32)2);	// 0x24[21:20]
	}
	break;
    }

    //+++++ Configure Rx BERT output +++++
    switch(pPortSt->RxBert) {
      case CTP_RX_BERT_OFF:
	fpga_set_rx_bert_clk(	  pNum, 0 );		// don't care
	fpga_set_rx_bert_dat_sel( pNum, 0 );		// don't care
	fpga_stop_bert(		  pNum);
	break;
      case CTP_RX_BERT_FROM_NET:
	fpga_set_bert_pat(	  pNum, pPortSt->BertPat);
	fpga_set_rx_bert_clk(	  pNum, 0 );		// from net
	fpga_set_rx_bert_dat_sel( pNum, 0 );		// from net
	fpga_start_bert(	  pNum);
	break;
      case CTP_RX_BERT_FROM_IF:
	fpga_set_bert_pat(	  pNum, pPortSt->BertPat);
	fpga_set_rx_bert_clk(	  pNum, 1 );		// from i/f
	fpga_set_rx_bert_dat_sel( pNum, 1 );		// from i/f
	fpga_start_bert(	  pNum);
	break;
    }
    fpga_send_fcfg(pPortSt->SccNum);
//  }
}

//--------------------------------------------------------------------------
void ctp_proc_t1_bert( int Card, int pNum )
{
  struct acrndrv_command	 ncmd;
  char				 SccBuf[40], Buf[80];
  int				 SccNum = Ctp.Card[Card].Port[pNum].SccNum;
  CTP_PORT_STATE		*pPortSt = &Ctp.Card[Card].Port[pNum];

  FUNC_PRT(ctp_proc_t1_bert, PF_MISC, pNum);
  // Aricent PR 880784 fix
  if(IS_T1E1(Card)) {
    sprintf(SccBuf,"scc%d",SccNum);
    ncmd.CmdType = SCC_CMD_T1_BERT;
    ncmd.CmdObj = pNum;
    if(pPortSt->Diagnostics) {
      ncmd.CmdObj2 = 0xffffff;
      ncmd.CmdObj3 = 0xffffff;
    } else {
      if(Db.Bndl[pPortSt->TxBertBndl].Type == CTP_BNDL_TYPE_VC){
	/* we can only test one channel bert on VCOMP bundle */
	ncmd.CmdObj2 |= 1<<Db.Bndl[pPortSt->TxBertBndl].Bndl.vc_bndl.vc_chan[0].SrcInfo.Chan;
	ncmd.CmdObj3 |= 1<<Db.Bndl[pPortSt->RxBertBndl].Bndl.vc_bndl.vc_chan[0].SrcInfo.Chan;
      } else {
	ncmd.CmdObj2 = Db.Bndl[pPortSt->TxBertBndl].Bndl.wp_bndl.tsBitMask;
	ncmd.CmdObj3 = Db.Bndl[pPortSt->RxBertBndl].Bndl.wp_bndl.tsBitMask;
      }
    }
    sprintf(Buf, "TxBertBndl 0x%x, RxBertBndl 0x%x\n",
	pPortSt->TxBertBndl, pPortSt->RxBertBndl );
    PRTS(GEN, ctp_proc_t1_bert, Buf);
    ncmd.CmdObj4 = pPortSt->BertPat;
    ncmd.CmdObj5[0] = pPortSt->TxBert;
    ncmd.CmdObj5[1] = pPortSt->RxBert;
    sprintf(Buf, "c%dp%d, txtsmask 0x%x, rxtsmask 0x%x, pattern 0x%x, txBert%d, rxBert%d\n",
	Card, pNum, ncmd.CmdObj2, ncmd.CmdObj3, ncmd.CmdObj4, ncmd.CmdObj5[0], ncmd.CmdObj5[1]);
    PRTS(GEN, ctp_proc_t1_bert, Buf);
    ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
  } else {
    PRT(MIN,Function call on non T1E1 card);
  }

  return;
}

//--------------------------------------------------------------------------
// This routine processes an incoming OAM message from a remote node. I
// generates an OAM event to the local state machine for that node.
//--------------------------------------------------------------------------
int ctp_proc_msg_rem_oam( CTP_Q_MSG * pMsg )
{
#ifdef LINUX64 
  CTP_Q_OAM_MSG          *pRMsg = (CTP_Q_OAM_MSG *)pMsg;
  u8 	 		 LocCid = pRMsg->CtpMsg.msg.RemOam.RemNcp.Port;
#else
  u8 	 		 LocCid = pMsg->CtpMsg.msg.RemOam.RemNcp.Port;
#endif
  int			 Card = pSysInfo->LocCid[LocCid].Card;
  int			 pNum = pSysInfo->LocCid[LocCid].pNum;
  CTP_PORT_STATE	*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  CTP_PORT_DBASE 	*pDbP = &Db.Card[Card].Port[pNum];
  struct timeval 	 now;
  char		 	 PrtBuf[300], PrtBuf1[300];
  u32		 	 RoundTripDelay, NewDdsFreq;
  u32			 MeasFreq, MeasFreqAcc, MeasPhase, MeasFreqHz;
  int			 bNum = util_get_next_bNum(pDbP, -1);	//Aricent PR 1116706
  CTP_BNDL_CNTRS        *pBndlCnt = &Ctp.Bndl_cnt[bNum];        /* Aricent PR 1117979, 1133355 Fix */
#ifdef VCTP
  int c_idx;
#endif
  FUNC_PRT(ctp_proc_msg_rem_oam, PF_PST, -1);

#ifdef DBG_MSG_QUEUE
  PRTU8P(EVE,CTP processing remote OAM message for local CID, LocCid);
#endif
#ifdef LINUX64 
  utl_get_node_string( &pRMsg->CtpMsg.msg.RemOam.LocNcp, PrtBuf1 );
#else
  utl_get_node_string( &pMsg->CtpMsg.msg.RemOam.LocNcp, PrtBuf1 );
#endif
  sprintf(PrtBuf,"Proc OAM message for LocCID %d from %s",LocCid,PrtBuf1);
  PRTS(GN3,,PrtBuf);

  if( (pSysInfo->LocCid[LocCid].Card == ~0) ||
      (pSysInfo->LocCid[LocCid].pNum == ~0) ) {
    int c,pn;
    int found_it=0;
    //--- Look for loccid in the port internal state of all db active ports
    for(c=0;c<CTP_MAX_CARDS;c++){
      if(!VOICE(c)) {
	for(pn=0;pn<pSysInfo->Card[c].PortsOnCard;pn++) {
	  pDbP = (CTP_PORT_DBASE *)&Db.Card[c].Port[pn];
	  if( pDbP->State == CTP_DBSTATE_UP ) {
	    pPortIntSt = (CTP_PORT_INT_STATE *)&Ctp.Card[c].PortInt[pn];
	    if( pPortIntSt->LocAdCid.Cid == LocCid ) {
	      pPortSt = (CTP_PORT_STATE *)&Ctp.Card[c].Port[pn];
	      Card = c;
	      pNum = pn;
	      found_it = 1;
	      PRTU8P(GN2,Found port for loccid,LocCid);
	    }
	  }
	  if(found_it) break;
	}
      }
      if(found_it) break;
    }
    if(!found_it) {
      PRTU8(GN2,OAM cannot be processed - Loccid not filled in, LocCid);
      //--- LocCid not active
      return(SUCCESS);
    }
  }

  if( ( pDbP->State == CTP_DBSTATE_UP ) &&
      ( !PBS(Card,pNum) && !SAToP(Card,pNum) ) ) {
#ifdef LINUX64 
    if ( ctp_check_port_cfg_endpoints(Card,pNum,pRMsg) == SUCCESS ) {
      if( pRMsg->CtpMsg.msg.RemOam.version < 2 ) {
	// This field was added in version 2. Must set to default.
	pRMsg->CtpMsg.msg.RemOam.OamSecPerPkt = CTP_OAM_SEC_PER_PKT;
      }
      //========== Process Round Trip Delay ==========
      if( pRMsg->CtpMsg.msg.RemOam.version > 2 ) {
	// OAM version 3 or higher, check for network round trip delay info
	if( pRMsg->CtpMsg.msg.RemOam.Depart != 0 ) {
#else
    if ( ctp_check_port_cfg_endpoints(Card,pNum,pMsg) == SUCCESS ) {
      if( pMsg->CtpMsg.msg.RemOam.version < 2 ) {
	// This field was added in version 2. Must set to default.
	pMsg->CtpMsg.msg.RemOam.OamSecPerPkt = CTP_OAM_SEC_PER_PKT;
      }
      //========== Process Round Trip Delay ==========
      if( pMsg->CtpMsg.msg.RemOam.version > 2 ) {
	// OAM version 3 or higher, check for network round trip delay info
	if( pMsg->CtpMsg.msg.RemOam.Depart != 0 ) {
#endif
	  // Check to see if saved timevals have been used (are zero)
	  if( (pPortIntSt->LocArr == 0) && (pPortIntSt->RemDpt == 0) ) {
	    // Save timevals in internal state, all times in microsec.
	    // version 4 has a place for iptables to add the received timestamp
	    // if this field is filled, use that value, otherwise grab a timestamp
	    // now for use.
#ifdef LINUX64 
	    if( ( pRMsg->CtpMsg.msg.RemOam.version > 3 ) &&
		( pRMsg->CtpMsg.msg.RemOam.Arrive != 0) ) {
	      pPortIntSt->LocArr = pRMsg->CtpMsg.msg.RemOam.Arrive;
#else
	    if( ( pMsg->CtpMsg.msg.RemOam.version > 3 ) &&
		( pMsg->CtpMsg.msg.RemOam.Arrive != 0) ) {
	      pPortIntSt->LocArr = pMsg->CtpMsg.msg.RemOam.Arrive;
#endif
	    } else {
	      gettimeofday( &now, NULL);
	      while (now.tv_usec < 0) {
		now.tv_usec += 1000000;
		now.tv_sec--;
	      }
	      while (now.tv_usec >= 1000000) {
		now.tv_usec -= 1000000;
		now.tv_sec++;
	      }
	      pPortIntSt->LocArr = (u32)(now.tv_usec + now.tv_sec*1000000);
	    }
#ifdef LINUX64 
	    pPortIntSt->RemDpt = pRMsg->CtpMsg.msg.RemOam.Depart;
#else
	    pPortIntSt->RemDpt = pMsg->CtpMsg.msg.RemOam.Depart;
#endif
	  }
#ifdef LINUX64 
	  if( ( pRMsg->CtpMsg.msg.RemOam.DelArr != 0 ) &&
	      ( pRMsg->CtpMsg.msg.RemOam.DelDep != 0 ) ) {
#else
	  if( ( pMsg->CtpMsg.msg.RemOam.DelArr != 0 ) &&
	      ( pMsg->CtpMsg.msg.RemOam.DelDep != 0 ) ) {
#endif
	    // We have enough data to calculate a roundtrip delay!
	    RoundTripDelay =
#ifdef LINUX64 
	      abs((pPortIntSt->LocArr - pRMsg->CtpMsg.msg.RemOam.DelDep) -
	      (pRMsg->CtpMsg.msg.RemOam.Depart - pRMsg->CtpMsg.msg.RemOam.DelArr));
#else
	      abs((pPortIntSt->LocArr - pMsg->CtpMsg.msg.RemOam.DelDep) -
	      (pMsg->CtpMsg.msg.RemOam.Depart - pMsg->CtpMsg.msg.RemOam.DelArr));
#endif
	    // Print to log odd values of RoundTripDelay
#ifdef DBG_NET_STATS
	    if ( (int)RoundTripDelay < 0 ) {
	      sprintf(PrtBuf,"Net r/t delay: (%d - %d) - (%d - %d) = %d ",
#ifdef LINUX64 
		  pPortIntSt->LocArr, pRMsg->CtpMsg.msg.RemOam.DelDep,
		  pRMsg->CtpMsg.msg.RemOam.Depart, pRMsg->CtpMsg.msg.RemOam.DelArr,
#else
		  pPortIntSt->LocArr, pMsg->CtpMsg.msg.RemOam.DelDep,
		  pMsg->CtpMsg.msg.RemOam.Depart, pMsg->CtpMsg.msg.RemOam.DelArr,
#endif
		  RoundTripDelay);
	      PRTSP(EVE,,PrtBuf);
	    }
#endif
            /* Aricent PR 1116706, 1117979, 1133355 Fix - START */
            if ( Db.Bndl[bNum].Type == CTP_BNDL_TYPE_CTP) {
              pBndlCnt->Bndl.ctp.Latency = (RoundTripDelay / 2);       /* Aricent PR 1106063 */
            }
            /* Aricent PR 1116706, 1117979, 1133355 Fix - END */
	    //Now process network r/t delay stats
	    if( pPortIntSt->NetDelays.Num == 0 ) {
	      pPortIntSt->NetDelays.MaxNetDelay = RoundTripDelay;
	      pPortIntSt->NetDelays.MinNetDelay = RoundTripDelay;
	      pPortIntSt->NetDelays.SumNetDelay = RoundTripDelay;
	    } else {
	      pPortIntSt->NetDelays.MaxNetDelay =
		(RoundTripDelay > pPortIntSt->NetDelays.MaxNetDelay) ?
		RoundTripDelay : pPortIntSt->NetDelays.MaxNetDelay;
	      pPortIntSt->NetDelays.MinNetDelay =
		(RoundTripDelay < pPortIntSt->NetDelays.MinNetDelay) ?
		RoundTripDelay : pPortIntSt->NetDelays.MinNetDelay;
	      pPortIntSt->NetDelays.SumNetDelay += RoundTripDelay;
	    }
	    pPortIntSt->NetDelays.Num++;
#ifdef DBG_NET_STATS
	    sprintf(PrtBuf,"Net r/t delay: (%d - %d) - (%d - %d)",
		pPortIntSt->LocArr,
#ifdef LINUX64 
		pRMsg->CtpMsg.msg.RemOam.DelDep,
		pRMsg->CtpMsg.msg.RemOam.Depart,
		pRMsg->CtpMsg.msg.RemOam.DelArr);
#else
		pMsg->CtpMsg.msg.RemOam.DelDep,
		pMsg->CtpMsg.msg.RemOam.Depart,
		pMsg->CtpMsg.msg.RemOam.DelArr);
#endif
	    PRTSP(EVE,,PrtBuf);
	    sprintf(PrtBuf,"Net r/t delay: %d usec",
		RoundTripDelay);
	    PRTSP(EVE,,PrtBuf);
	    sprintf(PrtBuf,"Net r/t delay max: %d, min: %d usec, num: %d",
		pPortIntSt->NetDelays.MaxNetDelay,
		pPortIntSt->NetDelays.MinNetDelay,
		pPortIntSt->NetDelays.Num);
	    PRTSP(EVE,,PrtBuf);
#endif
	  }
	}
      }
      //========== Process Autobaud ==========
      if( pDbP->dds_src == CTP_DDS_SRC_AUTOBAUD ) {
	double RemFreq;
	char pbuf[200];
	// Here we figure out if the frequency from the remote end is good.
	// Good means that it is a minimum freq and has not changed in value
	// beyond a maximum from it's nominal value. If it has, we need to
	// tell the driver to ignore incoming packets from the network until
	// the frequency has stabilized. We tell the driver to ignore
	// incoming packets by disabling RcvNrzPkts.
#ifdef LINUX64 
	MeasPhase   = pRMsg->CtpMsg.msg.RemOam.MeasPhase;
	MeasFreq    = pRMsg->CtpMsg.msg.RemOam.MeasFreq;
	MeasFreqAcc = pRMsg->CtpMsg.msg.RemOam.MeasFreqAcc;
#else
	MeasPhase   = pMsg->CtpMsg.msg.RemOam.MeasPhase;
	MeasFreq    = pMsg->CtpMsg.msg.RemOam.MeasFreq;
	MeasFreqAcc = pMsg->CtpMsg.msg.RemOam.MeasFreqAcc;
#endif
	RemFreq    = 2.0*(double)(MeasFreq)/(double)MeasFreqAcc;
	MeasFreqHz = (MeasFreq/MeasFreqAcc)*2;	// Convert to Hz
	if( MeasPhase != pPortIntSt->RemMeasPhase ) {
	  // Set the AutoBaud threshold to be 80% of the Adaptive Max freq
	  // offset so that Auto takes over when Adap poops out.
	  double MaxHzChange = (double)pPortIntSt->AdapMaxPpmOffset * pPortIntSt->RemSavFreq * 0.8 / 1000000.0;
          sprintf(pbuf,"MeasFreq %d MeasFreqAcc %d RemSavFreq %.2f RemFreq %.2f MaxHzChange %.2f.",
              MeasFreq, MeasFreqAcc, pPortIntSt->RemSavFreq, RemFreq, MaxHzChange);
	  PRTSP(GEN,Calc,pbuf);

	  // ----- Save new values to state structs -----
	  pPortIntSt->RemMeasPhase   = MeasPhase;
	  PRTDVP(GN2,New MeasPhase,MeasPhase);
	  PRTDVP(GN2,New Remote Measured Freq,MeasFreqHz);
	  // If the frequency has either changed or is too high, restart.
	  if( ( RemFreq    > (pPortIntSt->RemSavFreq + MaxHzChange) ) ||
	      ( RemFreq    < (pPortIntSt->RemSavFreq - MaxHzChange) ) ||
	      ( MeasFreqHz > (CTP_MAX_AUTO_FREQ*1000) ) ) {
	    if( MeasFreqHz > (CTP_MAX_AUTO_FREQ*1000) ) {
	      PRTDVP(EVE,Autobaud Frequency too high,MeasFreqHz);
	    } else {
	      PRTFVP(EVE,Autobaud Frequency Change to,RemFreq);
	    }
	    // ----- Save new values to state structs -----
	    pPortSt->RemTtFreq = MeasFreqHz;
	    pPortIntSt->RemSavFreq = RemFreq;
	    pPortIntSt->RemMeasFreqCnt = 5;
	    // ----- set DDS to new value
	    NewDdsFreq = (u32)(((double)MeasFreqHz/1000) * 0x20000);
	    fpga_clr_fcfg();
	    fpga_set_dds_freq( Card, pNum, NewDdsFreq );
	    if(IS_SER(Card)) fpga_set_dds_div(pNum, 0); //Aricent PR 1198066 Fix
	    fpga_send_fcfg(pPortSt->SccNum);
	    pPortSt->AdapDdsValue      = NewDdsFreq;
	    pPortIntSt->AdapDdsNominal = NewDdsFreq;
	    // ----- Set Autobaud "in-progress" flag
	    pPortIntSt->AutoComplete = NO;
	    pPortIntSt->AutoCompleteFlag = NO;
	    // ----- stop packet flow
	    //ctp_port_state_machine(Card,pNum,CTP_PORT_EVENT_AUTO_CHANGE,NULL);
	  } else {
	    if( pPortIntSt->RemMeasFreqCnt > 0 ) {
	      pPortIntSt->RemMeasFreqCnt--;
	      PRTDVP(GN1,new freq cntdwn,pPortIntSt->RemMeasFreqCnt);
	      if( pPortIntSt->RemMeasFreqCnt == 0 ) {
		// ----- reset Adaptive state
		pPortSt->AdapState = CTP_ADAP_STATE_WAIT;
		pPortIntSt->AdapStateCnt = CTP_ADAP_WAIT;
		// ----- Set Autobaud "complete" flag
		pPortIntSt->AutoComplete = YES;
		pPortIntSt->AutoCompleteFlag = YES;
		// ----- start packet flow
		//ctp_port_state_machine(Card,pNum,CTP_PORT_EVENT_AUTO_DONE,NULL);
	      }
	    }
	  }
	}
      }
      //========== Process Port State Machine ==========
#ifdef LINUX64 
      ctp_port_state_machine( Card,pNum, CTP_PORT_EVENT_REM_OAM, pRMsg );
#else
      ctp_port_state_machine( Card,pNum, CTP_PORT_EVENT_REM_OAM, pMsg );
#endif
    } else {
#ifdef LINUX64 
      utl_get_node_string( &pRMsg->CtpMsg.msg.RemOam.LocNcp, PrtBuf1 );
#else
      utl_get_node_string( &pMsg->CtpMsg.msg.RemOam.LocNcp, PrtBuf1 );
#endif
      sprintf(PrtBuf,"OAM end point check failed for LocCID %d from %s",LocCid,PrtBuf1);
      PRTS(MIN,,PrtBuf);
    }
  }
  return(SUCCESS);
}

//--------------------------------------------------------------------------
// We can't check everything in ctp_check_dbase because of diagnostics.
// This function is to make sure the bundle/port config is good before
// bringing up the bundle.
//--------------------------------------------------------------------------

//--------------------------------------------------------------------------
// This functions job is check that the database meets system specific
// requirements -> eg for refs of cards > 0:
//   => nova cards always use external fixed at 32k
//   => 12 port cards are external with either 32k or, if card 0 is using
//   external reference, freq set to that of the external ref for card 0.
//   Note: This routine gets used in places where ctp_add_port may not have
//   been called yet. => CANNOT use macros (eg IPT() that rely on PortInt.
//   Diagnostics brings up a port without a bundle attached, don't prevent
//   that here.
//   TODO This function does much more than what is described above.
//   Eventually, we should document this here for future developers
//   benefit.
//--------------------------------------------------------------------------
void ctp_check_dbase()
{
  int		 bNum, Card, pNum, i, div=1;
  int		 cfg_ref_out = YES;
  char 		 prtbuf[200];
#ifdef VCTP
  int c_idx;
#endif
  FUNC_PRT(ctp_check_dbase, PF_DBASE, -1);

  //--- Check through the bundles, & make sure Card & pNum are properly setup
  for( bNum=0; bNum<CTP_MAX_BNDLS; bNum++ ) {
    switch ( Db.Bndl[bNum].Type ) {
      case CTP_BNDL_TYPE_WP:
        //PR 1452875 fix -Start
        if (Db.Bndl[bNum].Bndl.wp_bndl.use_vip){
          if(ctp_nid_qry_ip(&Db.Bndl[bNum].Bndl.wp_bndl.virtual_ip) != CTP_IF_TYPE_VIP) {
            Db.Bndl[bNum].Bndl.wp_bndl.use_vip = 0;
            Db.Bndl[bNum].Bndl.wp_bndl.virtual_ip.v4 = 0;
            Db.Bndl[bNum].State = CTP_DBSTATE_DOWN;
            sprintf(prtbuf,"CESoPSN Bndl cfgd w/ stale virtual IP, Disabling...\n");
            PRTSB(MIN,,prtbuf);
          }
        }
        //PR 1452875 fix -End
	break;
      case CTP_BNDL_TYPE_SO:
	//--- DBase upgrades don't know SysType/PortsPerCard, ...
	if( (Db.Bndl[bNum].Bndl.so_bndl.pNum >= pSysInfo->PortsPerCard) &&
	    (Db.Bndl[bNum].Bndl.so_bndl.Card == 0) ) {	// Could be upgrade from pre 5.0!
	  int c  = Db.Bndl[bNum].Bndl.so_bndl.pNum/pSysInfo->PortsPerCard;
	  int pn = Db.Bndl[bNum].Bndl.so_bndl.pNum%pSysInfo->PortsPerCard;
	  Db.Bndl[bNum].Bndl.so_bndl.pNum = pn;
	  Db.Bndl[bNum].Bndl.so_bndl.Card = c;
	}
	if (Db.Bndl[bNum].Bndl.so_bndl.use_vip){
 	  if(ctp_nid_qry_ip(&Db.Bndl[bNum].Bndl.so_bndl.virtual_ip) != CTP_IF_TYPE_VIP) {
	    Db.Bndl[bNum].Bndl.so_bndl.use_vip = 0;
	    Db.Bndl[bNum].Bndl.so_bndl.virtual_ip.v4 = 0;
	    Db.Bndl[bNum].State = CTP_DBSTATE_DOWN;
	    sprintf(prtbuf,"SAToP Bndl cfgd w/ stale virtual IP, Disabling...\n");
	    PRTSB(MIN,,prtbuf);
	  }
	}  
	break;
      case CTP_BNDL_TYPE_CTP:
	//--- DBase upgrades don't know SysType/PortsPerCard, ...
	if( (Db.Bndl[bNum].Bndl.cp_bndl.pNum >= pSysInfo->PortsPerCard) &&
	    (Db.Bndl[bNum].Bndl.cp_bndl.Card == 0) ) {	// Could be upgrade from pre 5.0!
	  int c  = Db.Bndl[bNum].Bndl.cp_bndl.pNum/pSysInfo->PortsPerCard;
	  int pn = Db.Bndl[bNum].Bndl.cp_bndl.pNum%pSysInfo->PortsPerCard;
	  Db.Bndl[bNum].Bndl.cp_bndl.pNum = pn;
	  Db.Bndl[bNum].Bndl.cp_bndl.Card = c;

	}
	// Port output signal delay max CTP_MAX_SIGO_DELAY pkts.
	if( Db.Bndl[bNum].Bndl.cp_bndl.SigOutDelay > CTP_MAX_SIGO_DELAY ) {
	  PRTDVB(MIN,Resetting port SigOutDelay from, Db.Bndl[bNum].Bndl.cp_bndl.SigOutDelay);
	  Db.Bndl[bNum].Bndl.cp_bndl.SigOutDelay = 0;	// Default is 0!
	}
	
	if (Db.Bndl[bNum].Bndl.cp_bndl.use_vip){
 	  if(ctp_nid_qry_ip(&Db.Bndl[bNum].Bndl.cp_bndl.virtual_ip) != CTP_IF_TYPE_VIP) {
	    Db.Bndl[bNum].Bndl.cp_bndl.use_vip = 0;
	    Db.Bndl[bNum].Bndl.cp_bndl.virtual_ip.v4 = 0;
	    Db.Bndl[bNum].State = CTP_DBSTATE_DOWN;
	    sprintf(prtbuf,"CTP Bndl cfgd w/ stale virtual IP, Disabling...\n");
	    PRTSB(MIN,,prtbuf);
	  }
	}  
	break;
      default:
	break;
    }
    
  }

  if( pSysInfo->hdlc_ports != 0 ) {
    PRT(EVE,Found PBS port- checking that direct drive is off on all ports.);
    for(Card=0; Card<CTP_MAX_CARDS;Card++) {
      for( pNum=0; pNum<pSysInfo->Card[Card].PortsOnCard; pNum++ ) {
	CTP_PORT_DBASE * pDbP = &Db.Card[Card].Port[pNum];

	//--- Check through ports and make sure PBS ports are not bundled.
	if( PBS(Card,pNum) ) {
	  int bNum = 0;
	  while( bNum < CTP_MAX_BNDLS ) {
	    // TODO: Must deal with multiple source ports when that happens
	    int bndls_card = util_bndl_src_card( 0, &Db.Bndl[bNum] );
	    int bndls_pNum = util_bndl_src_pNum( 0, &Db.Bndl[bNum] );
	    if( (Card == bndls_card) &&
		(pNum == bndls_pNum) ) {
	      PRTDV(MIN,ctp_check_dbase: Found bundle using PBS port - initializing bundle,bNum);
	      util_init_bndl_dbase(&Db.Bndl[bNum], bNum);
	    }
	    bNum++;
	  }
	}

	//--- Check through PBS ports and add ip to CTP_NID_INFO strucure
	if( PBS(Card,pNum) && (pDbP->pkt_info.Local_IP != 0) ) {
	  char ifs[CTP_MAX_NAME_LEN];
	  CTP_NODE_STORAGE addNode;
	  sprintf(ifs,"scc%d", Ctp.Card[Card].Port[pNum].SccNum);
	  addNode.Type = CTP_IPV4;
	  addNode.v4 = pDbP->pkt_info.Local_IP;
	  ctp_nid_add_ip( 100+Ctp.Card[Card].Port[pNum].SccNum,
	      CTP_IF_TYPE_PBS, ifs, &addNode, 0 ,(int)pDbP->pkt_info.Mtu);
	}

      }	// End loop over pNum
    }	// End loop over Card

    for(bNum=0; bNum<CTP_MAX_BNDLS; bNum++) {
      if( Db.Bndl[bNum].Type == CTP_BNDL_TYPE_CTP ) {	// SAToP Must run ipt (see above)
	if( !(Db.Bndl[bNum].Bndl.cp_bndl.CfgFlags & CFG_BNDL_FLAG_IPT) ) {
	  sprintf(prtbuf,"CTP Bndl cfgd w/ dir_drv on. Disabling...\n");
	  PRTSB(MIN,,prtbuf);
	  Db.Bndl[bNum].Bndl.cp_bndl.CfgFlags |= CFG_BNDL_FLAG_IPT;
	}
      }
    }	// End of loop over bNum
  }

  //--- Check through for all_h110/VCOMP cards...
  for(Card=0; Card<CTP_MAX_CARDS;Card++) {
    if( IS_T1E1_2000(Card) ) {
        ctp_card_cfg_all_h110(Card, Db.Card[Card].card_all_h110);
    }
  }

  //--- Check through fractional T1E1 ports
  for(Card=0; Card<CTP_MAX_CARDS;Card++) {
    for( pNum=0; pNum<pSysInfo->Card[Card].PortsOnCard; pNum++ ) {
      CTP_PORT_DBASE * pDbP = &Db.Card[Card].Port[pNum];
      if( FRAC_T1E1(Card, pNum) ) {
	if( pDbP->DcardCfg1 & T1E1_MSK_E1 ) {
	  //--- Frame transport is required for fractional E1.
	  pDbP->DcardCfg1 &= ~T1E1_MSK_NO_FRM;
	} else {
	  //--- No CAS for fractional T1.
	  pDbP->DcardCfg1 &= ~T1E1_MSK_E1_CAS;
	}
      }
    }
  }

  if( (Db.Node[0].protocol != 47) && (Db.Node[0].protocol != pSysInfo->protocol) ) {
    //--- Database is configured for non-standard protocol & doesn't agree
    // with what we were passed from the command line. Iptables & tcqueue
    // are NOT setup correctly to use the database value. Only thing we can
    // do is log a message
    sprintf(prtbuf,"Unusable dbase protocol of %d using %d pls reconfig through menu\n",
	Db.Node[0].protocol, pSysInfo->protocol);
    PRTS(MIN,,prtbuf)
  }

  // Node descriptors: " " indicates empty text
  if(strcmp(Db.Node[0].NodeDesc,"") == 0)  strcpy(Db.Node[0].NodeDesc, " ");
  // Port descriptors: " " indicates empty text
  for(Card=0; Card<CTP_MAX_CARDS;Card++) {
    for( pNum=0; pNum<pSysInfo->Card[Card].PortsOnCard; pNum++ ) {
      CTP_PORT_DBASE * pDbP = &Db.Card[Card].Port[pNum];
      if( strcmp(pDbP->PortDesc, "" ) == 0 ) strcpy(pDbP->PortDesc, " ");
    }
  }

  //===== Clocking checking and configuration =====

  //--- Clean up Node State based on clocking dbase changes
#ifndef VCTP
  for( Card=0; Card<pSysInfo->CardsPerCpu; Card++ ) {
#else
  for(c_idx = 0; c_idx<pSysInfo->CardsPerCpu; c_idx++) {
    Card = cardIndx[c_idx];
#endif
    for( i=0; i<CTP_MAX_REFS_PER_NODE;i++) {
      //--- Reset NodeState ref structure if reference is disabled
      if(Db.Node[Card].ref[i].Port == CTP_REF_DISABLED ) {
	//PRTDVC(OFF,Resetting Node State Reference fields for disabled ref, i);
	memset( &Ctp.Node[Card].ref[i], 0 , sizeof(CTP_REFERENCE_STATE));
	if( Ctp.Node[Card].RefInUse == i ) {
	  Ctp.Node[Card].RefInUse = ~0;		// Set to invalid reference
	  Ctp.Node[Card].phdet_hold_valid = NO;
	}
      }
    }
  }
    

  // Card numbers greater than 1 are always set to external clock so that
  // they PLL lock to card 0. 2000 systems always lock up at 32K, but on 12
  // port systems, if the external reference is in use, all cards lock up
  // to the external reference at that frequency.

#ifndef VCTP
  for( Card=1; Card<pSysInfo->CardsPerCpu; Card++ ) {
#else
  for(c_idx = 1; c_idx<pSysInfo->CardsPerCpu; c_idx++) {
    Card = cardIndx[c_idx];
#endif
    PRTC(GN2,Checking refs for card);
    if( (pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150) ) {
      //XXX TODO: Manage gluon intercard references.
    } else {
      //---------- CTP20xx ----------
      //--- Nova: Config ref 0 to external/32k, (all others disabled).
      // Note: T1E1 card in H.110 node which is not the H.110 master set up
      // to pull reference from H.110 bus (then don't need spoke card)
      if( IS_T1E1_2000(Card) &&
	  pSysInfo->Clk.need_h110 &&
	  (pSysInfo->Clk.first_t1 != Card)
	) {
	div = 128; 	// External reference is 4.096 MHz
      } else {
	div = 1; 	// External reference is 32 KHz
      }
      if( pSysInfo->Clk.clk_rtm_hub_slot >= 0 ) {	// Hub RTM card found in node
	if( (Db.Node[Card].ref[0].Port != CTP_REF_EXTERNAL) ||
	    (Db.Node[Card].ref[0].Div != div) ){
	  PRTC(GEN,Configuring card to lock to (P5) ext ref);
	  Db.Node[Card].ref[0].Port = CTP_REF_EXTERNAL;
	  Db.Node[Card].ref[0].Div = div;
	}
      } else {	// No Hub RTM card in node
	// If there is no Hub Clock RTM in an H110 node, then there is no
	// clock distribution, so set the cards to free run... unless it is
	// a T1E1 which is not master. In that case, we can lock over the
	// H.110 bus. If not H110, we lock to the cards to the 32K
	// reference driven across the H.110 bus.
	if( pSysInfo->Clk.need_h110 ) {
	  if( IS_T1E1_2000(Card) && (pSysInfo->Clk.first_t1 != Card) ) {
	    PRTC(GEN,Configuring card to lock to (H110) ext ref);
	    Db.Node[Card].ref[0].Port = CTP_REF_EXTERNAL;
	    Db.Node[Card].ref[0].Div = div;
	  } else {
	    PRTC(GEN,Configuring card to free run);
	    Db.Node[Card].ref[0].Port = CTP_REF_DISABLED;
	    Db.Node[Card].ref[0].Div = 1;
	  }
	} else {
	  PRTC(GEN,Configuring card to lock to (P4) ext ref);
	  Db.Node[Card].ref[0].Port = CTP_REF_EXTERNAL;
	  Db.Node[Card].ref[0].Div = div;
	}
      }
      // disable all other refs... slave cards only need first ref
      for( i=1; i<CTP_MAX_REFS_PER_NODE;i++) {
	if( Db.Node[Card].ref[i].Port != CTP_REF_DISABLED ) {
	  PRTDVC(MAJ,Disabling ref, i);
	  Db.Node[Card].ref[i].Port = CTP_REF_DISABLED;
	  Db.Node[Card].ref[i].Div = 1;
	}
      }
    }
  }	// End of loop over cards


#ifndef VCTP
  for( Card = 0; Card < pSysInfo->CardsPerCpu; Card ++) {
#else
  for(c_idx = 0; c_idx<pSysInfo->CardsPerCpu; c_idx++) {
    Card = cardIndx[c_idx];
#endif
    if(IS_T1E1(Card)) {
      ctp_check_t1_cfg(Card);
      PRTDVC(GEN,check T1 cfg, Card);
    }
  }
}

