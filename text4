    }
    // Aricent PR 1362733 fix - End
  } else {
    Ctp.Snmp.TrapAble = 0;
    PRT(EVE,SNMP traps disabled);
    Ctp.Snmp.TrapType = 0;    // Aricent PR 1362733 fix
  }
  return(RetStat);
}

//-------------------------------------------------------------------------
int ctp_route_chk( int Card, int pNum )
{
#define MAX_ROUTE_ERR		4
  struct acrndrv_command	ncmd;
  char	 		SccBuf[10];
  int			rt_bad = 0, check_lvl = 2;
  CTP_PORT_STATE	*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  FUNC_PRT(ctp_route_chk, PF_PST, pNum);

  //--- check_lvl:
  //        0    : Return error if hh or egress device changes.
  //               Setup prebuilt pkt_hdr if change occurred.
  //        1    : Return error if either hh or egress device changed.
  //        2    : Return error only if egress device changed.
  if( (pPortSt->State == CTP_PORT_STATE_IN_SYNC) ||
      (pPortSt->State == CTP_PORT_STATE_RUNNING) ) { check_lvl = 1; }


  // Always return success for Hairpinned, Unidirectional Destination, & PBS ports.
  if( HAIRPIN(Card,pNum)  ||
      UNI_DIR_DST(Card,pNum)  ||
      (PBS(Card,pNum) ) ) {
    rt_bad = 0;
  } else {
    sprintf(SccBuf,"scc%d",pPortSt->SccNum);
    ncmd.CmdType = SCC_CMD_RT_LOOKUP;
    ncmd.CmdObj2 = check_lvl;
    ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
    if( (ncmd.CmdObj != 2) &&
	(strncmp(pPortIntSt->NetDev, "NONE", 4)==0) ) {
       sprintf(pPortIntSt->NetDev,"%s",ncmd.CmdObj5);
       PRTSP(GEN,Initializing egress dev as, pPortIntSt->NetDev);
    }
    //--- Want TWO bad route checks in a row to send state to CFG_FAIL
    if( (ncmd.CmdObj) ||
	(strncmp(pPortIntSt->NetDev,ncmd.CmdObj5, 4)) ) {	//--- This Rt changed....
      if( pPortIntSt->NetDev != NULL ) {
	struct CtpNidInfo iface;
	//--- Check to see if ehternet failover has removed old egress device
	memset( (char *)&iface, 0, sizeof(iface) );
	sprintf( iface.name, "%s", pPortIntSt->NetDev);
	/* Find the structure for NID interface in order to fill my node to use */
	if( ctp_nid_qry_dev( Card, pNum, &iface ) ) {
	  //-- Old device is gone, start using new....
	  sprintf(pPortIntSt->NetDev,"%s",ncmd.CmdObj5);
	  PRTSP(GEN,Setting egress dev as, pPortIntSt->NetDev);
	}
      }
      //--- If last was also bad, Send state to CFG_FAIL
      if ( pPortIntSt->RtStaleCnt >= MAX_ROUTE_ERR ) {
	rt_bad = 1;
        pPortIntSt->RtStaleCnt = 0;
	if( ncmd.CmdObj5 != NULL ) {
	  sprintf(pPortIntSt->NetDev,"%s",ncmd.CmdObj5);
          PRTSP(GEN,Setting egress dev as, pPortIntSt->NetDev);
	}
	PRTDVP(GN2,Route chk: dd rt_bad is,rt_bad);
      } else {
	  //--- Mark Rt bad for next time through.
	  pPortIntSt->RtStaleCnt++;
      }
    } else {		//--- This Rt good.
      pPortIntSt->RtStaleCnt = 0;
    }
  }
// PR 1334121 fix - Start
if((IPV6(Card,pNum)) && UNI_DIR_DST(Card,pNum)){
    sprintf(SccBuf,"scc%d",pPortSt->SccNum);
    ncmd.CmdType = SCC_CMD_RT_LOOKUP;
    ncmd.CmdObj2 = check_lvl;
    ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);

    if( (ncmd.CmdObj != 2) &&
        (strncmp(pPortIntSt->NetDev, "NONE", 4)==0) ) {
       sprintf(pPortIntSt->NetDev,"%s",ncmd.CmdObj5);
       PRTSP(GN3,unidirectional Initializing egress dev as, pPortIntSt->NetDev);
    }

}
// PR 1334121 fix - End

		// Hairpin or unidirectional destination.
  if( pPortIntSt->NetDev != NULL ) {
    PRTSP(GN3,Leaving ctp_route_chk with egress dev as, pPortIntSt->NetDev);
  }
  return rt_bad;
}

