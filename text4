		 (pPortIntSt->CntrSel == CTP_FREE_CNT_SEL_ST))) {
	      pPortIntSt->NomCtrFreq = (double)Freq/((double)Acc*500);
	      PRTFV(DBG,Just set nom tx freq,pPortIntSt->NomCtrFreq);
	      //--- Update buffer settings with more accurate values in case we
