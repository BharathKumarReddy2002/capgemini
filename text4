      pSysInfo->Card[slot].PldRev  = nstat.pld_rev;
      pSysInfo->Card[slot].FpgaRev = nstat.fpga_rev;

      sprintf(prtbuf,"Found card %d type %s rev %d with %d ports\n",
	  slot, (pSysInfo->Card[slot].Type == SCCARD)? "SCC": "T1",
