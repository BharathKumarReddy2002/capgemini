//-------------------------------------------------------------------------
// This function will connect the peak detector to a specific port:chan,
// and clear it to 0.
//-------------------------------------------------------------------------
int dcard_4w_clr_peak_det( int Card, int pNum, int chan )
{
  u32 data = 0;
  int sccNum = Ctp.Card[Card].Port[pNum].SccNum;
  FUNC_PRT(dcard_4w_clr_peak_det, PF_DCARD, pNum);

  BAILTESTF(chan>1,Invalid channel ID);
  fpga_clr_fcfg();
  if( chan   )	data |= 0x1;		// bit 0
  data |= 0x2;				// activate peak clear
  pld_set_reg(pNum,0x7,data,2);
  data &= ~0x2;				// DE-activate peak clear
  pld_set_reg(pNum,0x7,data,2);
  fpga_send_fcfg(sccNum);
  return(SUCCESS);
}

