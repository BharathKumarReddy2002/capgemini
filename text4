// Warning: Even though only the card is passed to the routine, the port is
// also passed implicitley via the port database DbP.
// TODO mike - I just copied this from menutl_get_port_type() for use in
// the ctp daemon domain. When we move to shared memory, this routine and
// that one can be collapsed into one.
int utl_get_port_type( int Card, int pNum )
{
  int type;
  if( CARDTYPE(Card) == T1CARD ) {
    type = PORT_TYPE_T1E1_CARD;	// T1card interface
  } else if( CARDTYPE(Card) == EMCARD ) {
    type = PORT_TYPE_4WEM;	// T1card interface
  } else if( CARDTYPE(Card) == FXSCRD ) {
    type = PORT_TYPE_FXS;	// T1card interface
  } else if( CARDTYPE(Card) == FXOCRD ) {
    type = PORT_TYPE_FXO;	// T1card interface
  } else if( CARDTYPE(Card) == SCCARD ) {
    //--- Available dcard, don't care if it is in use.
    switch(Dcard.Card[Card].Info[pNum].Type) {
      case DCARD_4WTO:
      type = PORT_TYPE_SER_DCARD_4WTO_DCARD;
        break;
      case DCARD_T1E1:
      type = PORT_TYPE_SER_DCARD_T1E1_DCARD;
        break;
      case DCARD_IRIG:
      type = PORT_TYPE_SER_DCARD_IRIG_DCARD;
        break;
      case DCARD_MS:
      type = PORT_TYPE_SER_DCARD_MS_DCARD;
        break;
      default:
      type = PORT_TYPE_SER_CARD;
        break;
    }
  } else {
    //--- Unknown card!
    type = PORT_TYPE_UNKNOWN;
  }
  return(type);
}

