{
  struct acrndrv_command         ncmd;
  int	old_scc, old_available;
  struct timeval	now;
  CTP_PORT_STATE	*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  CTP_PORT_DBASE        *pPortDb = &Db.Card[Card].Port[pNum];
  int                   bNum= util_get_next_bNum(pPortDb, -1); //Aricent PR 704072
  CTP_PORT_CNTRS	*pPortCnt = &Ctp.Card[Card].Cntr[pNum];
  CtpBndlCntrs          *pCsBndlCnt = &Ctp.Bndl_cnt[bNum].Bndl.ctp;
  char                  SccBuf[40];
  FUNC_PRT(ctp_init_port_state, PF_PST, pNum);

  //TODO Save old values through init.  Best would be to move these
  //    another global structure... Do that when there is time...
  old_scc = pPortSt->SccNum;
  old_available = pPortSt->Available;
  old_available = pPortSt->Available;
 //Aricent PR 704072 start
#ifndef  VCTP 
  sprintf(SccBuf,"scc%d",pPortSt->SccNum);
#else 
  sprintf(SccBuf,"scc%d",Card*pSysInfo->PortsPerCard+pNum);
#endif
  //--- clear scc counts
  ncmd.CmdType = SCC_CMD_CLR_CNTRS;
  ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
  ncmd.CmdType = SCC_CMD_CLR_FLAGS;
  ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
//Aricent PR 704072 End
  memset(pPortSt,0,sizeof(CTP_PORT_STATE));
  memset(pPortIntSt,0,sizeof(CTP_PORT_INT_STATE));
  memset(pPortCnt,0,sizeof(CTP_PORT_CNTRS));
  if(bNum < CTP_MAX_BNDLS )
    memset(pCsBndlCnt,0,sizeof(CtpBndlCntrs)); //Aricent PR 704072
  pPortSt->BertPat = BERT_PAT_15;
  pPortSt->Card = Card;
  pPortSt->pNum = pNum;
  if( p == -1 ) {	// Use what was there
    pPortSt->SccNum = old_scc;
    pPortSt->Available = old_available;
  } else {		// Initialize them, will be reset by ctp_check();
    pPortSt->SccNum    = ~0;;
    pPortSt->Available = 0;
  }
  pPortSt->RdntOnline = 2;	// Not YES or NO (will force transition logic)
  pPortSt->RdntActiveCnt = 12;	// So that port does not go online immediately
  gettimeofday(&now,NULL);
  pPortCnt->TimeLastClr = now.tv_sec;
  pPortCnt->Current.Buffer.restart_flag = 1;
  pPortIntSt->HdlcCryptoCounter = CRYPTO_WAIT_TIME(Db.Card[Card].Port[pNum].CryptoResync1);
  pPortIntSt->RdntTmToggleVal = 0;
  pPortIntSt->RdntTmToggleHold = 10;
