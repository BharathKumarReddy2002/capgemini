      pSysInfo->Card[slot].PcaRev = nstat.board_rev;

      sprintf(prtbuf,"Card rev %d;%s;slot %d;base scc %d\n",
	  nstat.board_rev, sccbuf, slot, pSysInfo->Card[slot].BaseSccNum);
      PRTS(EVE,,prtbuf);


