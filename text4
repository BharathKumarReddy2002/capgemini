int ctpd_get_perl_mbox ( int code, void * pParam, char *pSuffix )
{
  FILE	*pPerlMbox = NULL;
  u32   	ip1, ip2, ip3, ip4, TempIp;
  char	 	Buf[40], Buf2[40], SysRmCmd[100];
  unsigned int ma1, ma2, ma3, ma4, ma5, ma6;
  int	 	error = 0;
  ETH_ADDR	*pEthAddr;
  int	 	status;
  FUNC_PRT(ctpd_get_perl_mbox, PF_MISC, -1);

  sprintf(Buf,"%s/%s_%s",CTP_DIR,CTP_PERL_MBOX,pSuffix);
  sprintf(SysRmCmd,"/bin/rm %s",Buf);
  pPerlMbox = fopen(Buf, "r");
  if(pPerlMbox == NULL) {
    PRTS(MIN,Could not open file,Buf);
    error++;
    *(int *)pParam = 0;				// return NULL
    return(FAILURE);
  }
  switch(code) {
    case CTP_MBOX_CODE_MACADDR:
      pEthAddr = (ETH_ADDR  *)pParam;
      status = fscanf(pPerlMbox,"%2x:%2x:%2x:%2x:%2x:%2x",
	  (unsigned int *)&ma1, (unsigned int *)&ma2, (unsigned int *)&ma3,
	  (unsigned int *)&ma4, (unsigned int *)&ma5, (unsigned int *)&ma6 );
      if(status != 6) {
	PRTS(MIN,Could not get Mac address from file,Buf);
	fclose(pPerlMbox);
	return(FAILURE);
      } else {
	sprintf(Buf2,"%x:%x:%x:%x:%x:%x", (unsigned int)ma1, (unsigned int)ma2,
	    (unsigned int)ma3, (unsigned int)ma4, (unsigned int)ma5, (unsigned int)ma6);
	//PRTS(OFF,Mac address:,Buf2);
      }
      pEthAddr->octet[0] = ma1; pEthAddr->octet[1] = ma2;
      pEthAddr->octet[2] = ma3; pEthAddr->octet[3] = ma4;
      pEthAddr->octet[4] = ma5; pEthAddr->octet[5] = ma6;
      break;
    case CTP_MBOX_CODE_IP:
      status = fscanf(pPerlMbox,"%d.%d.%d.%d",(int *)&ip1, (int *)&ip2, (int *)&ip3, (int *)&ip4);
      if(status != 4) {
	PRTS(MIN,Could not get IP address from file,Buf);
	fclose(pPerlMbox);
	return(FAILURE);
      }
      TempIp  = ((ip1 << 24) & 0xff000000);
      TempIp |= ((ip2 << 16) & 0x00ff0000);
      TempIp |= ((ip3 << 8) & 0x0000ff00);
      TempIp |= ( ip4 & 0x000000ff);

      *(unsigned int *)pParam = TempIp;

      break;
    case CTP_MBOX_CODE_STRING:
      status = fscanf(pPerlMbox,"%s",(char *)pParam);
      if(status != 1) {
	PRTS(MIN,Could not get string from file,Buf);
	fclose(pPerlMbox);
	return(FAILURE);
      }
      break;
    default:
      PRTDV(MIN,Unsupported mbox code,code);
      break;
  }
  fclose(pPerlMbox);
  acorn_system(SysRmCmd);
  return(SUCCESS);
}

//--------------------------------------------------------------------------
int compare_longs (const void *a, const void *b)
{
  const u32 *da = (const u32 *) a;
  const u32 *db = (const u32 *) b;
  return (*da > *db) - (*da < *db);
}

//--------------------------------------------------------------------------
// This function generates a serial driver IOCTL configuration word from
// the global database structure.
//
// Dbase has an 8 bit word for each signal, and an array of 8 of these for
// all signals. Output signals are array indexes 3-0 (TM,DCD,CTS,DSR), and
// input signals are array indexes 7-4 (LL,DTR,RTS,RL).
// Output signal word:
// +--------------+------------------+
// | mode (4 bit) | Function (4 bit) |
// +--------------+------------------+
// mode = 0 -> MODE_FIXED,  Function[0] is fixed signal value
// mode = 1 -> MODE_INBAND, Function[1:0] is remote sig (LL,DTR,RTS,RL)
//
// Driver IOCTL 16 bit config word looks like:
// +--------+---------+---------+---------+
// | TM cfg | DCD cfg | CTS cfg | DSR cfg |
// +--------+---------+---------+---------+
// Each 4 bit cfg nibble:
//	5 - Fixed value of 1
//	4 - Fixed value of 0
//	3 - Follow remote LL
//	2 - Follow remote DTR
//	1 - Follow remote RTS
//	0 - Follow remote RL
//--------------------------------------------------------------------------
void ctp_gen_sigo_cfg( u8 Sig[CTP_MAX_SIGS], u16 * pSigCfg)
{
  u8	SigDb, Mode, Func;
  u16	SigCfg;
  int	i;
  FUNC_PRT(ctp_gen_sigo_cfg, PF_MISC, -1);

  *pSigCfg = 0;					// Clear cfg
  for(i=0;i<4;i++) {
    SigDb = Sig[i];
    Mode = (SigDb >> 4) & 0xf;
    Func = SigDb & 0xf;
    if( Mode == CTP_SIG_OUT_MODE_FIXED ) {
      if( (Func & 0x1) == 0 )	SigCfg = 4;
      else			SigCfg = 5;
    }
    else if( Mode == CTP_SIG_OUT_MODE_INBAND ) {
      SigCfg = Func & 0x3;
    }
    *pSigCfg |= (SigCfg << (i * 4));		// Put cfg in correct pos'n
  }
  //PRTV(OFF,Sigout CFG,*pSigCfg);
}

//--------------------------------------------------------------------------
// Dbase has an 8 bit word for each signal, and an array of 8 of these for
// all signals. Output signals are array indexes 3-0 (TM,DCD,CTS,DSR), and
// input signals are array indexes 7-4 (LL,DTR,RTS,RL).
// Input signal word:
// +--------------+------------------+
// | mode (4 bit) | Function (4 bit) |
// +--------------+------------------+
// mode = 1 -> MODE_DEMAND, Function[0] == 1 means flipped demand signal
//--------------------------------------------------------------------------
void ctp_gen_sigi_cfg( u8 Sig[CTP_MAX_SIGS], u16 * pDemandCfg)
{
  u8	SigDb, Mode, Func, Mask, Flip;
  int	i;
  FUNC_PRT(ctp_gen_sigi_cfg, PF_MISC, -1);

  *pDemandCfg = 0;				// Clear cfg
  Mask = Flip = 0;
  for(i=0;i<4;i++) {
    SigDb = Sig[i+4];
    Mode = (SigDb >> 4) & 0xf;
    Func = SigDb & 0xf;
    if( Mode == CTP_SIG_IN_MODE_DEMAND ) {
      if( (Func & 0x1) == 0 )	Flip |= (1 << i);
    }
    else Mask |= (1 << i);
    *pDemandCfg = (Flip << 8) | Mask;		// Build cfg word
  }
  //PRTV(OFF,Demand CFG,*pDemandCfg);
}

