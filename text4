//--------------------------------------------------------------------------
// This routine opens a socket to a remote host for transmission of OAM
// packets. The only item in the CTP_NODE_CONN structure which needs to be
// filled is the node IP address.
//--------------------------------------------------------------------------
int ctp_con_rem_node(CTP_NODE_CONN * pNodeConn, int flag, CTP_NODE_STORAGE node)
{
  struct hostent 	*pHost;
  struct in_addr 	 HostAddr;
  socklen_t		 OptLen = sizeof(int);
  int			 Status;
  int			 On=1;
  struct sockaddr_in	sockaddr;
  FUNC_PRT(ctp_con_rem_node, PF_IPC, -1);

  //PR-1864750 Start
  if (pNodeConn == NULL) {
      fprintf(stderr, "pNodeConn is NULL\n");
      return FAILURE;
  }
  //PR-1864750 End


  if(flag & CON_FLAG_USE_IPV6)
    pNodeConn->TxSock = socket(PF_INET6, SOCK_DGRAM, 0);
  else
    pNodeConn->TxSock = socket(PF_INET, SOCK_DGRAM, 0);

  BAILTESTF(pNodeConn->TxSock<0,Cant open OAM socket to remote device);
  PRTDV(GEN,Opened remote node conn using Tx Socket,pNodeConn->TxSock);

  if((flag & CON_FLAG_USE_IPV6)==0)
  {
    Status = setsockopt(pNodeConn->TxSock,
       			IPPROTO_IP,
			IP_TOS,
			(int *)&pNodeConn->Tos,
			OptLen );
    if(Status) {
      PRT(MAJ,Cant set IP_TOS socket option);
      PRTS(MAJ,Error message:,strerror(errno));
    }
  }
  if( flag & CON_FLAG_USE_SRC_PORT_MIRROR ) {
    // Set the socket not to do checksums
    Status = setsockopt(  pNodeConn->TxSock,
                        SOL_SOCKET,
                        SO_NO_CHECK,
                        &On,
                        OptLen );
    if(Status) {
      PRT(MAJ,Cant set SO_NO_CHECK socket option);
      PRTS(MAJ,Error message:,strerror(errno));
    }
  }
#if 0	// PR 995120
  // Set the socket not to do checksums
  Status = setsockopt(	pNodeConn->TxSock,
      			SOL_SOCKET,
			SO_NO_CHECK,
			&On,
			OptLen );
  if(Status) {
    PRT(MAJ,Cant set SO_NO_CHECK socket option);
    PRTS(MAJ,Error message:,strerror(errno));
  }
#endif
  if( flag & CON_FLAG_USE_VIP ) {
    //--- Set up socket option to share this IP
    Status = setsockopt(pNodeConn->TxSock,
	SOL_SOCKET,
	SO_REUSEADDR,
	&On,
	OptLen );
    if(Status) {
      PRT(MAJ,Cant set SO_REUSEADDR socket option);
      PRTS(MAJ,Error message:,strerror(errno));
    }
    //--- Must bind to the vip address so OAM's have proper source ip
    //    address (ie that of the vip).
    memset(&sockaddr, 0, sizeof(sockaddr)); //PR-1864750
    sockaddr.sin_family = AF_INET;
    sockaddr.sin_addr.s_addr = htonl(node.v4);
    sockaddr.sin_port = 0;
    if( bind( pNodeConn->TxSock,
	  (struct sockaddr *)&sockaddr,
	  sizeof(sockaddr) ) < 0) {
      PRT(MAJ,Error binding socket to address);
      PRTS(MAJ,Error message:,strerror(errno));
    }
  }

  if( pNodeConn->Node.Type == CTP_IPV4 ) {
    HostAddr.s_addr = htonl(pNodeConn->Node.v4);
    // Aricent PR 1426159 fix - Start
    pHost = (struct hostent *)gethostbyname((char *)inet_ntoa(HostAddr));
    BAILTESTF(pHost==0,Cant get host entity);

    PRTS(GEN,Opening Tx Sock to rem host,inet_ntoa(HostAddr));
    PRTDV(GEN,Tx Socket to remote host on UDP Port,pNodeConn->TxSock);

    //--- build socket address for remote device transmissions ---
    bcopy(pHost->h_addr, &pNodeConn->RemAddr.sin_addr, pHost->h_length);
    pNodeConn->RemAddr.sin_family = AF_INET;
    pNodeConn->RemAddr.sin_port = htons(pSysInfo->oam_port);
  } else if( pNodeConn->Node.Type == CTP_IPV6 ) {
    // CTP_NODE_CONN structure has no ipv6 address field that needs to be
    // filled in. As ipv6 address are filled in sockaddr_in6 structure in
    // ctp_send_msg() routine.
    PRT(GEN,Host Address is in IPv6 format);
    // Aricent PR 1426159 fix - End
  } else {
    PRT(MIN,Unsupported Host address format);
  }
  return(SUCCESS);
}

//--------------------------------------------------------------------------
// This routine checks the entire database, looking for active ports. For
// every active port, an OAM connection is made to the remote host (if one
// does not already exist) and the port is added to the appropriate linked
// list for monitoring.
//--------------------------------------------------------------------------
