void ctp_fill_eeprom_text(char *Buf) {
  int i=0;	
  FUNC_PRT(ctp_fill_eeprom_text, PF_START, -1);
  //--- Copy to SysInfo structure
  Buf[32] = 0;					// Make sure string ends
  while( Buf[i] != 0 ) {
    if( !isprint(Buf[i]) ) {			// If unprintable char...
      Buf[0] = 0;				// ...null entire string
      PRT(EVE,Found unprintable character - nulling string);
      break;
    }
    i++;
  }
  strncpy(pSysInfo->EEPromText, Buf, EEPROM_TEXT_LEN);
}

//--------------------------------------------------------------------------
// This routine reads the optional text message from the EEPROM. It is a
// string of up to 31 characters.
//--------------------------------------------------------------------------
void ctp_get_eeprom_text()
{
  struct acrndrv_command	 ncmd;
  int i;
  char				 Buf[80];

  FUNC_PRT(ctp_get_eeprom_text, PF_START, -1);
  memset(Buf, 0, sizeof(Buf));
  if ((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) {
#ifndef XMC
    char cmd_str[200];
    sprintf(cmd_str,"/acorn/bin/smbutil -F CTP_DESC -c 0 -r > /tmp/smbout\n");
    PRTS(GEN,running cmd,cmd_str);
    if(acorn_system(cmd_str)) {
      PRTS(MAJ,,"@@@ Problem running smbutil\n");
    } else {
      FILE *fptr;
      if((fptr = fopen("/tmp/smbout", "r+")) != NULL){
	fscanf(fptr, "Read-> CTP_DESC field, %[^.].", Buf);
	fclose(fptr);
	PRTS(GEN,Read,pSysInfo->EEPromText);
	ctp_fill_eeprom_text(Buf);
      } else {
	PRTS(MAJ,,"@@@ cant open smbout file\n");
      }
    }
    acorn_system("/bin/rm -f /tmp/smbout");
#else // XMC
    sprintf(Buf,"TODO: get vCTP EEPROM access working");
    ctp_fill_eeprom_text(Buf);
#endif // XMC

  } else {
    if(SCC_CARD(0)) {
      //----- pull text string out of EEPROM and check validity -----
      for(i=0x60;i<0x80;i++) {
	ncmd.CmdType = SCC_CMD_READ_EEPROM;
	ncmd.CmdObj = i;				// Value is a short at 16/17
	ioc_priv("scc0",SCC_IOCTL_CMD,&ncmd);
	Buf[i-0x60] = ncmd.CmdObj2;
	if( Buf[i-0x60] == 0 ) break;
      }
      ctp_fill_eeprom_text(Buf);
    }
  }
}

//--------------------------------------------------------------------------
// This routine reads the calibrated VCXO setting from the EEPROM. If it is
// not set, it will be 0xffff. A valid entry will have the MSB = 0.
//--------------------------------------------------------------------------
void ctp_get_pll_cal(int Card)
{
  char				SccBuf[40];
  struct acrndrv_command	ncmd;
  u16			Calibration = 0;
  FUNC_PRT(ctp_get_pll_cal, PF_REF, -1);

  if ((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) {
#ifndef XMC
    char cmd_str[200];
    sprintf(cmd_str,"/acorn/bin/smbutil -F CTP_VCX_R -c %d -r > /tmp/smbout\n", Card);
    PRTSC(GEN,running cmd,cmd_str);
    if(acorn_system(cmd_str)) {
      PRTS(MAJ,,"@@@ Problem running smbutil\n");
    } else {
      FILE *fptr;
      if((fptr = fopen("/tmp/smbout", "r+")) != NULL){
        #ifdef WRL
	fscanf(fptr, "Read-> CTP_VCX_R field, %hu.", &Calibration);
        #else
	fscanf(fptr, "Read-> CTP_VCX_R field, %d.", &Calibration);
        #endif
	fclose(fptr);
	/* Range check on the value 0~4096*/
	if(Calibration & 0xe000) Calibration = 0x800;
      } else {
	PRTS(MAJ,,"@@@ cant open smbout file\n");
      }
    }
    acorn_system("/bin/rm -f /tmp/smbout");
#else // XMC
    Calibration = 0x8000;	// center
#endif // XMC
  } else if( pSysInfo->SysType == SYS_TYPE_CTP_2000 ) {
    if( !((pSysInfo->Card[Card].SubType == HW_SUBTYPE_CTP2000_IM_8P_T1E1_B) ||
      (pSysInfo->Card[Card].SubType == HW_SUBTYPE_CTP2000_IM_8P_B)) ) { //For ctp2k old cards PR-1739392
      sprintf(SccBuf,"scc%d",pSysInfo->Card[Card].BaseSccNum);
      ncmd.CmdType = SCC_CMD_READ_EEPROM;
      ncmd.CmdObj = 17;				// Value is a short at 16/17
      ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);

      Calibration = ncmd.CmdObj2;
      ncmd.CmdObj = 16;				// Location 16 holds the MSB
      ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);

#ifdef TARGET
    Calibration += ncmd.CmdObj2 << 8;
#else // not TARGET
    Calibration = 1000;		// Bogus value
#endif // TARGET
  } else { //For ctp2k new cards CAP PR-1739392 Start
      sprintf(SccBuf,"scc%d",pSysInfo->Card[Card].BaseSccNum);
      ncmd.CmdType = SCC_CMD_READ_EEPROM;
      ncmd.CmdObj = CTP_VCXO_OFFSET+1;
      ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);

      Calibration = ncmd.CmdObj2;
      ncmd.CmdObj = CTP_VCXO_OFFSET;
      ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);

#ifdef TARGET
      Calibration += ncmd.CmdObj2 << 8;
      if(Calibration & 0xe000) Calibration = 0x800;
#else // not TARGET
      Calibration = 1000;               // Bogus value
#endif // TARGET
    }
  } //CAP PR-1739392 End

  Ctp.Node[Card].Calibration = Calibration;	// Make available for use
  if( (Calibration & 0x8000) == 0 ) {
    PRTU16C(EVE,Valid calibration value,Calibration);
  }
}

//--------------------------------------------------------------------------
// This routine writes the calibrated VCXO setting to the EEPROM. It also
// updates the node state so that the PLL routines know about it.
//--------------------------------------------------------------------------
void ctp_set_pll_calibration( int Card, u16 CalibValue )
{
  char				SccBuf[40];
  struct acrndrv_command	ncmd;
  FUNC_PRT(ctp_set_pll_calibration, PF_REF, -1);

  if ((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) {
#ifndef XMC	// Skip write for now
    char cmd_str[200];
    sprintf(cmd_str,"/acorn/bin/smbutil -q -F CTP_VCX_R -c %d -w %d\n",
	Card, CalibValue);
    PRTSC(GEN,running cmd,cmd_str);
    acorn_system(cmd_str);
#endif // XMC
  } else if( pSysInfo->SysType == SYS_TYPE_CTP_2000 ) {
    if( !((pSysInfo->Card[Card].SubType == HW_SUBTYPE_CTP2000_IM_8P_T1E1_B) ||
            (pSysInfo->Card[Card].SubType == HW_SUBTYPE_CTP2000_IM_8P_B)) ) { //For ctp2k old cards PR-1739392
      //PRTDV(OFF,Setting PLL calibration value,CalibValue);
      sprintf(SccBuf,"scc%d",pSysInfo->Card[Card].BaseSccNum);
      ncmd.CmdType = SCC_CMD_WRITE_EEPROM;
      ncmd.CmdObj = 17;				// Value is a u16 at 16/17
      ncmd.CmdObj2 = CalibValue & 0xff;
      ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);

      usleep(200000);				// wait 200 ms

      ncmd.CmdObj = 16;				// Location 16 holds the MSB
      ncmd.CmdObj2 = (CalibValue >> 8) & 0xff;
      ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
  } else { //For new cards of ctp2k CAP PR - 1739392 Start
       //PRTDV(OFF,Setting PLL calibration value,CalibValue);
       sprintf(SccBuf,"scc%d",pSysInfo->Card[Card].BaseSccNum);
       ncmd.CmdType = SCC_CMD_WRITE_EEPROM;
       ncmd.CmdObj = CTP_VCXO_OFFSET+1;
       ncmd.CmdObj2 = CalibValue & 0xff;
       ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);

       usleep(200000);                         // wait 200 ms

       ncmd.CmdObj = CTP_VCXO_OFFSET;
       ncmd.CmdObj2 = (CalibValue >> 8) & 0xff;
       ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
    } //CAP PR - 1739392 End
  }


  Ctp.Node[Card].Calibration = CalibValue;	// Make available for use
  if( (Ctp.Node[Card].Calibration & 0x8000) == 0 ) {
    PRTDVC(EVE,Prog valid clk calibration ,Ctp.Node[Card].Calibration);
  }
}

