//==================================================================
// This routine processes a State query message. It fills the return
// message with the requested data and sends it on its way.
//==================================================================
int ctp_proc_msg_st_qry( CTP_Q_MSG * pMsg )
{
  CTP_Q_MSG		 TMsg;
  int			 Card,pNum, bNum;
  FUNC_PRT(ctp_proc_msg_st_qry, PF_IPC, -1);
#ifdef DBG_MSG_QUEUE
  PRT(EVE,CTP processing state qry message);
#endif

    ctp_copy_msg_hdr( pMsg, &TMsg );	// build header of response message

    switch(pMsg->CtpMsg.MsgType) {
      case CTPMSGTYPE_ST_QRY_ETH:
        PRT(GEN,Received ST_QRY_ETH msg);
        bcopy(&Ctp.Eth, &TMsg.CtpMsg.msg.StE.St, sizeof(CTP_ETH_STATE));
        ctp_send_msg(&TMsg);
        break;

      case CTPMSGTYPE_ST_QRY_PORT:
	Card = pMsg->CtpMsg.msg.StP.Card;
	pNum = pMsg->CtpMsg.msg.StP.pNum;
	PRTP(GEN,Received ST_QRY_PORT msg);
	bcopy(&Ctp.Card[Card].Port[pNum],&TMsg.CtpMsg.msg.StP.St,sizeof(CTP_PORT_STATE));

	//PRT(DBG,=== Printing State Element);
	//util_prt_st_port(&Ctp.Port[Port]);
	//PRT(DBG,=== Printing State Element copied to Msg);
	//util_prt_st_port(&TMsg.CtpMsg.msg.StP.St);

	ctp_send_msg( &TMsg );
	break;

      case CTPMSGTYPE_ST_QRY_HDLC_PORT:
	Card = pMsg->CtpMsg.msg.StP.Card;
	pNum = pMsg->CtpMsg.msg.StP.pNum;
        PRTP(GEN,Received ST_QRY_HDLC_PORT msg);
	bcopy(&Ctp.Card[Card].PortInt[pNum].hdlcstatus,
	    &TMsg.CtpMsg.msg.HdlcP.St,sizeof(hdlc_status));
	ctp_send_msg( &TMsg );
        break;

      case CTPMSGTYPE_ST_QRY_DCARD:
	PRT(GEN,Received ST_QRY_DCARD msg for Dcard struct);
	bcopy(&Dcard,&TMsg.CtpMsg.msg.StD.St,sizeof(CTP_DCARD));
	ctp_send_msg( &TMsg );
	break;

      case CTPMSGTYPE_ST_QRY_NODE:
	Card = pMsg->CtpMsg.msg.StN.Ncp.Card;
	PRTDV(GEN,Received local ST_QRY_NODE msg for card,Card);
	bcopy(&Ctp.Node[Card],&TMsg.CtpMsg.msg.StN.St,sizeof(CTP_NODE_STATE));
	ctp_send_msg( &TMsg );
	break;
      case CTPMSGTYPE_ST_QRY_BNDL:
        bNum = pMsg->CtpMsg.msg.StB.bNum;
	PRTDV(GEN,Received local ST_QRY_BNDL msg for bndl,bNum);
	bcopy(&Ctp.Bndl[bNum],&TMsg.CtpMsg.msg.StB.St,sizeof(CTP_BNDL_STATE));
        ctp_send_msg( &TMsg );
	break;
      case CTPMSGTYPE_ST_QRY_DSP:
      {
        int dspId = pMsg->CtpMsg.msg.StDsp.dspId;
        ctp_get_dsp_usage(dspId);
        ctp_send_msg( &TMsg );
        break;
      }
      default:
	PRTV(MIN,Unexpected message type,pMsg->CtpMsg.MsgType);
	TMsg.CtpMsg.Status = FAILURE;
	break;
    }
  return(TMsg.CtpMsg.Status);
}



