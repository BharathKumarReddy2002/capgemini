//--- Sends network reference pkts
//    TODO: Add support for IPv6.
int ctp_netref_client(int sock) {
  FUNC_PRT(ctp_netref_client, PF_REF, -1);
  char datagram[4096];	// Probably should reduce the size here!
  CTP_IP_HDR *iph = (CTP_IP_HDR *)datagram;
  CTP_NET_REF_PAYLOAD *nr_data = (CTP_NET_REF_PAYLOAD *)(datagram + sizeof(CTP_IP_HDR));
  struct sockaddr_in sin;
  int iph_size = sizeof(CTP_IP_HDR);
  int stat, n_indx=0;
  char keybuf[20];
  CTP_NREFS_STATE NodeRef, IntCardRef;
  #ifdef XMC
  CTP_NREFS_STATE XmcCardRef;
  #endif
  PRT(GEN,ctp_netref_client called);

  memset(datagram, 0 , 4096);

  //--- Fill in netref pkt type
  nr_data->type = 1;	//TODO: make define!
  //--- Fill in ip header
  iph->ip_hl  = 5;
  iph->ip_v   = 4;
  iph->ip_tos = pNRefs->tos;
  iph->ip_id  = 0x00fc;		// Fixed at 252!!
  iph->ip_len = sizeof(CTP_NET_REF_PKT);
  iph->ip_ttl = pNRefs->ttl;
  iph->ip_p   = pSysInfo->protocol;
  iph->ip_sum = 0;		// Set later!
  // Source address will get rewritten by iptables mangle rule to address of egress if.
  iph->ip_src = inet_addr("172.0.3.252");

  sin.sin_family = AF_INET;
  sin.sin_port   = 0;	//Re bug in man pages
  sin.sin_addr.s_addr = iph->ip_src;	// Dst address, filled in below!!
  
  //--- Initial seq num....
  nr_data->seq_num = 0xfff0;
  
  //--- Following for CTP150 node reference 
  memset(&IntCardRef, 0, sizeof(CTP_NREFS_STATE));
  ctp_init_node_refs_params(&IntCardRef);
#ifdef XMC
  memset(&XmcCardRef, 0, sizeof(CTP_NREFS_STATE));
  ctp_init_node_refs_params(&XmcCardRef);
#endif


  while(1) {
    if(pNRefs->Type == CTP_NETREF_TYPE_SRC) {
      // TODO: Check for valid IP address before sending.....
      int err = 0;
      int indx;

      for(n_indx = 0; n_indx<CTP_MAX_NETREF_SLVS; n_indx++){
	//--- send if next node is not loopback
	if( (pNRefs->Node[n_indx].Type == CTP_IPV4) &&
	    (pNRefs->Node[n_indx].v4 != (u32)ntohl(inet_addr("127.0.0.1"))) ) {
	  iph->ip_tos = pNRefs->tos;	// Set again in case they changed...
	  iph->ip_ttl = pNRefs->ttl;	// Set again in case they changed...
	  iph->ip_dst = htonl(pNRefs->Node[n_indx].v4);
	  iph->ip_sum = csum( (unsigned short *)datagram, iph->ip_len>>1);
	  sin.sin_addr.s_addr = iph->ip_dst;

	  //--- Look for ts to send
	  indx = ctp_ts_state_find_node( pNRefs->Node[n_indx] );
	  if( (indx >= 0) && (indx < CTP_MAX_TS_STATE) ) {
	    char buff[80];
	    nr_data->cntr = pNRefs->TsState[indx].ts;
	    nr_data->cntr_seq_num = pNRefs->TsState[indx].seq_num;
	    ctp_ts_state_clear( indx );
	    sprintf(buff,"Sending NetRef with ts_sn %d ts 0x%x",
		nr_data->cntr_seq_num,
		(unsigned int)nr_data->cntr);
	    PRTS(DBG,,buff);
	  }

	  if( (err =sendto ( sock, datagram, iph->ip_len, 0, (struct sockaddr *) &sin, sizeof(sin))) < 0 ) {
	    PRTDV(MAJ,Error sending netref pkt,err);
	  } else {
#ifdef DBG_NETREF
	    char buff[180];
	    sprintf(buff,"Sent netref pkt to node #%d with seq_num %d & ts seq_num %d & ts 0x%x.\n",
		n_indx, nr_data->seq_num, nr_data->cntr_seq_num, nr_data->cntr);
	    PRTS(MIN,,buff);
#endif
	    PRTDV(DBG,netref pkt sent with seqnum,nr_data->seq_num);
	    ctp_ts_state_add_sn_src(nr_data->seq_num, pNRefs->Node[n_indx]);
	  }
	  //--- Bump sequence number
	  nr_data->seq_num++;
	}
      }
    } 
      //--- Processing int card reference for ctp150
    if(ctp150_int_card_ref_needed()) ctp150_proc_node_ref(&IntCardRef);
#ifdef XMC
    if(xmc_dpll_locked()) {
      ctp150_proc_node_ref(&XmcCardRef);
      PRT(TMP,XXX Process XMC holdover);
    } else {
/** PR 1285669 
** Commented the print to avoid flooding of logs 
***/
//      PRT(TMP,XXX Dont Process XMC holdover yet);
    }
#endif    
    usleep(215000);	// 0.215 second		//TODO make this variable/configurable!
  }
}

void ctp_netref_get_slope( double * pslope, double * pslope_a, u32 * pave, CTP_NREFS_STATE *pNodeRef, int intCard )
{
  CTP_NREFS_BUFFER * Cur = &pNodeRef->Current;
  CTP_NREFS_BUFFER * Pre = &pNodeRef->Previous;
  double c_y = 1.0/(32.0*1.024);
  int max_sam =intCard? CTP_MAX_NODEREF_SAM: CTP_MAX_NR_SAM;
  double c_x = ((double)(Cur->sam_start.tv_sec - Pre->sam_start.tv_sec)/((double)max_sam));
  int    delta_x, delta_y;
  int    Card = intCard;	// Just for Card level PRTs
  double slope;
  double delta_x_a;
  int    delta_y_a;
  double slope_a;
  u32    c_ave=0, p_ave=0;
  int 	 i, p = 1;
  double c_ave_n=0.0, p_ave_n=0.0;
  char	 PrtBuf[150];
  FUNC_PRT(ctp_netref_get_slope, PF_REF, -1);
  
#ifdef DBG_NETREF
  sprintf(PrtBuf,"c_x %.4f t1 %d t2 %d dt %d, ns %d.",
      c_x, Cur->sam_start.tv_sec, Pre->sam_start.tv_sec, 
      (Cur->sam_start.tv_sec - Pre->sam_start.tv_sec), max_sam);
  PRTSC(GN2,X-scale,PrtBuf);
#endif	// DBG_NETREF
  //--- delta_y is in units of 32*1024*1000 Hz clock
  delta_y = (int)(Cur->max[0] - Pre->max[0]);
  //--- Ignore skipped buffers in slope (denom) calculation...
  //--- delta_x units determined by time difference between sample starts
  delta_x = (int)(Cur->max_n[0] - Pre->max_n[0] + max_sam);

  //--- Slope is in ppm
  slope = ((double)delta_y*c_y)/((double)delta_x*c_x);
  sprintf(PrtBuf,"slope %.4f: c_y %.4f, d_y %d, c_x %.4f, d_x %d.",
      slope, c_y, delta_y, c_x, delta_x);
  PRTSC(GEN,Calc,PrtBuf);
  

  if      ( CTP_MAX_NR_LUCKY_SAM == 3 ) p=1;
  else if ( CTP_MAX_NR_LUCKY_SAM == 5 ) p=2;
  else if ( CTP_MAX_NR_LUCKY_SAM == 9 ) p=3;

  //--- Get slope from averages of max buffers....
  for(i=1;i<CTP_MAX_NR_LUCKY_SAM;i++) {	// Toss 1st!
    c_ave   += Cur->max[i] >> p;	// Not real average, but....
    c_ave_n += (double)(Cur->max_n[i]/CTP_MAX_NR_LUCKY_SAM);
    p_ave   += Pre->max[i] >> p;	// Not real average, but....
    p_ave_n += (double)(Pre->max_n[i]/CTP_MAX_NR_LUCKY_SAM);
  }
#ifdef DBG_NETREF
  sprintf(PrtBuf,"c_m %d, p_m %d, c_ave %d, p_ave %d",
      Cur->max[0], Pre->max[0], c_ave, p_ave);
  PRTSC(MIN,Calc,PrtBuf);
#endif	// DBG_NETREF

  //--- delta_y is in units of 32*1024*1000 Hz clock
  delta_y_a = (int)(c_ave - p_ave);
  //--- Ignore skipped buffers in slope (denom) calculation...
  //--- delta_x units determined by time difference between sample starts
  delta_x_a = (c_ave_n - p_ave_n + (double)max_sam);

  //--- Slope is in ppm
  slope_a = ((double)delta_y_a*c_y)/(delta_x_a*c_x);
  sprintf(PrtBuf,"ave slope %.4f: c_y %.4f, d_y %d c_x %.4f, d_x %.4f.",
      slope_a, c_y, delta_y_a, c_x, delta_x_a);
  PRTSC(GEN,Calc,PrtBuf);
#ifdef DBG_NETREF
  sprintf(PrtBuf,"ave slope %.4f: m0 0x%x (0x%x) m1 0x%x (0x%x) m2 0x%x (0x%x) m3 0x%x (0x%x).",
      slope_a, Cur->max[0], Pre->max[0], Cur->max[1], Pre->max[1],
      Cur->max[2], Pre->max[2], Cur->max[3], Pre->max[3]);
  PRTSC(MIN,Calc,PrtBuf);
#endif	// DBG_NETREF
  sprintf(PrtBuf,"slope %.4f ave slope %.4f ave %d.", slope, slope_a, c_ave);
  PRTSC(GN2,Calc,PrtBuf);

  *pslope   = slope;
  *pslope_a = slope_a;
  *pave     = c_ave;
}

void ctp_netref_calc_pll_adj(CTP_NREFS_STATE *pNodeRef, int intCard) {
  CTP_NREFS_BUFFER * Cur = &pNodeRef->Current;
  double c_y = 1.0/(32.0*1.024);
  double c_x = (double)(Cur->sam_start.tv_sec - pNodeRef->Previous.sam_start.tv_sec);
  int	 i,p;
  int    Card = intCard;	// Just for Card level PRTs
  char 	 PrtBuf[150];
  u32    ave;
  double slope, slope_ave, slope_mntn;
  double PpmPerPll = ((double)Ctp.Node[0].VcxoPpmRange)/((double)CTP_PHDET_SPAN);
  double pll_adjust_aggr = 0.0, pll_adjust_mntn = 0.0;
  double pll_adjust_abs, pll_adjust, pll_adjust_cap;
  int	 pll_adjust_act;
  int	 skip_it = 0;
  FUNC_PRT(ctp_netref_calc_pll_adj, PF_REF, -1);

  ctp_netref_get_slope( &slope, &slope_ave, &ave, pNodeRef, intCard);

  if(pNodeRef->State == CTP_NETREF_STATE_AGGR) {
    double slope_abs = (slope < 0) ? -slope : slope;
    pll_adjust_aggr = 0.45 * slope_ave / PpmPerPll;
    pll_adjust_cap  = 0.45 * (double)pNodeRef->MaxAdjPpb / (1000.0 * PpmPerPll);
    pll_adjust_cap *= 30.0;	// In aggressive state
    if( slope_abs < pNodeRef->AdapMntnSlope ) {
      PRTC(MIN,NetRef state transition: aggressive -> maintain);
      if(intCard) ctp_set_led(PLL_LED_GREEN, 1);
      else ctp_set_led(PLL_LED_GREEN, 0);
      pNodeRef->State = CTP_NETREF_STATE_MNTN;
      pNodeRef->BufSetPt = pNodeRef->buffer;
    }
  } else if(pNodeRef->State == CTP_NETREF_STATE_MNTN) {
    double buf_err = (double)((int)(ave - pNodeRef->BufSetPt)) * c_y;
    slope_mntn = buf_err/(c_x * pNodeRef->MntnDecay);
    sprintf(PrtBuf,"slope mntn %.4f max %d buf set %d diff %d (%.1f) decays %.1f",
        slope_mntn, ave, pNodeRef->BufSetPt, (Cur->max[0]-pNodeRef->BufSetPt),
        buf_err, pNodeRef->MntnDecay);
    PRTSC(GN2,Calc,PrtBuf);
    sprintf(PrtBuf,"MaxBufError %d, buff error %.1f slope_aggr %.2f slope_mntn %.2f.",
	pNodeRef->MaxBufError, buf_err, slope_ave, slope_mntn);
    PRTSC(EVE,Calc,PrtBuf);
    if( (buf_err >  (pNodeRef->MaxBufError)) ||
	(buf_err < -(pNodeRef->MaxBufError)) ||
	(pNodeRef->proc_cnt == 1) ) {
#ifdef DBG_NETREF
	sprintf(PrtBuf,"buf_err %.0f buf set %d ave %d m1 %d m2 %d m3 %d m4 %d pm %d s_a %.1f s_m %.1f",
	    buf_err, pNodeRef->BufSetPt, ave, Cur->max[0], Cur->max[1], Cur->max[2], 
	    Cur->max[4], pNodeRef->Previous.max[0], slope_ave, slope_mntn);
	PRTSC(MIN,Data:,PrtBuf);
#endif
      if( (pNodeRef->proc_cnt == 0) ) {
	//--- Possibly bad buffers, do not process this one or next...
	pNodeRef->proc_cnt = 1;
	skip_it = 1;
	PRTC(GEN,Skipping pll processing....);
      } else {
	if( (buf_err >  (pNodeRef->MaxBufError)) ||
	    (buf_err < -(pNodeRef->MaxBufError)) ) {
	  //--- Second time above MacBufError
	  PRTC(MIN,NetRef state transition: maintain -> aggressive);
	  ctp_set_led(PLL_LED_RED, 0);
	  pNodeRef->State = CTP_NETREF_STATE_AGGR;
	  pNodeRef->proc_cnt = 0;
	  skip_it = 0;
	} else {
	  pNodeRef->proc_cnt = 0;
	  skip_it = 1;
	  PRTC(GEN,Skipping pll processing....);
	}
      }
    } else {
      skip_it = 0;
    }
    pll_adjust_aggr = 0.45 * slope_ave  / PpmPerPll;	// Use average slope in maintain
    pll_adjust_mntn = 0.45 * slope_mntn / PpmPerPll;
    pll_adjust_cap  = 0.45 * (double)pNodeRef->MaxAdjPpb / (1000.0 * PpmPerPll);
  }
  pll_adjust = pll_adjust_aggr + pll_adjust_mntn;
  //--- Cap change
#ifdef DBG_NETREF
  {
    int prt_it=0;
    if( pll_adjust < -pll_adjust_cap ) prt_it = 1;
    if( pll_adjust >  pll_adjust_cap ) prt_it = 1;
    if( prt_it ) {
      char pbuf[150];
      sprintf(pbuf,"PpmPerPll %.4f, MaxAdjPpb %d, state %s, pll_adjust_cap %.1f pll_adjust %.1f",
	  PpmPerPll, pNodeRef->MaxAdjPpb,
	  (pNodeRef->State == CTP_NETREF_STATE_AGGR) ? "AGGR":"MNTN",
	  pll_adjust_cap, pll_adjust);
      PRTSC(MIN,Pll capped:,pbuf);
    }
  }
#endif
  if( pll_adjust < -pll_adjust_cap ) pll_adjust = -pll_adjust_cap;
  if( pll_adjust >  pll_adjust_cap ) pll_adjust =  pll_adjust_cap;

  pll_adjust_act = (int)pll_adjust;
  sprintf(PrtBuf,"PpmPerPll %.4f pll_adjust_aggr %.4f, pll_adjust_mntn %.4f  pll_adjust %.4f (%d)",
      PpmPerPll, pll_adjust_aggr, pll_adjust_mntn, pll_adjust, pll_adjust_act);
  PRTSC(GEN,Calc pll:,PrtBuf);

  if( (pll_adjust_act + pNodeRef->AdapPllValue) < 0 ) {
    pll_adjust_act = -pNodeRef->AdapPllValue;
  } else if ( (pll_adjust_act + pNodeRef->AdapPllValue) > 4095 ) {
    pll_adjust_act = 4095 - pNodeRef->AdapPllValue;
  }

  if( !skip_it) {
    pNodeRef->AdapPllValue += pll_adjust_act;
    pNodeRef->last_ppm_adj  = (pll_adjust_act * PpmPerPll) / 0.45;
    if(intCard){
	if(pll_adjust_act != 0) ctp_set_pll_fixed( pNodeRef->AdapPllValue, 2);
    } else ctp_set_pll_fixed( pNodeRef->AdapPllValue, 0);
    sprintf(PrtBuf,"pll adj act %d, new pll %d, ppm adj %.3f",
	pll_adjust_act, pNodeRef->AdapPllValue,pNodeRef->last_ppm_adj);
    PRTSC(GEN,Setting pll:,PrtBuf);
  }
}

void ctp_netref_proc_buffers(int intCard, CTP_NREFS_STATE *pNodeRef) {
  CTP_NREFS_BUFFER * Cur = &pNodeRef->Current;
  CTP_NREFS_BUFFER * Pre = &pNodeRef->Previous;
  int	i,p;
  int    Card = intCard;	// Just for Card level PRTs
  u32	ave = 0;
  char	PrtBuf[100];
  FUNC_PRT(ctp_netref_proc_buffers, PF_REF, -1);

#ifdef DBG_NETREF
  PRTDVC(MIN,Tossed samples,pNodeRef->nToss);
  sprintf(PrtBuf,"Cur max 0x%x at %d. Pre max 0x%x at %d.\n",
      Cur->max[0], Cur->max_n[0], Pre->max[0], Pre->max_n[0]);
  PRTSC(MIN,Processing buffers,PrtBuf);
  sprintf(PrtBuf,"Cur 2nd max 0x%x 3rd max 0x%x. Pre 2nd max 0x%x 3rd max 0x%x.\n",
      Cur->max[1], Cur->max[2], Pre->max[1], Pre->max[2]);
  PRTSC(GN2,Processing buffers,PrtBuf);

  if      ( CTP_MAX_NR_LUCKY_SAM == 3 ) p=1;
  else if ( CTP_MAX_NR_LUCKY_SAM == 5 ) p=2;
  else if ( CTP_MAX_NR_LUCKY_SAM == 9 ) p=3;

  for(i=1;i<CTP_MAX_NR_LUCKY_SAM;i++) { ave += Cur->max[i] >> p; }
  sprintf(PrtBuf,"ave 0x%x pos0 %d pos1 %d pos2 %d pos3 %d.\n",
      ave, Cur->max_n[0], Cur->max_n[1], Cur->max_n[2], Cur->max_n[3]);
  PRTSC(MIN,Processing buffers,PrtBuf);
#endif	// DBG_NETREF

  if(pNodeRef->State == CTP_NETREF_STATE_AGGR) {
    switch(--pNodeRef->proc_cnt) {
      case 0:
	ctp_netref_calc_pll_adj(pNodeRef, intCard);
	break;
      default:
	pNodeRef->proc_cnt = 2;
      case 1:
	PRTC(EVE,Waiting to calc netref slope while in aggressive state);
	break;
    }
  } else if (pNodeRef->State == CTP_NETREF_STATE_MNTN ) {
    ctp_netref_calc_pll_adj(pNodeRef, intCard);
  }
  
}

void ctp_netref_proc_buf(CTP_NREFS_STATE *pNodeRef, int intCard) {
  CTP_NREFS_BUFFER * Cur = &pNodeRef->Current;
  CTP_NREFS_BUFFER * Pre = &pNodeRef->Previous;
  int i;
  int    Card = intCard;	// Just for Card level PRTs
  int max_sam = intCard? CTP_MAX_NODEREF_SAM:CTP_MAX_NR_SAM;
  FUNC_PRT(ctp_netref_proc_buf, PF_REF, -1);

  //--- Check if we have enough samples to process
  if( Cur->num_sam >= max_sam ) {
    // Do any required processing before wiping out previous
    ctp_netref_proc_buffers(intCard, pNodeRef);
    // Copy current to previous
    memcpy(Pre,Cur,sizeof(CTP_NREFS_BUFFER));
    // Initialize current
    memset(Cur,0,sizeof(CTP_NREFS_BUFFER));
    gettimeofday(&Cur->sam_start,NULL);
    pNodeRef->nToss = 0;
  }
  //--- Add current buffer value & sort
  Cur->num_sam++;
  for(i=0;i<CTP_MAX_NR_LUCKY_SAM;i++){
    if( Cur->max[i] < pNodeRef->buffer ) {
      int j;
#ifdef DBG_NETREF
      char PrtBuf[200];
      sprintf(PrtBuf,"Buf 0x%x, pos 0x%x",
	  pNodeRef->buffer,Cur->num_sam);
      PRTSC(GEN,Sorting,PrtBuf);
      sprintf(PrtBuf,"m0 0x%x, m_n0 0x%x, m1 0x%x m_n1 0x%x, m2 0x%x, m_n2 0x%x, m3 0x%x, m_n3 0x%x",
	  Cur->max[0], Cur->max_n[0], Cur->max[1], Cur->max_n[1],
	  Cur->max[2], Cur->max_n[2], Cur->max[3], Cur->max_n[3]);
      PRTSC(GEN,Before,PrtBuf);
#endif	// DBG_NETREF

      for(j=CTP_MAX_NR_LUCKY_SAM-1;j>i;j--){
	Cur->max[j]   = Cur->max[j-1];
	Cur->max_n[j] = Cur->max_n[j-1];
      }
      Cur->max[i]   = pNodeRef->buffer;
      Cur->max_n[i] = Cur->num_sam;
      i = CTP_MAX_NR_LUCKY_SAM;	// Stop loop over i....
#ifdef DBG_NETREF
      sprintf(PrtBuf,"m0 0x%x, m_n0 0x%x, m1 0x%x m_n1 0x%x, m2 0x%x, m_n2 0x%x, m3 0x%x, m_n3 0x%x",
	  Cur->max[0], Cur->max_n[0], Cur->max[1], Cur->max_n[1],
	  Cur->max[2], Cur->max_n[2], Cur->max[3], Cur->max_n[3]);
      PRTSC(GEN,After-,PrtBuf);
#endif
    }
  }
}

//--- Accepts and processes network reference pkts
int ctp_netref_server(int sock) {
  char datagram[4096];	// Probably should reduce the size here!
  struct sockaddr_in sin;
  FUNC_PRT(ctp_netref_server, PF_REF, -1);
  
  PRT(GEN,ctp_netref_server called);

  while(1) {
    if(pNRefs->Type == CTP_NETREF_TYPE_SLV) {
      CTP_IP_HDR *iph = (CTP_IP_HDR *)datagram;
      int len;
      int n_indx=0;    // Aricent PR 1110275 fix
      if( pNRefs->State == CTP_NETREF_STATE_DIS ) {
	PRT(MIN,NetRef state transition: disabled -> wait);
	ctp_set_led(PLL_LED_RED, 0);
	pNRefs->State = CTP_NETREF_STATE_WAIT;
	ctp_init_node_refs_params(pNRefs);
	pNRefs->AdapPllValue = Ctp.Node[0].Calibration;
	ctp_set_pll_fixed( pNRefs->AdapPllValue, 1);
      }
      len = recv(sock, datagram, 4096, 0);
      PRTDV(GN3,Got message of size,len);
  //--Start Aricent PR-595515 "Enhance NetRef to include "starvation" state"
      // Aricent PR 1110275 fix - Start
/* Aricent PR 1534914 start */
/***
* recv_pkt value for index 1/2/3 changing on recieving pkts from masters,
* it's value should be 1 if ctpd is recieving netref pkt from configured
* master(s) and it should also clear if ctpd stop recieving  netref pkt
* from the master(s).
***/
      static int prio_1_indx = 0;
      for(n_indx = 0; n_indx < CTP_MAX_NETREF_MSTRS; n_indx++){
        if ( pNRefs->AssignedPriority[n_indx] == 1 ) prio_1_indx = n_indx;
        if(pNRefs->recv_pkt_flag[n_indx] <= 32) {
          pNRefs->recv_pkt_flag[n_indx] += 1;
        }
        else {
          pNRefs->recv_pkt[n_indx] = 0;
        }

        if( pNRefs->Node[n_indx].v4 == ntohl(iph->ip_src)) {
          pNRefs->recv_pkt_flag[n_indx] = 0;
          pNRefs->recv_pkt[n_indx] = 1;
        }
        else pNRefs->recv_pkt[n_indx] = 0;
/***
*  If prio 1 master stop transmitting netref pkt, then netref
* state stuck to starvation. If non-1-prio master is xmiting
* netref pkts then slave should change its assigned prio
* and sync to xmiting master. For this we need to advance
* its state (from starvation).
***/
        if( (pNRefs->Node[n_indx].v4 == ntohl(iph->ip_src)) && ( pNRefs->State == CTP_NETREF_STATE_STRV) &&
           ( pNRefs->recv_pkt[prio_1_indx] == 0 ) ) {
          pNRefs->NetRef_time_cnt = 0;
          if ((pNRefs->State == CTP_NETREF_STATE_STRV) &&
              (pNRefs->NetRef_old_state == CTP_NETREF_STATE_MNTN ) ){
                  PRT(MIN,NetRef state transition: starvation -> wait);
                  pNRefs->State = CTP_NETREF_STATE_WAIT ;
                  pNRefs->last_ppm_adj  = 0.0;
          }
        }
/* Aricent PR 1534914 end */
        /* Aricent PR 1117979, 1133355 Fix */
        if( pNRefs->Node[n_indx].v4 == ntohl(iph->ip_src) && pNRefs->AssignedPriority[n_indx] == 1) {
          pNRefs->NetRef_time_cnt = 0;
          if ((pNRefs->State == CTP_NETREF_STATE_STRV) &&
              (pNRefs->NetRef_old_state == CTP_NETREF_STATE_MNTN ) ){
                  PRT(MIN,NetRef state transition: starvation -> maintain);
                  pNRefs->State = CTP_NETREF_STATE_MNTN ;
          }
          if ((pNRefs->State == CTP_NETREF_STATE_STRV) &&
              (pNRefs->NetRef_old_state == CTP_NETREF_STATE_AGGR) ){
                  PRT(MIN,NetRef state transition: starvation -> aggressive);
                  pNRefs->State = CTP_NETREF_STATE_AGGR ;
          }
 //--End Aricent PR-595515 "Enhance NetRef to include "starvation" state"  
          int this, last, i;
	  CTP_NET_REF_PAYLOAD *nr_data = (CTP_NET_REF_PAYLOAD *)(datagram + sizeof(CTP_IP_HDR));
	  int sn    = nr_data->seq_num;
	  int ts_sn = nr_data->cntr_seq_num;
	  u32 rem_ts    = nr_data->cntr;
	  char	Buf[180],tBuf[180];

	  PRTDV(GN3,Got NetRef pkt with seq num, sn);
	  PRTDV(GN3,Got NetRef pkt with ts_sn, ts_sn);
	  PRTV(GN3,Got NetRef pkt with rem ts, rem_ts);
	  sprintf(Buf,"Have %d in seq, last sn %d, this sn %d",
	    pNRefs->num_in_seq, pNRefs->last_seq_num, sn);
	  PRTS(GN3,,Buf);

	  if( pNRefs->num_in_seq <16 ) {
	    PRTDV(GN2,Waiting for 16 in seq netref pkts have now,pNRefs->num_in_seq);
	  } else {
	    //--- Got 16 netref pkts in sequence. 
	    //    If we were in WAIT, transition to aggressive &
	    //    set initial buffer.
	    if( pNRefs->State == CTP_NETREF_STATE_WAIT ) {
	      pNRefs->buffer = 0x10000000;
	      pNRefs->State = CTP_NETREF_STATE_AGGR;
	      PRT(MIN,NetRef state transition: wait -> aggressive);
	    }
	    this = ctp_ts_state_add_rem_ts(ts_sn, rem_ts, sn);
	    if( this == -1 ) {
	      // Wait to make sure timestamps are parsed & saved before continuing here!
	      usleep(1000);
	      this = ctp_ts_state_add_rem_ts(ts_sn, rem_ts, sn);
	      if( this == -1 ) {
	        // Wait to make sure timestamps are parsed & saved before continuing here!
	        usleep(1000);
	        this = ctp_ts_state_add_rem_ts(ts_sn, rem_ts, sn);
	      }
	    }

	    last = ctp_ts_state_find_next_sn(ts_sn);

#ifdef DBG_NETREF
	    if( (ts_sn + 9 <= sn) ||
	        (ts_sn     >= sn) ) {
	      sprintf(tBuf," ");
	      for(i=0;i<CTP_MAX_TS_STATE;i++) {
	        sprintf(Buf,"%s%d",tBuf,pNRefs->TsState[i].state ? 1:0);
	        sprintf(tBuf,"%s",Buf);
	      }
	      sprintf(Buf,"%s this %d last %d ts_sn %d sn %d.",tBuf,this,last,ts_sn,sn);
	      PRTS(MIN,Have,Buf);
	    }
#endif	// DBG_NETREF

	    if( (last >= 0) && (last < CTP_MAX_TS_STATE) && 
	        (this >= 0) && (this < CTP_MAX_TS_STATE) ) {
	      u16 Sn1    = pNRefs->TsState[last].seq_num;
	      u16 Sn2    = pNRefs->TsState[this].seq_num;
	      u32 LocTs1 = pNRefs->TsState[last].ts;
	      u32 LocTs2 = pNRefs->TsState[this].ts;
	      u32 RemTs1 = pNRefs->TsState[last].rem_ts;
	      u32 RemTs2 = pNRefs->TsState[this].rem_ts;
	      u32 LocDif = LocTs2 - LocTs1;
	      u32 RemDif = RemTs2 - RemTs1;

//PR-1669472 fix
              sprintf(Buf,"Old buf %d rem ts 0x%x loc ts 0x%x ",
                pNRefs->buffer,RemTs1,LocTs1);
	      PRTS(DBG,,Buf);

	      PRTDV(DBG,Location of 1st sn, last);
	      PRTDV(DBG,Location of 2nd sn, this);
	      PRTU16(DBG,1st sn, Sn1);
	      PRTU16(DBG,2nd sn, Sn2);
	      if( LocTs1 > (LocTs2 + 0xf0000000) ) { LocDif += 0xffffffff; }
	      if( RemTs1 > (RemTs2 + 0xf0000000) ) { RemDif += 0xffffffff; }
#ifdef DBG_NETREF
	      if( (LocTs1 > LocTs2) ||
		(RemTs1 > RemTs2) ) {
	        PRTV(MIN,loc ts 1st sn, LocTs1);
	        PRTV(MIN,loc ts 2nd sn, LocTs2);
	        PRTV(MIN,rem ts 1st sn, RemTs1);
	        PRTV(MIN,rem ts 2nd sn, RemTs2);
	        PRTV(MIN,Loc diff, LocDif);
	        PRTV(MIN,Rem diff, RemDif);
	      }
#endif	// DBG_NETREF

	      ctp_ts_state_clear( last );

	      pNRefs->buffer += (RemDif - LocDif);
	      PRTV(DBG,buffer now,pNRefs->buffer);

	      //--- For some reason we get a bad hrc reading, this leads to 2
	      //    consectutive bad buffers values which we need to skip.
	      if( pNRefs->skip_next ) {
#ifdef DBG_NETREF
	        sprintf(Buf,"buf 0x%x: s/n %d & %d loc diff 0x%x rem diff 0x%x change %d.",
		  pNRefs->buffer,Sn2,Sn1,LocDif,RemDif,(LocDif-RemDif));
	        PRTS(MIN,Skipping next,Buf);
#endif	// DBG_NETREF
	        pNRefs->skip_next = 0;
	      } else if( ((RemDif > LocDif) && 
		        ((RemDif - LocDif) > (RemDif>>12) ||	// Depends on pkt rate!
		         (RemDif - LocDif) > (LocDif>>12) )) ||
		       ((LocDif > RemDif) && 
		        ((LocDif - RemDif) > (RemDif>>12) ||
		         (LocDif - RemDif) > (LocDif>>12) )) ) {
	        pNRefs->nToss += 2;
	        pNRefs->skip_next = 1;
#ifdef DBG_NETREF
	        if( pNRefs->nToss == CTP_MAX_NR_SAM ) PRTDV(MIN,Tossed so far,pNRefs->nToss);
	        sprintf(Buf,"buf 0x%x: s/n %d & %d loc diff 0x%x rem diff 0x%x change %d.",
		  pNRefs->buffer,Sn2,Sn1,LocDif,RemDif,(LocDif-RemDif));
	        PRTS(MIN,Skipping,Buf);
#endif	// DBG_NETREF
	      } else {
#ifdef DBG_NETREF
	        sprintf(Buf,"buf 0x%x: s/n %d & %d loc diff 0x%x rem diff 0x%x change %d.",
		  pNRefs->buffer,Sn2,Sn1,LocDif,RemDif,(LocDif-RemDif));
	        PRTS(MIN,Got,Buf);
#endif	// DBG_NETREF
	        ctp_netref_proc_buf(pNRefs, 0);
	      }

	    } else {
	      PRTDV(GN2,Could not find entry with sn,ts_sn);
	    }
	  //
	  }
        } else {
	  u32 src_ip = ntohl(iph->ip_src);
	  PRTV(GN2,Got NetRef pkt from, src_ip);
        }
      }
      // Aricent PR 1110275 fix - End
    } else {
      sleep(1);
      if( (pNRefs->Type != CTP_NETREF_TYPE_BNDL) &&	// Do not process state if netref is using bundle.....
	  (pNRefs->State != CTP_NETREF_STATE_DIS)) {	// Otherwise NetRef state should be disabled.
	switch(pNRefs->State) {
	  case CTP_NETREF_STATE_WAIT:
	    PRT(MIN,NetRef state transition: wait -> disabled);
	    break;
	  case CTP_NETREF_STATE_AGGR:
	    PRT(MIN,NetRef state transition: aggressive -> disabled);
	    break;
	  case CTP_NETREF_STATE_MNTN:
	    PRT(MIN,NetRef state transition: maintain -> disabled);
	    break;
          //--Aricent PR-595515 "Enhance NetRef to include "starvation" state"
          case CTP_NETREF_STATE_STRV:
            PRT(MIN,NetRef state transition: starvation -> disabled);
            break;
           //--End Aricent PR-595515 "Enhance NetRef to include "starvation" state"
	  default:
	    PRT(MIN,NetRef state transition: unknown -> disabled);
	    break;
	}
	ctp_set_led(PLL_LED_RED, 0);
        pNRefs->State = CTP_NETREF_STATE_DIS; 
	ctp_set_pll_fixed( Ctp.Node[0].Calibration, 1);
      }
    }
  }
}

static inline void ctp_parse_n_save_ts(char *buff )
{
  int seq_num;
  u32 ts;
  int stat;
  u32 src_ip;    // Aricent PR 1110275 fix

  FUNC_PRT(ctp_parse_n_save_ts, PF_REF, -1);

  if( pNRefs->Type == CTP_NETREF_TYPE_SRC ) {
    //--- Outgoing ts
//PR-1669472 fix
    stat = sscanf( buff, "nro%d %x", &seq_num, &ts);
    if( stat == 2 ) {
      PRTDV(GN2,ctp_parse_n_save_ts got seqnum, seq_num);
      PRTV(GN2,ctp_parse_n_save_ts got ts, ts);
      if( ctp_ts_state_add_ts_src(seq_num, ts) != SUCCESS ) {
	PRT(EVE,Could not save outgoing timestamp);
      }
    }
  } else if( pNRefs->Type == CTP_NETREF_TYPE_SLV ) {
    //--- Incoming ts
    // Aricent PR 1110275 fix - Start
    int n_indx = 0;
//PR-1669472 fix
    stat = sscanf( buff, "nri%d %x %x", &seq_num, &src_ip, &ts);
    if( stat == 3 ) {
      int max_sn_diff = (2 * CTP_MAX_NETREF_SLVS) + 1;
      PRTDV(GN2,ctp_parse_n_save_ts got seqnum, seq_num);
      PRTV(GN2,ctp_parse_n_save_ts got ts, ts);

      for(n_indx = 0; n_indx < CTP_MAX_NETREF_MSTRS; n_indx++) {
        if (pNRefs->Node[n_indx].v4 == src_ip) {
          /* Aricent PR 1117979, 1133355 Fix */
          if( pNRefs->Node[n_indx].v4 == src_ip && pNRefs->AssignedPriority[n_indx] == 1) {
            //--- Are we in sequence?	Allow up to 8 mising (needed for master
            //feeding multiple slaves).
            if( ((seq_num > max_sn_diff) && 
	     ((pNRefs->last_seq_num > (seq_num - max_sn_diff )) &&
	      (pNRefs->last_seq_num < seq_num) ) ) ||
	    (((pNRefs->last_seq_num + max_sn_diff) % 65536 > seq_num) &&
	     ((pNRefs->last_seq_num + max_sn_diff) % 65536 < (seq_num + max_sn_diff)) )) {
       	      pNRefs->num_in_seq = (pNRefs->num_in_seq > 15) ? 16 : pNRefs->num_in_seq + 1;
	      pNRefs->last_seq_num = seq_num;
            } else { 	// reset!
	      int i;
	      char buff[80];

	      sprintf(buff,"Last sn %d this sn %d.", pNRefs->last_seq_num, seq_num);
	      PRTS(GEN,Timestamps reset and cleared -,buff);

	      pNRefs->buffer = 0;
	      pNRefs->num_in_seq = 0;
	      pNRefs->last_seq_num = seq_num;
	      if( pNRefs->State == CTP_NETREF_STATE_AGGR ) {
	        PRT(MIN,NetRef state transition: aggressive -> wait);
	        pNRefs->State = CTP_NETREF_STATE_WAIT;
	        pNRefs->last_ppm_adj  = 0.0;
	      }
	      if( pNRefs->State == CTP_NETREF_STATE_MNTN ) {
	        PRT(MIN,NetRef state transition: maintain -> wait);
	        pNRefs->State = CTP_NETREF_STATE_WAIT;
	        pNRefs->last_ppm_adj  = 0.0;
	      }
              if( pNRefs->State == CTP_NETREF_STATE_STRV ) {
                if(pNRefs->NetRef_old_state == CTP_NETREF_STATE_MNTN) {
                  PRT(MIN,NetRef state transition: starvation -> maintain);
                  PRT(MIN,NetRef state transition: maintain -> wait);
                } else if(pNRefs->NetRef_old_state ==  CTP_NETREF_STATE_AGGR) {
                  PRT(MIN,NetRef state transition: starvation -> aggressive);
                  PRT(MIN,NetRef state transition: aggressive -> wait);
                }
                pNRefs->State = CTP_NETREF_STATE_WAIT;
                pNRefs->last_ppm_adj  = 0.0;
              }

	      //--- Clear out old timestamps....
	      for(i=0;i<CTP_MAX_TS_STATE;i++) ctp_ts_state_clear(i);
            }

            if( pNRefs->num_in_seq >= 16 ) {	// Start saving early!
	      if( ctp_ts_state_add_ts_slv(seq_num, ts) != SUCCESS ) {
	        int i, cnt=0;
	        for(i=0;i<CTP_MAX_TS_STATE;i++) {
	          if( pNRefs->TsState[i].state != CTP_TS_STATE_UNUSED ) cnt++;
	        }
	        PRTDV(EVE,Could not save incoming timestamp for seq_num, seq_num);
	        PRTDV(GEN,Number of used Ts,cnt);
	      }
            } else {
	      return;	//
            }
          } else {
            pNRefs->buffer = 0;
            if( pNRefs->State == CTP_NETREF_STATE_STRV ) {
              if(pNRefs->NetRef_old_state == CTP_NETREF_STATE_MNTN) {
                PRT(MIN,NetRef state transition: starvation -> maintain);
                PRT(MIN,NetRef state transition: maintain -> wait);
              } else if(pNRefs->NetRef_old_state ==  CTP_NETREF_STATE_AGGR) {
                PRT(MIN,NetRef state transition: starvation -> aggressive);
                PRT(MIN,NetRef state transition: aggressive -> wait);
              }
              pNRefs->State = CTP_NETREF_STATE_WAIT;
              pNRefs->last_ppm_adj  = 0.0;
            }
          }
        } 
      }
    }
  }
  // Aricent PR 1110275 fix - End

}

//--- Reads & processes timestamps
int ctp_netref_ts_proc(void) {
  char dev_name[80];
  int fd;
  FUNC_PRT(ctp_netref_ts_proc, PF_REF, -1);

  PRT(GEN,ctp_netref_ts_proc called);

  
  sprintf(dev_name,"/dev/hrc");
  PRTS(EVE,Opening,dev_name);
  fd = open(dev_name,O_RDONLY);

  if( fd == 0 ) {
    PRT(MAJ,Problems opening hrcdev);
  } else {
    int status;
    char buff[300];

    PRTS(EVE,Opened blocked read on,dev_name);
    while(1) {
      status = read(fd, buff, 100);
      if( status>0 ) {
	char  buf[300];
	PRTDV(DBG,Got status,status);
	#ifdef WRL
	snprintf(buf,status,"%s",buff);
	#else
	snprintf(buf,status,buff);
	#endif
	PRTS(GN3,Read:,buf);
	ctp_parse_n_save_ts(buff);
      } else {
/**** PR1399571-Fix ****/
//	PRTS(MIN,Problems reading,dev_name);
	exit;
      }
    }	// end of while(1)
  }
}

