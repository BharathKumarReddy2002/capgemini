  FUNC_PRT(ctp_del_all_ports, PF_MISC, -1);

  for(Card=0;Card<CTP_MAX_CARDS;Card++) {
    if( SCC_CARD(Card) ) {
      for(pNum=0;pNum<pSysInfo->Card[Card].PortsOnCard;pNum++) {
	if( (Db.Card[Card].Port[pNum].State == CTP_DBSTATE_UP) &&
	    (Ctp.Card[Card].Port[pNum].Available) ) {
	  PRTP(GEN,Deleting port);
	  ctp_del_port(Card,pNum);
        //Aricent PR 730873  start
          bNum= util_get_next_bNum(&Db.Card[Card].Port[pNum], -1);
         if(bNum < CTP_MAX_BNDLS){
           Ctp.Bndl[bNum].State = CTP_PORT_STATE_NOT_CFG;
        }
        //Aricent PR 730873  start
	  usleep(100000);		// sleep 100 ms before taking down the next port
	}
      }
    }
  }
  //util_prt_node_list(&Ctp.NodeList);
  return(SUCCESS);
