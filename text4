//--------------------------------------------------------------------------
// Scans through all elements of the database and make necessary changes to
// current database according to new database sent from menu/cmd
//--------------------------------------------------------------------------
int ctp_dbase_commit(int db_index)
{
  FILE *pFile;
  CTP_DBASE *pNewDb;
  char dbaseCloneFile[80], Buf[80];
  char	dbaseFile[100];
  int rtn = FAILURE, bndl, card, port;
#ifdef VCTP
  int c_idx;
#endif
  FUNC_PRT(ctp_dbase_commit, PF_IPC, -1);

  u32 att_bndl_bmask[(CTP_MAX_BNDLS/32)], chgd_bndl_bmask[(CTP_MAX_BNDLS/32)];
  u32 att_port_bmask[CTP_MAX_CARDS], chgd_port_bmask[CTP_MAX_CARDS];
  PRTDV(GEN, Try to open database , db_index);
  sprintf(dbaseCloneFile,"%s/%s_%d",CTP_CLONE_DB_DIR,CTP_DB_FILE,db_index);
  pFile = fopen(dbaseCloneFile, "rb");
  if( pFile == NULL)  return (rtn);

  pNewDb = malloc(sizeof(CTP_DBASE));

  if(pNewDb == NULL) { fclose(pFile); return (rtn);}

  fread(pNewDb, 1, sizeof(CTP_DBASE),pFile);
  fclose(pFile);
//--------------------------------------------------------------------------
// This is a multi-stage process.
// Stage 0. Check the new database integrity. TODO
// Stage 1. Disables the different bundle/ports/node configuration if in
//          current system the bundle/ports are in DBASE_UP state.
//          It is easier for one-one or one-multi bundle-port configuration
//          but difficult for many-one bundle-port relationship.We have to
//          keep a list of bundles need to be modified when scanning bundle/port
//          database. There is a case that bundle database not changing but port
//          database change result in multiple bundles have to be disabled/reactivate.
//          If bundle database has different source info/type. Then the bundle
//          has to be deleted. If current bundle type is NONE then do nothing.
// Stage 2. Copy the different databases.while activating bundles/ports which
//          need to be active.
// Stage 3. Replace save database to ram disk.
//--------------------------------------------------------------------------
  // Node difference TODO should it be the last one to config?
  if(memcmp(Db.Node, pNewDb->Node, sizeof(CTP_NODE_DBASE)))  {
    bcopy(pNewDb->Node,Db.Node,sizeof(CTP_NODE_DBASE));
/* Aricent PR699998 --Start */
    ctp_cfg_nref();  /* Added function call for netref */
/* Aricent PR699998 --End  */
    ctp_cfg_node_clks(0, -1 );
  }

//--------------------------------------------------------------------------
// Stage 1 start
//--------------------------------------------------------------------------

//--------------------------------------------------------------------------
// Step 1. Go through Port database, if different and up, then disable the port
//         and in case of T1 E1 and port is configured framed/ meaning it is possible
//         to be used by multiple bundles(CESoPSN/VCOMP), then leave it here. we need
//         to disable the associated bundles first.
//--------------------------------------------------------------------------
#ifndef VCTP
  for(card = 0; card < pSysInfo->CardsPerCpu; card ++){
#else
  for(c_idx = 0; c_idx<pSysInfo->CardsPerCpu; c_idx++) {
    card = cardIndx[c_idx];
#endif
    //--- Card level changes Aricent PR-947204 Start
    if( IS_T1E1_2000(card) ) {
        Db.Card[card].card_all_h110 = pNewDb->Card[card].card_all_h110;
        Db.Card[card].all_h110_cesop = pNewDb->Card[card].all_h110_cesop;
    } else if (VOICE(card)) {
        Db.Card[card].card_all_h110 = pNewDb->Card[card].card_all_h110;
        Db.Card[card].all_h110_cesop = pNewDb->Card[card].all_h110_cesop;
    } else {
        Db.Card[card].card_all_h110 = 0;
        Db.Card[card].all_h110_cesop = 0;
    }
    // Aricent PR-947204 End
    att_port_bmask[card] = 0;
    chgd_port_bmask[card] = 0;
    for(port = 0; port < pSysInfo->Card[card].PortsOnCard; port ++){
      CTP_PORT_DBASE *pDbP, *pNewDbP;
      pDbP = &Db.Card[card].Port[port];
      pNewDbP = &pNewDb->Card[card].Port[port];
      if(memcmp(pDbP, pNewDbP, sizeof(CTP_PORT_DBASE))) {
        chgd_port_bmask[card] |= 1<<port;
      // we have a different port configuration, and the current port status is up
        if(pDbP->State == CTP_DBSTATE_UP) {
          CTP_PORT_DBASE tmpDbP;
          if(IS_T1E1(card) && (pDbP->DcardCfg1 & T1E1_MSK_FRAME)) {
            att_port_bmask[card] |= 1<<port;
            continue;
          }
          // Disable the port;
          memcpy(&tmpDbP, pDbP, sizeof(CTP_PORT_DBASE));
          tmpDbP.State = CTP_DBSTATE_DOWN;
          ctp_port_cfg(card, port, &tmpDbP);
          sprintf(Buf, "Card %d, Port %d disabled at step 1!\n", card, port);
          PRTS(GEN, , Buf);
        }
      }
    }
  }

//--------------------------------------------------------------------------
// Step 2. Go through bundle database, if different and up, then disable the bundles
//         In case of CESoPSN bundle and adaptive master enabled, then leave it
//         untouched, because other bundles has to be disabled first.
// Two cases that we need to disable bndl when current state is active.
// 1. the database comparison failed.
// 2. even though bundle database is correct but the port database associated
//    with database is not the same.
//--------------------------------------------------------------------------
  // clean up the touched and attention bundle bit mask
  for(bndl = 0; bndl < (CTP_MAX_BNDLS/32); bndl ++) {
    chgd_bndl_bmask[bndl] = 0;
    att_bndl_bmask[bndl] = 0;
  }

  for(bndl = 0; bndl < CTP_MAX_BNDLS; bndl++) {
    card = util_bndl_src_card(0, &Db.Bndl[bndl]);
    port = util_bndl_src_pNum(0, &Db.Bndl[bndl]);

    if((memcmp(&Db.Bndl[bndl], &pNewDb->Bndl[bndl], sizeof(CTP_BNDL_DBASE)))
      || (chgd_port_bmask[card] & (1<<port))) {
      // Get need to be changed bndl bitMask
      chgd_bndl_bmask[bndl/32] |= (1<< (bndl%32));
      // If the bundle is currently not up, skip
      if(Db.Bndl[bndl].State != CTP_DBSTATE_UP) continue;

      if((Db.Bndl[bndl].Type==CTP_BNDL_TYPE_WP) &&
        (Db.Bndl[bndl].Bndl.wp_bndl.adpMaster)){
          att_bndl_bmask[bndl/32] |= (1<< (bndl%32));
      } else {
        CTP_BNDL_DBASE tmpDbB;
        memcpy(&tmpDbB, &Db.Bndl[bndl], sizeof(CTP_BNDL_DBASE));
        tmpDbB.State = CTP_DBSTATE_DOWN;
        ctp_bndl_cfg(&tmpDbB);
        sprintf(Buf, "Bundle %d disabled at step 2!\n", bndl);
        PRTS(GEN, , Buf);
      }
    }
  }
//--------------------------------------------------------------------------
// Step 3. Disable the bundles left over from Step 2.
//--------------------------------------------------------------------------
  for(bndl = 0; bndl < CTP_MAX_BNDLS; bndl++) {
    if(att_bndl_bmask[bndl/32] & (1<< (bndl%32))){
      CTP_BNDL_DBASE tmpDbB;
      memcpy(&tmpDbB, &Db.Bndl[bndl], sizeof(CTP_BNDL_DBASE));
      tmpDbB.State = CTP_DBSTATE_DOWN;
      ctp_bndl_cfg(&tmpDbB);
      sprintf(Buf, "Bundle %d disabled at step 3!\n", bndl);
      PRTS(GEN, , Buf);
    }
  }

//--------------------------------------------------------------------------
// Step 4. Disable the ports left over from Step 1.
//--------------------------------------------------------------------------
#ifndef VCTP
  for(card = 0; card < pSysInfo->CardsPerCpu; card ++){
#else
  for(c_idx = 0; c_idx<pSysInfo->CardsPerCpu; c_idx++) {
    card = cardIndx[c_idx];
#endif
    for(port = 0; port < pSysInfo->Card[card].PortsOnCard; port ++){
      if(att_port_bmask[card] & (1<<port)) {
      // T1E1 port need to be disabled
        CTP_PORT_DBASE *pDbP = &Db.Card[card].Port[port];
        CTP_PORT_DBASE tmpDbP;
        memcpy(&tmpDbP, pDbP, sizeof(CTP_PORT_DBASE));
        tmpDbP.State = CTP_DBSTATE_DOWN;
        ctp_port_cfg(card, port, &tmpDbP);
        sprintf(Buf, "Card %d Port %d disabled at step 4!\n", card, port);
        PRTS(GEN, , Buf);
      }
    }
  }

//--------------------------------------------------------------------------
// Step 5. Setting up new bundle database for usage later on
//--------------------------------------------------------------------------
  for(bndl = 0; bndl < CTP_MAX_BNDLS; bndl++) {
    if(chgd_bndl_bmask[bndl/32] & (1<< (bndl%32))){
      memcpy(&Db.Bndl[bndl], &pNewDb->Bndl[bndl], sizeof(CTP_BNDL_DBASE));
      Db.Bndl[bndl].State = CTP_DBSTATE_DOWN;
    }
  }
//--------------------------------------------------------------------------
// Stage 1 end.
//--------------------------------------------------------------------------

//--------------------------------------------------------------------------
// Stage 2 Begin
//--------------------------------------------------------------------------
  for(card = 0; card < CTP_MAX_CARDS; card ++){
    if(chgd_port_bmask[card] == 0) continue;
    for(port = 0; port < pSysInfo->Card[card].PortsOnCard; port ++){
      if(chgd_port_bmask[card] & (1<<port)) {
        CTP_PORT_DBASE *pDbP, *pNewDbP;
        pNewDbP = &pNewDb->Card[card].Port[port];
        ctp_port_cfg(card, port, pNewDbP);
        sprintf(Buf, "Card %d Port %d configured at stage 2!\n", card, port);
        PRTS(GEN, , Buf);
      }
    }
  }

  for(bndl = 0; bndl < CTP_MAX_BNDLS; bndl++) {
    if(chgd_bndl_bmask[bndl/32] & (1<< (bndl%32))){
      ctp_bndl_cfg(&pNewDb->Bndl[bndl]);
      sprintf(Buf, "Bundle %d configured at stage 2!\n", bndl);
      PRTS(GEN, , Buf);
    }
  }
// Stage 2 end
//--------------------------------------------------------------------------
// Stage 3 Begin
//--------------------------------------------------------------------------
  free(pNewDb);
  sprintf(&dbaseFile[0],"%s/%s", CTP_DB_DIR, CTP_DB_FILE );
  ctp_dbase_write( &Db, dbaseFile );
  rtn = SUCCESS;
  return rtn;
}

