//--------------------------------------------------------------------------
// This function will fix one signalling output to the value passed. If
// that signal was previously configured for InBand, it is reconfigured for
// fixed output.
//--------------------------------------------------------------------------
int ctp_set_single_sig_out( int Card, int pNum, int Sig, int Val)
{
  int	sccNum = Ctp.Card[Card].Port[pNum].SccNum;
  char				SccBuf[40],Buf[80];
  struct acrndrv_runtime_cfg	nrc;
  FUNC_PRT(ctp_set_single_sig_out, PF_MISC, pNum);

  BAILTESTF(Sig>4,Invalid Signal ID);

  sprintf(SccBuf,"scc%d",sccNum);
  ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
  // Modify port Output signal config. This is necessary in case any of the
  // signals are configured for in-band operation since it will update
  // output signals on us. When the IOCTL is called, it will process the
  // configuration changes and make the appropriate changes to the output
  // signals automatically.
  nrc.sig_out_cfg &= ~( 0xf << (Sig*4) );
  if( Val == 0 )	nrc.sig_out_cfg |= ( 0x4 << (Sig*4) );
  else			nrc.sig_out_cfg |= ( 0x5 << (Sig*4) );

  sprintf(Buf,"Setting signal 0x%x to value 0x%x",Sig,Val);
  PRTSP(GN3,,Buf);
  sprintf(Buf,"Setting signal nrc.sig_out_cfg = 0x%x",nrc.sig_out_cfg);
  PRTSP(GN3,,Buf);

  ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
  return(SUCCESS);
}

//--------------------------------------------------------------------------
// This function will fix all signalling outputs to the values passed. If
// any signals were previously configured for InBand, they are reconfigured
// for fixed output.
//--------------------------------------------------------------------------
void ctp_set_sig_out( int Card, int pNum, int Sigs)
{
  int	sccNum = Ctp.Card[Card].Port[pNum].SccNum;
  char				SccBuf[40];
  struct acrndrv_runtime_cfg	nrc;
  int				i;
  FUNC_PRT(ctp_set_sig_out, PF_MISC, pNum);

  sprintf(SccBuf,"scc%d",sccNum);
  ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
  // Modify port Output signal config. This is necessary in case any of the
  // signals are configured for in-band operation since it will update
  // output signals on us. When the IOCTL is called, it will process the
  // configuration changes and make the appropriate changes to the output
  // signals automatically.
  nrc.sig_out_cfg = 0;
  for(i=0;i<4;i++) {
    if( Sigs & ( 1 << i ) )	nrc.sig_out_cfg |= (5 << (i * 4));
    else			nrc.sig_out_cfg |= (4 << (i * 4));
  }
  ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
}

//--------------------------------------------------------------------------
// This function will configure:
// 1) Mode1 - The electrical interface (EIA-530, V.35, RS-232, etc...)
// 2) Mode2 - I/F type (DCE, DTE, DCE redundant, etc...)
// 3) Mode3 - Signaling ( ACTIVE -> DCD, CTS, DSR are active, TM is inactive)
// If Mode1 is a daughter card mode, Mode2 and Mode3 are the database
// parameters for that daughter card.
void ctp_cfg_if_mode( int Card, int pNum, CTP_PORT_DBASE *pDbP )
{
  int	sccNum = Ctp.Card[Card].Port[pNum].SccNum;
  char	SccBuf[40], PrtBuf[80];
  u32	Data, Level, Tmp, Tmp1;
  u8	Chan1En,Chan0En;
  u32	IfMode = (u32)pDbP->if_mode;
  struct acrndrv_command	ncmd;
  FUNC_PRT(ctp_cfg_if_mode, PF_PST, pNum);

  sprintf(SccBuf,"scc%d",sccNum);

  if(IS_T1E1(Card)) {
    int bNum= util_get_next_bNum(&Db.Card[Card].Port[pNum], -1);	// L3Harris SAToP fix PR-1838064
    CTP_BNDL_DBASE *pDbB  = (CTP_BNDL_DBASE *)&Db.Bndl[bNum];		// L3Harris SAToP fix PR-1838064
  /* if this card is T1 E1 card, the only thing we need to care about is loopback
   * which happens to be in the if_mode field, we may want to think about moving
   * it out. Oh yeah, and redundancy stuff now...
   */
    fpga_clr_fcfg();
    if( pDbP->RdntConfig & CFG_RDNT_MODE_MASK )	fpga_set_redundant_mode(pNum,1);
    else					fpga_set_redundant_mode(pNum,0);
    // PR-1838064 L3Harris SAToP fix - Start
    if( pDbB->Type == CTP_BNDL_TYPE_SO ) {
      if( pDbB->Bndl.so_bndl.CfgFlags & CFG_BNDL_FLAG_SATOP_BYTE_FLIP ) {
	PRTP(GEN,Enable RFC4533 Compliant bit order mode);
	fpga_set_byte_flip(pNum,1);
      } else fpga_set_byte_flip(pNum,0); 
    }
    // PR-1838064 L3Harris SAToP fix - End
    fpga_send_fcfg(sccNum);
    return;
  }
  //----- Disable packet loss mute function (in case it's on) -----
  //      Does nothing more than set a flag.

  ncmd.CmdType = SCC_CMD_CFG_4WTO_MUTE;
  ncmd.CmdObj = 0;				// Disable Muting
  ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);

  //----- Disable DCD (pulls high) to disable JTAG TMS on DCARD -----
  //	(Might have been burning up T1 module PLDs)
  fpga_clr_fcfg();
  if( ( Dcard.Card[Card].Info[pNum].Present == YES ) &&
      ( ! (pDbP->CfgFlags & CFG_PORT_FLAG_DCD_UNCLAMP) ) ) {
		fpga_set_dcd_disable(pNum,1);
      } else	fpga_set_dcd_disable(pNum,0);
  fpga_send_fcfg(sccNum);

  /* if detect following condition, it is loop to net test and
     interface side need to be off */
  if((Ctp.Card[Card].Port[pNum].Diagnostics == YES) &&
    (Ctp.Card[Card].Port[pNum].TxBert == CTP_TX_BERT_TO_NET) &&
    (Ctp.Card[Card].Port[pNum].RxBert == CTP_TX_BERT_TO_NET))
    IfMode = IF_MODE_OFF;

  //----- NRZ driver (anything but daughtercard) -----
  if( (IfMode >= IF_MODE_EIA530 ) && (IfMode <= IF_MODE_LPBK ) ) {
    fpga_clr_fcfg();
    // This will keep port offline until it is RUNNING (fast bit is always
    // reset in nova driver when Tx SCC starts). This this is the best
    // place to put this disable, since it is just before we configure the
    // I/O transceiver. Unfortunately, there is still a very small glitch
    // on the line, so activating a port on the offline leg of a Y cable
    // will cause a small glitch. No avoiding it...
    fpga_set_redundant_fast(pNum,1);
    if( (pDbP->RdntConfig & CFG_RDNT_MODE_MASK) &&
	(pDbP->RdntConfig & CFG_RDNT_FLAG_NO_TERM) ) {
      PRTP(MIN,Skip if_mode cfg untill we go online); 
    } else {
      //TODO This will not work with hotswap, will want to assign Card # to
      //    port (probably within CTP_PORT_STATE structure) when the card shows up.
      //    May also cause problems when a card is missing from multicard
      //    systems.
      fpga_set_sipex_508( Card, pNum, IfMode); //CAP PR 1734636
    }
    //-----------------------------------------
    switch(pDbP->IfType) {
      case IF_TYPE_DCE:	
	fpga_set_if_dce(pNum);
	PRTP(GN3,Calling fpga_set_if_dce);		
	break;
      case IF_TYPE_DTE:	
	fpga_set_if_dte(pNum);
	PRTP(GN3,Calling fpga_set_if_dte);		
	break;
      case IF_TYPE_DISABLED:	
	fpga_set_if_disable(Card,pNum); //CAP PR 1734636
	break;
      default:
	PRTV(MAJ,Disabling port output due to invalid Port Mode,pDbP->IfType);
	fpga_set_if_disable(Card,pNum); //CAP PR 1734636
	break;
    }
    //-----------------------------------------
    switch(pDbP->IfEncoding) {
      case IF_ENC_NRZ:	
	if( pDbP->CfgFlags & CFG_PORT_FLAG_HI_SPD ) {
	  // High speed mode uses the trans8 encoding method, but we
	  // calculate the TT frequency based on a divide-by-8 clock enable
	  fpga_set_encoding(pNum,IF_ENC_TRANS8);	
	  fpga_set_trans_st_output_en(pNum,1);	// Undo TRANS8 ST mux sel
	  if((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) fpga_set_hi_spd_mode(pNum,1); //Aricent PR 1198066 Fix
	  fpga_set_tt_freq_sel_dec(pNum,CTP_FREQ_CNT_SEL_SCC_EN);	
	  PRTP(GN3,Enable NRZ high speed mode);		
	} else {
	  fpga_set_encoding(pNum,IF_ENC_NRZ);	
	  fpga_set_tt_freq_sel_dec(pNum,CTP_FREQ_CNT_SEL_TT);	// from cable
	}
	break;
      case IF_ENC_ISOCH:	
	fpga_set_encoding(pNum,IF_ENC_ISOCH);	
	fpga_set_tt_freq_sel_dec(pNum,CTP_FREQ_CNT_SEL_TT_DEC);	// from decoder
	break;
      case IF_ENC_CDI:	
	fpga_set_encoding(pNum,IF_ENC_CDI);

	if( pDbP->div_val == 1 ) {
	  // High speed CDI, so we need to set flag and the variable rate value
	  double divider = util_power(10,pDbP->dds_div);
	  double CurFreq = (double)pDbP->dds_freq/(0x20000 * divider * pDbP->div_val * 2);
	  int rate = 25000 / (int)CurFreq;
	  fpga_set_hi_speed_cdi_enable(pNum,1);
	  fpga_set_hi_speed_cdi_rate(pNum,rate);
	} else {
	  // Low speed CDI, so we need to clear flag and set fixed rate
	  fpga_set_hi_speed_cdi_enable(pNum,0);
	  fpga_set_hi_speed_cdi_rate(pNum,0x5);
	}
	// Now we have to explicitly set conditioning
	fpga_set_nrz_mark(pNum,1);
	fpga_set_tt_freq_sel_dec(pNum,CTP_FREQ_CNT_SEL_TT_DEC);	// from decoder
	break;
      case IF_ENC_MSTAR:	
	fpga_set_encoding(pNum,IF_ENC_MSTAR);	
	fpga_set_tt_freq_sel_dec(pNum,CTP_FREQ_CNT_SEL_TT_DEC);	// from decoder
	break;
      case IF_ENC_TRANS:
      case IF_ENC_TRANS8:
	fpga_set_encoding(pNum,pDbP->IfEncoding);
	// Here we measure and report the users input clock, which has
	// nothing to do the packet build clock. It is useful, however, for
	// determining if the sample rate is high enough for TRANS.
	fpga_set_tt_freq_sel_dec(pNum,CTP_FREQ_CNT_SEL_TT);	
	//-------------
	if( pDbP->CfgFlags & CFG_PORT_FLAG_TRANS_FIFO ) {
	  fpga_set_trans_fifo_enable(pNum,1);
	} else {
	  fpga_set_trans_fifo_enable(pNum,0);
	}
	//-------------
	if( pDbP->CfgFlags & CFG_PORT_FLAG_TRFIFO_WRCLK_INV ) {
	  fpga_set_trans_fifo_wr_clk_inv(pNum,1);
	} else {
	  fpga_set_trans_fifo_wr_clk_inv(pNum,0);
	}
	//-------------
	if( pDbP->CfgFlags & CFG_PORT_FLAG_TRFIFO_RDCLK_INV ) {
	  fpga_set_trans_fifo_rd_clk_inv(pNum,1);
	} else {
	  fpga_set_trans_fifo_rd_clk_inv(pNum,0);
	}
	//-------------
	if( pDbP->CfgFlags & CFG_PORT_FLAG_TRANS_ST_IN ) {
	  fpga_set_trans_st_input_en(pNum,1);
	} else {
	  fpga_set_trans_st_input_en(pNum,0);
	}
	//-------------
	if( pDbP->CfgFlags & CFG_PORT_FLAG_TRANS_ST_OUT ) {
	  fpga_set_trans_st_output_en(pNum,1);
	} else {
	  fpga_set_trans_st_output_en(pNum,0);
	}
	break;
      case IF_ENC_TDM:
	{
	  int func = pDbP->tdm_func;
	  int rate = pDbP->tdm_rate;
	  int fpga_rate;
	  if( ctp_get_fpga_tdm_rate(pNum,func,rate,&fpga_rate) == SUCCESS ) {
	    fpga_set_encoding(pNum,IF_ENC_TDM);
	    fpga_set_tdm_func(pNum,(u32)func);
	    fpga_set_tdm_rate(pNum,(u32)fpga_rate);
	  }
	}
	fpga_set_tt_freq_sel_dec(pNum,CTP_FREQ_CNT_SEL_TT);	// from cable
	break;
      default:
	PRTV(MAJ,Disabling port output due to invalid Port Encoding,
	    pDbP->IfEncoding);
	fpga_set_if_disable(Card,pNum); //CAP PR 1734636
	fpga_set_tt_freq_sel_dec(pNum,CTP_FREQ_CNT_SEL_SCC_EN);	// from scc
	break;
    }
    // Drive output signals to proper initial state
    // This will set TM inactive and DSR/DCD/CTS active
    // Make sure to do this first, since we may change signaling states
    // later based on other configs (e.g. Redundancy)
    // Additional note: It is not clear what use it is to set the signals
    // here anyway, since the port state machine will set the output
    // signaling leads to the database configured values.
    fpga_set_signals_active( pNum );
    // Check for RD reclock request
    if( pDbP->CfgFlags & CFG_PORT_FLAG_RD_RECLOCK ) {
      fpga_set_rd_reclock_enable(pNum,1);
    } else {
      fpga_set_rd_reclock_enable(pNum,0);
    }
    // Check for SD Activity substitution for RTS
    if ( pDbP->CfgFlags & CFG_PORT_FLAG_SD_ACT_RTS ) {
      fpga_set_sd_activates_rts_en(pNum, 1);
    } else {
      fpga_set_sd_activates_rts_en(pNum, 0);
    }
    // PR 1462799
    fpga_send_fcfg(sccNum);
    // Check for Y cable redundancy
    ctp_cfg_if_mode_redundancy(Card, pNum, pDbP); 
    fpga_clr_fcfg(); 
    // Check for single ended drivers on RD(DSR)/RT(TM)
    if( pDbP->CfgFlags & CFG_PORT_FLAG_SINGLE_ENDED ) {
      fpga_set_single_ended_mode(pNum,1);
    } else {
      fpga_set_single_ended_mode(pNum,0);
    }
    if( (pSysInfo->SysType == SYS_TYPE_CTP_2000) ||	// CTP-2000 & CTP-150 support RTS gating
	((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) ) {
      // Check for RTS clock gating function, CTP-2000 only
      if( pDbP->CfgFlags & CFG_PORT_FLAG_CGATE_EN ) {
	fpga_set_clk_gate_en(pNum,1);
	if( pDbP->CfgFlags & CFG_PORT_FLAG_CGATE_INV ) {
	  fpga_set_clk_gate_inv(pNum,1);
	} else {
	  fpga_set_clk_gate_inv(pNum,0);
	}
      } else {
	fpga_set_clk_gate_en(pNum,0);
	fpga_set_clk_gate_inv(pNum,0);
      }
      if( pDbP->CfgFlags & CFG_PORT_FLAG_DATA_INV ) {
	fpga_set_nrz_invert(pNum,1);
      } else {
	fpga_set_nrz_invert(pNum,0);
      }
    }
    fpga_send_fcfg(sccNum);
  }
  //----- Daughter card setup -----
  else if( IfMode == IF_MODE_DCARD ) {
    int DcardType	= Dcard.Card[Card].Info[pNum].Type;
    int DcardPresent	= Dcard.Card[Card].Info[pNum].Present;
    int DcardFwRev	= Dcard.Card[Card].Info[pNum].FwRev;
    fpga_clr_fcfg();
    // PR 1172928 start (1180788 too)
    // This is actually a response to the fixes done for PR-1153461, which
    // turned out to cause issues with DCARD operation. The fix here is to
    // "undo" the damage, by setting the redundancy mode back to 0 (off).
    fpga_set_redundant_mode(pNum,0);		// Rdnt mode [2]
    fpga_set_redundant_cts_ctrl(pNum,0);	// Rdnt mode [1]
    fpga_set_redundant_mstr(pNum,0);		// Rdnt mode [0]
    // PR 1172928 end (1180788 too)
    fpga_set_if_dce(pNum);	// This will reset DCARD
    fpga_set_if_dcard(pNum);
    fpga_send_fcfg(sccNum);
    if( DcardPresent == YES ) {
      if( pDbP->DcardType == DcardType) {
	switch( DcardType ) {
	  //----- 4WTO -----
	  case DCARD_4WTO:
	    if( DcardFwRev <= 1) {
	      PRTDV(MIN,Invalid 4WTO f/w version,DcardFwRev);
	      break;
	    }
	    fpga_clr_fcfg();
	    Data = 0x0;				// Init to both channels off
	    if( pDbP->DcardCfg1 & CFG_4WTO_DUAL_CHAN ) {
	      Data |= 0x3;
	      Chan1En = 1;
	      Chan0En = 1;
	    } else {
	      if( pDbP->DcardCfg1 & CFG_4WTO_CHAN_1 ) {
		Data |= 0x2;
		Chan1En = 1;
	      } else {
		Data |= 0x1; Chan0En = 1;
	      }
	    }
	    if ( pDbP->DcardCfg1 & CFG_4WTO_INT_WORK ) Data |= 0x4; 
	    pld_set_reg(pNum,0x1,Data,2);	// Channel enables

	    Data = 0x0;				// Init squelch off
	    if( pDbP->DcardCfg1 & CFG_4WTO_SQUELCH_EN )  Data |= 0x5;
	    if( pDbP->DcardCfg1 & CFG_4WTO_SQUELCH_ACT ) Data |= 0xa;
	    pld_set_reg(pNum,0x8,Data,2);	// Squelch

	    pld_set_reg(pNum,0x2,0x0,2);	// Clear Interrupts
	    pld_set_reg(pNum,0x3,0x0,2);	// Signals off
	    pld_set_reg(pNum,0x6,0x0,2);	// Tones off
	    pld_set_reg(pNum,0x7,0x2,2);	// Clr Peak detect
	    pld_set_reg(pNum,0x9,0x0,2);	// No loops
	    pld_set_reg(pNum,0x0,0x9,2);	// sig en/diff/io en

	    fpga_send_fcfg(sccNum);
	    if( Chan1En ) {
	      //----- Wake up chip -----
	      dcard_4w_set_wpot_reg(Card,pNum,1,WPOT_WAKE_UP );
	      if( dcard_4w_w4_wpot_ready(Card,pNum,1) ) {
		PRT(MIN,Chip didnt wake up);
	      }
	      //----- Program levels -----
	      Level = (pDbP->DcardCfg1 >> 16) & 0xff;	// Input levels
	      dcard_4w_prog_wpot_tap(Card,pNum,1,0,Level);
	      dcard_4w_prog_wpot_tap(Card,pNum,1,1,Level);
	      Level = (pDbP->DcardCfg1 >> 24) & 0xff;	// Output levels
	      dcard_4w_prog_wpot_tap(Card,pNum,1,2,Level);
	    }
	    if( Chan0En ) {
	      //----- Wake up chip -----
	      dcard_4w_set_wpot_reg(Card,pNum,0,WPOT_WAKE_UP );
	      if( dcard_4w_w4_wpot_ready(Card,pNum,0) ) {
		PRT(MIN,Chip didnt wake up);
	      }
	      //----- Program levels -----
	      Level = (pDbP->DcardCfg1 >> 16) & 0xff;	// Input levels
	      dcard_4w_prog_wpot_tap(Card,pNum,0,0,Level);
	      dcard_4w_prog_wpot_tap(Card,pNum,0,1,Level);
	      Level = (pDbP->DcardCfg1 >> 24) & 0xff;	// Output levels
	      dcard_4w_prog_wpot_tap(Card,pNum,0,2,Level);
	    }
	    //----- Enable packet loss mute function -----
	    ncmd.CmdType = SCC_CMD_CFG_4WTO_MUTE;
	    ncmd.CmdObj = 1;			// Enable Muting
	    ncmd.CmdObj2 = 0x0;			// Initially non Mute
	    // This was set to 4, which translates to 24 - 32 ms of mute,
	    // but for some reason did not work on some WHCA circuits. So
	    // it is doubled here to help improve things.
	    ncmd.CmdObj3 = 24;			// TODO - make OS independent
	    ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
	    break;
	  //----- T1E1 -----
	  case DCARD_T1E1:
	    PRTP(EVE,Reset T1E1 dcard LIU);
	    dcard_t1_set_liu_reg(Card,pNum,0x22,0x80);	// Ctrl #2 - Reset LIU
	    usleep(32000);				// Sleep 32mS
	    //----- E1 -----
	    if( pDbP->DcardCfg1 & T1E1_MSK_E1 ) {
	      PRTP(EVE,Setup E1 dcard);
	      if( pDbP->DcardCfg1 & T1E1_MSK_E1_COAX ) {
		fpga_clr_fcfg();
		pld_set_reg(pNum,0x0,0x5,2);	// term 78/no loop/io en
		fpga_send_fcfg(sccNum);
	      } else {
		fpga_clr_fcfg();
		pld_set_reg(pNum,0x0,0x1,2);	// term 120/no loop/io en
		fpga_send_fcfg(sccNum);
	      }
	      dcard_t1_set_liu_reg(Card,pNum,0x20,0xf0);	// E1-HDB3
	    }
	    //----- T1 -----
	    else {
	      PRTP(EVE,Setup T1 dcard);
	      fpga_clr_fcfg();
	      pld_set_reg(pNum,0x0,0x9,2);	// term 100/no loop/io en
	      fpga_send_fcfg(sccNum);
	      if( pDbP->DcardCfg1 & T1E1_MSK_T1_AMI ) {
		dcard_t1_set_liu_reg(Card,pNum,0x20,0xd3);	// T1-AMI
	      } else {
		dcard_t1_set_liu_reg(Card,pNum,0x20,0xf3);	// T1-B8ZS
	      }
	    }
	    dcard_t1_set_liu_reg(Card,pNum,0x22,0x00);	// Ctrl #2
	    dcard_t1_set_liu_reg(Card,pNum,0x24,0x00);	// Ctrl #3
	    dcard_t1_set_liu_reg(Card,pNum,0x2e,0x03);	// Ctrl #4
	    dcard_t1_set_liu_reg(Card,pNum,0x26,0xff);	// Interrupt Clear

	    break;
	  //----- IRIG-B -----
	  case DCARD_IRIG:
	    usleep(5000);		// To allow FPGA to load
	    ctp_cfg_if_mode_irig( Card, pNum, pDbP );
	    break;
	  //----- MultiSvc DCARD -----
	  case DCARD_MS:
	    usleep(5000);		// To allow FPGA to load
	    {
	      u32 Mode;
	      getMaskVal(&pDbP->DcardCfg1,32,CFG_IRIG_MODE_MASK,&Mode);
	      switch(Mode) {
		case CFG_IRIG_MODE_IRIG:
		  ctp_cfg_if_mode_irig( Card, pNum, pDbP );
		  break;
		case CFG_IRIG_MODE_4WTO:
		case CFG_IRIG_MODE_AUDIO:
		  ctp_cfg_if_mode_ms_audio( Card, pNum, pDbP );
                  ctp_cfg_if_mode_redundancy(Card, pNum, pDbP); // PR 1462799
		  break;
		case CFG_IRIG_MODE_TDC:
		  ctp_cfg_if_mode_ms_tdc( Card, pNum, pDbP );
		  break;
	      }
	    }
	    break;
	  //----- Other -----
	  default:
	    PRTDV(MIN,Unsupported DCARD type,DcardType);
	    break;
	}
        fpga_send_fcfg(sccNum); // PR 1462799
      } else {
	PRT(MIN,Daughter card cfg does not match installed H/W);
	PRT(MIN,OK if someone is trying to load a DCARD PLD);
	// We want to enable this DCARD anyway, since we may be trying to
	// do a PLD JAM STAPL configuration.
	fpga_clr_fcfg();
	fpga_set_if_dcard(pNum);
	fpga_send_fcfg(sccNum);
      }
    } else {
      PRTP(EVE,No Daughter card installed on port);
    }
  } else {
    PRTDV(MIN,Unsupported i/f Mode,IfMode);
    fpga_clr_fcfg();
    fpga_set_if_disable(Card,pNum); //CAP PR 1734636
    fpga_send_fcfg(sccNum);
  }
}

/*|***********************************************************************
 *|# ctp_cfg_if_mode_irig - Configure MS or IRIG DCARD for irig mode
 *|***********************************************************************/
void ctp_cfg_if_mode_irig( int Card, int pNum, CTP_PORT_DBASE *pDbP )
{
  int	sccNum = Ctp.Card[Card].Port[pNum].SccNum;
  u32	Data, Level, Tmp, Tmp1;
  int DcardType		= Dcard.Card[Card].Info[pNum].Type;
  int DcardPresent	= Dcard.Card[Card].Info[pNum].Present;
  int DcardFwRev	= Dcard.Card[Card].Info[pNum].FwRev;
  FUNC_PRT(ctp_cfg_if_mode_irig, PF_PST, pNum);

  if( DcardFwRev < 0) {		// XXX mike - kludge, should be > 0
  //if( DcardFwRev <= 0) {
    PRTDV(MIN,Invalid IRIG f/w version,DcardFwRev);
    return;
  }

  Tmp = pDbP->DcardCfg1;
  PRTVP(GN3,DcardCfg1,Tmp);

  fpga_clr_fcfg();
  //--- mode reg
  Data = 0x0;

  if( pDbP->DcardCfg1 & CFG_IRIG_TX_EN ) {
    if( pDbP->DcardCfg1 & CFG_IRIG_EMUL ) {
      Data |= 0xb;	// Tx emulation to cable
    }	else {
      Data |= 0x3;	// Tx real data to cable
    }
  }
  if( pDbP->DcardCfg1 & CFG_IRIG_RX_EN ) {
    if( pDbP->DcardCfg1 & CFG_IRIG_EMUL ) {
      Data |= 0x5;	// Rx emulation to IP net
    }	else {
      Data |= 0x1;	// Rx real data from cable
    }
  }

  pld_set_reg(pNum,0x3,Data,4);
  PRTVP(GN3,IRIG mode reg,Data);

  //--- clk count reg
  Tmp = 0x0;
  pld_set_reg(pNum,0xa,0x0,4);	// Clk gap high byte = 0
  PRTVP(GN3,IRIG gapped clk count MSB,Tmp);
  Tmp = ((pDbP->DcardCfg1 & CFG_IRIG_CLK_CNT) >> 8) & 0xff;
  pld_set_reg(pNum,0x9,Tmp,4);
  PRTVP(GN3,IRIG gapped clk count LSB,Tmp);

  //--- clk period reg
  // IRIG-B runs at 100 bps, which is 10,000,000 ns/bit. We need
  // to figure out the clock period in multiples of 163 ns so
  // that the gapped clock fills "just under" this 10 ms period.
  // Note: changed it to 170 ns so that it would be a bit more
  // conservative.

  Tmp1 = ( 10000000 / (Tmp * 170) ) - 1;

  Tmp = (Tmp1 >> 8) & 0xff;
  PRTVP(GN3,IRIG clock period MSB,Tmp);
  pld_set_reg(pNum,0x8,Tmp,4);

  Tmp = Tmp1 & 0xff;
  PRTVP(GN3,IRIG clock period LSB,Tmp);
  pld_set_reg(pNum,0x7,Tmp,4);

  //--- Output high level ( 67 degrees )
  Tmp = (pDbP->DcardCfg1 >> 24) & 0xff;	// Dbase value
  Tmp1 = (Tmp * 0x7642) / 0x100;	// 67 degree scaled value

  Tmp = (Tmp1 >> 8) & 0xff;
  PRTVP(GN3,IRIG out hi level 67 deg MSB,Tmp);
  pld_set_reg(pNum,0x1b,Tmp,4);	// MSB

  Tmp = Tmp1 & 0xff;
  PRTVP(GN3,IRIG out hi level 67 deg LSB,Tmp);
  pld_set_reg(pNum,0x1a,Tmp,4);	// LSB

  //--- Output high level ( 22 degrees )
  Tmp = (pDbP->DcardCfg1 >> 24) & 0xff;	// Dbase value
  Tmp1 = (Tmp * 0x30fc) / 0x100;	// 22 degree scaled value

  Tmp = (Tmp1 >> 8) & 0xff;
  PRTVP(GN3,IRIG out hi level 22 deg MSB,Tmp);
  pld_set_reg(pNum,0x19,Tmp,4);	// MSB

  Tmp = Tmp1 & 0xff;
  PRTVP(GN3,IRIG out hi level 22 deg LSB,Tmp);
  pld_set_reg(pNum,0x18,Tmp,4);	// LSB

  //--- Output low level ( 67 degrees )
  Tmp = (pDbP->DcardCfg1 >> 16) & 0xff;	// Dbase value
  Tmp1 = (Tmp * 0x7642) / 0x100;	// 67 degree scaled value

  Tmp = (Tmp1 >> 8) & 0xff;
  PRTVP(GN3,IRIG out lo level 67 deg MSB,Tmp);
  pld_set_reg(pNum,0x17,Tmp,4);	// MSB

  Tmp = Tmp1 & 0xff;
  PRTVP(GN3,IRIG out lo level 67 deg LSB,Tmp);
  pld_set_reg(pNum,0x16,Tmp,4);	// LSB

  //--- Output low level ( 22 degrees )
  Tmp = (pDbP->DcardCfg1 >> 16) & 0xff;	// Dbase value
  Tmp1 = (Tmp * 0x30fc) / 0x100;	// 22 degree scaled value

  Tmp = (Tmp1 >> 8) & 0xff;
  PRTVP(GN3,IRIG out lo level 22 deg MSB,Tmp);
  pld_set_reg(pNum,0x15,Tmp,4);	// MSB

  Tmp = Tmp1 & 0xff;
  PRTVP(GN3,IRIG out lo level 22 deg LSB,Tmp);
  pld_set_reg(pNum,0x14,Tmp,4);	// LSB

  //--- HW control reg
  Data = 0x0;				// DSR/CTS off/ module LED
  Data |= 0x80;			// Release Codec reset
  pld_set_reg(pNum,0x5,Data,4);
  PRTVP(GN3,IRIG HW ctrl reg,Data);

  //--- Analog control reg
  Data = 0x0;				// Default everything disabled
  // Was 7, but differential is the right choice
  Data |= 0x05;			// Enable Channel 0
  pld_set_reg(pNum,0x4,Data,4);
  PRTVP(GN3,IRIG Analog ctrl reg,Data);
  //---
  pld_set_reg(pNum,0xb,0,4);	// Clear
  pld_set_reg(pNum,0xe,0,4);	// Clear
  pld_set_reg(pNum,0xf,0,4);	// Clear
  pld_set_reg(pNum,0x10,0,4);	// Clear

  fpga_send_fcfg(sccNum);
}

/*|***********************************************************************
 *|# ctp_cfg_if_mode_ms_audio - Configure MS DCARD for audio mode
 *|***********************************************************************/
void ctp_cfg_if_mode_ms_audio( int Card, int pNum, CTP_PORT_DBASE *pDbP )
{
  //char Buf[100];
  int	sccNum = Ctp.Card[Card].Port[pNum].SccNum;
  u32	Master,DualChan,ULaw,SquelchEn,SquelchAct,Rate,OutLvl0,OutLvl1;
  int	ClkCnt, CodecCode, AudiokHz, Data, Temp;
  double	ClkGap;
  int DcardType		= Dcard.Card[Card].Info[pNum].Type;
  int DcardPresent	= Dcard.Card[Card].Info[pNum].Present;
  int DcardFwRev	= Dcard.Card[Card].Info[pNum].FwRev;
  FUNC_PRT(ctp_cfg_if_mode_ms_audio, PF_PST, pNum);

  if( DcardFwRev <= 0) {
    PRTDV(MIN,Invalid IRIG f/w version,DcardFwRev);
    return;
  }

  getMaskVal(&pDbP->DcardCfg1,32,CFG_IRIG_MASTER_SRC,&Master);
  getMaskVal(&pDbP->DcardCfg1,32,CFG_IRIG_DUAL_CHAN,&DualChan);
  getMaskVal(&pDbP->DcardCfg1,32,CFG_IRIG_ULAW,&ULaw);
  getMaskVal(&pDbP->DcardCfg1,32,CFG_IRIG_SQUELCH_EN,&SquelchEn);
  getMaskVal(&pDbP->DcardCfg1,32,CFG_IRIG_SQUELCH_ACT,&SquelchAct);
  getMaskVal(&pDbP->DcardCfg1,32,CFG_IRIG_AUDIO_RATE,&Rate);
  getMaskVal(&pDbP->DcardCfg1,32,CFG_IRIG_AUDIO_OUTLVL_0,&OutLvl0);
  getMaskVal(&pDbP->DcardCfg1,32,CFG_IRIG_AUDIO_OUTLVL_1,&OutLvl1);

  fpga_clr_fcfg();

  // Mode Reg --------------			
			Data  = 0x11;
  if( DualChan )	Data |= 0x02;
           		Data |= 0x04; //PR 1524860 fix
  pld_set_reg(pNum,0x3,(u32)Data,4);
  PRTVP(GN3,MS DCARD mode reg,Data);
  // Analog Ctrl Reg --------------			
			Data  = 0x05;
  if( DualChan )	Data |= 0x50;
  pld_set_reg(pNum,0x4,(u32)Data,4);
  PRTVP(GN3,MS DCARD analog ctrl reg,Data);
  // H/W Ctrl Reg --------------			
			Data  = 0x80;	// Codec not reset
  pld_set_reg(pNum,0x5,(u32)Data,4);
  PRTVP(GN3,MS DCARD hw ctrl reg,Data);
  // Clk Cnt Regs --------------			
  			ClkCnt = 8;	// 8 bits per sample
  if( !ULaw )		ClkCnt *= 2;	// 8 vs 16 bit samples
  if( DualChan )	ClkCnt *= 2;	// dual channel vs. single
			Data  = ClkCnt & 0xff;
  pld_set_reg(pNum,0x9,(u32)Data,4);	// bits[7:0]
			Data  = (ClkCnt >> 8) & 0xff;
  pld_set_reg(pNum,0xa,(u32)Data,4);	// bits[15:8]
  PRTVP(GN3,MS DCARD ClkCnt,ClkCnt);
  // Clk Gap Regs --------------			
  getAudioRateInfo((int)Rate, 1, &AudiokHz);
  Temp  = AudiokHz * 163 * (ClkCnt + 1);
  ClkGap  = (double)((double)1000000/(double)Temp);
			Data  = (int)ClkGap & 0xff;
  pld_set_reg(pNum,0x7,(u32)Data,4);	// bits[7:0]
  PRTVP(GN3,MS DCARD ClkGapLo,Data);
			Data  = ((int)ClkGap >> 8) & 0xff;
  pld_set_reg(pNum,0x8,(u32)Data,4);	// bits[15:8]
  PRTVP(GN3,MS DCARD ClkGapHi,Data);
  // Func Ctrl Reg --------------			
			Data  = 0x00;
  if( DualChan ) {
    if( SquelchEn )	Data |= 0x50;
    if( !SquelchAct )	Data |= 0xa0;
  } else {
    if( SquelchEn )	Data |= 0x10;
    if( !SquelchAct )	Data |= 0x20;  // Aricent PR 860112
  }
  pld_set_reg(pNum,0xe,(u32)Data,4);
  PRTVP(GN3,MS DCARD func ctrl reg,Data);
  // Codec Ctrl Reg --------------			
  getAudioRateInfo((int)Rate, 0, &CodecCode);
			Data  = 0x00;
  if( ULaw )		Data |= 0x08;
			Data |= (CodecCode & 0x7); // codec[2:0]
  pld_set_reg(pNum,0x10,(u32)Data,4);
  PRTVP(GN3,MS DCARD codec ctrl reg,Data);
  // TODO - Work with Rick to figure this out. Apparently there are some
  // PLD strangenesses
#if 0
  // Output Level Chan 0 Reg --------------			
			Data = OutLvl0;
    pld_set_reg(pNum,0x14,(u32)Data,4);
  // Output Level Chan 1 Reg --------------			
			Data = OutLvl1;
    pld_set_reg(pNum,0x15,(u32)Data,4);
#else
  //PR :1910270 Fix Start
  int bNum = util_get_next_bNum(&Db.Card[Card].Port[pNum], -1);
  if( Db.Bndl[bNum].Type == CTP_BNDL_TYPE_CTP){
        //sprintf(Buf,"#ms_audio CTP_BNDL_TYPE_CTP\n");
        //R_PRTS(MAJ,,Buf);
    Data = OutLvl0;
    pld_set_reg(pNum,0x14,(u32)Data,4);
    pld_set_reg(pNum,0x15,(u32)Data,4);
  }else if( Db.Bndl[bNum].Type == CTP_BNDL_TYPE_WP){
        //sprintf(Buf,"#ms_audio CTP_BNDL_TYPE_CESoPSN\n");
        //R_PRTS(MAJ,,Buf);
    if( DualChan ) {
    	Data = OutLvl0;
    	pld_set_reg(pNum,0x14,(u32)Data,4);

    	Data = OutLvl1;
    	pld_set_reg(pNum,0x15,(u32)Data,4);
    }else{
    	Data = OutLvl0;
    	pld_set_reg(pNum,0x14,(u32)Data,4);
    	pld_set_reg(pNum,0x15,(u32)0,4);
    }
  }
  //PR :1910270 Fix End
#endif

  pld_set_reg(pNum,0xb,0,4);	// Clear
  pld_set_reg(pNum,0xf,0,4);	// Clear
  pld_set_reg(pNum,0x16,0,4);	// Clear
  pld_set_reg(pNum,0x17,0,4);	// Clear
  pld_set_reg(pNum,0x18,0,4);	// Clear
  pld_set_reg(pNum,0x19,0,4);	// Clear
  pld_set_reg(pNum,0x1a,0,4);	// Clear
  pld_set_reg(pNum,0x1b,0,4);	// Clear

  fpga_send_fcfg(sccNum);
}

/*|***********************************************************************
 *|# ctp_cfg_if_mode_ms_tdc - Configure MS DCARD for TDC mode
 *|***********************************************************************/
void ctp_cfg_if_mode_ms_tdc( int Card, int pNum, CTP_PORT_DBASE *pDbP )
{
  int	sccNum = Ctp.Card[Card].Port[pNum].SccNum;
  u32	Master,Rate,OutLvl0,NrzDco;
  int	ClkCnt, CodecCode, AudiokHz, Data, Temp;
  double	ClkGap,FifoDelay;
  int DcardType		= Dcard.Card[Card].Info[pNum].Type;
  int DcardPresent	= Dcard.Card[Card].Info[pNum].Present;
  int DcardFwRev	= Dcard.Card[Card].Info[pNum].FwRev;
  char PrtStr[200];
  FUNC_PRT(ctp_cfg_if_mode_ms_audio, PF_PST, pNum);

  if( DcardFwRev <= 0) {
    PRTDV(MIN,Invalid IRIG f/w version,DcardFwRev);
    return;
  }

  getMaskVal(&pDbP->DcardCfg1,32,CFG_IRIG_MASTER_SRC,&Master);
  getMaskVal(&pDbP->DcardCfg1,32,CFG_IRIG_TDC_NRZ_RATE,&Rate);
  getMaskVal(&pDbP->DcardCfg1,32,CFG_IRIG_AUDIO_OUTLVL_0,&OutLvl0);

  fpga_clr_fcfg();

  // Debug Reg --------------			
			Data  = 14;
  pld_set_reg(pNum,0xff,(u32)Data,4);
  PRTVP(GN3,MS DCARD debug reg,Data);
  // Mode Reg --------------			
			Data  = 0x31;
  if( Master )		Data |= 0x04;
  pld_set_reg(pNum,0x3,(u32)Data,4);
  PRTVP(GN3,MS DCARD mode reg,Data);
  // Analog Ctrl Reg --------------			
  if( Master )		Data = 0x04;
  else			Data = 0x01;	// Ch 0 only
  pld_set_reg(pNum,0x4,(u32)Data,4);
  PRTVP(GN3,MS DCARD analog ctrl reg,Data);
  // H/W Ctrl Reg --------------			
			Data  = 0x80;
  if( !Master )		Data |= 0x0c;	// Enable NRZ out
  pld_set_reg(pNum,0x5,(u32)Data,4);
  PRTVP(GN3,MS DCARD hw ctrl reg,Data);
  // Clk Cnt Regs --------------			
  			ClkCnt = ((Rate >> 1) + 64) / 8;
			Data  = ClkCnt & 0xff;
  pld_set_reg(pNum,0x9,(u32)Data,4);	// bits[7:0]
			Data  = (ClkCnt >> 8) & 0xff;
  pld_set_reg(pNum,0xa,(u32)Data,4);	// bits[15:8]
  PRTVP(GN3,MS DCARD ClkCnt,ClkCnt);
  // Clk Gap Regs --------------			
  ClkGap  = (double)((double)768/((double)ClkCnt+1));	
  if( ClkGap < 1 ) ClkGap = 1;
			Data  = (int)ClkGap & 0xff;
  pld_set_reg(pNum,0x7,(u32)Data,4);	// bits[7:0]
  PRTVP(GN3,MS DCARD ClkGapLo,Data);
			Data  = ((int)ClkGap >> 8) & 0xff;
  pld_set_reg(pNum,0x8,(u32)Data,4);	// bits[15:8]
  PRTVP(GN3,MS DCARD ClkGapHi,Data);
  // Func Ctrl Reg --------------			
			Data  = 0x00;
  pld_set_reg(pNum,0xe,(u32)Data,4);
  PRTVP(GN3,MS DCARD func ctrl reg,Data);
  // Codec Ctrl Reg --------------			
			Data  = 0x0c;	// Fixed at 8kHz uLaw
  if( Master )		Data |= 0x03;
  pld_set_reg(pNum,0x10,(u32)Data,4);
  PRTVP(GN3,MS DCARD codec ctrl reg,Data);
  // Output Level Chan 0 Reg --------------			
			Data = OutLvl0;
  pld_set_reg(pNum,0x14,(u32)Data,4);
  PRTVP(GN3,MS DCARD ch 0 output lvl reg,Data);
  // NRZ DCO --------------			
  			NrzDco = Rate << 2;	// N x 8k
			Data  = ((u32)NrzDco >> 8) & 0xff;
  pld_set_reg(pNum,0x1b,(u32)Data,4);	// bits[15:8]
  PRTVP(GN3,MS DCARD NrzDcoMsb,Data);
			Data  = (u32)NrzDco & 0xff;
  pld_set_reg(pNum,0x1a,(u32)Data,4);	// bits[7:0]
  PRTVP(GN3,MS DCARD NrzDcoLsb,Data);
  // PLL DCO --------------			
  if( Master ) {	
    pld_set_reg(pNum,0x19,0x02,4);	// Interleave factor unused
    pld_set_reg(pNum,0x18,0x00,4);	// CInterleave factor unusedlear
  } else {
			Data  = ((u32)NrzDco >> 8) & 0xff;
    pld_set_reg(pNum,0x19,(u32)Data,4);	// bits[15:8]
    PRTVP(GN3,MS DCARD PllDcoMsb,Data);
			Data  = (u32)NrzDco & 0xff;
    pld_set_reg(pNum,0x18,(u32)Data,4);	// bits[7:0]
    PRTVP(GN3,MS DCARD PllDcoLsb,Data);
  }
  // FIFO Delay --------------			
  FifoDelay  = (double)((double)1.245 * (double)Rate);
			Data  = (int)FifoDelay & 0xff;
  pld_set_reg(pNum,0x16,(u32)Data,4);	// bits[7:0]
  PRTVP(GN3,MS DCARD FifoDelayLsb,Data);
			Data  = ((int)FifoDelay >> 8) & 0xff;
  pld_set_reg(pNum,0x17,(u32)Data,4);	// bits[15:8]
  PRTVP(GN3,MS DCARD FifoDelayMsb,Data);

  // Other Regs --------------			
  pld_set_reg(pNum,0x15,0,4);	// Clear
  pld_set_reg(pNum,0xf,0,4);	// Clear
  pld_set_reg(pNum,0xb,0,4);	// Clear

  // Func Ctrl Reg (last) --------------			
			Data  = 0x30;
  //if( Master and ISOCH)		Data |= 0x40;	// TODO
  pld_set_reg(pNum,0xe,(u32)Data,4);
  PRTVP(GN3,MS DCARD func ctrl reg,Data);

  fpga_send_fcfg(sccNum);
}

/*|***********************************************************************
 *|# ctp_get_fpga_tdm_rate - 
 *|***********************************************************************/
u32 ctp_get_fpga_tdm_rate( int pNum, int func, int rate, int *pFrate )
{
  int Status = SUCCESS;
  FUNC_PRT(ctp_get_fpga_tdm_rate, PF_PST, pNum);

  switch(func) {
    case IF_ENC_TDM_SLOW_CLK:
    case IF_ENC_TDM_MSTAR:
      // Single interleave sig, so any of the TDM rates will work
      if( (rate != 1) && (rate != 2) && (rate != 4) &&
	  (rate != 8) && (rate != 16) ) {
	PRTV(MAJ,Invalid TDM Rate for slow/mstar func,rate);
	Status = FAILURE;
      }
      break;
    case IF_ENC_TDM_TDC:
      // 2 interleave sigs, so exclude rate = 1 (bits/32)
      if( (rate != 2) && (rate != 4) &&
	  (rate != 8) && (rate != 16) ) {
	PRTV(MAJ,Invalid TDM Rate for tdc func,rate);
	Status = FAILURE;
      }
      break;
    case IF_ENC_TDM_4XSIG:
      // 4 interleave sigs, so exclude rates 1 and 2 (bits/32)
      if( (rate != 4) && (rate != 8) && (rate != 16) ) {
	PRTV(MAJ,Invalid TDM Rate for 4xsig func,rate);
	Status = FAILURE;
      }
      break;
    default:
      PRTV(MAJ,Invalid TDM Function,func);
      Status = FAILURE;
      break;
  }

  // Now convert the bits/32 rate value to the value that the FPGA wants
  switch(rate) {
    case 1:	*pFrate = 7; break;
    case 2:	*pFrate = 1; break;
    case 4:	*pFrate = 2; break;
    case 8:	*pFrate = 3; break;
    case 16:	*pFrate = 4; break;
    default:
      PRTV(MAJ,Invalid TDM Rate,rate);
      Status = FAILURE;
      break;
  }

  return Status;
}

u32 ctp_get_frac_chan_en( int Card, int pNum )
{
  CTP_PORT_DBASE *pDbP = &Db.Card[Card].Port[pNum];
  int channels = pDbP->DcardCfg2;
  int i = channels;
  u32 chan_en=0;
  FUNC_PRT(ctp_get_frac_chan_en, PF_PST, pNum);
  if( pDbP->DcardCfg1 & T1E1_MSK_E1 ) {
    //-- Fractional E1
    int cas = (pDbP->DcardCfg1 & T1E1_MSK_E1_CAS)? 1 : 0;
    chan_en |= 0x80000000;		// Framing timeslot
    while ( i > 0 ) { chan_en |= 0x1 << (i-1); i--; }
    if( cas ) {
      if( channels > 15 ) { chan_en |= 0x1 << (channels); }
      chan_en |= 0x8000;
    }
  } else {
    //-- Fractional T1
    while ( i > 0 ) { chan_en |= 0x1 << (i-1); i--; }
  }
  return chan_en;
}

