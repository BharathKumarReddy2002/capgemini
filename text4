//--------------------------------------------------------------------------
int ctp_proc_msg_cmd( CTP_Q_MSG * pMsg )
{
  CTP_Q_MSG			 TMsg;
  struct acrndrv_runtime_cfg	 nrc;
  struct acrndrv_command	 ncmd;
  struct acrndrv_cmd_log	 ncmdl;
  struct eth_command		 ecmd;
  char				 Buf[40],SccBuf[40],PrtBuf[100];
  char				 dbaseFile[100];
  u32				 Ref,Bad,Acc,Freq,Sync,Error,Nvmem;
  u32				 Sigs,Val,Val1,Addr,Data,Mode,Chunks,Chan,Pot;
  u32				 Enable,Level,IoEn,SingleEnded,Loop,SigEn;
  u32				 DualChan,Src,Div,Duty,Per,Sig,Mask;
  int				 Exponent, Multiplier = 0, Status, i, j;
  int				 Card, pNum;
  FILE				*pBufFile;
  struct timeval	 	 now;
  char			 	 EthBuf[8];
  CTP_PORT_STATE		*pPortSt;
  CTP_PORT_INT_STATE		*pPortIntSt;
  CTP_PORT_CNTRS		*pPortCnt;
  CTP_PORT_DBASE		*pDbP;
//Aricent PR602377 Fix Start -- Added runtime config for If_mode
  CTP_PORT_DBASE               TempDbp;
//Aricent PR602377 Fix End
#ifdef VCTP
  int c_idx;
#endif
  FUNC_PRT(ctp_proc_msg_cmd, PF_IPC, -1);
#ifdef DBG_MSG_QUEUE
  PRT(EVE,CTP processing cmd message);
#endif

  ctp_copy_msg_hdr( pMsg, &TMsg );	// build header of response message

  //--- Most common commands are port commands where card/port are stored
  //    in Obj1, we get these here, then if it is not a port command we get
  //    what we need later.
  Card = CARD_INFO(pMsg->CtpMsg.msg.Cmd.Obj1);
  pNum = PNUM_INFO(pMsg->CtpMsg.msg.Cmd.Obj1);
  pDbP = &Db.Card[Card].Port[pNum];
  if( (Card < CTP_MAX_CARDS) &&
      (CARDTYPE(Card)) ) {
    if( pNum < pSysInfo->Card[Card].PortsOnCard ) {
      //--- We have a good Card, pNum & Port in case this is a port command.
      pPortSt    = &Ctp.Card[Card].Port[pNum];
      pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
      pPortCnt   = &Ctp.Card[Card].Cntr[pNum];
    }
  }
  sprintf(&dbaseFile[0],"%s/%s", CTP_DB_DIR, CTP_DB_FILE );
  switch( pMsg->CtpMsg.msg.Cmd.CmdType ) {
    case CTPCMDTYPE_DB_SAVE:
      PRT(GEN,Saving Database);
      ctp_dbase_write( &Db, dbaseFile );
      break;
    case CTPCMDTYPE_RECENTER_PORT:
      if (pPortSt->Available) {
	sprintf(SccBuf,"scc%d",pPortSt->SccNum);
	PRTP(GEN,Recenter buffer on port);
	ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
	nrc.restart = YES;
	nrc.starve_flag = NO;
	ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      } else {
	PRTP(EVE,Tried to recenter on missing card for port);
      }
      break;
    case CTPCMDTYPE_RESET_BUFMON:
      if (pPortSt->Available) {
        // Aricent PR 947222 Fix - Start
        int bNum = pMsg->CtpMsg.msg.Cmd.Obj2 - 1;
        if(bNum >= 0 && bNum < CTP_MAX_BNDLS)
          sprintf(SccBuf,"cbc%d",Db.Bndl[bNum].Bndl.wp_bndl.cbc_num);
        else {
          if(pPortSt->SccNum == CTP_SCC_NONE) break;
          sprintf(SccBuf,"scc%d",pPortSt->SccNum);
        }
        // Aricent PR 947222 Fix - End
	PRTP(GEN,Resetting buffer monitor for port);
	ncmd.CmdType = SCC_CMD_RESET_BUFMON;
	ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
      } else {
	PRTP(GEN,Tried to reset bufmon on missing card for port);
      }
      break;
    case CTPCMDTYPE_TST_CLR_ETH:
#ifndef DBG_NO_ETH_IOCTL
      if( !strncmp(pPortIntSt->NetDev,"eth",3) ) {
        //Aricent PR 830151 --- clear eth counts 
        if(strlen(pPortIntSt->NetDev) > 5) {
          sscanf(pPortIntSt->NetDev, "%4s", EthBuf);
        } else {
          sprintf(EthBuf, "%s", pPortIntSt->NetDev);
        }
	ecmd.CmdType = ETH_CMD_CLR_CNTRS;
	ioc_priv(EthBuf,ETH_IOCTL_CMD,&ecmd);
	ecmd.CmdType = ETH_CMD_CLR_FLAGS;
	ioc_priv(EthBuf,ETH_IOCTL_CMD,&ecmd);
	PRT(GEN,Clear Eth Info);
      }
#endif //DBG_NO_ETH_IOCTL
      break;
    case CTPCMDTYPE_CLR_BNDL_CNT:
    {
      int bNum = pMsg->CtpMsg.msg.Cmd.Obj1;
      CTP_BNDL_CNTRS *pBndlCnt = &Ctp.Bndl_cnt[bNum];
      if(!SCC_CARD(Card)) break;
      Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
      pNum = util_bndl_src_pNum(0, &Db.Bndl[bNum]);
      pPortSt = &Ctp.Card[Card].Port[pNum];
      switch(Db.Bndl[bNum].Type) {
        case CTP_BNDL_TYPE_CTP:
	case CTP_BNDL_TYPE_SO:	      
	  sprintf(SccBuf,"scc%d",pPortSt->SccNum);
	  break;
	case CTP_BNDL_TYPE_WP:
          sprintf(SccBuf,"cbc%d",Db.Bndl[bNum].Bndl.wp_bndl.cbc_num); //Aricent PR-947222 
	  break;
	default:
	  break;
      }	    
      PRTB(GEN,Clearing Bndl Info);
      ncmd.CmdType = SCC_CMD_CLR_CNTRS;
      ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
      ncmd.CmdType = SCC_CMD_CLR_FLAGS;
      ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
      memset( (char *)&pBndlCnt->Bndl.ctp.Previous,
	    0,sizeof(struct acrndrv_runtime_stats));
      pBndlCnt->Bndl.ctp.Current.Counters.underflow_cnt = 0;
      pBndlCnt->Bndl.ctp.Current.Counters.overflow_cnt  = 0;
      pBndlCnt->Bndl.ctp.LongBufMon.Counters.underflow_cnt = 0;
      pBndlCnt->Bndl.ctp.LongBufMon.Counters.overflow_cnt  = 0;
      //Aricent PR 1273976 fix start
      if(IS_T1E1_2000(Card) || IS_T1E1(Card) || (pDbP->DcardType == DCARD_T1E1)){
        pBndlCnt->Bndl.ctp.LOFOccurCnt = 0;
      }
      //Aricent PR 1273976 fix end

      gettimeofday(&now,NULL);
      pBndlCnt->Bndl.ctp.TimeLastClr = now.tv_sec;
      /* Aricent PR 1117979, 1133355 Fix - Start */
      if (Db.Bndl[bNum].Type == CTP_BNDL_TYPE_CTP)
        pBndlCnt->Bndl.ctp.Latency = 0;
      /* Aricent PR 1117979, 1133355 Fix - End */
      break;
    }  
    case CTPCMDTYPE_TST_CLR_SCC:
      if(!SCC_CARD(Card)) break;
      if (pPortSt->Available) {
        // Aricent PR 947222 Fix - Start
        int bNum = pMsg->CtpMsg.msg.Cmd.Obj2 - 1;
        if(bNum >= 0 && bNum < CTP_MAX_BNDLS) {
          sprintf(SccBuf,"cbc%d",Db.Bndl[bNum].Bndl.wp_bndl.cbc_num);
        }
        else {
          if(pPortSt->SccNum == CTP_SCC_NONE) break;
          sprintf(SccBuf,"scc%d",pPortSt->SccNum);
          bNum = pPortIntSt->bNum;
        }
        // Aricent PR 947222 Fix - End
	PRTP(GEN,Clearing Scc Info);
	ncmd.CmdType = SCC_CMD_CLR_CNTRS;
	ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
	ncmd.CmdType = SCC_CMD_CLR_FLAGS;
	ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
	memset( (char *)&pPortCnt->Previous,
	    0,sizeof(struct acrndrv_runtime_stats));
	pPortCnt->Current.Counters.underflow_cnt = 0;
	pPortCnt->Current.Counters.overflow_cnt  = 0;
	pPortCnt->LongBufMon.Counters.underflow_cnt = 0;
	pPortCnt->LongBufMon.Counters.overflow_cnt  = 0;
	gettimeofday(&now,NULL);
	pPortCnt->TimeLastClr = now.tv_sec;
        /* Aricent PR 1117979, 1133355 Fix - Start */
        if ( Db.Bndl[bNum].Type == CTP_BNDL_TYPE_CTP )
          pPortCnt->Latency = 0;
        /* Aricent PR 1117979, 1133355 Fix - End */
	if(!PBS(Card, pNum) && !IS_BRIDGE(Card, pNum)) {
	  if((bNum >= 0) && (bNum < CTP_MAX_BNDLS)) {
	    // if there is a bndl associated to the port then copy the 
	    // counters to bundle statistics field.	  
	    bcopy(&pPortCnt->Current, &Ctp.Bndl_cnt[bNum].Bndl.ctp, 
	          sizeof(CtpBndlCntrs));	  
	  }
        }	
      } else {
	PRTP(GEN,Tried to clear cntrs on missing card for port);
      }
      break;
    case CTPCMDTYPE_TST_CLR_PLL:
      PRTP(GEN,Clearing BERT Info);
      Ctp.Node[0].PllRuntime = 0;
      Ctp.Node[0].PllLossSec  = 0;
      break;
    case CTPCMDTYPE_PORT_CLR_BERT:
      if (pPortSt->Available) {
	PRTP(GEN,Clearing BERT Info);
	pPortCnt->BertRunSec  = 0;
	pPortCnt->BertSyncSec = 0;
	pPortCnt->BertErrSec  = 0;
	pPortCnt->BertSync    = 0;
	pPortCnt->BertSyncLossCnt = 0;
	pPortCnt->BertErrCnt      = 0;
	gettimeofday(&now,NULL);
	pPortCnt->TimeLastClr = now.tv_sec;
      } else {
	PRTP(GEN,Tried to clear bert on missing card for port);
      }
      break;
    case CTPCMDTYPE_TST_ETH_DROP_PKT:
      if (pPortSt->Available) {
	sprintf(SccBuf,"scc%d",pPortSt->SccNum);
	PRTP(GEN,Dropping pkt toward Network);
	ncmd.CmdType = SCC_CMD_DROP_PKT_TO_NET;
	ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
      } else {
	PRTP(EVE,Tried to drop eth pkt on missing card for port);
      }
      break;
    case CTPCMDTYPE_START_REF_FREQ:
      Ref = pMsg->CtpMsg.msg.Cmd.Obj1;
      Card = pMsg->CtpMsg.msg.Cmd.Obj2;
      fpga_clr_fcfg();
      fpga_set_ref_freq_sel(Ref);
      fpga_restart_ref_freq();
      fpga_send_fcfg(pSysInfo->Card[Card].BaseSccNum);
      PRTC(GEN,CTPCMDTYPE_START_REF_FREQ);
      break;
    case CTPCMDTYPE_GET_REF_FREQ:
      Card = pMsg->CtpMsg.msg.Cmd.Obj1;
      fpga_clr_fcfg();
      fpga_get_port_freq(0xfe);	// 0xfe is special code for node
      fpga_send_fcfg(pSysInfo->Card[Card].BaseSccNum);
      fpga_get_port_freq_val(0,&Freq,&Acc); // chk returned vals
      if( Acc & 0x100 )	Bad = 1;
      else		Bad = 0;
      Acc &= 0xff;		// remove bad bit
      //PRTDVC(OFF,Reference Bad val,Bad);
      //PRTDVC(OFF,Reference Acc val,Acc);
      //PRTDVC(OFF,Reference Freq val,Freq);
      TMsg.CtpMsg.msg.Cmd.Obj1 = Bad;
      TMsg.CtpMsg.msg.Cmd.Obj2 = Acc;
      TMsg.CtpMsg.msg.Cmd.Obj3 = Freq;
      PRTC(GEN,CTPCMDTYPE_GET_REF_FREQ);
      break;
    case CTPCMDTYPE_ENABLE_WINPATH:
      Card = pMsg->CtpMsg.msg.Cmd.Obj1;
      fpga_clr_fcfg();
      fpga_enable_winpath();	// enable winpath
      fpga_send_fcfg(pSysInfo->Card[Card].BaseSccNum);
      break;
    case CTPCMDTYPE_DISABLE_WINPATH:
      Card = pMsg->CtpMsg.msg.Cmd.Obj1;
      fpga_clr_fcfg();
      fpga_disable_winpath();	// disable winpath
      fpga_send_fcfg(pSysInfo->Card[Card].BaseSccNum);
      break;
    case CTPCMDTYPE_GET_UWINMON_STATUS:
      Card = pMsg->CtpMsg.msg.Cmd.Obj1;
      fpga_clr_fcfg();
      fpga_get_uwinmon_status(); // get winmon ready or not
      fpga_send_fcfg(pSysInfo->Card[Card].BaseSccNum);
      fpga_get_uwinmon_status_val(0, &Val);
      TMsg.CtpMsg.msg.Cmd.Obj2= Val;
      break;
    case CTPCMDTYPE_KILL_CTP:
      PRT(GEN,CTPCMDTYPE_KILL_CTP);
      break;
    case CTPCMDTYPE_PORT_DBASE_INIT:
      if( (pDbP->State == CTP_DBSTATE_UP) &&
	  (Ctp.Card[Card].Port[pNum].Available) ) {
	PRTP(GEN,Deleting port);
	ctp_del_port(Card,pNum);
      }
      util_init_port_dbase(pDbP,CTP_PORT_DBASE_VERSION);
      if( IS_T1E1(Card) ) {
      /* This routine is only be called through diagnostics
         it is safe to configure T1 Card port as framed for
         CESoPSN bundle configuration */
        util_init_t1_dbase(pDbP);
        pDbP->DcardCfg1 |= T1E1_MSK_FRAME;
      }
      ctp_check_dbase();
      PRTP(GEN,CTPCMDTYPE_PORT_DBASE_INIT);
      break;
    case CTPCMDTYPE_WHOLE_DBASE_INIT:
      ctp_disable_all_bundles();	// Moved out of ctp_init_dbase()
      ctp_del_all_ports();		// Moved out of ctp_init_dbase()
      ctp_init_dbase(&Db);
      ctp_check_dbase();
      PRT(GEN,CTPCMDTYPE_WHOLE_DBASE_INIT);
      break;
    case CTPCMDTYPE_NODE_DBASE_INIT:
      util_init_node_dbase(&Db.Node[0]);
      ctp_check_dbase();
      PRT(GEN,CTPCMDTYPE_NODE_DBASE_INIT);
      break;
    case CTPCMDTYPE_PORT_STATE_INIT:
      ctp_init_port_state(Card,pNum,-1);
      PRT(GEN,CTPCMDTYPE_PORT_STATE_INIT);
      break;
    case CTPCMDTYPE_PORT_START_BERT:
      if (pPortSt->Available) {
        //Aricent PR 989527 fix - Start
	fpga_clr_fcfg();
	fpga_start_bert(pNum);
	fpga_send_fcfg(pPortSt->SccNum);
        //Aricent PR 989527 fix - End
	PRTP(GEN,CTPCMDTYPE_PORT_START_BERT);
      } else {
	PRTP(EVE,Tried to start bert on missing card for port);
      }
      break;
    case CTPCMDTYPE_PORT_RESET_BERT:
      if (pPortSt->Available) {
        if(IS_T1E1_2000(Card)) {
          ctp_timer_proc_wp_bert(Card,pNum);
        } else {
	  fpga_clr_fcfg();
	  fpga_reset_bert(pNum);
	  fpga_send_fcfg(pPortSt->SccNum);
        }
	PRTP(GEN,CTPCMDTYPE_PORT_RESET_BERT);
      } else {
	PRTP(EVE,Tried to reset bert on missing card for port);
      }
      break;
    case CTPCMDTYPE_PORT_STOP_BERT:
      if (pPortSt->Available) {
        //Aricent PR 989527 fix - Start
        fpga_clr_fcfg();
	fpga_stop_bert(pNum);
	fpga_send_fcfg(pPortSt->SccNum);
        //Aricent PR 989527 fix - End
	PRTP(GEN,CTPCMDTYPE_PORT_STOP_BERT);
      } else {
	PRTP(EVE,Tried to stop bert on missing card for port);
      }
      break;
    case CTPCMDTYPE_PORT_CHECK_BERT:
      if (pPortSt->Available) {
        if(IS_T1E1_2000(Card)) {
          ctp_timer_proc_wp_bert(Card,pNum);
          Sync = pPortCnt->BertSync;
          Error = pPortCnt->BertErrCnt;
        } else {
	  fpga_clr_fcfg();
	  fpga_get_port_read_reg(pNum);
	  fpga_send_fcfg(pPortSt->SccNum);
	  fpga_get_port_bert_sync_val(0, &Sync);
	  fpga_get_port_bert_err_cnt_val(0, &Error);
	}
	TMsg.CtpMsg.msg.Cmd.Obj1 = Sync;
	TMsg.CtpMsg.msg.Cmd.Obj2 = Error;
	PRTP(GEN,CTPCMDTYPE_PORT_CHECK_BERT);
      } else {
	PRTP(EVE,Tried to check bert on missing card for port);
      }
      break;
    case CTPCMDTYPE_TST_DUMP_FPGA_PORT_WR_REGS:
