//--- Main process for CTP150 node reference 
void ctp150_proc_node_ref(CTP_NREFS_STATE *pNodeRef)
{
  struct acrndrv_command	 ncmd;
  u32 ts0, ts1;
  FUNC_PRT(ctp150_proc_node_ref, PF_REF, -1);
  ncmd.CmdType = SCC_CMD_GET_INT_CARD_REF;
/*** PR1311627 - start ***/
#ifdef XMC
  ncmd.CmdObj = cardIndx[1];
#endif
/*** PR1311627 - end ***/
  ioc_priv("scc0",SCC_IOCTL_CMD,&ncmd);
  ts0 = ncmd.CmdObj2;
  ts1 = ncmd.CmdObj;
  //--- First one sample
  if(pNodeRef->State == CTP_NETREF_STATE_DIS) {
    pNodeRef->State = CTP_NETREF_STATE_AGGR;
    pNodeRef->buffer = 0x10000000;
//    pNodeRef->AdapPllValue = Ctp.Node[1].Calibration;
    pNodeRef->AdapPllValue = 0x800;
    ctp_set_pll_fixed( pNodeRef->AdapPllValue, 3);
  } else {
    u32 LocDif = ts0 - pNodeRef->TsState[0].ts;
    u32 RemDif = ts1 - pNodeRef->TsState[0].rem_ts;
    if( pNodeRef->TsState[0].ts > (ts0 + 0xf0000000) ) { LocDif += 0xffffffff; }
    if( pNodeRef->TsState[0].rem_ts > (ts1 + 0xf0000000) ) { RemDif += 0xffffffff; }
    pNodeRef->buffer += (RemDif - LocDif);
#ifdef VCTP
    ctp_netref_proc_buf(pNodeRef, cardIndx[1]);
#else
    ctp_netref_proc_buf(pNodeRef, 1);
#endif
  }	      
  pNodeRef->TsState[0].ts = ts0;
  pNodeRef->TsState[0].rem_ts = ts1;
}

