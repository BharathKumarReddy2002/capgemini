//--------------------------------------------------------------------------
// This routine is only called by the CTP_NET_TASK to accept messages from
// any remote nodes.
//--------------------------------------------------------------------------
int ctp_open_socket_for_rx( void )
{
  struct sockaddr_in 	sockaddr;
  struct sockaddr_in6 	sockaddr6;

  FUNC_PRT(ctp_open_socket_for_rx, PF_IPC, -1);

  //------------- create socket --------------
  pSysInfo->RxSock = socket(PF_INET, SOCK_DGRAM, 0);
  if(pSysInfo->RxSock < 0) {
    //perror("opening datagram socket");
    return(FAILURE);
  }
  sockaddr.sin_family = AF_INET;
  sockaddr.sin_addr.s_addr = INADDR_ANY;
  sockaddr.sin_port = htons(pSysInfo->oam_port);

  if(bind(pSysInfo->RxSock,
	(struct sockaddr *)&sockaddr,
	sizeof(sockaddr) ) < 0) {
    //perror("bind");
    return(FAILURE);
  }

  pSysInfo->RxSock6 = socket(PF_INET6, SOCK_DGRAM, 0);
  if(pSysInfo->RxSock6 < 0) {
    //perror("opening datagram socket for IPv6");
    return(FAILURE);
  }
  PRT(GEN,Rx Socket Created);

  //------------- bind socket to port --------------
  sockaddr6.sin6_family = AF_INET6;
  sockaddr6.sin6_addr = in6addr_any;
  sockaddr6.sin6_port = htons(pSysInfo->oam_port_v6);
  sockaddr6.sin6_flowinfo = 0;
  sockaddr6.sin6_scope_id = 0;

  if(bind(pSysInfo->RxSock6,
	 (struct sockaddr *)&sockaddr6,
	  sizeof(sockaddr6) ) < 0) {
    //perror("bind");
    return(FAILURE);
  }

  PRTDV(GEN,Rx Socket bound to port,pSysInfo->oam_port);
  return(SUCCESS);
}

//--------------------------------------------------------------------------
int ctp_netd_stop()
{
  int			status;
  FUNC_PRT(ctp_netd_stop, PF_MISC, -1);

  PRT(EVE,CTP Net Task received SIGTERM signal);

  NetTaskRunning = NO;

  if(pSysInfo->RxSock >= 0)
  {
    status = close(pSysInfo->RxSock);
    if(status < 0)
    {
      PRT(MAJ,Error closing socket);
      //perror("closing datagram socket");
      return(FAILURE);
    }
    else PRT(GEN,Socket successfully closed);
  }
  else PRT(MAJ,NULL RxSock);

  if(pSysInfo->RxSock6 >= 0)
  {
    status = close(pSysInfo->RxSock6);
    if(status < 0)
    {
      PRT(MAJ,Error closing socket6);
      //perror("closing datagram socket6");
      return(FAILURE);
    }
    else PRT(GEN,Socket6 successfully closed);
  }
  else PRT(MAJ,NULL RxSock6);
  return(SUCCESS);
}

