//--------------------------------------------------------------------------
// Scans through all the bundle mask elements looking to see if port
// has been assigned to a bundle. Returns 1 if assigned to any bundle, 0
// otherwise.
// The function is pulled off from ctp_util.c since we have to go through
// all the bundles' database now to find out the connection between port and
// bundle from port database. And ctp_util is too generic. Same function exists
// in ctpd.c
//--------------------------------------------------------------------------
int util_get_next_bNum( CTP_PORT_DBASE *pPortDb, int last_bNum )
{
  int bn;
  int found = 0;
  int dbg = 0;
  char	*fn = "util_get_next_bNum";

  for( bn=last_bNum+1; bn<CTP_MAX_BNDLS; bn++) {
    if(Db.Bndl[bn].Type == CTP_BNDL_TYPE_NONE) {
      continue;
    } else if(Db.Bndl[bn].Type == CTP_BNDL_TYPE_VC) {
      int chan = 0;
      CTP_SRC_INFO *pSrcInfo;
      for(chan = 0; chan < CTP_MAX_CHAN_PER_VCOMP; chan ++){
        pSrcInfo = &Db.Bndl[bn].Bndl.vc_bndl.vc_chan[chan].SrcInfo;
        if((pSrcInfo->Used) &&
          (pPortDb->Card == pSrcInfo->Card) &&
          (pPortDb->pNum == pSrcInfo->pNum))
        {
          found = 1;
          break;
        }
      }
      if(found) break;
    // Aricent PR-947222 Start
    } else if(CTP_BNDL_TYPE_WP == Db.Bndl[bn].Type) {
      int chan = 0;
      CTP_SRC_INFO *pSrcInfo;
      for(chan = 0; chan < CTP_MAX_CHAN_PER_CESOPSN; chan ++){
        pSrcInfo = &Db.Bndl[bn].Bndl.wp_bndl.SrcInfo[chan];
        if((pSrcInfo->Used) &&
          (pPortDb->Card == pSrcInfo->Card) &&
          (pPortDb->pNum == pSrcInfo->pNum))
        {
          found = 1;
          break;
        }
      }
      if(found) break;
    } 
    // Aricent PR-947222 End
    else if((pPortDb->Card == util_bndl_src_card(0, &Db.Bndl[bn])) &&
      (pPortDb->pNum == util_bndl_src_pNum(0, &Db.Bndl[bn]))) {
      found = 1;
      break;
    }
  }
  if( !found ) bn = CTP_MAX_BNDLS;
  return bn;
}

//--------------------------------------------------------------------------
// Scans through all the bundle mask elements looking to see if port
// has been assigned to a bundle. Returns 1 if assigned to any bundle, 0
// otherwise.
//--------------------------------------------------------------------------
int util_port_is_bndld( CTP_PORT_DBASE *pPortDb )
{
  int bndld;
  bndld = util_get_next_bNum(pPortDb, -1);
  if(bndld == CTP_MAX_BNDLS) bndld = 0;
  else bndld = 1;
  return bndld;
}

