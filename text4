void ctp_vc_send_oam ( int bNum )
{
  CTP_Q_MSG 		 TMsg;
  CTP_Q_VC_OAM_MSG	*pTMsg = (CTP_Q_VC_OAM_MSG *)&TMsg;
  CTP_BNDL_STATE 	*pBndlSt = &Ctp.Bndl[bNum];
  int 			 sNum;
  int Card = pBndlSt->Bndl.vc_bndl.StSrcInfo[0].Card;
  int Port = pBndlSt->Bndl.vc_bndl.StSrcInfo[0].pNum;
  FUNC_PRT(ctp_vc_send_oam, PF_VSIG, -1);

  memset(&TMsg, 0, sizeof(CTP_Q_MSG));

  pTMsg->CtpMsg.MsgType	= CTPMSGTYPE_REM_VC_OAM;
  pTMsg->CtpMsg.msg.RemVcOam.bNum    = bNum;
  pTMsg->CtpMsg.msg.RemVcOam.version = 2;
  pTMsg->CtpMsg.msg.RemVcOam.type    = CTP_VC_OAM_TYPE_ALL;
  if((pBndlSt->Conn.Node.v4 & 0xffffff00) == 0x7f000000) {
    CTP_BNDL_DBASE *pBndlDb = &Db.Bndl[bNum];
    pTMsg->CtpMsg.msg.RemVcOam.cid     = pBndlDb->RemAdCid.Node.v4 & 0xff;
  } else pTMsg->CtpMsg.msg.RemVcOam.cid     = pBndlSt->RemAdCid.Cid;
  pTMsg->CtpMsg.msg.RemVcOam.numVCh  = pBndlSt->Bndl.vc_bndl.numVCh;
  pTMsg->CtpMsg.msg.RemVcOam.alarm = 0;
  if(IS_T1E1_2000(Card)){
    CTP_PORT_STATE  *pPortSt = &Ctp.Card[Card].Port[Port];
    if(pPortSt->t1State & (T1_ALARM_LOF | T1_ALARM_LOS |T1_ALARM_AIS))
    //--- set alarm for T1 card
      pTMsg->CtpMsg.msg.RemVcOam.alarm = 1;
  }
  for(sNum=0; sNum<CTP_MAX_CHAN_PER_VCOMP;sNum++) {
    if(pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Used) {
      pTMsg->CtpMsg.msg.RemVcOam.Sigs[sNum] = pTMsg->CtpMsg.msg.RemVcOam.alarm ? 0xf:
	VC_SIGS_IN(pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Card,
	           pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].pNum,
		   pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Chan);
    } else {
      break;
    }
  }
  ctp_send_msg(&TMsg);
}

void ctp_send_rdnt_oam ( int Card, int pNum )
{
  CTP_Q_MSG TMsg;
  CTP_Q_OAM_MSG		*pTMsg = (CTP_Q_OAM_MSG *)&TMsg;
  CTP_PORT_DBASE	*pDbP = &Db.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  CTP_PORT_STATE	*pPortSt = &Ctp.Card[Card].Port[pNum];
  int bNum = util_get_next_bNum( pDbP, -1);
  CTP_BNDL_DBASE        *pDbB = &Db.Bndl[bNum];
  CTP_BNDL_STATE 	*pBndlSt = &Ctp.Bndl[bNum];
  int LocCardPort = ((Card & 0xff) << 8) | (pNum & 0xff);
  int RemCardPort = pDbP->RdntPort;
  FUNC_PRT(ctp_send_rdnt_oam, PF_IPC, -1);

  memset(&TMsg, 0, sizeof(CTP_Q_MSG));

  TMsg.mtype = 3;				// reserved and fixed
  TMsg.CtpMsg.MsgType	= CTPMSGTYPE_RDNT_LINK_OAM;
  TMsg.CtpMsg.msg.RemRdntOam.version = 1;	// Init to 1 (first version)
  TMsg.CtpMsg.msg.RemRdntOam.LocCardPort = LocCardPort;
  TMsg.CtpMsg.msg.RemRdntOam.RemCardPort = RemCardPort;
  TMsg.CtpMsg.msg.RemRdntOam.Active = pPortSt->RdntActive;	// Tell other side whats up
  TMsg.CtpMsg.msg.RemRdntOam.LocNcp.Node = *((CTP_NODE *)&pPortIntSt->LocAdCid.Node);
  // The CID is how ctp_send_msg() eventually finds the socket to send OAM to...
  TMsg.CtpMsg.msg.RemRdntOam.LocNcp.Port = (u8)pPortIntSt->LocAdCid.Cid;

  //util_dump_qmsg((void *)&TMsg);

  ctp_send_msg(&TMsg);
}
