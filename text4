//--- Process signaling change messages from voice interface/channel
void ctp_vc_proc_if_sig_change ( CTP_Q_MSG * pMsg )
{
  int  Card = (int)pMsg->CtpMsg.OrigTask;
  int  pNum = (int)pMsg->CtpMsg.SubType;
  int  Chan = (int)pMsg->CtpMsg.Ident;
  int  bNum = util_get_next_bNum(&Db.Card[Card].Port[pNum],-1);
  u8   OldOutSigs = VC_SIGS_OUT(Card,pNum,Chan);
  u8   OldSigs = VC_SIGS(Card,pNum,Chan);
  u8   status  = 0xf & pMsg->CtpMsg.Status;
  char PrtStr[80];
  FUNC_PRT(ctp_proc_sig_change, PF_VSIG, -1);

  sprintf(PrtStr,"chan %d and status 0x%x", Chan, status );
  PRTSP(GN2,Got CTPMSGTYPE_SIG_CHANGE msg with , PrtStr );

  //--- Now look to see if this port is part of a bundle
    switch( CARDTYPE(Card)) {
    case T1CARD:
      if( bNum < CTP_MAX_BNDLS ) {
	int tb;
	int sNum = 0;
	int found_it = 0;
	u8   rx_sigs = status;

	while( (!found_it) && (bNum < CTP_MAX_BNDLS) ) {
	  CTP_BNDL_STATE * pBndlSt = &Ctp.Bndl[bNum];    // Aricent PR 1265050 fix
	  if( (pBndlSt->State != CTP_PORT_STATE_NOT_CFG) &&
	      (pBndlSt->Bndl.vc_bndl.sig) &&
	      (pBndlSt->Bndl.vc_bndl.oam) ) {
	    for(sNum=0; sNum < CTP_MAX_CHAN_PER_VCOMP; sNum++) {
	      if( (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Card == Card) &&
		  (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].pNum == pNum) &&
		  (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Chan == Chan) ) {
		found_it = 1;
		break;
	      }
	    }
	  }
        if (found_it) break;
	  //--- Else check next bundle to see if Chan is a source
	  tb = bNum;
	  bNum = util_get_next_bNum(&Db.Card[Card].Port[pNum],tb);    // Aricent PR 1265050 fix
	}
        if(found_it) {
	  u16 new_rx_sigs, new_tx_sigs;
	  //--- Save signaling
	  pVcSigs->Card[Card].Port[pNum].Chan[Chan] = (OldOutSigs<<4) | rx_sigs;
	  new_tx_sigs = (u16) VC_SIGS_OUT(Card,pNum,Chan);
	  new_rx_sigs = (u16) VC_SIGS_IN(Card,pNum,Chan);
	  sprintf(PrtStr,"Chan %d part of bundle %d saved sigs are 0x%x Tx, 0x%x Rx",
	      Chan, bNum, new_tx_sigs, new_rx_sigs);
	  PRTSP(GN1,, PrtStr );
	  ctp_vc_send_sig_ch_oam(bNum, Card, pNum, Chan, sNum);
	} else {
	  //--- Channel was not part of any known bundle
	}
      } else {
	PRTP(GEN,Ignoring signaling change message on non-bundled port);
      }
      break;
    case EMCARD:
      {
	u16 new_rx_sigs, new_tx_sigs;
	u8   rx_sigs = status;
        if(Chan) PRTDVP(MIN,Got signaling for non-zero channel,Chan);
	//--- Save signaling
	pVcSigs->Card[Card].Port[pNum].Chan[0] = (OldOutSigs<<4) | rx_sigs;
	new_tx_sigs = (u16) VC_SIGS_OUT(Card,pNum,0);
	new_rx_sigs = (u16) VC_SIGS_IN(Card,pNum,0);
        if( bNum < CTP_MAX_BNDLS ) {
	  int sNum = 0;
	  // Aricent PR 1265050 fix - Start
	  CTP_BNDL_STATE * pBndlSt = &Ctp.Bndl[bNum];
	  CTP_BNDL_DBASE * pBndlDb = &Db.Bndl[bNum]; //Aricent PR-947222
	  // Aricent PR 1265050 fix - End

	  //--- Find sNum
	  for(sNum=0; sNum < CTP_MAX_CHAN_PER_VCOMP; sNum++) {
	    // Aricent PR-947222 Start
	    if(Db.Bndl[bNum].Type == CTP_BNDL_TYPE_WP){    // Aricent PR 1265050 fix
	      if( (pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].Card == Card ) &&
		  (pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].pNum == pNum)  &&
		  (pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].Chan == 0 )) {
		break;
	      } 
	    } else if( (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Card == Card) &&
		(pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].pNum == pNum) &&
		(pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Chan == 0) ) {
	      break;
            }
          // Aricent PR-947222 End
    	  }
	  // Aricent PR-947222 Start 
	  if( CTP_BNDL_TYPE_WP == Db.Bndl[bNum].Type )     // Aricent PR 1265050 fix
	    ctp_set_vc_sig(bNum, Card, pNum, 0);
	  // Aricent PR-947222 End
	  else ctp_vc_send_sig_ch_oam(bNum, Card, pNum, 0, sNum);
	}
	sprintf(PrtStr,"saved sigs are 0x%x Tx, 0x%x Rx",
	    new_tx_sigs, new_rx_sigs);
	PRTSP(GN1,, PrtStr );
      }
      break;
    case FXOCRD:
      {
	int loopStart = GROUND_START(Card,pNum) ? 0 : 1;
        if(Chan) PRTDVP(MIN,Got signaling for non-zero channel,Chan);
	//--- Save signaling
	if( loopStart ) {
	  switch(status) {
	    case CTP_VP_EVENT_ONHOOK:
	      { // Mike - PR 1597669 fix Start
		u8 event = CTP_VP_EVENT_ONHOOK;
		u8 event_val = 0;
		voice_state_machine((u8)bNum,(u8)Card,(u8)pNum,(u8)event,(u8)event_val,(u8)0);
	      } // Mike - PR 1597669 fix End
	      break;
	    case CTP_VP_EVENT_RING:
	      { // Mike - PR 1597669 fix Start
		u8 event = CTP_VP_EVENT_RING;
		u8 event_val = RING_ON(Card,pNum);	// RING_ON() set in ctp_proc_vb_msg()
		voice_state_machine((u8)bNum,(u8)Card,(u8)pNum,(u8)event,(u8)event_val,(u8)0);
	      } // Mike - PR 1597669 fix End
	      break;
	    default:
	      break;
	  }
	} else {	// loopstart end, groundstart start
	  int OldTxAB = (VC_SIGS_OUT(Card,pNum,0) >> 2) & 0x3;
	  int OldSigs = (int)VC_SIGS(Card,pNum,0);
	  //--- Ground start
	  switch(status) {
	    case CTP_VP_EVENT_ONHOOK:
	      break;
	    case CTP_VP_EVENT_RING:
	      PRTP(EVE,Got ringing CTPMSGTYPE_SIG_CHANGE msg);
	      //--- Save signaling
	      pVcSigs->Card[Card].Port[pNum].Chan[0]  = 0x00;			// B bit low!
	      pVcSigs->Card[Card].Port[pNum].Chan[0] |= (OldSigs & 0xf0);	// Preserve Tx sigs
	      break;
	    case CTP_VP_EVENT_TIP_GND:
	      PRTP(MIN,Got tip gnd CTPMSGTYPE_SIG_CHANGE msg);
	      //--- Save signaling
	      PRTVP(DBG,** OldTxAB,OldTxAB);
	      PRTVP(DBG,** Old sigs,OldSigs);
	      if( OldTxAB == 0x1 ) { // We were idle,
		pVcSigs->Card[Card].Port[pNum].Chan[0] = 0x50;	// FXS is initiating call, preserve Tx sigs
	      } else {
		pVcSigs->Card[Card].Port[pNum].Chan[0] = 0x05;	// FXO is initiating call
	      }
	      break;
	    case CTP_VP_EVENT_TIP_OPEN:
	      PRTP(MIN,Got tip open CTPMSGTYPE_SIG_CHANGE msg);
	      //--- Save signaling
	      if( !RING_GROUND(Card,pNum) ) {
                int sigs;
		//--- Attached FXS responding to our on-hook
		pVcSigs->Card[Card].Port[pNum].Chan[0]  = 0x5f;		// Only B bit high!
		PRTP(GN1,Transition to gs_idle complete);
		//--- FXS ungrounded tip, finish hanging up fxo
		ctp_vb_cmd(Card,pNum,CTP_VB_CMD_FXO_LOOP_START);
		ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXO_ON_HOOK);
		ctp_vb_cmd(Card,pNum,CTP_VB_CMD_FXO_TIP_SENSE);
		sigs = VC_SIGS(Card,pNum,0);
		PRTVP(DBG,Sigs now,sigs);
	      } else {
		if(OFF_HOOK(Card,pNum)) {
		  //--- Attached FXS initiating on-hook
		  pVcSigs->Card[Card].Port[pNum].Chan[0]  = 0x0f;		// Both bits high!
		  pVcSigs->Card[Card].Port[pNum].Chan[0] |= (OldSigs & 0xf0);	// Preserve Tx sigs
		} else {
		//--- Ignore spurious tip-open
		  PRTP(DBG,Ignore spurious tip-open);
		}
	      }
	      break;
	    default:
	      break;
	  }
	  } // end groundstart
	if( bNum < CTP_MAX_BNDLS ) {
	  // Aricent PR 1265050 fix - Start
	  CTP_BNDL_STATE * pBndlSt = &Ctp.Bndl[bNum];
	  CTP_BNDL_DBASE * pBndlDb = &Db.Bndl[bNum]; //Aricent PR-947222
	  // Aricent PR 1265050 fix - End
	  if( pBndlSt->State == CTP_PORT_STATE_RUNNING ) {
	    int sNum = 0;
	    u8  bBit = (VC_SIGS_IN(Card,pNum,0) & 0x4) ? 1 : 0;
	    u8  aBit = (VC_SIGS_IN(Card,pNum,0) & 0x8) ? 1 : 0;
	    u8 oldaBit = (OldSigs & 0x8) ? 1 : 0;
	    int send_chng = 0;

	      //--- Find sNum
	      for(sNum=0; sNum < CTP_MAX_CHAN_PER_VCOMP; sNum++) {
                // Aricent PR-947222 Start
               if(Db.Bndl[bNum].Type == CTP_BNDL_TYPE_WP){
                if( (pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].Card == Card ) &&
                 (pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].pNum == pNum)  &&
                 (pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].Chan == 0 )) {
                  break;
                 } 
	      }
              // Aricent PR-947222 End
	      else if( (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Card == Card) &&
		  (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].pNum == pNum) &&
		  (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Chan == 0) ) {
		break;
	      }
	    }

	      // Now exec only if gnd start proto
	      if( !loopStart ) {	
	      //--- Always reset ring timer when b bit falls.
	      if( !bBit )  RING_SEC(Card,pNum) = 6;

	      //--- Do we need to turn ON Ring state & Send indication to remote?
	      if( !bBit && !RING_ON(Card,pNum) ) {
		//--- Turn on ring flag
		RING_ON(Card,pNum) = 1;

		//--- Always send sig ch oam when bBit falls.
		send_chng = 1;
	      }
	      }

	      if( !loopStart ) {
		send_chng = 1;
	      }

	      if(send_chng) { 
	      // Aricent PR-947222 Start 
	      if( CTP_BNDL_TYPE_WP == Db.Bndl[bNum].Type )    // Aricent PR 1265050 fix
		ctp_set_vc_sig(bNum, Card, pNum, 0);
	      // Aricent PR-947222 End
	      else  ctp_vc_send_sig_ch_oam(bNum, Card, pNum, 0, sNum);
	    } // end send_chng
	  } // end pBndlSt->State == CTP_PORT_STATE_RUNNING
	} // end bNum < CTP_MAX_BNDLS
	}
      break;
    case FXSCRD:
      {
	int loopStart = GROUND_START(Card,pNum) ? 0 : 1;
	int onHook = 0;
	int rb_ctl_needed = 0;
	CTP_BNDL_DBASE * pBndlDb = &Db.Bndl[bNum]; //Aricent PR-947222, PR-1265050 fix

	if(Chan) PRTDVP(MIN,Got signaling for non-zero channel,Chan);
	//--- Save signaling
	if( loopStart ) {
	  switch(status) {
	    case CTP_VP_EVENT_OFFHOOK:
	      { // Mike - PR 1597669 fix Start
		u8 event = CTP_VP_EVENT_OFFHOOK;
		u8 event_val = 0;
		voice_state_machine((u8)bNum,(u8)Card,(u8)pNum,(u8)event,(u8)event_val,(u8)0);
	      } // Mike - PR 1597669 fix End
	      break;
	    case CTP_VP_EVENT_ONHOOK:
	      { // Mike - PR 1597669 fix Start
		u8 event = CTP_VP_EVENT_ONHOOK;
		u8 event_val = 0;
		voice_state_machine((u8)bNum,(u8)Card,(u8)pNum,(u8)event,(u8)event_val,(u8)0);
	      } // Mike - PR 1597669 fix End
	      break;
	    default:
	      break;
	  }
	  if( bNum < CTP_MAX_BNDLS ) {
	    // Aricent PR 1265050 fix - Start
	    CTP_BNDL_STATE * pBndlSt = &Ctp.Bndl[bNum];
	    CTP_BNDL_DBASE * pBndlDb = &Db.Bndl[bNum]; //Aricent PR-947222
	    // Aricent PR 1265050 fix - End
	    if( pBndlSt->State == CTP_PORT_STATE_RUNNING ) {
	      int sNum = 0;
	      u8  aBit = (VC_SIGS_IN(Card,pNum,0) & 0x8) ? 1 : 0;

	      //--- Find sNum
	      for(sNum=0; sNum < CTP_MAX_CHAN_PER_VCOMP; sNum++) {
		// Aricent PR-947222 Start
		if(CTP_BNDL_TYPE_WP == Db.Bndl[bNum].Type) {    // Aricent PR 1265050 fix
		  if( (pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].Card == Card ) &&
		      (pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].pNum == pNum)  &&
		      (pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].Chan == 0 )) {
		    break;
		  }
		} 
		// Aricent PR-947222 End
		else if( (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Card == Card) &&
		    (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].pNum == pNum) &&
		    (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Chan == 0) ) {
		  break;
		}
              }
	    }	// end: if( pBndlSt->State == CTP_PORT_STATE_RUNNING ) 
	  }	// end: if( bNum < CTP_MAX_BNDLS ) 
	} else {
	  //--- Ground start
	  switch(status) {
	    case CTP_VP_EVENT_OFFHOOK:
	      PRTP(MIN,Got OffHook CTPMSGTYPE_SIG_CHANGE msg);
	      //--- Save signaling
	      pVcSigs->Card[Card].Port[pNum].Chan[0]  = 0x5f;
	      break;
	    case CTP_VP_EVENT_ONHOOK:
	      PRTP(MIN,Got OnHook CTPMSGTYPE_SIG_CHANGE msg);
	      //--- Save signaling
	      pVcSigs->Card[Card].Port[pNum].Chan[0]  = 0xf5;			// A bit low!
	      // Reset to ground start idle
	      ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_GND_START);
	      ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_RING_SENSE);
	      ctp_vb_cmd(Card, pNum, CTP_VB_CMD_FXS_HOOK_SENSE);
	      break;
	    case CTP_VP_EVENT_RING_GND:
	      PRTP(MIN,Got Ring Gnd CTPMSGTYPE_SIG_CHANGE msg);
	      //--- Save signaling
	      pVcSigs->Card[Card].Port[pNum].Chan[0]  = 0x00;			// Both bits low!
	      pVcSigs->Card[Card].Port[pNum].Chan[0] |= (OldSigs & 0xf0);	// Preserve Tx sigs
	      break;
	    default:
	      break;
	  }
          if( bNum < CTP_MAX_BNDLS ) {
	    // Aricent PR 1265050 fix - Start
	    CTP_BNDL_STATE * pBndlSt = &Ctp.Bndl[bNum];
	    CTP_BNDL_DBASE * pBndlDb = &Db.Bndl[bNum]; //Aricent PR-947222
	    // Aricent PR 1265050 fix - End
	    if( pBndlSt->State == CTP_PORT_STATE_RUNNING ) {
	      int sNum = 0;
	      //--- Port is part of running bundle, find sNum & send OAM
	      for(sNum=0; sNum < CTP_MAX_CHAN_PER_VCOMP; sNum++) {
		// Aricent PR-947222 Start
		if (  Db.Bndl[bNum].Type == CTP_BNDL_TYPE_WP) {    // Aricent PR 1265050 fix
		  if( (pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].Card == Card ) &&
		      (pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].pNum == pNum)  &&
		      (pBndlDb->Bndl.wp_bndl.SrcInfo[sNum].Chan == 0 )) {
		    break;
		  }
                } else if( (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Card == Card) &&
		    (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].pNum == pNum) &&
		    (pBndlSt->Bndl.vc_bndl.StSrcInfo[sNum].Chan == 0) ) {
		  break;
		}
                // Aricent PR-947222 End
	      }
	      // Aricent PR-947222 Start 
	      if( CTP_BNDL_TYPE_WP == Db.Bndl[bNum].Type )    // Aricent PR 1265050 fix
		ctp_set_vc_sig(bNum, Card, pNum, 0);
	      // Aricent PR-947222 End
	      else ctp_vc_send_sig_ch_oam(bNum, Card, pNum, 0, sNum);
	    }
	  }
	}
      }
      break;
    default:
      PRTDV(MIN,Got signaling change indication from unsupported card, Card);
      break;
  }
}

void ctp_vc_send_sig_ch_oam ( int bNum, int Card, int pNum, int Chan, int sNum )
{
  CTP_Q_MSG TMsg;
  CTP_Q_VC_SIG_MSG * pTMsg = (CTP_Q_VC_SIG_MSG *)&TMsg;
  FUNC_PRT(ctp_vc_send_sig_ch_oam, PF_VSIG, -1);

  //PRTDVP(MIN,Sending signal change OAM for bndl, bNum);

  if( (bNum >= 0) && (bNum < CTP_MAX_BNDLS) &&
      (sNum >= 0) && (sNum < CTP_MAX_CHAN_PER_VCOMP) ) {
    CTP_BNDL_STATE * pBndlSt = &Ctp.Bndl[bNum];
    int	rx_sigs = VC_SIGS_IN(Card,pNum,Chan);

    if( (pBndlSt->State != CTP_PORT_STATE_NOT_CFG) &&
	(pBndlSt->Bndl.vc_bndl.sig) &&
	(pBndlSt->Bndl.vc_bndl.oam) ) {
      memset(&TMsg, 0, sizeof(CTP_Q_MSG));

      pTMsg->CtpMsg.MsgType	= CTPMSGTYPE_REM_VC_OAM;
      pTMsg->CtpMsg.msg.RemVcSig.bNum    = bNum;
      pTMsg->CtpMsg.msg.RemVcSig.version = 1;
      pTMsg->CtpMsg.msg.RemVcSig.type    = CTP_VC_OAM_TYPE_CHNG;
      if((pBndlSt->Conn.Node.v4 & 0xffffff00) == 0x7f000000) {
        CTP_BNDL_DBASE *pBndlDb = &Db.Bndl[bNum];
        pTMsg->CtpMsg.msg.RemVcSig.cid     = pBndlDb->RemAdCid.Node.v4 & 0xff;
      } else pTMsg->CtpMsg.msg.RemVcSig.cid     = pBndlSt->RemAdCid.Cid;
      pTMsg->CtpMsg.msg.RemVcSig.chan    = sNum;
      pTMsg->CtpMsg.msg.RemVcSig.Sigs    = (rx_sigs & 0xf);

      PRTVB(GEN,**** Sending sig change OAM with sig, rx_sigs);
      //--- Send message 3 times....
      ctp_send_msg(&TMsg);
      ctp_send_msg(&TMsg);
      ctp_send_msg(&TMsg);
    }
  }
}

