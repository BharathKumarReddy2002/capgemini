void ctp_proc_ser_loop( int Card, int pNum )
{
  CTP_PORT_STATE	*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_DBASE	*pPortDb = &Db.Card[Card].Port[pNum];
  FUNC_PRT(ctp_proc_ser_loop, PF_MISC, pNum);

  fpga_clr_fcfg();
  //+++++ Configure serial interface loops +++++
  switch(pPortSt->SerLoop) {
    case CTP_SER_LOOP_OFF:
      fpga_set_rx_fifo_clk(           pNum, pPortDb->rf_sel);	// normal
      fpga_set_rx_scc_clk(            pNum, pPortDb->rx_sel);	// normal
      fpga_set_tx_if_clk(             pNum, pPortDb->rt_sel);	// normal
      fpga_set_serloop_to_net_enable( pNum, INACTIVE_H );	// disable
      fpga_set_serloop_to_if_enable(  pNum, INACTIVE_H );	// disable
      break;
    case CTP_SER_LOOP_TO_NET:
      fpga_set_rx_fifo_clk(           pNum, pPortDb->tx_sel);
      fpga_set_rx_scc_clk(            pNum, pPortDb->tx_sel);
      fpga_set_tx_if_clk(             pNum, pPortDb->rt_sel);	// normal
      fpga_set_serloop_to_net_enable( pNum, ACTIVE_H );
      fpga_set_serloop_to_if_enable(  pNum, INACTIVE_H );	// disable
      break;
    case CTP_SER_LOOP_TO_IF:
      // I do not want to assume that I know how to set the clocks for a
      // loop here... It does not work with voice modules if I uncomment
      // the following lines... There may be more work to do here to make
      // this work under all situations.
      //fpga_set_rx_fifo_clk(           pNum, pPortDb->rf_sel);	// normal
      //fpga_set_rx_scc_clk(            pNum, pPortDb->rx_sel);	// normal
      //fpga_set_tx_if_clk(             pNum, pPortDb->rf_sel);
      fpga_set_serloop_to_if_enable(  pNum, ACTIVE_H );
      fpga_set_serloop_to_net_enable( pNum, INACTIVE_H );	// disable
      break;
  }
#if 0
  // This is an old bug (looks like bugzilla), and it is interfering with
  // my new redundancy scheme. I think we should be OK to remove this patch
  // for the time being and maybe deal with it if it comes up later -mike
  /* fix bug#369 */
  if( pPortDb->RdntConfig & CFG_RDNT_MODE_MASK ) {
    if(pPortSt->SerLoop == CTP_SER_LOOP_TO_IF) {
      fpga_set_redundant_mode(pNum,0);
    } else fpga_set_redundant_mode(pNum,1);
  }
#endif
  fpga_send_fcfg(pPortSt->SccNum);
}

