//-------------------------------------------------------------------------
void ctp_read_if_name_reply( struct nlmsghdr *nlr, int nll)
{
  int            rtl;
  struct rtattr *rtap;
  u8 i;

  FUNC_PRT(ctp_read_if_name_reply, PF_START, -1);
  for(i=0;i < 128; i++)
    memset(&ifName[i], 0xff, sizeof(CTP_IF_NAME));
  i = 0;
  for(; NLMSG_OK(nlr, nll); nlr=NLMSG_NEXT(nlr, nll)) {
    struct ifinfomsg    *ifmsg = (struct ifinfomsg *)NLMSG_DATA(nlr);
    rtap = (struct rtattr *)IFLA_RTA(ifmsg);
    rtl  = IFLA_PAYLOAD(nlr);

    for(; RTA_OK(rtap,rtl); rtap=RTA_NEXT(rtap, rtl)) {
      switch (rtap->rta_type) {
        case IFLA_IFNAME:
          sprintf(ifName[i].name, "%s", (char *)RTA_DATA(rtap));
          if( !strncmp(ifName[i].name, "eth", 3) ) {
            ifName[i++].index = ifmsg->ifi_index;
          }
          break;
        default:
          break;
      }
    }
  }
}

int qry_if_name (int sock)
{
  struct iovec          iov;
  CTP_NI_REQ            req;
  struct msghdr         msg;
  char                  buf[24576], *p;
  int                   sent, read, nll = 0;
  struct sockaddr_nl    ra;     // Remote address
  struct nlmsghdr       *nlp;

  FUNC_PRT(qry_nid_ip_info, PF_START, -1);

  //--- Build req
  if( ctp_build_if_req(&req) == FAILURE ) {
    PRT(MIN,**** Could not build netlink RTM_GETLINK req ****);
    return 1;
  }

  //--- Build msg
  bzero(&iov, sizeof(iov));
  iov.iov_base = (void *)&req.nlh;
  iov.iov_len  = req.nlh.nlmsg_len;

  bzero(&ra, sizeof(ra));
  ra.nl_family = AF_NETLINK;

  bzero(&msg, sizeof(msg));
  msg.msg_name = (void *)&ra;
  msg.msg_namelen = sizeof(ra);
  msg.msg_iov = &iov;
  msg.msg_iovlen = 1;

  //--- Send msg
  sent = sendmsg(sock, &msg, 0);
  if( sent == -1 ) {
    PRT(MIN,**** Problem sending netlink msg. ****);
    return 1;
  }

  //--- Get responses
  bzero(buf, sizeof(buf));
  p = buf;
  while(1) {
    bzero(buf, sizeof(buf));                               // PR-947222
    read = recv(sock, p, sizeof(buf), 0);                  // PR-947222
    nlp  = (struct nlmsghdr *)p;
    //--- Read reply
    ctp_read_if_name_reply( nlp, read);                    // PR-947222
    if( nlp->nlmsg_type == NLMSG_DONE ) { break; }
  }

  return 0;
}

int ctp_search_if_name(int index, char *pName)
{
  int i;
  for(i = 0; i < 128; i ++) {
    if(ifName[i].index == index) {
      sprintf(pName, "%s", ifName[i].name);
      return 0;
    } else if (ifName[i].index == 0xffffffff) {
      return 1;
    }
  }
  return 0;
}

//-------------------------------------------------------------------------
void ctp_read_nid_reply( struct nlmsghdr *nlr, int nll, int msg_type )
{
  int		 rtl;
  struct rtattr	*rtap;
  char		 ips[46], ifs[IF_NAMESIZE], prtBuf[100];
  u32		 ip;
  CTP_NODE_STORAGE addNode;

  FUNC_PRT(ctp_read_nid_reply, PF_START, -1);

  for(; NLMSG_OK(nlr, nll); nlr=NLMSG_NEXT(nlr, nll)) {
    struct ifaddrmsg    *ifmsg = (struct ifaddrmsg *)NLMSG_DATA(nlr);
    int		found_ip=0;
    rtap = (struct rtattr *)IFA_RTA(ifmsg);
    rtl  = IFA_PAYLOAD(nlr);

    for(; RTA_OK(rtap,rtl); rtap=RTA_NEXT(rtap, rtl)) {
      switch (rtap->rta_type) {
        case IFA_ADDRESS:
          if( ifmsg->ifa_family == AF_INET6 ) {
	    if(ifmsg->ifa_scope==RT_TABLE_UNSPEC) {
              inet_ntop(AF_INET6, RTA_DATA(rtap), ips, 46);
	      found_ip = 1;
	      addNode.Type = CTP_IPV6;
	      inet_pton(AF_INET6, ips, &addNode.v6);
              if(ctp_search_if_name(ifmsg->ifa_index, ifs)) {
                sprintf(prtBuf, "No interface name for if_index %d", ifmsg->ifa_index);
                PRTS(MAJ, netlink qry, prtBuf);
              }
	    }
          } else if(ifmsg->ifa_family == AF_INET ){
	    inet_ntop(AF_INET, RTA_DATA(rtap), ips, 24);
	    found_ip = 1;
	    addNode.Type = CTP_IPV4;
	    addNode.v4 = (u32)ntohl(inet_addr(ips));
	  }
          break;
	case IFA_LABEL:
	  sprintf(ifs, "%s", (char *)RTA_DATA(rtap));
	  break;
	default:
	  PRTDV(EVE,Do not know how to handle raouting attr type, rtap->rta_type);
	  break;
      }
    }
    if(found_ip == 0) continue;
    sprintf(prtBuf, "Got ip %s , dev name %s for interface index %d",
	ips, ifs, ifmsg->ifa_index);
    PRTS(GEN,netlink qry,prtBuf);
   /* ARICENT FIX Start - PR1290078 */
    //Added to map inerface index to interface name
    //In case of IPV6 it does not have IFA_LABEL
    if(addNode.Type == CTP_IPV6)
        if_indextoname(ifmsg->ifa_index, ifs);
    /* ARICENT FIX End - PR1290078 */
    if( !strncmp(ifs, "eth", 3) ) {		// Add ethernet addresses.
      ctp_nid_add_ip( ifmsg->ifa_index, CTP_IF_TYPE_ETH, ifs, &addNode, 0, 0);
      if((Ctp.LocNode.v4 == 0)&&(addNode.Type== CTP_IPV4)) {
	Ctp.LocNode.v4 = ip;
	PRTS(MIN, Just set LocNode, ips);
      }
      if( (Ctp.LocNode.v6.s6_addr32[0] == 0) &&
	  (Ctp.LocNode.v6.s6_addr32[1] == 0) &&
	  (Ctp.LocNode.v6.s6_addr32[2] == 0) &&
	  (Ctp.LocNode.v6.s6_addr32[3] == 0) &&
          (addNode.Type== CTP_IPV6)) {
	  Ctp.LocNode.v6 = addNode.v6;
          PRTS(MIN, Just set ipv6 LocNode, ips);
      }
    } else if( !strncmp(ifs, "lo:", 3) ) {	// Add virtual ip addresses.
      ctp_nid_add_ip( ifmsg->ifa_index, CTP_IF_TYPE_VIP, ifs, &addNode, 0, 0);
    }
  }
}

//-------------------------------------------------------------------------
int ctp_get_nid_info( void )
{
  int	status, RetStat = 0;
  int	sock;
  struct sockaddr_nl	la;	// Local address
  FUNC_PRT(ctp_get_nid_info, PF_START, -1);

#ifdef  DBG_MSG_QUEUE
  //--- sysinfo seemed to be getting too large for sending through sysvipc
  // messages. Get info on ipc via the command 'ipcs -l' (not on flash).
  // -> max size of message (bytes) = 8192
  // ==> Max message size for ctpd is set by CTP_MAX_MSG_SIZE in ctp.h
  {
    int	msg_size = sizeof( struct CtpMsg);
    int sysinfo_size = sizeof( struct CtpSys );
    int interfa_size = sizeof( struct CtpNidInfo );
    int sockadd_size = sizeof( struct sockaddr_storage );
    int ctpnode_size = sizeof( struct ctp_node );
    int ctpnodestore_size = sizeof( struct ctp_node_storage );
    PRTDV(MIN, Size of messages is, msg_size);
    PRTDV(MIN, Size of SysInfo is, sysinfo_size);
    PRTDV(MIN, Size of interface struct is, interfa_size);
    PRTDV(MIN, Size of sockaddr_storage is, sockadd_size);
    PRTDV(MIN, Size of ctp_node struct  is, ctpnode_size);
    PRTDV(MIN, Size of ctp_node_storage struct  is, ctpnodestore_size);
  }
#endif
  //--- Open netlink socket
  sock = socket(PF_NETLINK, SOCK_RAW, NETLINK_ROUTE);

  //--- Bind local address
  bzero(&la, sizeof(la));
  la.nl_family	= AF_NETLINK;
  la.nl_pad	= 0;
  la.nl_pid	= getpid();
  la.nl_groups	= 0;
  status = bind(sock, (struct sockaddr *)&la, sizeof(la));
  if( status ) {
    PRT(MIN,**** Failed to bind netlink socket to local address. Trying again... ****);
    usleep(10000);
    status = bind(sock, (struct sockaddr *)&la, sizeof(la));
    if( status ) {
      PRT(MIN,**** Failed to bind netlink socket 2nd time. ****);
      RetStat = 1;
      goto close;
    }
  }

  RetStat = qry_if_name( sock );
  if(RetStat) goto close;

  RetStat = qry_nid_ip_info (sock, AF_INET);
  if(RetStat) goto close;

  RetStat = qry_nid_ip_info (sock, AF_INET6);

close:
  close(sock);

  return(RetStat);
}

int qry_nid_ip_info (int sock, int addFamily)
{
  struct iovec		iov;
  CTP_NL_REQ 		req;
  struct msghdr		msg;
  char			buf[8990], *p; //PR 986759 fix
  int 			sent, read, nll = 0;
  struct sockaddr_nl	ra;	// Remote address
  struct nlmsghdr       *nlp;

  FUNC_PRT(qry_nid_ip_info, PF_START, -1);

  //--- Build req
  if( ctp_build_nid_req(&req, addFamily, RTM_GETADDR) == FAILURE ) {
    PRT(MIN,**** Could not build netlink RTM_GETADDR req ****);
    return 1;
  }

  //--- Build msg
  bzero(&iov, sizeof(iov));
  iov.iov_base = (void *)&req.nlh;
  iov.iov_len  = req.nlh.nlmsg_len;

  bzero(&ra, sizeof(ra));
  ra.nl_family = AF_NETLINK;

  bzero(&msg, sizeof(msg));
  msg.msg_name = (void *)&ra;
  msg.msg_namelen = sizeof(ra);
  msg.msg_iov = &iov;
  msg.msg_iovlen = 1;

  //--- Send msg
  sent = sendmsg(sock, &msg, 0);
  if( sent == -1 ) {
    PRT(MIN,**** Problem sending netlink msg. ****);
    return 1;
  }

  //--- Get responses
  bzero(buf, sizeof(buf));
  p = buf;
  while(1) {
    read = recv(sock, p, sizeof(buf)-nll, 0);
    nlp  = (struct nlmsghdr *)p;
    if( nlp->nlmsg_type == NLMSG_DONE ) { break; }
    p += read;
    nll += read;
  }

  //--- Read reply
  nlp = (struct nlmsghdr *)buf;
  ctp_read_nid_reply( nlp, nll, RTM_GETADDR );
  return 0;
}

