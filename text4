// This function map the token ( e.g TRAP_PT_SDINACTIVE) with trap number and return the number
int trap_number(char *key)
{
    int i = 0;
    char *name = Trap_type[i].str;
    while (name) {
        if (strncmp(name, key, strlen(key)-1) == 0)
            return Trap_type[i].n;
        name = Trap_type[++i].str;
    }
    return 0;
}

// This function will set the particular trap bit ON or OFF  based on entry in file /etc/sysconfig/ctp
// If entry in /etc/sysconfig/ctp, TRAPS=DFLT_OFF,TRAP_PT_TT_BAD,TRAP_PT_SDINACTIVE
// Default all traps are disabled, and the list is to indicate which traps to enable
// If entry in /etc/sysconfig/ctp, TRAPS=DFLT_ON,TRAP_PT_TT_BAD,TRAP_PT_SDINACTIVE
// Default all traps are enabled, and the list is to indicate which traps to disable

int ctpd_set_trap_enable ( char *token)

{

  int num;

  FUNC_PRT(ctpd_set_trap_enable, PF_TRAP, -1);

  if (strncmp(token, "DFLT_OFF", 8)==0){
    trap_bitmap = 0x00000000;
  }

  num = trap_number(token);
  //if token entry is DFLT_OFF, DFLT_ON then return
  if (num == 0)
    return;
  //if trap bit is set with DFLT_ON then unset other list of traps to disable
  //In else part if trap bit is not set( DFLT_OFF) then set other list of traps to enable
  if ( (trap_bitmap &(1<<31))){
    trap_bitmap = trap_bitmap & (~ (1 << (num-1)));
  }else{
    trap_bitmap = (1 << (num-1)) | trap_bitmap;
  }
}

//This function verify whether ctpd process is running or not

int check_ctpd_running (void) {

  char cmd_str[200];
  int Status = 0, is_ctpd = 0;

  FUNC_PRT(check_ctpd_running, PF_TRAP, -1);

  sprintf(cmd_str,"/bin/ps aux | /bin/grep /acorn/bin/ctpd | /usr/bin/wc -l > /tmp/ctpd_running");

  if(acorn_system(cmd_str)) {
      R_PRTS(MAJ,," Problem running ctpd\n");
  } else {
    FILE *fptr;
    if((fptr = fopen("/tmp/ctpd_running", "r")) != NULL){
     fscanf(fptr, "%d", &is_ctpd);
     fclose(fptr);
    }
  }
 acorn_system("/bin/rm -f /tmp/ctpd_running");

  if (is_ctpd) {
   R_PRTS(MIN,," ctpd process running\n");
   return 0;
  }
 return 1;
}

//This function  verify when ctpd comes up and then read file /etc/sysconfig/ctp
// If entry in file, TRAPS=DFLT_OFF,TRAP_PT_TT_BAD,TRAP_PT_SDINACTIVE
// Default all traps are disabled, and the list is to indicate which traps to enable
// If entry in file, TRAPS=DFLT_ON,TRAP_PT_TT_BAD,TRAP_PT_SDINACTIVE
// Default all traps are enabled, and the list is to indicate which traps to disable

int ctp_update_enable_trap_info( void ) {

  int ctpd_running = check_ctpd_running ( );

  FUNC_PRT(ctp_update_enable_trap_info, PF_TRAP, -1);

 if(ctpd_running == 0){
    const char *delimiter_characters = " , = ";
    char line[500]={0};
    char *ctp_file = "/etc/sysconfig/ctp";
    FILE *fp = fopen( ctp_file, "r" );
    char *token_list;
    char *str = "TRAPS";

    if( fp == NULL ){
     fprintf( stderr, "Unable to open file %s\n", ctp_file );
    }else{
     while( fgets(line,sizeof line,fp) != NULL ){
      if((strstr(line, str))){
       token_list = strtok( line, delimiter_characters );
       while( token_list != NULL ){
         ctpd_set_trap_enable(token_list);
         token_list = strtok( NULL, delimiter_characters );
       }
      }
     }
    if( ferror(fp) ){
     perror( "The following error occurred" );
    }
     fclose( fp );
    }
    return 0;
 }
}
