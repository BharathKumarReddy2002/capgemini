void ctp_proc_long_timer( )
{
  FUNC_PRT(ctp_proc_long_timer, PF_IPC, -1);

  if( pSysInfo->TimerTicks >= CTP_LONG_TIMER ) {

//Need to debug after the fix will enable the watchdog
#ifdef TARGET
    //----------------------------------------------
    //----- pet (and enable) system watchdog
    //----------------------------------------------
    int		 WatchDog;
    WatchDog = pSysInfo->WatchDog;
/*** PR-1614911 fix start ***/
    if ( pSysInfo->nova_type == 1 ) {
      if(WatchDog == 0) {
        acorn_system("/usr/bin/ipmitool mc watchdog reset");          //Reset ipmi w/d timer
      }
    }
    else {
      if(WatchDog == -1) {
       //	TODO PRT(MAJ,***** ***** Problems with watchdog device ***** *****);
      } else {
        ioctl(WatchDog, WDIOC_KEEPALIVE, 0);
        PRT(DBG,Pet nova watchdog device);
      }
    }
/*** PR-1614911 fix end ***/
    //----------------------------------------------
    //----- Read and store board temperatures on CTP-2000 (se or te)
    //----- Only get one board temp per long_timer cycle
    //----- as it requires bitbanging the driver.
    //----------------------------------------------
    if( pSysInfo->SysType == SYS_TYPE_CTP_2000 ) {
      int i = (pSysInfo->Chassis.last_board_temp++)%CTP_MAX_CARDS;
      if(SCC_CARD(i)) pSysInfo->Chassis.board_temp[i] = ctp_read_board_temp(i);
      pSysInfo->Chassis.last_board_temp%= CTP_MAX_CARDS;
    } else if( pSysInfo->SysType == SYS_TYPE_CTP_150 ) { // CTP150
      //----------------------------------------------
      //----- Read and store board temperatures on CTP-150
      //----- /acorn/bin/get_sensors puts sensors output into
      //----- /acorn/log/sensors.out where snmpAcorn.pl retrieves it.
      //----------------------------------------------
      acorn_system_quiet("/acorn/bin/get_sensors");
    } else { // CTP151 PR-1722528 start
      int cards = 0;
      for( cards = 0 ; cards <= 1; cards++)
	pSysInfo->Chassis.board_temp[cards] = ctp151_read_board_temp(cards);
    } // PR-1722528 end

    //----------------------------------------------
    //----- Check chassis fans/power supply/temperatures
    //----------------------------------------------
    /* chassis info for CTP151 is already checked in AcornSysMon.pl using sensors_pwr_fan.pl */
    if( pSysInfo->SysType == SYS_TYPE_CTP_2000 ) {	
      ctp_chk_chassis(); 
    }
#endif // TARGET
    pSysInfo->TimerTicks = 1;
  } else {
    pSysInfo->TimerTicks++;
  }
}

