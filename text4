//--------------------------------------------------------------------------
// This routine checks the entire database, looking for active bundles. For
// every active bundle, disable them.
//--------------------------------------------------------------------------
int ctp_disable_all_bundles(void)
{
  int	bNum;
  FUNC_PRT(ctp_disable_all_bundles, PF_MISC, -1);

  for(bNum=0;bNum<CTP_MAX_BNDLS;bNum++) {
    if(Db.Bndl[bNum].State == CTP_DBSTATE_UP){
      int Card = util_bndl_src_card(0,&Db.Bndl[bNum]);
      int pNum = util_bndl_src_pNum(0,&Db.Bndl[bNum]);
      switch(Db.Bndl[bNum].Type) {
        case CTP_BNDL_TYPE_WP:
          if(Ctp.Card[Card].Port[pNum].Available) {
	     ctp_wp_bndl_act(bNum,0); // Aricent PR  708106  
	}  
          break;
        case CTP_BNDL_TYPE_VC:
          ctp_vc_bndl_act(bNum, 0);
          break;
        default: // Aricent PR 910024 fix  
          break;
      }
    }
  }
  
  return(SUCCESS);
}

