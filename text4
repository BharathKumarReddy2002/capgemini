// PR-1722528 start
int ctp151_read_board_temp( int Card )
{
  char addr[] = {0x18, 0x4c, 0x1a, 0x4e};
  char SysCmdStr[100] = {0};
  FILE *brd_tmpfile = NULL;
  char getadd[50] = {0};
  int i2cbus, brd_temp = 0, i;
  int found = 0;
  int temp_ok = 1,num;

  FUNC_PRT(ctp151_read_board_temp, PF_MISC, -1);
  for( i = 0 ; i < 4; i++)
  {
    if(!found) {
      if(Card == 0) i2cbus = 15;
      else  i2cbus = 14;

      memset(SysCmdStr, 0, sizeof(SysCmdStr));
      sprintf(SysCmdStr, "/usr/sbin/i2cdetect -y %d 0x%x 0x%x | grep %x >> /tmp/board_tmp", 
              i2cbus, addr[i], addr[i], addr[i]);
      system(SysCmdStr);

      memset(getadd, 0, sizeof(getadd));
      if((brd_tmpfile = fopen("/tmp/board_tmp", "r")) != NULL) {
        fgets(getadd, sizeof getadd, brd_tmpfile);
	system("rm /tmp/board_tmp");
	fclose(brd_tmpfile);
      }

      if(strstr(getadd,"18") || strstr(getadd,"4c") || strstr(getadd,"1a") || strstr(getadd,"4e")) {
        found++;
        memset(SysCmdStr, 0, sizeof(SysCmdStr));
        sprintf(SysCmdStr, "/usr/sbin/i2cget -y %d 0x%x 0  >> /tmp/board_tmp", i2cbus, addr[i]);
        system(SysCmdStr);
        if((brd_tmpfile = fopen("/tmp/board_tmp", "r")) != NULL) {
          fscanf(brd_tmpfile, "%x", &brd_temp);
          system("rm /tmp/board_tmp");
          fclose(brd_tmpfile);

         //PR :1863969 Fix start
          if( brd_temp > 60 ) {  //Keeping threshlod temp 60, incase any change need to modify it
            temp_ok = 0;
          }
          if( Ctp.Snmp.TrapAble ) {
             if( temp_ok == 0 ) {
               //--- Trap sent, update SysInfo
                num = trap_number("TRAP_HW_TEMP");
                if (trap_bitmap & (1 << (num - 1))){
                   ctp_send_trap( 0,0, TRAP_HW_TEMP, temp_ok);
                }
             }
          }
          //PR :1863969 Fix end
        }
      }
    }
  }
  PRTVC(GEN,Read board temperature, brd_temp);
  return brd_temp;
}// PR-1722528 end

