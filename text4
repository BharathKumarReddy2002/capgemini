//==================================================================
// This routine returns the header size, in bytes, for data pkts
//==================================================================
int ctp_hdr_size(int Card, int pNum)
{
  int hdr_size = 14;	// Ethernet

  if( IPV6(Card,pNum) ) {
    hdr_size += 40;	// IPv6 hdr
    hdr_size += 6;	// CTP signals/port/seq num.
  } else {
    hdr_size += 20;	// IPv4 hdr
    if( SAToP(Card,pNum) ) {
      hdr_size += 8;	// UDP hdr
      hdr_size += 4;	// SAToP ctrl word
    } else {
      hdr_size += 2;	// CTP signals
    }
  }
  return hdr_size;
}

//==================================================================
// This routine configures a port. There are many config commands
//==================================================================
int ctp_cfg_port(int Card, int pNum, int Cmd)
{
  CTP_PORT_STATE	*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  CTP_PORT_CNTRS	*pPortCnt = &Ctp.Card[Card].Cntr[pNum];
  CTP_PORT_DBASE	*pDbP = &Db.Card[Card].Port[pNum];
  CTP_PORT_STATE         *pTempPortSt;
  struct in_addr	 My_in_addr;
  int			 Ret, status;
  char			 SccBuf[10], HairPinBuf[10], Netdev[10];
  struct acrndrv_static_stat	nss, hp_nss;
  struct acrndrv_static_cfg	nsc;
  struct acrndrv_runtime_cfg	nrc;
  struct eth_runtime_cfg	erc;
  struct acrndrv_command	ncmd;
  char			 ip_str[46], PrtBuf[80], CmdStr[200];
  char			 EthBuf[8];
  int			 remote_cid =0;
  int 			 pps, speed;
  FUNC_PRT(ctp_cfg_port, PF_PST, pNum);
  struct t_brcmd brcmd;
  int pvc;
  int bNum, bType, i, dport;    // Aricent PR 1478968 fix
  int PbsCard, PbspNum;

  if(!PBS(Card,pNum)) {
    bNum = util_get_next_bNum(pDbP, -1);
    bType = Db.Bndl[bNum].Type;
    // Only do this type of hairpin checking on CTP ports
    if( bType == CTP_BNDL_TYPE_CTP ) {
      if( ctp_chk_hairpin( Card, pNum ) ) {
        int h_pNum = ~0, h_Card = ~0;	// pNum & Card for other end of hairpin
        pPortIntSt->RunFlags |= PORT_RUN_FLAG_HAIRPIN;
        pPortIntSt->RunFlags &= ~PORT_RUN_FLAG_HP_REM_CID;
        remote_cid = pPortIntSt->RemAdCid.Cid;

        //--- Scan through other bundles to find a local cid that matches our
        //    remote_cid. Bundle may not yet be activated, so can't rely on
        //    pSysInfo->LocCid info which only gets filled in during ctp_add_port
        for(i=0; i<CTP_MAX_BNDLS; i++) {
          if( Db.Bndl[i].Type == CTP_BNDL_TYPE_CTP ) {
            if( remote_cid == Db.Bndl[i].Bndl.cp_bndl.LocCid ) {
              //--- Found other end, now get card & pNum
              h_pNum = Db.Bndl[i].Bndl.cp_bndl.pNum;
              h_Card = Db.Bndl[i].Bndl.cp_bndl.Card;
              pPortIntSt->RunFlags |= PORT_RUN_FLAG_HP_REM_CID;
            }
          }
        }
        if( (pPortIntSt->RunFlags & PORT_RUN_FLAG_HP_REM_CID) == 0 ) {
          PRTB(EVE,No remote hairpin bundle found);
/**** ctpd crashing when hp config with rem != cid, bcz h_pNum & h_pNum remains -1 
      To fix this prob, following code added
****/
          h_pNum = pNum;
          h_Card = Card;
          pPortIntSt->RunFlags |= PORT_RUN_FLAG_HP_REM_CID;
        }

        sprintf(HairPinBuf,"scc%d",Ctp.Card[h_Card].Port[h_pNum].SccNum);
        PRTSP(GEN,ctp_cfg_port: Hairpinned to,HairPinBuf);
        //--- Get static stat for pointer to device.
        status = ioc_priv(HairPinBuf,SCC_GET_STATIC_STAT,&hp_nss);
      }else{
        pPortIntSt->RunFlags &= ~PORT_RUN_FLAG_HAIRPIN;
      }
    }
  }

  sprintf(SccBuf,"scc%d",pPortSt->SccNum);

  sprintf(PrtBuf,"Card %d Port %d %s bNum %d bType: %s Cmd: %s", Card, pNum, SccBuf, bNum, //Aricent PR 1202814 fix
      (bType == CTP_BNDL_TYPE_CTP)	? "CTP"		:
      (bType == CTP_BNDL_TYPE_WP)	? "CESPOSN"	:
      (bType == CTP_BNDL_TYPE_SO)	? "SATOP"	:
      (bType == CTP_BNDL_TYPE_VC)	? "VCOMP"	: "NONE",
      (Cmd == CTP_PORT_CMD_DOWN)		? "DOWN"	:
      (Cmd == CTP_PORT_CMD_UP)			? "UP"		:
      (Cmd == CTP_PORT_CMD_STOP)		? "STOP"	:
      (Cmd == CTP_PORT_CMD_START)		? "START"	:
      (Cmd == CTP_PORT_CMD_BLOCK_TX_PKTS)	? "BLOCK_TX"	:
      (Cmd == CTP_PORT_CMD_UNBLOCK_TX_PKTS)	? "UNBLOCK_TX"	:
      (Cmd == CTP_PORT_CMD_BLOCK_RX_PKTS)	? "BLOCK_RX"	:
      (Cmd == CTP_PORT_CMD_UNBLOCK_RX_PKTS)	? "UNBLOCK_RX"	:
      (Cmd == CTP_PORT_CMD_PROC_SER_LOOP)	? "SER_LOOP"	:
      (Cmd == CTP_PORT_CMD_PROC_BERT)		? "BERT"	:
      (Cmd == CTP_PORT_CMD_PKT_LOOP_SER)	? "LOOP_SER"	:
      (Cmd == CTP_PORT_CMD_PKT_LOOP_ETH)	? "UNLOOP_ETH"	:
      (Cmd == CTP_PORT_CMD_PKT_UNLOOP_SER)	? "LOOP_SER"	:
      (Cmd == CTP_PORT_CMD_PKT_UNLOOP_ETH)	? "UNLOOP_ETH"	:
      (Cmd == CTP_PORT_CMD_PKT_LOOP_BOTH)	? "LOOP_BOTH"	:
      (Cmd == CTP_PORT_CMD_PKT_UNLOOP_BOTH)	? "UNLOOP_BOTH"	:
      (Cmd == CTP_PORT_CMD_CFG_CLKS)		? "CFG CLKS"	: "??");
  PRTSP(GEN,ctp_cfg_port:,PrtBuf);


  status = 0;		// When > 0, we return a failure.
  switch(Cmd) {
    //============================================================
    case CTP_PORT_CMD_DOWN:
      // NOTE: Make sure that all the code executes in this case statement,
      // since we need to get to the end where the checked out bandwidth is
      // returned to the system. (i.e. don't use BAILTEST macros)
      PRTSP(GN2,Bringing DOWN,SccBuf);
      if( !PBS(Card,pNum) ) {
	//--- Clear fractional t1 reg bits
	if( (Dcard.Card[Card].Info[pNum].Present == YES) &&
	    (pDbP->if_mode == IF_MODE_DCARD) &&
	    (pDbP->DcardType == DCARD_T1E1) ) {
	  ctp_cfg_frac_t1_regs( Card, pNum, 0);
	}
	//--- Remove mangle rules
// Aricent Fix for PR740702 -- Start
	if( (SAToP(Card,pNum)) && (pPortIntSt->CheckedOutSpeed) ) {
// Aricent Fix for PR740702 -- End
	  int SatPort = 8*Card  + pNum;
	  if( SAToP_GRE(Card,pNum) ) {
	    if( USE_VIP(Card,pNum) ) {
	      util_ip_string(pPortIntSt->LocAdCid.Node.v4, ip_str);
	      sprintf(CmdStr,"-p gre -j SAToP --port %d --vip %s\n", SatPort, ip_str);
	    } else {
	      sprintf(CmdStr,"-p gre -j SAToP --port %d\n", SatPort);
	    }
            Ret = ctp_ipt_mangle(Card, pNum, 0, pPortIntSt->NetDev, CmdStr);
            if( Ret ) { PRTP(MIN,CANT del SAToP iptables rules); }
	  } else {
                 // Aricent PR 1478968 fix - Start
            if( SATOP_USE_SAME_SRC_DST_UDP(bNum) ) {	// PR 1820995 fix
              dport = pPortIntSt->RemAdCid.Cid;
            } else { dport = 2142; }
	    PRTDV(GEN,Num 3 Setting SAToP dport to,dport); // PR 1820995 fix
	    if( USE_VIP(Card,pNum) ) {
	      util_ip_string(pPortIntSt->LocAdCid.Node.v4, ip_str);
	      sprintf(CmdStr,"-p udp --dport %d --sport %d -j SAToP --port %d --vip %s\n",
                  dport, pPortIntSt->RemAdCid.Cid, SatPort, ip_str);
	    } else {
	      sprintf(CmdStr,"-p udp --dport %d --sport %d -j SAToP --port %d\n",
                  dport, pPortIntSt->RemAdCid.Cid, SatPort);
              // Aricent PR 1478968 fix - End
	    }
            Ret = ctp_ipt_mangle(Card, pNum, 0, pPortIntSt->NetDev, CmdStr);
            if( Ret ) { PRTP(MIN,CANT del SAToP iptables rules); }
          }
	} else if( pPortIntSt->NodeToUseSt == CTP_PORT_LOC_ADDR_VIP ) {
	  util_ip_string(pPortIntSt->LocAdCid.Node.v4, ip_str);
	  //--- Must manage mangle rules for iptables ports......
	  sprintf(CmdStr,"-p %d -j ACORN_DATA --vip %s \n",
	      pSysInfo->protocol, ip_str);
	  Ret = ctp_ipt_mangle(Card, pNum, 0, pPortIntSt->NetDev, CmdStr);
	  if( Ret ) { PRTP(MIN,CANT del ACORN_DATA iptables rules for vip port); }
	}

	if( bType == CTP_BNDL_TYPE_CTP ) {
	  if( (pSysInfo->LocCid[pPortIntSt->LocAdCid.Cid].Card != Card) ||
	      (pSysInfo->LocCid[pPortIntSt->LocAdCid.Cid].pNum != pNum) ) {
	    PRTP(DBG,Do not clear out loccid info - belongs to another port);
	  } else {
	    PRTU8P(DBG,Clear out loccid info for CID,pPortIntSt->LocAdCid.Cid);
	    //--- Clear the pSysInfo->LocCid info...
	    pSysInfo->LocCid[pPortIntSt->LocAdCid.Cid].Card = ~0;
	    pSysInfo->LocCid[pPortIntSt->LocAdCid.Cid].pNum = ~0;
	    pSysInfo->LocCid[pPortIntSt->LocAdCid.Cid].bNum = ~0;
	  }
  	  if(IPV6(Card,pNum)) {
	    inet_ntop(AF_INET6, &pPortIntSt->LocAdCid.Node.v6, ip_str, 46);
	    sprintf(CmdStr,"-p %d -j ACORN_DATA --addr %s --port %d \n",
	        pSysInfo->protocol, ip_str,
	        (pPortIntSt->LocAdCid.Cid) );
	    Ret = ctp_ip6t_mangle(Card, pNum, 0, pPortIntSt->NetDev, CmdStr); //PR 1409765
	  }
	}


	ctp_port_mirror_cfg(Card, pNum, 0);

#ifndef DBG_NO_ETH_IOCTL
	if( !strncmp(pPortIntSt->NetDev,"eth",3) ) {	// Dont do on PBS!
	  PRTP(FNC,CTP processing circuit emulation port);
	  if( (!(HAIRPIN(Card,pNum))) &&
	      (strcmp(&pPortIntSt->NetDev[0],"NONE") != 0 ) &&
	      (pPortSt->Diagnostics == NO) ) {
	    //--- stop processing NRZ packets in eth driver ---
            //Aricent PR 830151 fix - Do not IOCTL on vlan ports
            if(strlen(pPortIntSt->NetDev) > 5) {
               sscanf(pPortIntSt->NetDev, "%4s", EthBuf);
            } else {
               sprintf(EthBuf, "%s", pPortIntSt->NetDev);
            }
	    erc.port = pPortIntSt->LocAdCid.Cid;
	    status = ioc_priv(EthBuf,ETH_GET_RUNTIME_CFG,&erc);
	    if( status ) { PRTP(MIN,Cant IOCTL port); }
	    erc.SendNrzPkts	= NO;
	    erc.RcvNrzPkts	= NO;
	    if( !SAToP(Card,pNum) ) {
	      status = ioc_priv(EthBuf,ETH_SET_RUNTIME_CFG,&erc);
	      if( status ) { PRTP(MIN,Cant IOCTL port); }
	    }
	  }
	}
#endif //DBG_NO_ETH_IOCTL
	//--- stop processing NRZ packets in ser driver ---
	status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
	if( status ) { PRTP(MIN,Cant IOCTL port); }
	nrc.SendNrzPkts	= NO;
	nrc.RcvNrzPkts	= NO;
	status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
	if( status ) { PRTP(MIN,Cant IOCTL port); }
	nrc.sig_out_cfg	= 0x5555;	// Set signaling output high (=OFF)
	status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
	if( status ) { PRTP(MIN,Cant IOCTL port); }
	//--- ser driver DOWN ---
	PRTS(DBG,Setting interface to DOWN,SccBuf);
	status = ioc_updn(SccBuf,DOWN);
	if( status ) { PRTP(MIN,Cant IOCTL port); }
	//--- clear out port counters ---
	memset((char *)&pPortCnt->Previous,0,
	    sizeof(struct acrndrv_runtime_stats));
	memset((char *)&pPortCnt->Current,0,
	    sizeof(struct acrndrv_runtime_stats));
	pPortCnt->Current.Buffer.restart_flag = 1;	// Start with reset flag set!
        if( (bType == CTP_BNDL_TYPE_CTP) || (bType == CTP_BNDL_TYPE_SO) ) {
          Ret = ctp_release_bw(Card, pNum);
          if( Ret ) { PRTP(MIN,Problem with BW release); }
        }
      } else {
	//--- PBS port
	char	NetDev[6];

        // De-configure bridging if applicable.
        if (pDbP->CfgFlags & CFG_PORT_FLAG_BRIDGE) {
          for (pvc = 0; pvc < BRIDGE_MAX_PVCS; pvc++) {
            brcmd.cmd = BC_CMD_SET_CONFIG;
            brcmd.port = pPortSt->SccNum;
            brcmd.unit = pvc;
            brcmd.config.flags = 0;
            Ret = l2bridge_send_cmd(&brcmd);
	    if( Ret ) { PRTP(MIN,Error sending cmd to l2bridge module); }
          }
        }

	//--- Stop queues on PBS interface
	sprintf(CmdStr,"/etc/init.d/tcqueue stop scc%d", pPortSt->SccNum);
	PRTSP(EVE,About to issue cmd,CmdStr);
	Ret = acorn_system(CmdStr);
	usleep(50000);					// Sleep in usec

        if (!(pDbP->CfgFlags & CFG_PORT_FLAG_BRIDGE)) {
	  //--- Remove iptables mangle rules
          sprintf(NetDev,"scc%d", pPortSt->SccNum);
          sprintf(CmdStr,"-p %d -j ACORN_DATA \n", pSysInfo->protocol);
          Ret = ctp_ipt_mangle(Card, pNum, 0, NetDev, CmdStr);
	  if( Ret ) { PRTP(MIN,CANT del ACORN_DATA iptables rules on PBS port); }
        }

	//--- Take down the interface
	sprintf(CmdStr,"/sbin/ifconfig scc%d down", pPortSt->SccNum);
	PRTSP(EVE,About to issue cmd,CmdStr);
	Ret = acorn_system(CmdStr);
	usleep(50000);					// Sleep in usec

        //--- Delete any PVCs that have been added for frame-relay
        if (pDbP->CfgFlags & CFG_PORT_FLAG_BRIDGE) {
          if (pDbP->pkt_info.Encap == CTP_ENCAP_FRAME_RELAY) {
            for (pvc = 0; pvc < BRIDGE_MAX_PVCS; pvc++) {
              if (pDbP->bridge_info.bridge[pvc].flags & BRIDGE_FLAG_CONFIGURED) {
                sprintf(CmdStr, "/acorn/bin/sethdlc scc%d delete %d",
		    pPortSt->SccNum,(int)pDbP->bridge_info.bridge[pvc].dlci);
                PRTSP(EVE,About to issue cmd,CmdStr);
                Ret = acorn_system(CmdStr);
		if( Ret ) { PRTP(MIN,CANT create PVC); }
              }
            }
          }
        }
	usleep(50000);					// Sleep in usec
	status = ctp_request_bw(Card, pNum, &speed, &pps);
  
	redistribute_pps_to_pbs_ports(Card,pNum);
      }
      break;
    //============================================================
    case CTP_PORT_CMD_UP:
      // NOTE: Bandwidth checkout is being done at the very beginning of
      // this port UP. If there is an abnormal exit from the port up, you
      // would think that it would be important to call the function to
      // release the bandwidth but FEAR NOT, since every call to bring the
      // port UP should be followed immediatedly by a port DOWN if the UP
      // was unsuccessful (Exceptions to this case are TOO_SLOW and
      // TOO_FAST, since they do not actually check out any bandwidth. This
      // way we don't leave a port in a partially up state when there are
      // problems.
      PRTSP(GEN,Bringing UP,SccBuf);

      //===================================================================
      //==========  CTP_PORT_CMD_UP for CktEm Bundle
      //===================================================================
      if( !PBS(Card,pNum) ) {
        if( (bType == CTP_BNDL_TYPE_CTP) || (bType == CTP_BNDL_TYPE_SO) ) {
          status = ctp_request_bw(Card, pNum, &speed, &pps);
          BAILTESTF(status,Problem with BW checkout);
        }
        if( SAToP(Card,pNum) ) {
	  PRTP(FNC,CTP processing SAToP port);
	  if( (SAToP_GRE(Card,pNum)) &&
	      (pSysInfo->protocol == 47) ) BAILTESTF(FAILURE,SAToP-GRE with system set for CTP-GRE);
	} else {
	  if( bType == CTP_BNDL_TYPE_CTP ) {
	    PRTP(FNC,CTP processing circuit emulation port);
	    //--- Fill in the Ctp.LocCid info...
	    if( (pSysInfo->LocCid[pPortIntSt->LocAdCid.Cid].Card == ~0) &&
		(pSysInfo->LocCid[pPortIntSt->LocAdCid.Cid].pNum == ~0) &&
		(pSysInfo->LocCid[pPortIntSt->LocAdCid.Cid].bNum == ~0) )  {
	      pSysInfo->LocCid[pPortIntSt->LocAdCid.Cid].Card = Card;
	      pSysInfo->LocCid[pPortIntSt->LocAdCid.Cid].pNum = pNum;
	      pSysInfo->LocCid[pPortIntSt->LocAdCid.Cid].bNum = bNum;
	    } else {
	      PRTDVB(MIN,Problems bringing up bundle - LOCCID in use, pPortIntSt->LocAdCid.Cid);
	      pPortSt->StReason = CTP_PORT_STATE_REASON_LOCCID;
	      BAILTESTmP(FAILURE,LocCid in use);
	    }
	  }
	}
	//--- Look for existing virtual ip and fail if we don't find it.
	if( USE_VIP(Card,pNum) ) {
	  util_ip_string(pPortIntSt->LocAdCid.Node.v4, ip_str);
	  //PRTS(EVE,,PrtBuf);
	  if( pPortIntSt->virtual_ip.v4 != 0 ) {
	    if( ctp_nid_qry_ip( &pPortIntSt->virtual_ip ) != CTP_IF_TYPE_VIP ) {
	      //--- Didn't find vip, log msg
	      sprintf(PrtBuf,"Card %d Port %d didnt find existing vip %s to use.\n",
		  Card, pNum, ip_str);
	      PRTS(EVE,,PrtBuf);
	      BAILTESTmP(FAILURE,VIP failure);
	    }
	    // block of code to avoid problem of generating ARP REQ with
	    // source address as VIP address
            util_ip_string(pPortIntSt->RemAdCid.Node.v4, ip_str);
	    sprintf(CmdStr, "ping -c 1 %s > /dev/null &", ip_str);	//XXX PING
            acorn_system_quiet(CmdStr);
	    PRTS(TMP,Generating ping via cmd,CmdStr);
	  } else {
	    //--- NULL address, log msg
	    sprintf(PrtBuf,"Card %d Port %d cant use null vip (%s).\n",
		Card, pNum, ip_str);
	    PRTS(EVE,,PrtBuf);
	    BAILTESTmP(FAILURE,VIP failure);
	  }
	}

	//--- stop processing NRZ packets in ser driver ---
	status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
	BAILTESTmP(status,Cant IOCTL scc);
	nrc.SendNrzPkts	= NO;
	nrc.RcvNrzPkts	= NO;
	status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
	BAILTESTmP(status,Cant IOCTL scc);
	//--- ser driver DOWN ---
	//    Without this diags failed with complaints about can't ioctl
	//    scc -> port goes to CfgFAIL!!! Not sure what that is about.
	PRTS(GEN,Setting interface to UP,SccBuf);
	status = ioc_updn(SccBuf,DOWN);
	BAILTESTmP(status,Cant IOCTL scc);

	//+++++ If nova or gluon, cfg SCC fifo thresholds
	{
	  int	fifo = 0, txFill, txThresh, rxThresh;
	  //----- CTP2000 non-serial or CTP2000 old serial -----
	  if( ( (pSysInfo->SysType == SYS_TYPE_CTP_2000) && 
		(CARDTYPE(Card) != SCCARD) ) ||
	      ( (pSysInfo->SysType == SYS_TYPE_CTP_2000) && 
		(CARDTYPE(Card) == SCCARD) &&
		(pSysInfo->Card[Card].SubType != HW_SUBTYPE_CTP2000_SER_NEW) )
	    ) {
	    if( CTP_NOVA_FIXED_FIFO <= CTP_NOVA_MAX_FIFO ) {
	      fifo = CTP_NOVA_FIXED_FIFO;
	    } else {
	      // Set fifo so that 2^fifo <= pkt_size in dwords
	      while ( (( 0x4 << fifo) <= pPortIntSt->loc_pkt_size )
		  && (fifo <= CTP_NOVA_MAX_FIFO) ) { fifo++; }
	      if( fifo >= 1 ) fifo--;
	      if( pps < 64)   fifo = 2;
	      if( pps < 16)   fifo = 1;
	      if( pps <  4)   fifo = 0;
	    }
	    txFill = fifo; txThresh = fifo; rxThresh = fifo;
	  //----- CTP2000 new serial -----
	  } else if( (pSysInfo->SysType == SYS_TYPE_CTP_2000) && 
		     (CARDTYPE(Card) == SCCARD) &&
		     (pSysInfo->Card[Card].SubType == HW_SUBTYPE_CTP2000_SER_NEW)
		   ) {
	    // Same as CTP-150, but only Rx Threshold is capped
	    u32	kbps = (pps * pPortIntSt->loc_pkt_size * 8)/1000;
	    PRTDVP(GEN,New NOVA Serial Ckt kbps,kbps);
            PRTDVP(GEN,New NOVA Serial Ckt pps,pps);
	    int	mask = 0x00001000;
	    if( kbps & 0xffffe000 ) { fifo = 7; } 
	    else {
	      fifo = 6;
	      while( (mask & kbps) == 0 ) { 
		mask >>= 1; 
		if(fifo == 1) break;
		fifo--; 
	      }
	    }
	    if( fifo < 1 ) fifo = 1;	// Enforce minimum value
	     #if 1  // PR 1820351 Fix start
             if(pSysInfo->nova_type == 2) {
               PRTP(GEN,Compensating for slower PCI on PP833);
               fifo += 1;
               if( fifo > 7 ) fifo = 7;  // Enforce max value of 7
             }
             #endif // PR 1820351 Fix end

	    txFill = fifo; txThresh = fifo; rxThresh = fifo;
	  //----- CTP150 all -----
	  } else if( ((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) &&
	     ( (bType == CTP_BNDL_TYPE_CTP) || (bType == CTP_BNDL_TYPE_SO) ) ) {
	    // The calculation for the CTP150 is based on bit rate. It was
	    // detemerined emprically that the worst case PCIe latency is
	    // around 40 us. So the goal here is to keep FIFOs at levels
	    // that will allow 250-500 us PCIe latency. For example, 1-2M
	    // ckts get fifo level 3 (2^N DWORDs, or 32 bytes) which allows
	    // .5-.25 latency.
	    u32	kbps = (pps * pPortIntSt->loc_pkt_size * 8)/1000;
	    PRTDVP(GEN,Gluon Ckt kbps,kbps);
	    int	mask = 0x00001000;
	    if( kbps & 0xffffe000 ) { fifo = 7; } 
	    else {
	      fifo = 6;
	      while( (mask & kbps) == 0 ) { 
		mask >>= 1; 
		if(fifo == 1) break;
		fifo--; 
	      }
	    }
	    if( fifo < 1 ) fifo = 1;	// Enforce minimum value
	    txFill = fifo; txThresh = fifo; rxThresh = fifo;
	    // For some unknown reason, the Gluon PCIe can't xfer > 16 QWORDs.
	    // So we cap the params that determine xfer size to <= 4.
	    if( fifo > CTP_GLUON_MAX_FIFO ) {
	      txFill = CTP_GLUON_MAX_FIFO;
	      rxThresh = CTP_GLUON_MAX_FIFO;
	      PRTDVP(GEN,Gluon FIFOs capped to,txFill);
	    }
	  }
	  if ( (bType == CTP_BNDL_TYPE_CTP) || (bType == CTP_BNDL_TYPE_SO) ) {
	    PRTDVP(GEN,Setting FIFOs using pps , pps);
	    PRTU16P(GEN,Setting FIFOs using pkt_size,pPortIntSt->loc_pkt_size);
	    PRTDVP(GEN,Setting FIFOs to, fifo);
	    ncmd.CmdType = SCC_CMD_CFG_DMA_FIFO;
	    ncmd.CmdObj = pPortSt->SccNum;
	    ncmd.CmdObj2 = txFill;
	    ncmd.CmdObj3 = txThresh;
	    ncmd.CmdObj4 = rxThresh;
	    ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
	  }
	}
        // Aricent PR 880784 fix - Start
	if( ((pSysInfo->SysType == SYS_TYPE_CTP_150) || (pSysInfo->SysType == SYS_SUBTYPE_CTP_150)) &&
	    (IS_SER(Card)) &&
	    (bType == CTP_BNDL_TYPE_WP)) {
	  double speed_dbl;
	  int chan, loc_speed;
	  calc_port_speed( Card, pNum, &speed_dbl );
	  loc_speed = (int)speed_dbl;
	  fpga_clr_fcfg();
          // Aricent PR 1462790 fix - Start
          if(pDbP->if_mode == IF_MODE_DCARD) {
            fpga_set_4wto_cesop_en(pNum,1);
            if( pDbP->DcardCfg1 & CFG_4WTO_DUAL_CHAN )  chan = 2;
            else                                        chan = 1;
            fpga_set_frac_t1e1_chan( pNum, (chan-1) );
            PRTP(GEN,^^^^^ Additional programming for 4WTO serial CESoPSN);
	  } else {
            if( (loc_speed == 0) || (loc_speed % 64) ) {
              PRTDVP(MAJ,Illegal speed for serial CESoPSN, speed);
            } else {
             chan = loc_speed / 64;
             PRTDVP(GEN,serial CESoPSN speed, loc_speed);
             PRTDVP(GEN,serial CESoPSN chan, chan);
             fpga_set_frac_t1e1_chan( pNum, (chan-1) );
            }
            fpga_set_tx_scc_clk(pNum,CTP_CLK_SEL_DDS);          // Serial CESoP must use DDS
            PRTP(GEN,^^^^^ Additional programming for non-4WTO serial CESoPSN);
	  }
         // Aricent PR 1462790 fix - End
	  fpga_set_cesop_serial_to_if(pNum,1);	
	  fpga_send_fcfg(pPortSt->SccNum);
	}
        // Aricent PR 880784 fix - End
	// Aricent PR-947222 Start
        if( IS_T1E1_2000(Card) && CTP_BNDL_TYPE_WP == bType) {
          fpga_clr_fcfg();
          fpga_set_cesop_t1_to_net_if(pNum,1);
          fpga_send_fcfg(pPortSt->SccNum);
        }
	// Aricent PR-947222 End 

	//+++++ Configure the drivers for port operation
	//----- Get SCC static status -----
	status = ioc_priv(SccBuf,SCC_GET_STATIC_STAT,&nss);
	BAILTESTmP(status,Cant IOCTL scc);
	//----- Set SCC static config -----
	bzero(&nsc, sizeof(nsc));
	nsc.ip_src_addr	= My_in_addr.s_addr;
        nsc.ipv6_src_addr.s6_addr32[3] = htonl(My_in_addr.s_addr);
        nsc.ipv6_src_addr.s6_addr32[2] = 0;
        nsc.ipv6_src_addr.s6_addr32[1] = 0;
        nsc.ipv6_src_addr.s6_addr32[0] = 0;

	//--- Setup destination address
        nsc.ip_dst_addr	= htonl(pPortIntSt->RemAdCid.Node.v4);
        nsc.ipv6_dst_addr = pPortIntSt->RemAdCid.Node.v6;
	if( HAIRPIN(Card,pNum) ) {
	  int has_rem_cid = pPortIntSt->RunFlags & PORT_RUN_FLAG_HP_REM_CID;
	  unsigned long temp;
	  BAILTESTmP(!has_rem_cid,No remote hairpin bundle found);
	  if( pPortIntSt->RemAdCid.Node.Type == CTP_IPV4 ) {
	    unsigned int	TmpLocalIp;
	    TmpLocalIp  = ((172 << 24) & 0xff000000);
	    TmpLocalIp |= ((  0 << 16) & 0x00ff0000);
	    TmpLocalIp |= ((  3 <<  8) & 0x0000ff00);
	    TmpLocalIp |= (remote_cid & 0x000000ff);
	    nsc.ip_dst_addr	= (u32)htonl(TmpLocalIp);
	  } else {
	    nsc.ipv6_dst_addr.s6_addr32[0]  = 0;
	    nsc.ipv6_dst_addr.s6_addr32[1]  = 0;
	    nsc.ipv6_dst_addr.s6_addr32[2]  = 0;
	    nsc.ipv6_dst_addr.s6_addr32[3]  = htonl((172<<24)+(remote_cid << 8)+ 101);
	  }
	  //--- Use pointer to other scc dev.
	  nsc.pEthDev	= (struct net_device *)hp_nss.pSerDev;
          #ifdef WRL
	  temp = (unsigned long)nsc.pEthDev;
          #else
	  temp = (int)nsc.pEthDev;
          #endif
	  PRTVP(GEN,Remote network hairpin device address is,temp);
	} else {
	  nsc.pEthDev = (struct net_device *)NULL;	// Gets filled during rt lookup
	  //--- Clear out internal state so ctp_route_check knows how driver is set!
	  sprintf(pPortIntSt->NetDev,"NONE");
	}

	nsc.rx_pkt_size	 = pPortIntSt->loc_pkt_size;
	nsc.service_type = pPortIntSt->svc_type;
	nsc.rem_port	 = (u8)pPortIntSt->RemAdCid.Cid;
	nsc.LocCid  	 = (u8)pPortIntSt->LocAdCid.Cid;
	nsc.time_to_live = pPortIntSt->time_to_live;
	nsc.tx_scc_clk	= pDbP->tx_sel;
	nsc.rx_scc_clk	= pDbP->rx_sel;
        nsc.tdm_rate	= pPortIntSt->tdm_rate; // TDM operation
	nsc.div_src	= pDbP->div_src;
	nsc.cntr_src	= pPortIntSt->CntrSel;	// Internal state may not be the best place for this
	nsc.PortFlags	= pDbP->CfgFlags;
	nsc.RdntFlags	= pDbP->RdntConfig;
	nsc.DcardCfg1	= pDbP->DcardCfg1;	// PR 1569847
#ifdef HACK_FREE_CNTR
	PRT(MAJ,**** CntrRatio Fixed at 1 for DIV *****);
	nsc.cntr_ratio 	= 1;
#else
	nsc.cntr_ratio 	= pPortIntSt->CntrRatio;
#endif
	nsc.div		= pDbP->div_val;
	nsc.max_missing	= pPortIntSt->StarveCnt;
	nsc.req_in_seq 	= pPortIntSt->ReqInSeq;
	nsc.pFFfill	= pPortIntSt->pFFfill;
	nsc.PktProtect	= pPortIntSt->PktProtect;
	nsc.protocol	= pSysInfo->protocol;
        nsc.encoding	= pDbP->IfEncoding;   // PR-1462843
	if( SAToP(Card,pNum) ) {
	  nsc.if_cfg |= IF_CFG_SATOP;
	  if( SAToP_GRE(Card,pNum) ) {
	    nsc.if_cfg |= IF_CFG_T_GRE;
	    nsc.sup 	= pPortIntSt->MPLS_LO;	//--- MPLS label to remote  (out)
	    nsc.dup 	= pPortIntSt->MPLS_LI;	//--- MPLS label from remote (in)
	  } else {
	    nsc.sup 	= pPortIntSt->RemAdCid.Cid;
	    nsc.dup 	= pPortIntSt->dup;
	  }
	} else {	// No SAToP support with fractional T1!
	  if( FRAC_T1E1(Card, pNum) ) {
	    int i = pDbP->DcardCfg2;
	    u32 chan_en = ctp_get_frac_chan_en(Card, pNum);
	    if( !(pDbP->DcardCfg1 & T1E1_MSK_E1) ) {
	      i = (pDbP->DcardCfg2 > 24) ? 24 : pDbP->DcardCfg2;
	    }

	    //--- Set/clear fractional t1 reg bits AFTER ioc_priv nsc
	    ctp_cfg_frac_t1_regs( Card, pNum, 1);
	    //--- If we are using a T1E1 dcard AND fractional T1 is enabled
	    //    pass flag and chan mask to driver.
	    nsc.if_cfg	|= IF_CFG_FT1E1;

	    //--- Transport frame?
	    if( pDbP->DcardCfg1 & T1E1_MSK_E1 ){
	      nsc.if_cfg |= IF_CFG_E1;
	      nsc.if_cfg &= ~IF_CFG_NO_FRM;
	    } else {
	      nsc.if_cfg &= ~IF_CFG_E1;
	      if( pDbP->DcardCfg1 & T1E1_MSK_NO_FRM ) nsc.if_cfg |= IF_CFG_NO_FRM;
	    }

	    PRTDV(GEN,DcardCfg2:,pDbP->DcardCfg2);
	    PRTDV(GEN,Channels to enable:,i);
	    PRTDV(GN3,Channel mask:,chan_en);
	    nsc.frac_t1e1_chan_en	 = chan_en;
	  } else {
	    nsc.frac_t1e1_chan_en	 = 0xffffffff;
	  }
	}
        if(IPV6(Card,pNum)) {nsc.if_cfg |= IF_CFG_IPv6; }
	nsc.IsDrDrv = 1;	// Assume Direct Drive for now
	if( IPT(Card,pNum) ) { nsc.IsDrDrv   = 0; }

	//----- Set SCC runtime config -----
	nrc.StartDel	= ticks_to_cntr( pPortIntSt->StartDel, Card, pNum);
	nrc.MaxDel	= ticks_to_cntr( pPortIntSt->MaxDel, Card, pNum);
	nrc.MinDel	= ticks_to_cntr( pPortIntSt->MinDel, Card, pNum);
	nrc.SendNrzPkts	= NO;
	nrc.RcvNrzPkts	= NO;
	nrc.nrz_loop 	= NO;
	nrc.restart	= YES;
	nrc.SigOutDelay	= pPortIntSt->SigOutDelay;
	nrc.DebugPrintFlag = pPortIntSt->DebugPrintFlag;
	ctp_gen_sigo_cfg( pDbP->Sig, &nrc.sig_out_cfg);
	ctp_gen_sigi_cfg( pDbP->Sig, &nrc.sig_inp_cfg);

	if(CARDTYPE(Card) == T1CARD) {
	  int all_h110 = Db.Card[Card].card_all_h110;
	  u32 val;
	  nsc.t1Cfg.onOff = (ctp_bndl_type_wp(Card, pNum))?2:1;
	  nsc.t1Cfg.framing = pDbP->DcardCfg1 & T1E1_MSK_E1;
	  nsc.t1Cfg.lineCoding = (pDbP->DcardCfg1 & T1E1_MSK_T1_AMI) >> 1;
	  if(((pDbP->DcardCfg1 & T1E1_MSK_FRAME)==0) || (!ctp_bndl_type_wp(Card, pNum))) {
            // PR 1309312 - Start
            if( IS_CTP_FRAC_T1_WO_FRAME_ON_T1CARD ) {
              //PRT(OFF,PR1309312 - Enable Dallas framer);
              nsc.t1Cfg.framemode = (pDbP->DcardCfg1 & T1E1_MSK_T1_D4) >> 2; // Enable Dallas framer
              //PRT(OFF,PR1309312 - Set Dallas External Tx Sync);
              nsc.t1Cfg.onOff = 2;      // Set to "Winpath mode" which in turn will
                                        // enable TX_Sync signal driven into Dallas
            } else {
            // PR 1309312 - End
              nsc.t1Cfg.framemode = 2;  // Dallas runs unframed
            } // PR 1309312
	  } else nsc.t1Cfg.framemode = (pDbP->DcardCfg1 & T1E1_MSK_T1_D4) >> 2;
	  nsc.t1Cfg.cableLength = (pDbP->DcardCfg1 & T1E1_MSK_BUILDOUT)>>4;
	  nsc.t1Cfg.signaling = (pDbP->DcardCfg1 & T1E1_MSK_E1_CAS)?1:0;
	  nsc.t1Cfg.h110 = 0;
	  if( pDbP->DcardCfg1 & T1E1_MSK_H110) {
	    if( all_h110 ) { nsc.t1Cfg.h110 = 1; } 
	    else           { nsc.t1Cfg.h110 = 2; }
	  }
	  // The following config is needed since the Dallas TxSer mux was
	  // decoupled and configured with it's own dedicated FPGA config bits
	  fpga_clr_fcfg();
	  val = ctp_bndl_type_wp(Card, pNum) ? 1 : 0;		// Winpath or Packer to Framer
	  fpga_set_framer_txser_sel(Card, pNum,val);	
	  fpga_send_fcfg(pPortSt->SccNum);

	}
	if( (pSysInfo->hdlc_ports) && (pPortSt->Diagnostics) ) {
	  u32   	TmpLocalIp;
	  PRT(GEN,Diagnostics fixup for systems with hdlc ports);
	  //--- Fixup for diagnostics when PBS/layer 2 ports active on node
	  TmpLocalIp  = ((172 << 24) & 0xff000000);
	  TmpLocalIp |= ((  0 << 16) & 0x00ff0000);
	  TmpLocalIp |= ((  3 <<  8) & 0x0000ff00);
	  TmpLocalIp |= (       251  & 0x000000ff);	// Note, outside of allowed CID range!
	  nsc.ip_dst_addr	= (u32)htonl(TmpLocalIp);
	  nsc.ip_src_addr	= (u32)htonl(TmpLocalIp);
	  nsc.time_to_live      = 255;
	  nsc.IsDrDrv   = 0;
	}

	PRTSP(GEN,Configuring SCC interface static and runtime,SccBuf);
	status = ioc_priv(SccBuf,SCC_SET_STATIC_CFG,&nsc);
	BAILTESTmP(status,Cant IOCTL scc);

	// If redundancy mode is enabled, the H/W will be determining
	// whether or not the Tx output should be enabled. So the
	// initial state here is to have the output disabled.
	if( pDbP->RdntConfig & CFG_RDNT_MODE_MASK ) {
	  PRTP(EVE,Redundant port so leaving T1E1 output disabled);
	} else {
          //Aricent PR 989527 fix - Start
          if(bNum != CTP_MAX_BNDLS) {
            if(IS_T1E1(Card))
	      ctp_enable_Dallas_tx_output(bNum, 1);
          }
          //Aricent PR 989527 fix - End
	}

	/* if it is in winpath mode, break, that's all we need */
	if(ctp_bndl_type_wp(Card, pNum)) {
	  // Aricent PR 880784 fix -  Don't program for serial CESoPSN bundle
	  if(IS_T1E1(Card)) {
	    if(IS_ABRG(Card)) pPortSt->SerLoop = CTP_SER_LOOP_TO_NET;	// PR 1565597 Always looped ToNet
	    ctp_proc_t1_loop(Card,pNum);
	    ctp_proc_t1_bert( Card, pNum );
	  }
	  break;
	}

	//--- Do ctp_route_chk to setup egress device. Check will probably
	//    fail as OAMs havn't gone out => no hh yet.
	ctp_route_chk(Card, pNum);

	// TODO mike - In a perfect world, this check would have been
	// handled well before here. Maybe someday...
	//
        //--- If it's of VLAN interface but the port is direct drive
        if(strlen(pPortIntSt->NetDev) > 5) {
   	  if(!IPT(Card,pNum)) {
	    pPortSt->StReason = CTP_PORT_STATE_REASON_VLAN;
	    BAILTESTmP(FAILURE,VLAN failure);
	  }
	}
	PRTSP(EVE,UP: Got dev name from rt lookup,pPortIntSt->NetDev);

	//--- Add mangle table rules
	if( SAToP(Card,pNum) ) {
	  int SatPort = 8*Card  + pNum;
	  PRTDVP(GN2,Adding ipt SAToP rules with SatPort, SatPort);
	  if( SAToP_GRE(Card,pNum) ) {
	    if( USE_VIP(Card,pNum) ) {
	      util_ip_string(pPortIntSt->LocAdCid.Node.v4, ip_str);
	      sprintf(CmdStr,"-p gre -j SAToP --port %d --vip %s\n", SatPort, ip_str);
	    } else {
	      sprintf(CmdStr,"-p gre -j SAToP --port %d \n", SatPort);
	    }
            Ret = ctp_ipt_mangle(Card, pNum, 1, pPortIntSt->NetDev, CmdStr);
            BAILTESTmP(Ret, CANT add SAToP iptables rules);
	  } else {
            // Aricent PR 1478968 fix - Start
            if( SATOP_USE_SAME_SRC_DST_UDP(bNum) ) {	// PR 1820995 fix
              dport = pPortIntSt->RemAdCid.Cid;
            } else { dport = 2142; }
	    PRTDV(GEN,Num 1 Setting SAToP dport to,dport); // PR 1820995 fix
	    if( USE_VIP(Card,pNum) ) {
	      util_ip_string(pPortIntSt->LocAdCid.Node.v4, ip_str);
	      sprintf(CmdStr,"-p udp --dport %d --sport %d -j SAToP --port %d --vip %s\n",
                  dport, pPortIntSt->RemAdCid.Cid, SatPort, ip_str);
	    } else {
	      sprintf(CmdStr,"-p udp --dport %d --sport %d -j SAToP --port %d\n",
                  dport, pPortIntSt->RemAdCid.Cid, SatPort);
              // Aricent PR 1478968 fix - End
	    }
            Ret = ctp_ipt_mangle(Card, pNum, 1, pPortIntSt->NetDev, CmdStr);
            BAILTESTmP(Ret, CANT add SAToP iptables rules);
          }
	} else if( pPortIntSt->NodeToUseSt == CTP_PORT_LOC_ADDR_VIP ) {
	  util_ip_string(pPortIntSt->LocAdCid.Node.v4, ip_str);
	  //--- Must manage mangle rules for iptables ports......
	  sprintf(CmdStr,"-p %d -j ACORN_DATA --vip %s\n",
	      pSysInfo->protocol, ip_str);
	  Ret = ctp_ipt_mangle(Card, pNum, 1, pPortIntSt->NetDev, CmdStr);
	  BAILTESTmP(Ret, CANT add ACORN_DATA iptables rules for vip port);
        /*PR 1470068 fix start*/
        } else if( IPV6(Card, pNum) && UNI_DIR_DST(Card, pNum) ) {
          if( ( (strncmp(&pPortIntSt->NetDev[0],"eth",3) == 0) ||
                (strncmp(&pPortIntSt->NetDev[0],"scc",3) == 0) ) &&
                (!(HAIRPIN(Card,pNum))) ) {
            struct CtpNidInfo iface;

            PRTP(GEN,UP: Processing non-vip port);
            memset( (char *)&iface, 0, sizeof(iface) );
            sprintf( iface.name, "%s", pPortIntSt->NetDev);
            // Find the structure for NID interface in order to fill my node to use
            if( ctp_nid_qry_dev( Card, pNum, &iface ) ) {
              PRTP(MIN, ctp_nid_qry_dev NO interface match found);
              BAILTESTmP(FAILURE,NID failure);
            }

            pPortIntSt->LocAdCid.Node = iface.addr_store;
            pPortIntSt->NodeToUseSt = CTP_PORT_LOC_ADDR_IF;
            pPortIntSt->LocAdCid.Node.Type = CTP_IPV6;

            // IO control SCC
            nsc.ipv6_src_addr = iface.addr_store.v6;
            nsc.ip_src_addr = htonl(iface.addr_store.v4);

            PRTSP(GEN,Configuring SCC interface static and runtime,SccBuf);
            status = ioc_priv(SccBuf,SCC_SET_STATIC_CFG,&nsc);
            BAILTESTmP(status,Cant IOCTL scc);
          } else if (HAIRPIN(Card,pNum)) {
            /* well, filling the structure with the destination node, we may be able
               to make port mirroring happy*/
            pPortIntSt->LocAdCid.Node = pPortIntSt->RemAdCid.Node;
          } else {
            PRTP(EVE,NetDev not eth or PBS port);
            BAILTESTmP(FAILURE,device failure);
          }
        } /*PR 1470068 fix end*/

	ctp_port_mirror_cfg(Card, pNum, 1);

	//--- Now get ip of egress device.
	if( !USE_VIP(Card,pNum) &&
	    !UNI_DIR_DST(Card,pNum) &&
	    !(pPortSt->Diagnostics) ) {
	  if( ( (strncmp(&pPortIntSt->NetDev[0],"eth",3) == 0) ||
		(strncmp(&pPortIntSt->NetDev[0],"scc",3) == 0) ) &&
                (!(HAIRPIN(Card,pNum))) ) {
	    struct CtpNidInfo iface;

	    PRTP(GEN,UP: Processing non-vip port);
	    memset( (char *)&iface, 0, sizeof(iface) );
	    sprintf( iface.name, "%s", pPortIntSt->NetDev);
	    // Find the structure for NID interface in order to fill my node to use
	    if( ctp_nid_qry_dev( Card, pNum, &iface ) ) {
	      PRTP(MIN, ctp_nid_qry_dev NO interface match found);
	      BAILTESTmP(FAILURE,NID failure);
	    }

	    pPortIntSt->LocAdCid.Node = iface.addr_store;
	    pPortIntSt->NodeToUseSt = CTP_PORT_LOC_ADDR_IF;
	    pPortIntSt->LocAdCid.Node.Type = IPV6(Card,pNum)?CTP_IPV6:CTP_IPV4;

	    // IO control SCC
	    nsc.ipv6_src_addr = iface.addr_store.v6;
	    nsc.ip_src_addr = htonl(iface.addr_store.v4);

	    PRTSP(GEN,Configuring SCC interface static and runtime,SccBuf);
	    status = ioc_priv(SccBuf,SCC_SET_STATIC_CFG,&nsc);
	    BAILTESTmP(status,Cant IOCTL scc);
	  } else if (HAIRPIN(Card,pNum)) {
	    /* well, filling the structure with the destination node, we may be able
	       to make port mirroring happy*/
	    pPortIntSt->LocAdCid.Node = pPortIntSt->RemAdCid.Node;
	  } else {
	    PRTP(EVE,NetDev not eth or PBS port);
	    BAILTESTmP(FAILURE,device failure);
	  }
	}
        /* ARICENT FIX Start - PR1290068 */
        if((IPV6(Card,pNum)) && !(SAToP(Card,pNum)) && (pPortIntSt->NodeToUseSt != CTP_PORT_LOC_ADDR_VIP)) {
        // no vip for IPV6 yet
          // PR 1334121 fix - Start
          if (strncmp(pPortIntSt->NetDev, "NONE", 4)==0) {
             PRTP(GEN, No mangle rule applied);
          }
          else {
          // PR 1334121 fix - End
          inet_ntop(AF_INET6, &pPortIntSt->LocAdCid.Node.v6, ip_str, 46);
          sprintf(CmdStr,"-p %d -j ACORN_DATA --addr %s --port %d \n",
              pSysInfo->protocol, ip_str,
              (pPortIntSt->LocAdCid.Cid) );
          Ret = ctp_ip6t_mangle(Card, pNum, 1, pPortIntSt->NetDev, CmdStr); //PR 1409765
          }
        }
       /* ARICENT FIX End - PR1290068 */	
	//--- Tell the driver what to use as a source address
	if( IPT(Card,pNum) ) {
	  //--- Mangle rules setup src ip address, even for vip ports.
	  u32   	TmpLocalIp;
	  nsc.ipv6_src_addr.s6_addr32[0]  = 0;
	  nsc.ipv6_src_addr.s6_addr32[1]  = 0;
	  nsc.ipv6_src_addr.s6_addr32[2]  = 0;
	  nsc.ipv6_src_addr.s6_addr32[3]  = htonl((172<<24)+(pPortIntSt->LocAdCid.Cid << 8)+ 100);

	  TmpLocalIp  = ((  172 << 24) & 0xff000000);
	  TmpLocalIp |= ((    0 << 16) & 0x00ff0000);
	  if(SAToP(Card,pNum)) {
	    //--- Fixup for SAToP
	    TmpLocalIp |= ((       1 << 8) & 0x0000ff00);
	    TmpLocalIp |= ((8*Card + pNum) & 0x000000ff);
	  } else {
	    TmpLocalIp |= ((    3 <<  8) & 0x0000ff00);
	    TmpLocalIp |= ((    pPortIntSt->LocAdCid.Cid   ) & 0x000000ff);
	  }
	  nsc.ip_src_addr = (u32)htonl(TmpLocalIp);
	  PRTSP(GEN,Configuring SCC interface static and runtime,SccBuf);
	  status = ioc_priv(SccBuf,SCC_SET_STATIC_CFG,&nsc);
	  BAILTESTmP(status,Cant IOCTL scc);
	} else if( pPortIntSt->NodeToUseSt == CTP_PORT_LOC_ADDR_VIP ) {
	  //---
	  char Buf[INET_ADDRSTRLEN];
	  nsc.ip_src_addr = htonl(pPortIntSt->LocAdCid.Node.v4);
	  if(inet_ntop(AF_INET, &nsc.ip_src_addr, Buf, INET_ADDRSTRLEN)) {
	    PRTSP(GEN, vip source ipv4, Buf);
	  }
	  PRTSP(GEN,Configuring SCC interface static and runtime,SccBuf);
	  status = ioc_priv(SccBuf,SCC_SET_STATIC_CFG,&nsc);
	  BAILTESTmP(status,Cant IOCTL scc);
	} else {
	  //--- Standard direct drive port already setup.
	}

	status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
	BAILTESTmP(status,Cant IOCTL scc 3);

	//+++++ Now, bring up the port (in LOOP)
	PRTSP(DBG,Setting interface to UP,SccBuf);
	status = ioc_updn(SccBuf,UP);
	BAILTESTmP(status,Cant IOCTL scc 2);
	//break;		// leave it in loop for now...

	//+++++ Wait for things to settle (100 ms)
	usleep(100000);

	//--- set up serial loops and BERT tester ---
	if(IS_T1E1(Card)) {
	  if(IS_ABRG(Card)) pPortSt->SerLoop = CTP_SER_LOOP_TO_NET;	// PR 1565597 Always looped ToNet
	  ctp_proc_t1_loop(Card,pNum);
	} else {
	  ctp_proc_ser_loop(Card,pNum);
	}
	if(ctp_bndl_type_wp(Card, pNum)) {
	  // Aricent PR 880784 fix -  Don't program for serial CESoPSN bundle
	  if(IS_T1E1(Card))	ctp_proc_t1_bert( Card, pNum );
	  else			ctp_proc_bert_cfg( Card, pNum );
	}
	else			ctp_proc_bert_cfg( Card, pNum );
      //===================================================================
      //==========  CTP_PORT_CMD_UP for PBS Port
      //===================================================================
      } else {
	//--- PBS port
        struct PktInfo pkt_info = pDbP->pkt_info;
        int i;
        struct in_addr loc, rem;
        char ip_a[20], ip_b[20], ifs[16];
        CTP_NODE_STORAGE addNode;

        PRTP(FNC,CTP processing pkt based serial port);

	status = ctp_request_bw(Card, pNum, &speed, &pps);
	redistribute_pps_to_pbs_ports(Card,pNum);

	// There are many places where this process of bringing up a PBS
	// port can go wrong (search for BAILTEST). If any of them fails,
	// it does notify the user with a log message, but the recovery may
	// not be graceful (it just leaves a mess and exits the function).
	// In order to avoid these problems, here is the place (at the
	// beginning of the port config process) to do checks and abort if
	// there is a problem. Eventually, when there are enough checks, we
	// may want to consolidate things into a separate function, but for
	// now...
        BAILTESTmP((pDbP->pkt_info.Local_IP == 0),Error - Local IP is 0.0.0.0);
        BAILTESTmP((pDbP->pkt_info.Remote_IP == 0),Error - Remote IP is 0.0.0.0);

        sprintf(ifs,"scc%d", pPortSt->SccNum);
        sprintf(CmdStr,"/sbin/ifconfig %s down", ifs);
        PRTSP(EVE,About to issue cmd,CmdStr);
        Ret = acorn_system(CmdStr);
        BAILTESTmP(Ret, CANT ifconfig scc down);

        usleep(50000);					// Sleep in usec
        //--- set proto type
        /*
         * For L2 bridge mode, we have all sorts of different encapsulation
         * options. If we're not in bridge mode, we just do what we did
         * before and basically accept defaults.
         */
        if (pDbP->CfgFlags & CFG_PORT_FLAG_BRIDGE) {
          if (pkt_info.Encap == CTP_ENCAP_CHDLC) {
            sprintf(CmdStr, "/acorn/bin/sethdlc %s cisco interval %d timeout %d", ifs,
                    (int)pDbP->bridge_info.settings.cisco.interval,
                    (int)pDbP->bridge_info.settings.cisco.timeout);
          } else if (pkt_info.Encap == CTP_ENCAP_FRAME_RELAY) {
            sprintf(CmdStr, "/acorn/bin/sethdlc %s fr lmi %s %s t391 %d t392 %d n391 %d n392 %d n393 %d", ifs,
                    pDbP->bridge_info.settings.fr.lmi == CTP_LMI_ANSI ? "ansi" : "ccitt",
                    pDbP->bridge_info.settings.fr.dce == LMI_FR_DTE  ? ""  : "dce",
                    (int)pDbP->bridge_info.settings.fr.t391, (int)pDbP->bridge_info.settings.fr.t392,
                    (int)pDbP->bridge_info.settings.fr.n391, (int)pDbP->bridge_info.settings.fr.n392,
                    (int)pDbP->bridge_info.settings.fr.n393);
          } else if (pkt_info.Encap == CTP_ENCAP_PPP) {
            sprintf(CmdStr,"/acorn/bin/sethdlc %s ppp", ifs);
          }
        } else {
          if( pkt_info.Encap == CTP_ENCAP_CHDLC ) {
            sprintf(CmdStr,"/acorn/bin/sethdlc %s cisco interval 15 timeout 30", ifs);
          } else if( pkt_info.Encap == CTP_ENCAP_PPP ) {
            sprintf(CmdStr,"/acorn/bin/sethdlc %s ppp", ifs);
          }
        }
        PRTSP(EVE,About to issue cmd,CmdStr);
        Ret = acorn_system(CmdStr);
        BAILTESTmP(Ret, CANT sethdlc scc);
        usleep(50000);					// Sleep in usec
        if (pDbP->CfgFlags & CFG_PORT_FLAG_BRIDGE) {
          if (pkt_info.Encap == CTP_ENCAP_FRAME_RELAY) {
            for (pvc = 0; pvc < BRIDGE_MAX_PVCS; pvc++) {
              if (pDbP->bridge_info.bridge[pvc].flags & BRIDGE_FLAG_CONFIGURED) {
                sprintf(CmdStr, "/acorn/bin/sethdlc %s create %d",
		    ifs, (int)pDbP->bridge_info.bridge[pvc].dlci);
                PRTSP(EVE,About to issue cmd,CmdStr);
                Ret = acorn_system(CmdStr);

                // If at first you don't succeed...
                if (Ret) {
                  sprintf(CmdStr, "/acorn/bin/sethdlc %s delete %d",
		      ifs, (int)pDbP->bridge_info.bridge[pvc].dlci);
                  PRTSP(EVE,About to issue cmd,CmdStr);
                  Ret = acorn_system(CmdStr);
                  sprintf(CmdStr, "/acorn/bin/sethdlc %s create %d",
		      ifs, (int)pDbP->bridge_info.bridge[pvc].dlci);
                  PRTSP(EVE,About to issue cmd,CmdStr);
                  Ret = acorn_system(CmdStr);
                }
                BAILTESTmP(Ret, Unable to create PVC);
              }
            }
          }
        }

        usleep(50000);					// Sleep in usec

        //--- ifconfig so routing engine gets what it needs
        loc.s_addr = htonl(pDbP->pkt_info.Local_IP);
        rem.s_addr = htonl(pDbP->pkt_info.Remote_IP);
        sprintf(ip_a, "%s", inet_ntoa(loc));
        sprintf(ip_b, "%s", inet_ntoa(rem));
        sprintf(CmdStr,"/sbin/ifconfig %s %s pointopoint %s up",
            ifs, ip_a, ip_b );
        PRTSP(EVE,About to issue cmd,CmdStr);
        Ret = acorn_system(CmdStr);
        BAILTESTmP(Ret, CANT ifconfig scc pointopoint);
        usleep(50000);					// Sleep in usec
        ctp_set_mtu(Card,pNum,pDbP->pkt_info.Mtu);
        usleep(50000);					// Sleep in usec
        set_nom_ctr_freq(Card,pNum);
        ctp_cfg_port(Card, pNum, CTP_PORT_CMD_CFG_CLKS);
        usleep(50000);					// Sleep in usec
        addNode.Type = CTP_IPV4;
        addNode.v4 = htonl(loc.s_addr);

        ctp_nid_add_ip( 100+pPortSt->SccNum, CTP_IF_TYPE_PBS, ifs, &addNode, speed, (int)pDbP->pkt_info.Mtu);

        // Configure bridging if the port is in L2 mode.
        if (pDbP->CfgFlags & CFG_PORT_FLAG_BRIDGE) {
          for (pvc = 0; pvc < BRIDGE_MAX_PVCS; pvc++) {
            if (pDbP->bridge_info.bridge[pvc].flags & BRIDGE_FLAG_CONFIGURED) {
              // Bring up the Ethernet interface the port is bridged to, if it's down.
              sprintf(CmdStr,"/sbin/ifconfig eth%d up", pDbP->bridge_info.bridge[pvc].eth_if);
              PRTSP(EVE,About to issue cmd,CmdStr);
              Ret = acorn_system(CmdStr);
              BAILTESTmP(Ret, CANT ifconfig Ethernet interface up for bridge);

              // Enable simple queueing to drop packets gracefully.
              sprintf(CmdStr,"/etc/init.d/tcqueue start scc%d 1 1 1 L2AGG", pPortSt->SccNum);
              PRTSP(EVE,About to issue cmd,CmdStr);
              Ret = acorn_system(CmdStr);
              //BAILTESTmP(Ret, CANT enable l2agg tc);	// TODO this test fails (and should not)
            }

            // Send a command to the l2bridge kernel module to configure the bridge.
            brcmd.cmd = BC_CMD_SET_CONFIG;
            brcmd.port = pPortSt->SccNum;
            brcmd.unit = pvc;
            brcmd.config.scc_encap = pDbP->pkt_info.Encap;
            sprintf(brcmd.config.eth_if_name, "eth%d", pDbP->bridge_info.bridge[pvc].eth_if);
            sprintf(brcmd.config.scc_if_name, "scc%d", pPortSt->SccNum);
            brcmd.config.vlan_id = pDbP->bridge_info.bridge[pvc].vlan_id;
            brcmd.config.dlci = pDbP->bridge_info.bridge[pvc].dlci;
            memcpy(brcmd.config.dmac, pDbP->bridge_info.bridge[pvc].dmac, 6);
            brcmd.config.flags = pDbP->bridge_info.bridge[pvc].flags | BRIDGE_FLAG_ACTIVE;
            Ret = l2bridge_send_cmd(&brcmd);
            BAILTESTmP(Ret, Error sending command to l2bridge kernel module);
          }
        } else {
          // Non-L2 PBS port, so set up L3 stuff (mangles and routes)
          //--- Add iptables mangle rules
          sprintf(CmdStr,"-p %d -j ACORN_DATA \n", pSysInfo->protocol);
          Ret = ctp_ipt_mangle(Card, pNum, 1, ifs, CmdStr);
          BAILTESTmP(Ret, CANT add ACORN_DATA iptables rules on PBS port);

	  // Enable queueing similar to Ethernet I/F
	  sprintf(CmdStr,"/etc/init.d/tcqueue start scc%d %d %d %d PBS", 
	      pPortSt->SccNum,
	      pSysInfo->protocol,
	      pSysInfo->oam_port,
	      pSysInfo->oam_port_v6 );
	  PRTSP(EVE,About to issue cmd,CmdStr);
	  Ret = acorn_system(CmdStr);
	  //BAILTESTmP(Ret, CANT enable PBS tc);	// TODO this test fails (and should not)

          //--- add static routes
          for (i=0; i<3; i++) {
            if( pkt_info.Routes[i].use == YES ) {
              struct in_addr net, mask;
              net.s_addr = htonl(pkt_info.Routes[i].network);
              mask.s_addr = htonl(pkt_info.Routes[i].netmask);
              sprintf(ip_a, "%s", inet_ntoa(net));
              sprintf(ip_b, "%s", inet_ntoa(mask));
              sprintf(CmdStr,"/sbin/route add -net %s netmask %s dev %s", ip_a, ip_b, ifs );
              PRTSP(EVE,About to issue cmd,CmdStr);
              Ret = acorn_system(CmdStr);
              BAILTESTmP(Ret, CANT route add);
            }
          }
        }
      }

      //--- Clear out lastlong & lucky info
      memset((char *)&pPortCnt->LastLong,0,
	                    sizeof(struct acrndrv_runtime_stats));
      pPortCnt->LongBufMon.Buffer.Largest   = 0;
      pPortCnt->LongBufMon.Buffer.NLargest  = 0;
      pPortCnt->LongBufMon.Buffer.NNLargest = 0;
      pPortCnt->LongBufMon.Buffer.Smallest  = 0;
      pPortCnt->LongBufMon.Buffer.Avg       = 0;
      break;
    //============================================================
    case CTP_PORT_CMD_START:
      PRTSP(GEN,STARTING,SccBuf);
      //----- Get SCC static status for nss.pSerDev -----
      status = ioc_priv(SccBuf,SCC_GET_STATIC_STAT,&nss);
      BAILTESTF(status,Cant IOCTL scc);

      if( !(HAIRPIN(Card,pNum)) && (pPortSt->Diagnostics == NO) ) {
	int	hdr_size = ctp_hdr_size(Card,pNum);
	//--- Reset RtStaleCntr
	pPortIntSt->RtStaleCnt = 0;
	//--- Setup hard headers.
	ncmd.CmdType = SCC_CMD_RT_LOOKUP;
	ncmd.CmdObj2 = 0;
	ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd);
	//--- Check for failure returned
	// TODO we probably need to move this to ctp_route_chk function
	// For unidirectional destination, we don't need hardware header since
	// we are not sending data out of egress device
	if((UNI_DIR_DST(Card,pNum)) &&(ncmd.CmdObj==1)) {PRTDVP(EVE, Route lookup return, ncmd.CmdObj);}
	else {BAILTESTF(ncmd.CmdObj, Route lookup failed);}

	//--- Check for NULL/NONE ncmd.CmdObj5 (dev name).
	if( (ncmd.CmdObj5 == NULL) || (ncmd.CmdObj5 == NULL) ) { return FAILURE; }
	sprintf(pPortIntSt->NetDev,"%s",ncmd.CmdObj5);
	PRTSP(EVE,START: Got dev name from rt lookup,pPortIntSt->NetDev);
	PRTDVP(EVE,START: Got mtu of egress device,ncmd.CmdObj4);
	if( ncmd.CmdObj4 < (pPortIntSt->loc_pkt_size + hdr_size) ) {
	  sprintf(PrtBuf,"Problem with port start pkt_size (%d) + hdr size (%d) > mtu (%d) of egress dev %s",
	      pPortIntSt->loc_pkt_size, hdr_size, (int)ncmd.CmdObj4, pPortIntSt->NetDev);
	  PRTSP(MIN,,PrtBuf );
	  return(BAD_MTU);
	}
	if( !UNI_DIR_DST(Card,pNum) &&
	     (strncmp(pPortIntSt->NetDev, "scc",3) != 0) ) {
	  BAILTESTm(ncmd.CmdObj,Route lookup failed- dont know how to get to remote);
	}
	PRTSP(EVE,Starting port with netdev,pPortIntSt->NetDev);

#ifndef DBG_NO_ETH_IOCTL
	if( !strncmp(pPortIntSt->NetDev,"eth",3) ) {	// Dont do on PBS!
	  //--- Setup ETH driver ---
	  // Be extremely careful here, since EthBuf is only used to ioctrol ethernet
	  // driver and in VLAN case we don't want to ioctrol VLAN interface, in
	  // stead, the iocontrol still goes to physical interface. This way it will
	  // avoid io control failure.
	  if(strlen(pPortIntSt->NetDev) > 5) {
	    sscanf(pPortIntSt->NetDev, "%4s", EthBuf);
	  } else {
	    sprintf(EthBuf, "%s", pPortIntSt->NetDev);
	  }
	  erc.port = pPortIntSt->LocAdCid.Cid;
	  status = ioc_priv(EthBuf,ETH_GET_RUNTIME_CFG,&erc);
	  BAILTESTF(status,Cant IOCTL eth);
	  erc.eth_loop	= pPortSt->EthLoop;
	  if( IPT(Card,pNum) ) { erc.IsDrDrv 	= 0; }
	  else { erc.IsDrDrv 	= 1; }
	  erc.protocol	= pSysInfo->protocol;
	  erc.pSerDev	= (struct net_device *)nss.pSerDev;	// for erc.port
	  erc.SendNrzPkts	= NO;
	  erc.RcvNrzPkts	= NO;		//TODO Not used by ethernet driver!
	  if( !SAToP(Card,pNum) ) status = ioc_priv(EthBuf,ETH_SET_RUNTIME_CFG,&erc);
	  BAILTESTF(status,Cant IOCTL eth);
	  //--- Only set eth SendNrzPkts/RcvNrzPkts to YES for direct drive
	  if( !(IPT(Card,pNum)) ) {
	    //--- Start ETH driver ---
	    erc.SendNrzPkts	= YES;
	    erc.RcvNrzPkts	= YES;		//TODO Not used by ethernet driver!
	    if( UNI_DIR_SRC(Card,pNum) ) { erc.SendNrzPkts = NO; }
	    if( !SAToP(Card,pNum) ) status = ioc_priv(EthBuf,ETH_SET_RUNTIME_CFG,&erc);
	    BAILTESTF(status,Cant IOCTL eth);
	  }
	}
#endif //DBG_NO_ETH_IOCTL

      }
      //----- Get SCC runtime cfg ---
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      //--- Now start sending pkts!
      nrc.nrz_loop	= pPortSt->NrzLoop;
      if( FRAC_T1E1(Card, pNum) ) {
	pPortIntSt->FracFlags = ctp_get_frac_flags(Card, pNum);	// Qry & store flags.
	nrc.SendNrzPkts = (pPortIntSt->FracFlags & CTP_FT1_FLAG_LOF_NB) ? NO : YES;
      } else {
	nrc.SendNrzPkts	= YES;
      }
      nrc.RcvNrzPkts	= YES;
      if( UNI_DIR_DST(Card,pNum) ) { nrc.SendNrzPkts = NO; }
      if( UNI_DIR_SRC(Card,pNum) ) { nrc.RcvNrzPkts  = NO; }
      sprintf(PrtBuf,"Setting SendNrzPkts = %s, RcvNrzPkts = %s\n",
	  nrc.SendNrzPkts ? "YES" : "NO", nrc.RcvNrzPkts ? "YES" : "NO" );
      PRTSP(GEN,,PrtBuf);
      status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc 1);
      break;
    //============================================================
    case CTP_PORT_CMD_STOP:
      PRTSP(GN2,STOPPING,SccBuf);
#ifndef DBG_NO_ETH_IOCTL
      if( !strncmp(pPortIntSt->NetDev,"eth",3) ) {	// Dont do on PBS!
	if( (!(HAIRPIN(Card,pNum))) &&
	    (strcmp(&pPortIntSt->NetDev[0],"NONE") != 0 ) &&
	    (pPortSt->Diagnostics == NO) ) {
	  //--- stop processing NRZ packets in eth driver ---
            //Aricent PR 830151 fix - Do not IOCTL on vlan ports
            if(strlen(pPortIntSt->NetDev) > 5) {
               sscanf(pPortIntSt->NetDev, "%4s", EthBuf);
            } else {
               sprintf(EthBuf, "%s", pPortIntSt->NetDev);
            }
	  erc.port = pPortIntSt->LocAdCid.Cid;
	  status = ioc_priv(EthBuf,ETH_GET_RUNTIME_CFG,&erc);
	  BAILTESTF(status,Cant IOCTL eth);
	  erc.SendNrzPkts	= NO;
	  erc.RcvNrzPkts	= NO;
	  erc.IsDrDrv     = 0;
	  if( !SAToP(Card,pNum) ) status = ioc_priv(EthBuf,ETH_SET_RUNTIME_CFG,&erc);
	  BAILTESTF(status,Cant IOCTL eth);
	}
      }
#endif //DBG_NO_ETH_IOCTL
      //--- stop processing NRZ packets in ser driver ---
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      nrc.SendNrzPkts	= NO;
      nrc.RcvNrzPkts	= NO;
      status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      break;
    //============================================================
    case CTP_PORT_CMD_BLOCK_TX_PKTS:
      PRTSP(GEN,BLOCKING TX PKTS,SccBuf);
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      nrc.RcvNrzPkts	= NO;
      status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      break;
    //============================================================
    case CTP_PORT_CMD_UNBLOCK_TX_PKTS:
      PRTSP(GN3,UNBLOCKING TX PKTS,SccBuf);
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      nrc.RcvNrzPkts	= YES;
      status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      break;
    //============================================================
    case CTP_PORT_CMD_BLOCK_RX_PKTS:
      PRTSP(GEN,BLOCKING RX PKTS,SccBuf);
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      nrc.SendNrzPkts	= NO;
      status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      break;
    //============================================================
    case CTP_PORT_CMD_UNBLOCK_RX_PKTS:
      PRTSP(GN2,UNBLOCKING RX PKTS,SccBuf);
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      nrc.SendNrzPkts	= YES;
      status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      break;
    //============================================================
    case CTP_PORT_CMD_PROC_SER_LOOP:
      if(IS_T1E1(Card)) {
	if(IS_ABRG(Card)) pPortSt->SerLoop = CTP_SER_LOOP_TO_NET;	// PR 1565597 Always looped ToNet
	ctp_proc_t1_loop(Card,pNum);
      } else {
        ctp_proc_ser_loop(Card,pNum);
      }
      break;
    //============================================================
    case CTP_PORT_CMD_PROC_BERT:
      if( !PBS(Card,pNum) && !FRAC_T1E1(Card, pNum) ) {
        // Aricent PR 880784 fix
	if(ctp_bndl_type_wp(Card, pNum)) {
	  // Don't program for serial CESoPSN bundle
	  if(IS_T1E1(Card))	ctp_proc_t1_bert( Card, pNum );
	  else			ctp_proc_bert_cfg( Card, pNum );
	}
	else			ctp_proc_bert_cfg( Card, pNum );
      }
      break;
    //============================================================
    case CTP_PORT_CMD_PKT_LOOP_SER:
#ifndef DBG_NO_ETH_IOCTL
      if( !strncmp(pPortIntSt->NetDev,"eth",3) ) {	// Dont do on PBS!
	PRTSP(GEN,Looping SCC and ETH,SccBuf);
	//--- Stop sending packets from eth ---
	sprintf(EthBuf, "%s", pPortIntSt->NetDev);
	erc.port = pPortIntSt->LocAdCid.Cid;
	status = ioc_priv(EthBuf,ETH_GET_RUNTIME_CFG,&erc);
	BAILTESTF(status,Cant IOCTL eth);
	if(erc.eth_loop == NO) {
	  erc.SendNrzPkts	= NO;
	  if( !SAToP(Card,pNum) ) status = ioc_priv(EthBuf,ETH_SET_RUNTIME_CFG,&erc);
	  BAILTESTF(status,Cant IOCTL eth);
	}
      }
#endif //DBG_NO_ETH_IOCTL
      //--- ser driver loops pkts back to self ---
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      nrc.nrz_loop 	= YES;
      status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      break;
    //============================================================
    case CTP_PORT_CMD_PKT_LOOP_ETH:
      PRTSP(GEN,Looping SCC and ETH,SccBuf);
      //--- Stop sending packets from ser ---
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      if(nrc.nrz_loop == NO) {
	nrc.SendNrzPkts	= NO;
	status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
	BAILTESTF(status,Cant IOCTL scc);
      }
#ifndef DBG_NO_ETH_IOCTL
      if( !strncmp(pPortIntSt->NetDev,"eth",3) ) {	// Dont do on PBS!
	//--- eth driver loops pkts back to LAN ---
	sprintf(EthBuf, "%s", pPortIntSt->NetDev);
	erc.port = pPortIntSt->LocAdCid.Cid;
	status = ioc_priv(EthBuf,ETH_GET_RUNTIME_CFG,&erc);
	BAILTESTF(status,Cant IOCTL eth);
	erc.eth_loop	= YES;
	if( !SAToP(Card,pNum) ) status = ioc_priv(EthBuf,ETH_SET_RUNTIME_CFG,&erc);
	BAILTESTF(status,Cant IOCTL eth);
      }
#endif //DBG_NO_ETH_IOCTL
      break;
    //============================================================
    case CTP_PORT_CMD_PKT_UNLOOP_SER:
      PRTSP(GEN,Looping SCC and ETH,SccBuf);
      //--- ser driver sends pkts to eth ---
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      nrc.nrz_loop 	= NO;
      status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
#ifndef DBG_NO_ETH_IOCTL
      if( !strncmp(pPortIntSt->NetDev,"eth",3) ) {	// Dont do on PBS!
	//--- Start sending packets from eth ---
	sprintf(EthBuf, "%s", pPortIntSt->NetDev);
	erc.port = pPortIntSt->LocAdCid.Cid;
	status = ioc_priv(EthBuf,ETH_GET_RUNTIME_CFG,&erc);
	BAILTESTF(status,Cant IOCTL eth);
	if(erc.eth_loop == NO) {
	  erc.SendNrzPkts	= YES;
	  if( !SAToP(Card,pNum) ) status = ioc_priv(EthBuf,ETH_SET_RUNTIME_CFG,&erc);
	  BAILTESTF(status,Cant IOCTL eth);
	}
      }
#endif //DBG_NO_ETH_IOCTL
      break;
    //============================================================
    case CTP_PORT_CMD_PKT_UNLOOP_ETH:
      PRTSP(GEN,Looping SCC and ETH,SccBuf);
#ifndef DBG_NO_ETH_IOCTL
      if( !strncmp(pPortIntSt->NetDev,"eth",3) ) {	// Dont do on PBS!
	//--- eth driver sends pkts to ser ---
	sprintf(EthBuf, "%s", pPortIntSt->NetDev);
	erc.port = pPortIntSt->LocAdCid.Cid;
	status = ioc_priv(EthBuf,ETH_GET_RUNTIME_CFG,&erc);
	BAILTESTF(status,Cant IOCTL eth);
	erc.eth_loop	= NO;
	if( !SAToP(Card,pNum) ) status = ioc_priv(EthBuf,ETH_SET_RUNTIME_CFG,&erc);
	BAILTESTF(status,Cant IOCTL eth);
      }
#endif //DBG_NO_ETH_IOCTL
      //--- Start sending packets from ser ---
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      if(nrc.nrz_loop == NO) {
	nrc.SendNrzPkts	= YES;
	status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
	BAILTESTF(status,Cant IOCTL scc);
      }
      break;
    //============================================================
    case CTP_PORT_CMD_PKT_LOOP_BOTH:
      //--- ser driver loops pkts back to self ---
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      nrc.nrz_loop 	= YES;
      status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
#ifndef DBG_NO_ETH_IOCTL
      if( !strncmp(pPortIntSt->NetDev,"eth",3) ) {	// Dont do on PBS!
	//--- eth driver loops pkts back to LAN ---
	sprintf(EthBuf, "%s", pPortIntSt->NetDev);
	erc.port = pPortIntSt->LocAdCid.Cid;
	status = ioc_priv(EthBuf,ETH_GET_RUNTIME_CFG,&erc);
	BAILTESTF(status,Cant IOCTL eth);
	erc.eth_loop	= YES;
	if( !SAToP(Card,pNum) ) status = ioc_priv(EthBuf,ETH_SET_RUNTIME_CFG,&erc);
	BAILTESTF(status,Cant IOCTL eth);
      }
#endif //DBG_NO_ETH_IOCTL
      break;
    //============================================================
    case CTP_PORT_CMD_PKT_UNLOOP_BOTH:
#ifndef DBG_NO_ETH_IOCTL
      if( !strncmp(pPortIntSt->NetDev,"eth",3) ) {	// Dont do on PBS!
	//--- unloop eth driver ---
	sprintf(EthBuf, "%s", pPortIntSt->NetDev);
	erc.port = pPortIntSt->LocAdCid.Cid;
	status = ioc_priv(EthBuf,ETH_GET_RUNTIME_CFG,&erc);
	BAILTESTF(status,Cant IOCTL eth);
	erc.eth_loop	= YES;
	if( !SAToP(Card,pNum) ) status = ioc_priv(EthBuf,ETH_SET_RUNTIME_CFG,&erc);
	BAILTESTF(status,Cant IOCTL eth);
      }
#endif //DBG_NO_ETH_IOCTL
      //--- unloop nrz driver ---
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      nrc.nrz_loop 	= YES;
      status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      break;
    //============================================================
    case CTP_PORT_CMD_CFG_CLKS:
      PRTSP(GEN,Configuring clocks,SccBuf);

      // We also need to set the DDS value in the Port state so that we can
      // make adjustments if adaptive clocking is enabled.
      if( pDbP->dds_src != CTP_DDS_SRC_AUTOBAUD ) {
	pPortSt->AdapDdsValue      = pDbP->dds_freq;
	pPortIntSt->AdapDdsNominal = pDbP->dds_freq;
	PRTU16P(GEN,Just set Adap Dds Value, pPortSt->AdapDdsValue);

	if( pPortSt->NetRefAdapBndl ) { 
	  //--- On ctp restart, Ctp.Node[0].Calibration gets set after
	  //    bundles are activated, so if we need it & it is bad, we 
	  //    read it here.
	  if( Ctp.Node[0].Calibration = ~0 ) ctp_get_pll_cal(0);

	  pNRefs->AdapPllValue       = Ctp.Node[0].Calibration;
	  pPortIntSt->AdapPllNominal = Ctp.Node[0].Calibration;
	  ctp_set_pll_fixed( pNRefs->AdapPllValue, 1);
	  PRTU16P(GEN,Just set Adap Pll Value, pNRefs->AdapPllValue);
	}
      }

      #ifdef WRL
      PRTU8P(GN1,Setting  dds_div,pDbP->dds_div);
      PRTU8P(GN1,Setting   tx_sel, pDbP->tx_sel);
      #else
      PRTU8P(GN1,Setting  dds_div,(u8)pDbP->dds_div);
      PRTU8P(GN1,Setting   tx_sel,(u8)pDbP->tx_sel);
      #endif
      PRTDVP(GN1,Setting dds_freq,pDbP->dds_freq);
      fpga_clr_fcfg();
      if( !PBS(Card,pNum) ) {
	fpga_set_buf_cntr_clk(pNum, pPortIntSt->CntrSel );
	PRTDVP(GN1,Just set buf free cntr source to, pPortIntSt->CntrSel );
      }
     if(!IS_T1E1(Card) ) { //Aricent PR 947222 and 1198066 Fix
      fpga_set_rx_if_clk(   pNum, ((u32)pDbP->st_sel & 0x3) );
      fpga_set_rx_fifo_clk( pNum, ((u32)pDbP->rf_sel & 0x3) );
      }
      // Newer T1E1 FPGAs support only DDS and TT (MSB of [1:0] select)
      // PR 1037209 - start
      if(IS_T1E1(Card)) {
        fpga_set_rx_scc_clk(  pNum, ((u32)pDbP->rx_sel & 0x2) );  
	fpga_set_tx_scc_clk(  pNum, ((u32)pDbP->tx_sel & 0x2) ); 
      } else {
        fpga_set_rx_scc_clk(  pNum, ((u32)pDbP->rx_sel & 0x3) );
	fpga_set_tx_scc_clk(  pNum, ((u32)pDbP->tx_sel & 0x3) ); 
      }
      // PR 1037209 - end
     if(!IS_T1E1(Card)) //Aricent PR 947222 and 1198066 Fix
         fpga_set_tx_if_clk(   pNum, ((u32)pDbP->rt_sel & 0x3) );
      if( pDbP->CanClkCfg == CTP_CLKCFG_TDM_TDC ) {
       if(!IS_T1E1(Card)) //Aricent PR 947222 and 1198066 Fix
	fpga_set_tdc_insert(pNum,(u32)1);
      }

      if( pDbP->dds_src == CTP_DDS_SRC_AUTOBAUD ) {
	fpga_set_dds_freq(  Card, pNum, (u32)pPortIntSt->AdapDdsNominal);
	if(!IS_T1E1(Card)) fpga_set_dds_div(   pNum, (u32)0); // Aricent PR 1198066 Fix 
      } else {
	fpga_set_dds_freq(  Card, pNum, (u32)pDbP->dds_freq );
        if(!IS_T1E1(Card)) //Aricent PR 947222 and 1198066 Fix
	 fpga_set_dds_div(   pNum, ((u32)pDbP->dds_div & 0xf) );
      }
      PRTV(GN2, dds_freq, pDbP->dds_freq);
      PRTV(GN2, dds_div, pDbP->dds_div);
      if(!IS_T1E1(Card)) { //Aricent PR 947222, 1010381 and 1198066 Fix
       fpga_set_div_src(     pNum, ((u32)pDbP->div_src & 0x3) );
       fpga_set_div(         pNum, ((u32)pDbP->div_val & 0xffff) );  // Aricent PR-1010381 Fix 
       fpga_set_sig_reg(     pNum, 0);	// Clear for config below
      }

      // Start fix PR 892644 and PR 909921      
      if( IS_SER(Card) && (!PBS(Card, pNum)) && (!SAToP(Card,pNum))) {
	int idle_val;
	switch ( bType ) {
	  case CTP_BNDL_TYPE_CTP: 
	    idle_val = Db.Bndl[bNum].Bndl.cp_bndl.pFFfill & 0x1; 
	    break;
	  case CTP_BNDL_TYPE_WP:  
	    idle_val = Db.Bndl[bNum].Bndl.wp_bndl.pFFfill & 0x1; 
	    break;
	  default:             
	    PRTDV(MIN,Illegal bundle type for idle val, bType); 
	    break;
	}
	fpga_set_tx_data_idle_val( pNum, idle_val );
      }
      // End fix PR 892644

      PRTP(FNC,About to program clks);
      fpga_send_fcfg(pPortSt->SccNum);

      PRTP(FNC,About to call ctp_cfg_if_mode);
      ctp_cfg_if_mode(Card,pNum,pDbP);

      // Here we set the initial value for the signaling outputs. Since
      // the driver is the one that ultimately controls the signaling
      // output (due to In Band signaling), we must tell the driver what
      // value we set the signals to. This IOCTL also has the side effect
      // of writing the signaling outputs to the interface.
      status = ioc_priv(SccBuf,SCC_GET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);
      ctp_gen_sigo_cfg( pDbP->Sig, &nrc.sig_out_cfg);
      status = ioc_priv(SccBuf,SCC_SET_RUNTIME_CFG,&nrc);
      BAILTESTF(status,Cant IOCTL scc);

      break;
    //============================================================
    default:
      PRTVP(MIN,Unexpected Cmd type,Cmd);
      break;
  }
  return(SUCCESS);
}

//==================================================================
// This routine deletes a port from the system. It removes the port from
// the remote nodes list of ports. If that was the only port on the nodes
// list, it removes the node from the node list and closes the OAM
// connection. The port driver is also shut down.
//==================================================================
int ctp_del_port( int Card, int pNum )
{
  struct acrndrv_command	 ncmd;
  CTP_PORT_STATE	*pPortSt = &Ctp.Card[Card].Port[pNum];
  CTP_PORT_INT_STATE	*pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
  FILE			*pBufFile = NULL;
  CTP_PORT_DBASE	*pDbP = &Db.Card[Card].Port[pNum];
  int			 satop = SAToP(Card,pNum);
  int			 cesopsn = ctp_bndl_type_wp(Card, pNum);
  int			 t1e1h110 = (IS_T1E1_2000(Card) && IS_H110(Card,pNum))?1:0;
  char			 SccBuf[40];
  FUNC_PRT(ctp_del_port, PF_PST, pNum);

  if( pPortSt->Diagnostics ) PRTP(GEN,ctp_del_port for Diagnostics);
  PRTP(GEN,Deleting port);
  if( pPortSt->Diagnostics == NO ) {
    // This port is not in diagnostics mode
    if( (pPortSt->Available) && (!t1e1h110) && // card is plugged in
	(!PBS(Card, pNum))) {	// ! SAToP bundle Aricent PR 1605449 fix
      ctp_discon_rem_node(&pPortIntSt->Conn);	// close OAM socket conn
      // If redundant port with S/W link enabled, close rdnt OAM socket conn
      if( pDbP->RdntConfig & CFG_RDNT_MODE_MASK ) {
	if( pDbP->RdntConfig & CFG_RDNT_FLAG_SW_LINK ) {
	  ctp_discon_rem_node(&pPortIntSt->RdntConn);
	}
      }
    }
  } else {
    PRTP(GEN,Deleting diagnostic port);
  }

  if(pPortSt->NetRefAdapBndl == 1 ) {
    PRTP(EVE,Disabling adaptive bundle used by NetRef);
    pPortSt->NetRefAdapBndl = 0;
    pNRefs->State = CTP_NETREF_STATE_DIS;
  }

  if( IS_H110(Card, pNum)) {
      ctp_add_t1e1_h110(pDbP, pPortSt, 0);
   }
  // Send command to winpath to delete port
  else if(cesopsn){  // Aricent PR 880784 fix
    if(IS_T1E1(Card)) ctp_add_t1e1_h110(pDbP, pPortSt, 0);
  }

// if(!Db.Card[Card].all_h110_cesop) {//Aricent PR-947222
  ctp_port_state_machine(Card,pNum,CTP_PORT_EVENT_DB_DISABLED,NULL); // bring port down
  ctp_init_port_state(Card,pNum,-1);	//clr out runtime info

  //--- Init port regs (Mainly to turn off T1E1 port LEDs)
  ncmd.CmdType = SCC_CMD_INIT_PORT_REGS;
  ncmd.CmdObj = pNum;
  sprintf(SccBuf,"scc%d", pPortSt->SccNum);
  if( ioc_priv(SccBuf,SCC_IOCTL_CMD,&ncmd) ) {
    PRTP(MIN, Cant IOCTL scc to init port regs);
  }

  // We want to make sure serial if is tristated when bundle is disabled
  if( IS_SER(Card) ) {
    fpga_clr_fcfg();
    fpga_set_sipex_508( Card, pNum, (u32)IF_MODE_OFF); //CAP PR 1734636
    fpga_send_fcfg(pPortSt->SccNum);
  }

// }

  sprintf(pPortIntSt->NetDev, "NONE");

  return(SUCCESS);
}

//==================================================================
// This routine processes a runtime config message. Runtime configuration
// relates to items which are not saved in the database (i.e. loops).
// It fills the return
// message with the requested data and sends it on its way.
//==================================================================
int ctp_proc_msg_st_cfg( CTP_Q_MSG * pMsg )
{
  CTP_Q_MSG		 TMsg;
  unsigned int		 NrzLoop,EthLoop,SerLoop,TxBert,RxBert,BertPat;
  int			 Card, pNum, bNum;
  CTP_PORT_STATE	*pPortSt;
  CTP_BNDL_STATE	*pBndlSt;
  FUNC_PRT(ctp_proc_msg_st_cfg, PF_IPC, -1);
#ifdef DBG_MSG_QUEUE
  PRT(EVE,CTP processing runtime cfg message);
#endif

  ctp_copy_msg_hdr( pMsg, &TMsg );	// build header of response message

  switch(pMsg->CtpMsg.MsgType) {
    case CTPMSGTYPE_ST_CFG_PORT:
      Card = pMsg->CtpMsg.msg.StP.Card;
      pNum = pMsg->CtpMsg.msg.StP.pNum;
      pPortSt = &Ctp.Card[Card].Port[pNum];
      PRTP(GEN,Received ST_CFG_PORT msg);

      //PRT(OFF,=== Printing Current State);
      //util_prt_st_port(&Ctp.Port[Port]);
      //PRT(OFF,=== Printing New State from Msg);
      //util_prt_st_port(&pMsg->CtpMsg.msg.StP.St);

      //--- This is a message coming over from some menu task ---
      //--- Only deal with the runtime config parameters ---

      //--- First, save the current state of runtime config
      NrzLoop = pPortSt->NrzLoop;
      EthLoop = pPortSt->EthLoop;
      SerLoop = pPortSt->SerLoop;
      TxBert  = pPortSt->TxBert;
      RxBert  = pPortSt->RxBert;
      BertPat = pPortSt->BertPat;
      //--- Then, copy over the new state
      pPortSt->NrzLoop = pMsg->CtpMsg.msg.StP.St.NrzLoop;
      pPortSt->EthLoop = pMsg->CtpMsg.msg.StP.St.EthLoop;
      pPortSt->SerLoop = pMsg->CtpMsg.msg.StP.St.SerLoop;
      pPortSt->TxBert  = pMsg->CtpMsg.msg.StP.St.TxBert;
      pPortSt->RxBert  = pMsg->CtpMsg.msg.StP.St.RxBert;
      pPortSt->TxBertBndl  = pMsg->CtpMsg.msg.StP.St.TxBertBndl;
      pPortSt->RxBertBndl  = pMsg->CtpMsg.msg.StP.St.RxBertBndl;
      pPortSt->BertPat = pMsg->CtpMsg.msg.StP.St.BertPat;
      pPortSt->Diagnostics = pMsg->CtpMsg.msg.StP.St.Diagnostics;
      if( pPortSt->Diagnostics ) PRTP(GEN,CTPMSGTYPE_ST_CFG_PORT for Diagnostics);

      //=== Process Runtime State changes ===

      if(SerLoop != pPortSt->SerLoop) {
	PRTP(GEN,Processing serial loop change);
	ctp_port_state_machine(Card,pNum,CTP_PORT_EVENT_SER_LOOP_CHANGE,NULL);
      }

      if( ( BertPat != pPortSt->BertPat ) ||
	  ( TxBert  != pPortSt->TxBert ) ||
	  ( RxBert  != pPortSt->RxBert ) ) {
	//PRTDV(OFF,Processing BERT change for port,Port);
	ctp_port_state_machine(Card,pNum,CTP_PORT_EVENT_BERT_CHANGE,NULL);
      }

      ctp_send_msg( &TMsg );		// Send response message
      break;

    case CTPMSGTYPE_ST_CFG_BNDL:
      bNum = pMsg->CtpMsg.msg.StB.bNum;
      pBndlSt = &Ctp.Bndl[bNum];
      PRTB(GEN,Received ST_CFG_BNDL msg);
      if(Db.Bndl[bNum].Type != CTP_BNDL_TYPE_VC) {
      // Only VC bndls are not using the following setting.	      
        pBndlSt->Bndl.ctp.MissPktsForTrap = pMsg->CtpMsg.msg.StB.St.Bndl.ctp.MissPktsForTrap;
        pBndlSt->Bndl.ctp.LatePktsForTrap = pMsg->CtpMsg.msg.StB.St.Bndl.ctp.LatePktsForTrap;
      }	
      break;
    case CTPMSGTYPE_ST_CFG_NODE:
      PRT(GEN,Received ST_CFG_NODE msg);
      bcopy(&pMsg->CtpMsg.msg.StN.St,&Ctp.Node[0],sizeof(CTP_NODE_STATE));

      ctp_send_msg( &TMsg );		// Send response message
      break;

    default:
      PRTV(MIN,Unexpected message type,pMsg->CtpMsg.MsgType);
      TMsg.CtpMsg.Status = FAILURE;
      break;
  }
  return(TMsg.CtpMsg.Status);
}

//==================================================================
// This routine processes a Database query message. It fills the return
// message with the requested data and sends it on its way.
//==================================================================
int ctp_proc_msg_db_qry( CTP_Q_MSG * pMsg )
{
  CTP_Q_MSG		TMsg;
  int			Card, pNum;
  FUNC_PRT(ctp_proc_msg_db_qry, PF_IPC, -1);
#ifdef DBG_MSG_QUEUE
  PRT(EVE,CTP processing database qry message);
#endif

    ctp_copy_msg_hdr( pMsg, &TMsg );	// build header of response message

    switch(pMsg->CtpMsg.MsgType) {
      case CTPMSGTYPE_DB_QRY_PORT:
	Card = pMsg->CtpMsg.msg.DbP.Card;
	pNum = pMsg->CtpMsg.msg.DbP.pNum;
	PRTP(GEN,Received DB_QRY_PORT msg);
	if( Card > CTP_MAX_CARDS ) {
	  PRTDVP(MIN,Got CTP_MAX_CARDS < Passed card:,Card);
	  TMsg.CtpMsg.Status = FAILURE;
	}
	if( pNum > pSysInfo->Card[Card].PortsOnCard ) {
	  PRTDVP(GN1,Got pSysInfo->Card[Card].PortsOnCard < Passed pNum:,pNum);
	  TMsg.CtpMsg.Status = FAILURE;
	}
	bcopy(&Db.Card[Card].Port[pNum],&TMsg.CtpMsg.msg.DbP.Db,sizeof(CTP_PORT_DBASE));

	//PRT(DBG,=== Printing Dbase Element);
//	util_prt_db_port(&pDbP-> CTP_DBASE_VERSION);
	//PRT(DBG,=== Printing Dbase Element copied to Msg);
//	util_prt_db_port(&TMsg.CtpMsg.msg.DbP.Db, CTP_DBASE_VERSION);

	ctp_send_msg( &TMsg );
	break;

      case CTPMSGTYPE_DB_QRY_NODE:
	PRT(GEN,Received DB_QRY_NODE msg);
	bcopy(&Db.Node[0],&TMsg.CtpMsg.msg.DbN.Db,sizeof(CTP_NODE_DBASE));

	ctp_send_msg( &TMsg );
	break;
      case CTPMSGTYPE_DB_QRY_BNDL:
	{
	  int bNum  = pMsg->CtpMsg.msg.DbB.bNum & 0xff;
	  PRTB(GEN,Received DB_QRY_BNDL msg);
	  bcopy(&Db.Bndl[bNum], &TMsg.CtpMsg.msg.DbB, sizeof(CTP_BNDL_DBASE));
	  ctp_send_msg( &TMsg ); // send response as soon as we got the message
	}

	break;
      default:
	PRTV(MIN,Unexpected message type,pMsg->CtpMsg.MsgType);
	TMsg.CtpMsg.Status = FAILURE;
	break;
    }
  return(TMsg.CtpMsg.Status);
}

//==================================================================
// This routine flush buffer stats file
//==================================================================
void ctp_buf_stats_flush(int bNum)
{
  CTP_BNDL_STATE *pBndlSt = &Ctp.Bndl[bNum];
  FILE *pBufFile;
  char Buf[80];
  // Aricent PR 1343796 fix - Start
#ifdef WRL
  struct stat  FileStat;
  mode_t mod=0x81ff;
#endif
  // Aricent PR 1343796 fix - End
  FUNC_PRT(ctp_buf_stats_flush, PF_IPC, -1);

  //----- Create current file name string
  sprintf(Buf,"%s/%s%d%c",CTP_DIR,CTP_BUF_STATS_FILE,bNum,
          pBndlSt->BufStatsPingPongChar);
  pBufFile = (FILE *)pBndlSt->pBufStatsFile;
  if( pBufFile != NULL ) {
  //----- Close file to flush data to it
    if( fclose(pBufFile) == 0 ) {
    //----- Now, reopen it for appending
      pBufFile = fopen(Buf,"a");
      // Aricent PR 1343796 fix - Start
#ifdef WRL
      if( stat(Buf, &FileStat) != -1 ) {
	if ( FileStat.st_mode != 0x81ff ) { // if not 0777 mode
	  chmod (Buf,mod);
	}
      }
#endif
      // Aricent PR 1343796 fix - End
      if( pBufFile != NULL ) {
	pBndlSt->pBufStatsFile = (u64)pBufFile; //PR-1853239 // PR 1851876
        PRTS(EVE,Stats file flushed,Buf);
      } else { PRTB(MIN,Error reopening stats file); }
    } else { PRTB(MIN,Error closing stats file); }
  } else { PRTB(MIN,no stats file currently open); }
}

