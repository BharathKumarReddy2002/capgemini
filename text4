//--------------------------------------------------------------------------
// This routine is executed when a timer message arrives from the Timer
// task. This is usually once every second. Local Node state machines are
// sent timer events for updating their states and OAM messages are sent to
// all remote nodes.
//--------------------------------------------------------------------------
int ctp_proc_msg_timer( CTP_Q_MSG * pMsg )
{
  char			 SccBuf[100],Buf[100],PrtBuf[100];
  CTP_Q_MSG		 TMsg;
  CTP_PORT_STATE	*pPortSt;
  CTP_PORT_INT_STATE	*pPortIntSt;
  CTP_PORT_CNTRS	*pPortCnt;
  int			 Card, pNum, bNum;
  int			 status,index,t1AlarmTrapFlag=0;
  //int			 RxFifoFlt;
  u32			 BertSync,BertSyncLoss,BertErrCnt;
  //int			 Pps;
  int			 SccNum;
  double		 TtFreq;
  u32			 Acc, Freq, reqAcc;
  struct timeval	 now;
  struct acrndrv_runtime_stat	RStat;
  struct acrndrv_runtime_cfg	nrc;
  // Aricent PR 1110275 fix - Start
  int starve_flag = 0;
  int n_indx = 0;
  int mstrs_count = 0;
  int pkt_recv = 0;     //Aricent PR 1141812 fix
#ifdef VCTP
  int c_idx;
#endif
  // Aricent PR 1110275 fix - End
  // Aricent PR 1362733 fix - Start
  FILE *fptr = NULL;
  int Status = 0, is_snmp = 0;
  // Aricent PR 1362733 fix - End
#ifdef DBG_PROC_MSG_TIMER
  struct timeval	 t_start, t_end;
  int	 diff_msec;
#endif	//DBG_PROC_MSG_TIMER
  FUNC_PRT(ctp_proc_msg_timer, PF_IPC, -1);
#ifdef DBG_MSG_QUEUE
  PRT(EVE,CTP processing timer message);
#endif

#ifdef DBG_PROC_MSG_TIMER
  gettimeofday (&t_start, NULL);
  while (t_start.tv_usec < 0)
  {
    t_start.tv_usec += 1000000;
    t_start.tv_sec--;
  }
  while (t_start.tv_usec >= 1000000)
  {
    t_start.tv_usec -= 1000000;
    t_start.tv_sec++;
  }
#endif	//DBG_PROC_MSG_TIMER

  ctp_proc_long_timer();
  // Aricent PR 1362733 fix - Start
  if((fptr = fopen("/acorn/tmp/snmp_cfg", "r")) != NULL){
    fscanf(fptr, "%d", &is_snmp);
    fclose(fptr);
  }
  if (is_snmp == 1) {
    Status = ctp_update_trap_info();
    if (Status) {
      PRT(MIN,Failed to update internal SNMP trap info from file);
    } else {
      PRT(MIN,Updated internal SNMP trap info from file);
      acorn_system("echo 0 > /acorn/tmp/snmp_cfg");
    }
  }
  // Aricent PR 1362733 fix - End  
  
  //PR :1863969 Fix start
  if(pSysInfo->SysType == SYS_TYPE_CTP_150 ||  pSysInfo->SysType == SYS_SUBTYPE_CTP_150 ) {
    ctp151_proc_ps_fans();
  }
  //PR :1863969 Fix end

  if(pSysInfo->SysType == SYS_TYPE_CTP_2000) {
    ctp2000_proc_ps_fans();	  
  } 
  ctp_trans_trap();
  CTP_NREFS_STATE *__old_pNRefs = pNRefs; //PR-1874138
  //added ctp_get_nrefs_info() to populate pNRefs as its getting corrupted
  ctp_get_nrefs_info(); //PR-1874138
//--Start Aricent PR-595515 "Enhance NetRef to include "starvation" state"
  // Aricent PR 1110275 fix - Start
  pNRefs->NetRef_time_cnt++;
  for(n_indx = 0; n_indx < CTP_MAX_NETREF_MSTRS; n_indx++) {
    if( pNRefs->AssignedPriority[n_indx] == 1) {    /* Aricent PR 1117979, 1133355 Fix */
      if( (pNRefs->State  ==  CTP_NETREF_STATE_MNTN )&&
               (pNRefs->NetRef_time_cnt >= NETREF_STRV_WAIT_SEC ) &&
           (pNRefs->Type  ==  CTP_NETREF_TYPE_SLV )){
              pNRefs->NetRef_old_state = CTP_NETREF_STATE_MNTN;
              pNRefs->State = CTP_NETREF_STATE_STRV;
              PRT(MIN,NetRef state transition: maintain -> starvation);
              starve_flag = 1;
      }
      if( (pNRefs->State  ==  CTP_NETREF_STATE_AGGR )&&
               (pNRefs->NetRef_time_cnt >= NETREF_STRV_WAIT_SEC ) &&
           (pNRefs->Type  ==  CTP_NETREF_TYPE_SLV )){
              pNRefs->NetRef_old_state = CTP_NETREF_STATE_AGGR;
              pNRefs->State = CTP_NETREF_STATE_STRV;
              PRT(MIN,NetRef state transition: aggressive -> starvation);
              starve_flag = 1;
      }
    }
 //--End Aricent PR-595515 "Enhance NetRef to include "starvation" state"
    if( (pNRefs->State  ==  CTP_NETREF_STATE_WAIT )&&
            (pNRefs->NetRef_time_cnt >= NETREF_WAIT_SEC ) &&
           (pNRefs->Type  ==  CTP_NETREF_TYPE_SLV) && (pNRefs->recv_pkt[n_indx] == 1) ) {    //Aricent PR 1141812 fix
      if (pNRefs->Node[n_indx].v4 != (u32)ntohl(inet_addr("127.0.0.1"))) {
        starve_flag = 1;
        break;
      }
    }
  }
  n_indx = 0;
  if ( starve_flag ) {
    while (n_indx < CTP_MAX_NETREF_MSTRS) {
      if (pNRefs->Node[n_indx].v4 != (u32)ntohl(inet_addr("127.0.0.1"))) {
        mstrs_count++;
      }
      //Aricent PR 1141812 fix - Start
      if ((pNRefs->recv_pkt[n_indx] == 1) && (pNRefs->AssignedPriority[n_indx] != 1))
        pkt_recv = 1;
      //Aricent PR 1141812 fix - End
      n_indx++;
    }
    n_indx = 0;
    if (mstrs_count > 1 && pkt_recv == 1)    //Aricent PR 1141812 fix
      PRT(MIN,Primary not good..switching to next highest priority primary);
    for(n_indx = 0; n_indx < mstrs_count; n_indx++) {
      if ((pNRefs->Node[n_indx].v4 != (u32)ntohl(inet_addr("127.0.0.1")))
       && (pkt_recv == 1)) {    //Aricent PR 1141812 fix
        /* Aricent PR 1117979, 1133355 Fix */
        if (pNRefs->AssignedPriority[n_indx] == 1) {
          pNRefs->AssignedPriority[n_indx] = mstrs_count;
          PRTDV(DBG,Assigning priority,mstrs_count);
        } else if (pNRefs->AssignedPriority[n_indx] == 2) {
          pNRefs->AssignedPriority[n_indx] = 1;
          PRT(DBG,Assigning priority one);
        } else if (pNRefs->AssignedPriority[n_indx] == 3) {
          pNRefs->AssignedPriority[n_indx] = 2;
          PRT(DBG,Assigning priority two);
        } else {
          pNRefs->AssignedPriority[n_indx] = 3;
          PRT(DBG,Assigning priority three);
        }
        pNRefs->recv_pkt[n_indx] = 0;    //Aricent PR 1141812 fix
      } else {
        PRT(DBG,No ip assigned so no switching);
      }
    }
/* Aricent PR 1534914 start */
    struct nref_slave_info nref_data;
    for(n_indx = 0; n_indx < CTP_MAX_NETREF_MSTRS; n_indx++) {
      if(pNRefs->AssignedPriority[n_indx] == 1) {
        break;
      }
    }
    if (n_indx < CTP_MAX_NETREF_MSTRS) { // prio 1 is not available
      nref_data.nref_master_prio_one_ip = pNRefs->Node[n_indx].v4;
      nref_data.nref_slave_en = 1;
    }
    else {
      nref_data.nref_master_prio_one_ip = (u32)ntohl(inet_addr("127.0.0.1"));
      nref_data.nref_slave_en = 0;
    }
    ioc_priv("scc0",SCC_CFG_NETREF_SLAVE,&nref_data);
/* Aricent PR 1534914 end */
  }
  starve_flag = 0;
  n_indx = 0;
  mstrs_count = 0;
  pkt_recv = 0;    //Aricent PR 1141812 fix
  // Aricent PR 1110275 fix - End
  memset(&TMsg, 0, sizeof(CTP_Q_MSG));
  //--- set static common fields in rem_oam message to be transmitted ---
  //--- NOTE: This is NOT a response message to the timer daemon!!!
  TMsg.CtpMsg.MsgType		= CTPMSGTYPE_REM_OAM;
  TMsg.CtpMsg.OrigTask		= CTP_TASK;
  TMsg.CtpMsg.OrigTaskQid	= Ctp.Task[CTP_TASK].Qid;
  TMsg.CtpMsg.OrigNode		= *((CTP_NODE *)&Ctp.LocNode);
  TMsg.CtpMsg.DestTask		= CTP_TASK;
  TMsg.CtpMsg.DestTaskQid	= 0;		// not used
  //TMsg.CtpMsg.DestNode 	= (set below)
  TMsg.CtpMsg.SubType		= RESPONSE;
  TMsg.CtpMsg.Status		= SUCCESS;

  //PRT(FAT,Manual program crash);
  //StayInProgram = NO;

  //--------------------------------------------------
  //----- process each vc/wp bundle on this node -----
  //--------------------------------------------------
  for(bNum=0; bNum<CTP_MAX_BNDLS; bNum++) {
    CTP_BNDL_STATE * pBndlSt = &Ctp.Bndl[bNum];
    if(pBndlSt->State != CTP_PORT_STATE_NOT_CFG) {
      switch(Db.Bndl[bNum].Type) {
        case CTP_BNDL_TYPE_VC:
          ctp_vc_proc_bndl(bNum);
	 // Start Aricent PR-846282 
	  ctp_proc_bndl_buf(bNum); /*here calculating 1 min buffer stats*/ 
	  break;
	// End Aricent PR-846282
        case CTP_BNDL_TYPE_WP:
	    if((pBndlSt->State == CTP_PORT_STATE_IN_SYNC) ||
	      (pBndlSt->State == CTP_PORT_STATE_RUNNING))
            ctp_proc_buff_mon(bNum);
	   // Aricent PR-947222 Start 
	   Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
	   if(Db.Card[Card].all_h110_cesop) {
            // Aricent PR-996102 Start
            if(pBndlSt->State == CTP_PORT_STATE_RUNNING &&
               pBndlSt->Bndl.ctp.activeBundle == 1 )      // Aricent PR 1009496 Fix 
            // Aricent PR-996102 End 
            ctp_vc_proc_bndl(bNum);
	   }
	   // Aricent PR-947222 End 
	   ctp_bndl_state_machine(bNum,CTP_PORT_EVENT_TIMER); // Aricent PR-799637
           break;

	case CTP_BNDL_TYPE_SO:  
	case CTP_BNDL_TYPE_CTP:  
	{
	  Card = util_bndl_src_card(0, &Db.Bndl[bNum]);
	  pNum = util_bndl_src_pNum(0, &Db.Bndl[bNum]);
          pPortSt = &Ctp.Card[Card].Port[pNum];
	  if( (pPortSt->State == CTP_PORT_STATE_IN_SYNC) ||
	      (pPortSt->State == CTP_PORT_STATE_RUNNING) ) {
	    ctp_proc_buff_mon(bNum);
	  }
	  // Currently copy whatever get from bundle counters to port, 
	  // since port state machine uses it.
	  bcopy(&Ctp.Bndl_cnt[bNum].Bndl.ctp, 
	    &Ctp.Card[Card].Cntr[pNum].Current, sizeof(CtpBndlCntrs));  
	}    
	  break;  
        default:
          break;  
      }
    }
  }
  adt_check_state();

  //------------------------------------------
  //----- process each port on this node -----
  //------------------------------------------
  for(Card=0;Card<CTP_MAX_CARDS;Card++) {
// Aggregate t1 los/lof alarms per card and be able to tell the status change	  
    u8 t1LosPortBitMap = Ctp.Card[Card].t1LosPortBitMap;
    u8 t1LofPortBitMap = Ctp.Card[Card].t1LofPortBitMap;
    if(!SCC_CARD(Card)) continue;
    Ctp.Card[Card].t1LosPortBitMap = 0;	  
    Ctp.Card[Card].t1LofPortBitMap = 0;	  
    for(pNum=0;pNum<pSysInfo->Card[Card].PortsOnCard;pNum++) {
      CTP_PORT_DBASE *pDbP = (CTP_PORT_DBASE *)&Db.Card[Card].Port[pNum];
      pPortIntSt = &Ctp.Card[Card].PortInt[pNum];
      pPortSt = &Ctp.Card[Card].Port[pNum];
      pPortCnt = &Ctp.Card[Card].Cntr[pNum];
      TMsg.CtpMsg.Ident		= 0;		// not used

      if(IS_H110(Card,pNum)) {
       if(!Db.Card[Card].all_h110_cesop) // Aricent PR-947222
        ctp_timer_proc_t1card(Card, pNum);
        continue; // we don't process anything else but query status for h110 port
      }

      if( (SCC_CARD(Card)) &&		// scc ports only!
	  (pPortSt->Available)) {
	int	tt_freq_idx, sd_act_idx;
	int	SdActivity, PrevSdActivity, RdntOnline;
	int	StActivity, PrevStActivity;
	int	TtActivity, PrevTtActivity;
	int	RdntRemActive, PrevRdntRemActive;
	int	RdntLocActive, PrevRdntLocActive;
	int	RdntActive, PrevRdntActive;
        int     num; // Aricent PR 1356307 fix
        //Aricent PR 880784 fix
	if(IS_T1E1(Card) && ctp_bndl_type_wp(Card, pNum)) {
	  if(pDbP->State == CTP_DBSTATE_UP) ctp_timer_proc_t1card(Card, pNum);
	  ctp_timer_proc_wp_bert(Card, pNum);
	  continue;
	};
	SccNum = pPortSt->SccNum;
	sprintf(SccBuf,"scc%d",SccNum);
	//===== Processing when port is ACTIVE =====
	if((pDbP->State == CTP_DBSTATE_UP)&&
	    (pPortSt->Available)) { 
	  double tempTt = (double)Freq/((double)Acc*500.0);
	  //----- Get TT frequency measurement -----
	  PRTP(GN3,FPGA: Read Port TT freq and diag reg);
	  fpga_clr_fcfg();
	  //index = fpga_get_fcfg_cycle();
	  tt_freq_idx = fpga_get_fcfg_cycle();
	  fpga_get_port_freq(pNum);	// Tell FPGA to dump TT results
	  sd_act_idx = fpga_get_fcfg_cycle();
	  fpga_get_port_read_reg(pNum);	// Read diag_read register
	  fpga_send_fcfg(SccNum);
	  if(IS_T1E1(Card)) {
	    if(pDbP->DcardCfg1 & T1E1_MSK_E1) {
	      Freq = 2048000*2;
	    }else {
	      Freq = 1544000*2;
	    }
	    Acc = 4;
	    // No activity detects for T1E1 FPGA, so squelch inactivity alarms
	    pPortSt->SdActivity = PrevSdActivity = 1;
	    pPortSt->StActivity = PrevStActivity = 1;
	    pPortSt->TtActivity = PrevTtActivity = 1;
	  } else {
	    fpga_get_port_freq_val(tt_freq_idx,&Freq,&Acc);	// Now get results
	    fpga_get_port_sd_activity(sd_act_idx,&SdActivity);	// Now get results
	    fpga_get_port_st_activity(sd_act_idx,&StActivity);	// Now get results
	    fpga_get_port_tt_activity(sd_act_idx,&TtActivity);	// Now get results

	    PrevSdActivity = (int) pPortSt->SdActivity;
	    pPortSt->SdActivity = (u8)SdActivity;
    	    // Aricent PR 1173307 fix - Start
            if((IS_SER(Card)) && (!PBS(Card,pNum))) {
              if( (PrevSdActivity == 1) && (SdActivity == 0) ) {
                PRTP(MAJ,SD input (From IF) lost activity);
                // Aricent PR 1356307 fix - Start
                num = trap_number("TRAP_PT_SDINACTIVE");
                if (trap_bitmap & (1 << (num - 1))){
