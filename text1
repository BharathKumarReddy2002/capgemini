#PR-1846896 Start
sub read_file_contents {
    my ($file) = @_;
    open my $fh, '<', $file or return undef;
    local $/ = undef;
    my $content = <$fh>;
    close $fh;
    return $content;
}

sub write_file_contents {
    my ($file, $data) = @_;
    open my $fh, '>', $file or die "Cannot write $file: $!";
    print $fh $data;
    close $fh;
}

sub compute_config_checksum {
    my $snmpd_conf = read_file_contents($SNMPD_CONF) // '';
    my $var_snmp = read_file_contents($VAR_SNMP_FILE) // '';
    return sha1_hex($snmpd_conf . $var_snmp );
    #return sha1_hex($snmpd_conf . $var_snmp . $syscfg_output);
}

sub load_snmp_config_once {
    my $checksum = compute_config_checksum();
    my $reload = 1;

    if (-f $CACHE_FILE) {
        my $cache = read_file_contents($CACHE_FILE);
        if ($cache =~ /^checksum=(\w+)/m && $1 eq $checksum) {
            # Cache hit
            ($trap_comm) = ($cache =~ /^trap_comm=(.*)/m);
            ($trap_engine) = ($cache =~ /^trap_engine=(.*)/m);
            my ($host_str) = ($cache =~ /^trap_hosts=(.*)/m);
            my ($user_str) = ($cache =~ /^trap_user=(.*)/m);
            my ($pass_str) = ($cache =~ /^trap_pass=(.*)/m);

            ($IS_TRAP) = ($cache =~ /^is_trap=(\d+)/m);
            ($IS_V2) = ($cache =~ /^is_v2=(\d+)/m);
            ($IS_V3) = ($cache =~ /^is_v3=(\d+)/m);

	    my @host_arr = split /,/, $host_str;
	    my @user_arr = split /,/, $user_str;
	    my @pass_arr = split /,/, $pass_str;

	    for my $i (1 .. $MAX_SNMP_USERS) {
              $trap_user[$i]  = $user_arr[$i - 1] // "none";
              $trap_pass[$i]  = $pass_arr[$i - 1] // "none";
              $trap_hosts[$i] = $host_arr[$i - 1] // "none";
            }
            $reload = 0;
        }
    }

    if ($reload) {
        # Evaluate IS_* values
        $IS_TRAP = `$GREP "trapcommunity" $SNMPD_CONF | $GREP -v "#" | $WC -l | $AWK '{print \$1}'`;
        $IS_V3   = `$GREP "createUser" $SNMPD_CONF | $GREP -v "#" | $WC -l | $AWK '{print \$1}'`;
        $IS_V2   = `egrep '(rocommunity|rwcommunity)' $SNMPD_CONF | egrep -v "#" | $WC -l | $AWK '{print \$1}'`;
        chomp($IS_TRAP); chomp($IS_V3); chomp($IS_V2);

        # Defaults
        $trap_comm = "none";
        $trap_engine = "none";
        for ($index = 1; $index <= $MAX_SNMP_USERS; $index++) {
            $trap_hosts[$index] = "none";
            $trap_user[$index] = "none";
            $trap_pass[$index] = "none";
        }

        if (-f $SNMPD_CONF) {
            $trap_comm = `$GREP "^trapcommunity" $SNMPD_CONF | $AWK '{ print \$2 }' | tail -1`;
            chomp($trap_comm);
            $trap_comm = "none" if $trap_comm eq "";
        }

        if (-f $VAR_SNMP_FILE) {
            $trap_engine = `$GREP "^oldEngineID" $VAR_SNMP_FILE | $AWK '{ print \$2 }' | tail -1`;
            chomp($trap_engine);
            $trap_engine = "none" if $trap_engine eq "";
        }

        for ($index = 1; $index <= $MAX_SNMP_USERS; $index++) {
	    my $sink = `/acorn/perl/scripts/syscfg -r -u snmptrap -o sink$index 2>/dev/null`;
	    chomp($sink);	
	    $trap_hosts[$index] = ($sink ne '') ? $sink : 'none';
        }

        for ($index = 1; $index <= $MAX_SNMP_USERS; $index++) {
	    $user_string = `/acorn/perl/scripts/syscfg -r -u snmptrap -o user$index 2>/dev/null`;
    	    chomp($user_string);
            my ($u, $p) = (split / /, $user_string)[0, 1];
            $trap_user[$index] = $u // "none";
            $trap_pass[$index] = $p // "none";
        }

	# Ensure all indices are initialized to avoid warnings
	my @hosts = map { defined $trap_hosts[$_] ? $trap_hosts[$_] : "none" } (1 .. $MAX_SNMP_USERS);
	my @users = map { defined $trap_user[$_]  ? $trap_user[$_]  : "none" } (1 .. $MAX_SNMP_USERS);
	my @passw = map { defined $trap_pass[$_]  ? $trap_pass[$_]  : "none" } (1 .. $MAX_SNMP_USERS);

        # Write to cache
        my $cache_data = "checksum=$checksum\n";
        $cache_data .= "trap_comm=$trap_comm\n";
        $cache_data .= "trap_engine=$trap_engine\n";
	$cache_data .= "trap_hosts=" . join(",", grep { defined $_ } @trap_hosts) . "\n";
	$cache_data .= "trap_user="  . join(",", grep { defined $_ } @trap_user)  . "\n";
	$cache_data .= "trap_pass="  . join(",", grep { defined $_ } @trap_pass)  . "\n";
        $cache_data .= "is_trap=$IS_TRAP\n";
        $cache_data .= "is_v2=$IS_V2\n";
        $cache_data .= "is_v3=$IS_V3\n";
        write_file_contents($CACHE_FILE, $cache_data);
    }
}

