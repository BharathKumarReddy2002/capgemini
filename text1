sub get_sem
{
  my ( $sem, $label ) = @_;
  $sem->op(
      0, 0, 0,    # Wait till clear
      0, 1, SEM_UNDO # Take semaphore
      );
}

sub rel_sem
{
  my ( $sem, $label ) = @_;
  $sem->op(
      0, -1, IPC_NOWAIT # Release semaphore
      );
}

#**** useage: log_it(Level, "Message" ); ****
sub log_it
{
  my ( $level, $Message ) = @_;
  my $dt = localtime();
  my $host = `hostname`;
  chomp($host);
  if( $level < $LOG_LEVEL ) {
    get_sem ( $LOG_SEM, "LOG_SEM" );
    open (WRITETO, ">> $LOG_FILE");
    print WRITETO "$dt $host snmptrap: $Message\n";
    close (WRITETO);
    rel_sem ( $LOG_SEM, "LOG_SEM" );
  }
}

sub HostPingable
{
  my ($trap_host) = @_;
  my $ping_tries = 0;
  my $success = $NO;
  log_it(4, "HostPingable: function enter with trap host $trap_host.");
  while ( $ping_tries < $MAX_PING_TRIES ) {
    $ping_tries++;
    log_it(3, "HostPingable: Pinging $trap_host tries = $ping_tries of  $MAX_PING_TRIES");
    if ($trap_host =~ /(\d+)\.(\d+)\.(\d+)\.(\d+)/) {
      if ( `ping -c 1 -W 1 $trap_host > /dev/null && echo "SUCCESS"` =~ /SUCCESS/ ) {
        log_it(3, "HostPingable: Reached trap host $trap_host after $ping_tries attempt(s).");
        $success = $YES;
        $ping_tries = $MAX_PING_TRIES;    # Exit loop!
      }
    } else {
      if ( `ping -6 -c 1 -W 1 $trap_host > /dev/null && echo "SUCCESS"` =~ /SUCCESS/ ) {
        log_it(3, "HostPingable: Reached trap host $trap_host after $ping_tries attempt(s).");
        $success = $YES;
        $ping_tries = $MAX_PING_TRIES;    # Exit loop!
      }
    }
  }
  if ( $success == $NO ) {
    log_it(3, "HostPingable: Cound not ping trap host $trap_host in $ping_tries tries.");
  }
  return $success;
}



