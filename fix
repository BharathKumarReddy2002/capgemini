sub snmpdconf_set_add
{
  my $fn = (caller(0))[3]; fen($fn);
  my ($snmp, $num_cfgd_snmp) = @_ ;
  my (@choices);
  my $index = 1;
  my $found_mt_idx = 0;
  my ($sel);
  if($DEBUG){print "snmpdconf_set_add: Function Enter\n";}
  if($num_cfgd_snmp >= $MAX_SNMP_USERS) {
    print "$num_cfgd_snmp SNMP users are already configured on the system\n";
    print "deletion of a user is required prior to addition of a new one \n";
  } else {
    $num_cfgd_snmp++;
    # find the available slot in the snmp hash
    while( ($index<=$MAX_SNMP_USERS) && ($found_mt_idx==0) ) {
      if( $snmp->{$index}{used} eq "yes" ) { $index++; }
      else { $found_mt_idx++; }
    }
    if($DEBUG){print "Free hash index: $index\n"; }
    $snmp->{$index}{used} = "yes";
    #----
    @choices = ('SNMPv2','SNMPv3');
    $sel = ask_for_choice(\@choices,$#choices);
    $sel =~ /SNMPv(\d+)/;
    $snmp->{$index}{SNMPv} = $1;
    if($DEBUG){print "SNMPv: $snmp->{$index}{SNMPv}\n"; }
    #----
    if( $snmp->{$index}{SNMPv} == 2 ) {
      @choices = ('Read-Only','Read-Write');
      $sel = ask_for_choice(\@choices,$#choices);
      if( $sel =~ /Read-Only/ ) { $snmp->{$index}{rw} = "ro"; }
      else {                      $snmp->{$index}{rw} = "rw"; }
      if($DEBUG){print "rw: $snmp->{$index}{rw}\n"; }
      #----
      print "\nComm string may have character set from 0x21(!) to 0x7e(~), characters backtick (\`), single quote ('),comma(,),and double quote (\") are not allowed. \n"; #PR-1846890 
      $snmp->{$index}{comm} = ask_for_string("the SNMP Community String");
      if($DEBUG){print "comm: $snmp->{$index}{comm}\n"; }
    } else {
      $snmp->{$index}{rw} = "ro";
      #----
      print "\nSNMPv3 user string may have character set from 0x21(!) to 0x7e(~), characters backtick (\`), single quote ('),comma (,) and double quote (\") are not allowed.\n";#PR-1846890 
      $snmp->{$index}{user} = ask_for_string("the SNMPv3 User");
      if($DEBUG){print "user: $snmp->{$index}{user}\n"; }
      #----
      # UPDATED: Prompting for two separate passwords
      print "\nSNMPv3 passwords may have character set from 0x21(!) to 0x7e(~), characters backtick (\`), single quote ('), comma (,), and double quote (\") are not allowed. \n";#PR-1846890 
      print "SNMPv3 passwords length must be at least 8 chars\n"; 
      
      $snmp->{$index}{auth_pass} = ask_for_string("the SNMPv3 Auth password (SHA)");
      if($DEBUG){print "auth_pass: $snmp->{$index}{auth_pass}\n"; }

      $snmp->{$index}{priv_pass} = ask_for_string("the SNMPv3 Priv password (AES)");
      if($DEBUG){print "priv_pass: $snmp->{$index}{priv_pass}\n"; }
    }
    # Aricent PR 1362733 fix - Start
    @choices = ('IPv4','IPv6');
    $sel = ask_for_choice(\@choices,$#choices);
    $sel =~ /IPv(\d+)/;
    $snmp->{$index}{IPv} = $1;
    if($DEBUG){print "IPv: $snmp->{$index}{IPv}\n"; }
    #----
    if( $snmp->{$index}{IPv} == 4 ) {
      $sel = ask_for_ip("query IP (0.0.0.0 for any IP)", "0.0.0.0");
      if( $sel =~ /0\.0\.0\.0/ ) {
        if( $snmp->{$index}{SNMPv} == 2 ) {
          $snmp->{$index}{ip} = "default";
        } else {
          $snmp->{$index}{ip} = "";
        }
      } else { $snmp->{$index}{ip} = $sel; }
    } else {
      $sel = ask_for_ipv6_add("query IP (::0 for any IP)", "::0");
      if( $sel =~ /::0/ ) {
        if( $snmp->{$index}{SNMPv} == 2 ) {
          $snmp->{$index}{ip} = "default";
        } else {
          $snmp->{$index}{ip} = "";
        }
      } else { $snmp->{$index}{ip} = $sel; }
    }
    # Aricent PR 1362733 fix - End
  }
}

sub snmpdconf_write
{
  my $fn = (caller(0))[3]; fen($fn);
  my ($snmp) = @_ ;
  my ($index);
  my $tmp = "/tmp/foo";
  if($DEBUG){print "snmpdconf_write: Function Enter\n";}


  # Flush all the old configs from snmpd.conf file
  open( WRITE, "> $tmp" ) or return $NO_SUCH_FILE;
  open( READ, "< $SNMPDCONF" ) or return $NO_SUCH_FILE;
  while(<READ>) {
    if( ($_ =~ /rocommunity/) ||
    ($_ =~ /rwcommunity/) ||
    ($_ =~ /rouser/)      ||
    ($_ =~ /createUser/)  ||
    ($_ =~ /trapsess/)    ||  # ADDED: Flush old trapsess lines
    ($_ =~ /syslocation/) ||
    ($_ =~ /^pass/)       ||
    ($_ =~ /syscontact/) ) {
    chomp($_);
      if( $DEBUG ) { print "Deleting |$_| from file\n"; }
    } else {
      print WRITE "$_";
    }
  }

  # Add new configs to end of snmpd.conf file
  print WRITE "syslocation \"$snmp->{location}\"\n";
  print WRITE "syscontact  \"$snmp->{contact}\"\n";

  for($index=1;$index<=$MAX_SNMP_USERS;$index++) {
    if( $snmp->{$index}{used} eq "yes" ) {
      if( $DEBUG ) { print "Writing SNMPv"; }
      if( $snmp->{$index}{SNMPv} == 2 ) {
    if( $DEBUG ) { print "2 user # $index\n"; }
    print WRITE $snmp->{$index}{rw} . "community";
    if( $snmp->{$index}{IPv} == 6 ) { print WRITE "6 "; }
    else {                             print WRITE "  "; }
    print WRITE $snmp->{$index}{comm} . " ";
    if( $snmp->{ $index}{ip} eq "default") { print WRITE "default\n"; }
    else { print WRITE $snmp->{$index}{ip} . "\n"; }
      } else {      # SNMPv3
    if( $DEBUG ) { print "3 user # $index\n"; }
    print WRITE $snmp->{$index}{rw} . "user ";
    print WRITE $snmp->{$index}{user} . " priv\n";
    
    # UPDATED: Write createUser with both Auth and Priv passwords in quotes
    # Note: The IP at the end is maintained as a storage hack for the query IP filter
    print WRITE "createUser " . $snmp->{$index}{user};
    print WRITE " SHA \"" . $snmp->{$index}{auth_pass} . "\" AES \"" . $snmp->{$index}{priv_pass} . "\" ";
    print WRITE $snmp->{$index}{ip} . "\n"; 
      }
    }
  }
  print WRITE "pass .1.3.6.1.4.1.18841 /acorn/perl/scripts/snmpAcorn.pl\n";

  close( READ );
  close( WRITE );
  # Now copy the tmp file back to snmpdconf
  move $tmp, $SNMPDCONF;
  FLUSH_ETC();
}

