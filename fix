int ctpd_get_perl_mbox_user ( void * pParam1, void * pParam2, void * pParam3, char *pSuffix )
{
  int user_status;
  FILE *user_fp = NULL;
  char Buf[40], SysRmCmd[100];
  FUNC_PRT(ctpd_get_perl_mbox_user, PF_MISC, -1);

  sprintf(Buf,"%s/%s_%s",CTP_DIR,CTP_PERL_MBOX,pSuffix);
  sprintf(SysRmCmd,"/bin/rm %s",Buf);
  user_fp = fopen(Buf, "r");
  if(user_fp == NULL) {
    PRTS(MIN,Could not open file,Buf);
    *(int *)pParam1 = 0;                         // return NULL
    *(int *)pParam2 = 0;
    *(int *)pParam3 = 0;
    return(FAILURE);
  }
  user_status = fscanf(user_fp,"%s %s %s",(char *)pParam1, (char *)pParam2, (char *)pParam3);
  if(user_status != 3) {
    PRTS(MIN,Could not get string from file,Buf);
    fclose(user_fp);
    return(FAILURE);
  }
  fclose(user_fp);
  acorn_system(SysRmCmd);
  return(SUCCESS);
}
