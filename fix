sub snmpdconf_useage
{
  my $fn = (caller(0))[3]; fen($fn);
  print "\n";
  print "Usage: syscfg -s -u snmpdconf [-o interactive] [-v \':<token>:[<token>:]\']\n";
  print "  -o interactive option will ask the user for input (menu mode)\n";
  print "  -v strings begin and end with a \":\", and have one or more tokens\n";
  print "  Valid tokens are:\n";
  print "  CO,<string>  = Contact String.  Alphanum, -, _ or space\n";
  print "  LO,<string>  = Location String. Alphanum, -, _ or space\n";
  print "  STx  = Enable or disable SNMP daemon (1=enable,0=disable).\n";
  print "  USR,rw|ro,2,4|6,comm,ip,\n";
  print "\trw|ro - read/write or read-only snmp user\n";
  print "\t2     - SNMPv2 user (SNMPv1 also)\n";
  print "\t4|6   - IPv4 or IPv6 user\n";
  print "\tcomm  - community string may use character set in the range 0x21(!) to 0x7e(~)).\n";
  print "\t        Characters not allowed are: backtick(\`),single quote('),comma(,) and double quote(\").\n"; #PR-1846890
  print "\tip    - IP access for specific IP address, or \"default\" for any IP\n";
  print "\t      - IP (v4&v6) Subnet access is OK using CIDR notation\n";
  print "  USR,ro,3,user,auth_pass,priv_pass,ip,\n";
  print "\tro        - read-only snmp user\n";
  print "\t3         - SNMPv3 user\n";
  print "\tuser      - username may use character set in the range 0x21(!) to 0x7e(~).\n";
  print "\t            Characters not allowed are: backtick(\`),single quote('),comma(,) and double quote(\").\n"; #PR-1846890
  print "\tauth_pass - Authentication password (SHA) (must be at least 8 chars)\n";
  print "\tpriv_pass - Privacy password (AES) (must be at least 8 chars)\n";
  print "\t            Passwords may have character set from 0x21(!) to 0x7e(~).\n";                     
  print "\t            Characters not allowed are: backtick(\`),single quote('),comma(,) and double quote(\").\n";#PR-1846890
  print "\tip        - IP access for specific IP address, or \"default\" for any IP\n";
  print "\n  Notes:\n";
  print "\t- Leaving out CO and LO tokens will result in those fields being\n";
  print "\t  set to \"Unset\" in the config file\n";
  print "\t- Only USR tokens specified will exist on the system after config\n";
  print "\t  All previous SNMP users will be deleted\n";
  print "\n";
  print "Usage: syscfg -r -u snmpdconf \n";
  print "\tDumps current SNMP config in above -v format\n";
  exit $E_UNKNOWN;
}


sub snmpdconf_read
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $snmp, $opts ) = @_;
  if( $DEBUG ) { print "snmpdconf_read: Function Enter\n"; }
  my $num_cfgd_snmp = 0;
  my ($index, $p_err );
  # Initialize hash to all unused entries
  for($index=1;$index<=$MAX_SNMP_USERS;$index++) { 
    $snmp->{$index}{used} = "no"; }
  $snmp->{location} = "Unset";
  $snmp->{contact} = "Unset";
  $p_err = $OK;

  #----- Get config from file -----
  $index = 1;
  open(  READ, "< $SNMPDCONF" ) or return $NO_SUCH_FILE;
  while (<READ>) {
    # As of version 5.3.0.1, we use rwcommunity to setup v2c access
    # Format: rwcommunity <community name> [<ip>|default]
    # Note: default is equilavent to not specifying a server ip. In these
    # cases requests form ANY ip are serviced.
    if( $_ =~ /^(..)community6\s+(\S+)\s*(\S*)/ ) {
      if($DEBUG){print "snmpdconf_read: found IPv6 comm, USR $index\n"; }
      $snmp->{$index}{used}  = "yes";
      $snmp->{$index}{SNMPv} = 2;
      $snmp->{$index}{rw}    = $1;
      $snmp->{$index}{IPv}   = 6;
      $snmp->{$index}{comm}  = $2;
      $snmp->{$index}{ip}    = $3;
      $index++;
    } 
    elsif( $_ =~ /^(..)community\s+(\S+)\s*(\S*)/ ) {
      $snmp->{$index}{used}  = "yes";
      $snmp->{$index}{SNMPv} = 2;
      $snmp->{$index}{rw}    = $1;
      $snmp->{$index}{IPv}   = 4;
      $snmp->{$index}{comm}  = $2;
      $snmp->{$index}{ip}    = $3;
      $index++;
    } 
    # UPDATED REGEX: Captures user, auth_pass, priv_pass, and ip
    elsif( $_ =~ /^createUser\s+([!-~]+)\s+\w+\s+"([!-~]+)"\s+\w+\s+"([!-~]+)"\s+([!-~]*)/ ) { # Aricent PR 1362733 fix PR-1846890
      $snmp->{$index}{used} = "yes";
      $snmp->{$index}{SNMPv} = 3;
      $snmp->{$index}{user} = $1;
      $snmp->{$index}{auth_pass} = $2;
      $snmp->{$index}{priv_pass} = $3;
      # Aricent PR 1362733 fix - Start
      $snmp->{$index}{ip}   = $4;
      if($snmp->{$index}{ip} =~ /(\d+)\.(\d+)\.(\d+)\.(\d+)/) {
        $snmp->{$index}{IPv}   = 4;
      } else {
        $snmp->{$index}{IPv}   = 6;
      }
      # Aricent PR 1362733 fix - End
      $snmp->{$index}{rw} = "ro";   # only do read-only for now
      $index++;
    } 
    elsif( $_ =~ /^syslocation\s+\"(.+)\"/ ) {
      $snmp->{location} = $1;
    } elsif( $_ =~ /^syscontact\s+\"(.+)\"/ ) {
      $snmp->{contact} = $1;
    }
  }
  close ( READ );

  #----- Get daemon state -----
  $snmp->{state} = `$SELF -r -u daemon -o snmpd`; chomp($snmp->{state});
  $snmp->{state} =~ /ST(\d)/; $snmp->{state} = $1;
  if($DEBUG){print "snmpdconf_read: found state: $snmp->{state}\n"; }
  return $p_err;
}

sub snmpdconf_check
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $snmp, $opts ) = @_;
  if( $DEBUG ) { print "snmpdconf_check: Function Enter\n"; }
  my $num_cfgd_snmp = 0;
  my ($index, $p_err, $ipv4_hex, $ipv4_mask );
  $p_err = 0;
  
  #--- Check Location string
  if( $snmp->{location} !~ /^[=;\sA-Za-z0-9_-]+$/ ) {
    print "---> Bad chars in location string: $snmp->{location}, ";
    $snmp->{location} = "Unset";
    print "Setting to: $snmp->{location}\n";
    print "\tUsage: Only alphanumeric or the characters ; = - _ are allowed.\n";
  } else {
    #$snmp->{location} =~ s/\s+/_/; # change spaces to "_"
  }
  #--- Check Contact string
  if( $snmp->{contact} !~ /^[=;\sA-Za-z0-9_-]+$/ ) {
    print "---> Bad chars in contact string: $snmp->{contact}, ";
    $snmp->{contact} = "Unset";
    print "Setting to: $snmp->{contact}\n";
    print "\tUsage: Only alphanumeric or the characters ; = - _ are allowed.\n";
  } else {
    #$snmp->{contact} =~ s/\s+/_/;  # change spaces to "_"
  }

  for($index=1;$index<=$MAX_SNMP_USERS;$index++) { 
    if( $snmp->{$index}{used} eq "yes" ) {
      if($DEBUG){print "Found USR at index $index\n"; }
      #--- SNMPv2 ---
      if( $snmp->{$index}{SNMPv} == 2 ) {
    if( ($snmp->{$index}{rw} ne "ro" ) && 
        ($snmp->{$index}{rw} ne "rw" ) ) {
      $p_err++; 
      print "---> bad SNMPv: $snmp->{$index}{rw}\n"; 
    }
    #--- SNMPv2 Community ---
    if($DEBUG){print "Checking comm string: $snmp->{$index}{comm}\n";}
    if( $snmp->{$index}{comm} !~ /^[\!\#\@A-Za-z0-9_\-\?^&\{}\[\]%~=\$|\/<>:;.+*(\)\\]+$/ ) { #PR-1846890
      $p_err++; print "---> Bad chars in comm string: $snmp->{$index}{comm}\n";
    }
      }
      #--- SNMPv3 ---
      elsif( $snmp->{$index}{SNMPv} == 3 ) {
        if( $snmp->{$index}{user} !~ /^[\!\#\@A-Za-z0-9_\-\?^&\{}\[\]%~=\$|\/<>:;.+*(\)\\]+$/ ) { #PR-1846890
          $p_err++; print "---> Bad chars in user string: $snmp->{$index}{user}\n";
        }
        
        # Check Auth Password
        if( $snmp->{$index}{auth_pass} !~ /^[\!\#\@A-Za-z0-9_\-\?^&\{}\[\]%~=\$|\/<>:;.+*(\)\\]+$/ ) { #PR-1846890
          $p_err++; print "---> Bad chars in auth_pass string: $snmp->{$index}{auth_pass}\n";
        }
        if( length($snmp->{$index}{auth_pass}) < 8 ) {
          $p_err++; print "---> Auth Passwd length is less than 8 chars\n"; 
          if($DEBUG){print "auth_pass length: %d\n", length($snmp->{$index}{auth_pass}); }
        }

        # Check Priv Password
        if( $snmp->{$index}{priv_pass} !~ /^[\!\#\@A-Za-z0-9_\-\?^&\{}\[\]%~=\$|\/<>:;.+*(\)\\]+$/ ) { #PR-1846890
          $p_err++; print "---> Bad chars in priv_pass string: $snmp->{$index}{priv_pass}\n";
        }
        if( length($snmp->{$index}{priv_pass}) < 8 ) {
          $p_err++; print "---> Priv Passwd length is less than 8 chars\n"; 
          if($DEBUG){print "priv_pass length: %d\n", length($snmp->{$index}{priv_pass}); }
        }
      }
      else {
        $p_err++;
        print "---> bad SNMPv: $snmp->{$index}{SNMPv}\n";
      }
      # Aricent PR 1362733 fix - Start
      if( ($snmp->{$index}{SNMPv} == 2) || ($snmp->{$index}{SNMPv} == 3) ) {
        #--- SNMPv2/v3 IPv4 ---
        if( $snmp->{$index}{IPv} == 4 ) {
          if( ($snmp->{$index}{ip} ne "default") && ($snmp->{$index}{ip} ne "")) {
            if( $snmp->{$index}{ip} =~ /$IPV4ADDFORMAT\/(\d+)/ ) {
              $o1=$1; $o2=$2; $o3=$3; $o4=$4;
              $snmp->{$index}{ip_bits} = $5;
            } elsif( $snmp->{$index}{ip} =~ /$IPV4ADDFORMAT/ ) {
              $o1=$1; $o2=$2; $o3=$3; $o4=$4;
              $snmp->{$index}{ip_bits} = 32;
            } else {
              $p_err++;
              print "---> Bad IP address format: $snmp->{$index}{ip}\n";
              $ipv4_hex = 0; $ipv4_mask = 0;
              $o1=$o2=$o3=$o4=0;
              $snmp->{$index}{ip_bits} = 32;
            }
            $ipv4_hex = ($o1<<24)+($o2<<16)+($o3<<8)+$o4;
            if($DEBUG){print "ip_bits:  $snmp->{$index}{ip_bits}\n"; }
            if( $snmp->{$index}{ip_bits} == 32 ) {
              $ipv4_mask = 0xffffffff;
            } else {
              $ipv4_mask = (1 << $snmp->{$index}{ip_bits}) - 1;
              $ipv4_mask = $ipv4_mask << (32 - $snmp->{$index}{ip_bits});
            }
            if($DEBUG){printf("ipv4_hex:  0x%x\n",$ipv4_hex); }
            if($DEBUG){printf("ipv4_mask: 0x%x\n",$ipv4_mask); }
            my $not_mask = 0xffffffff ^ $ipv4_mask;
            if($DEBUG){printf("not_mask: 0x%x\n",$not_mask); }
            if( $ipv4_hex & $not_mask ) {
              $p_err++;
              print "---> Improper CIDR format: $snmp->{$index}{ip}\n";
            }
          } elsif( ($snmp->{$index}{ip} eq "default") || ($snmp->{$index}{ip} eq "")) {
            if($DEBUG){print "IPv4 address set to default"; }
          } else {
            $p_err++;
            print "---> Bad IPv4 address string: $snmp->{$index}{ip}\n";
          }
        }
        #--- SNMPv2/v3 IPv6 ---
        elsif( $snmp->{$index}{IPv} == 6 ) { 
          if( ($snmp->{$index}{ip} ne "default") && ($snmp->{$index}{ip} ne "")) {
            if( $snmp->{$index}{ip} =~ /$IPV6ADDFORMAT\/(\d+)/ ) {
              $snmp->{$index}{ip_bits} = $1;
            } elsif( $snmp->{$index}{ip} =~ /$IPV6ADDFORMAT/ ) {
              $snmp->{$index}{ip_bits} = 32;
            } else {
              $p_err++; print "---> Bad IP address format: $snmp->{$index}{ip}\n";
            }
          } elsif( ($snmp->{$index}{ip} eq "default") || ($snmp->{$index}{ip} eq "")) {
            if($DEBUG){print "IPv6 address set to default"; }
          } else {
            $p_err++;
            print "---> Bad IPv6 address string: $snmp->{$index}{ip}\n";
          }
        }
        #--- SNMPv2/v3 IPv? ---
        else {
          $p_err++;
          print "---> Bad IPv: $snmp->{$index}{IPv}\n";
        }
      }
      # Aricent PR 1362733 fix - End

      if($p_err) { 
    print "===> Errors found during check: Deleting SNMP user\n"; 
        $snmp->{$index}{used} = "no"; 
    $p_err = $OK;   # reset the error counter
      }
    } 
  }

  return $p_err;
}

sub snmpdconf_set
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $snmp, $opts, $string ) = @_;
  # Aricent PR 1255040 fix - Start
