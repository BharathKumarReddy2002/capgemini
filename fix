      chop ( $rtn = <STDIN> );
      if ( $rtn =~ /add/ ) {
    snmpdconf_set_add($snmp, $cnt);
    snmpdconf_check($snmp, $opts);
      } elsif ( $rtn =~ /del/ ) {
    if($cnt == 0) { print "Sorry, but there are no SNMP users configured\n" }
    else { snmpdconf_set_del($snmp, $cnt); }
      }
      print "\n\n";
    }
    if( $cnt ) { $snmp->{state} = 1; }  # users exist, so enable daemon
    else       { $snmp->{state} = 0; }
  } 
  #=========== Non-Interactive (from string) ============
  else {
    my $index;
    my $p_err = 0;
# Initialize hash to all unused entries
    for($index=1;$index<=$MAX_SNMP_USERS;$index++) { 
      $snmp->{$index}{used} = "no"; }
    $snmp->{location} = "Unset";
    $snmp->{contact} = "Unset";
    $index = 1;

    while( ($string ne ":") && ($p_err == 0) ) {
      if($DEBUG){print STDOUT "---> String to parse: \"$string\"\n";}
      #--- LO token
      if( $string =~ s/^:LO,([^:]+):/:/ )  { 
    $snmp->{location} = $1;
    if($DEBUG){print STDOUT "---> location: \"$1\"\n";}
      }
      #--- CO token
      elsif( $string =~ s/^:CO,([^:]+):/:/ )  { 
    $snmp->{contact} = $1;
    if($DEBUG){print STDOUT "---> contact: \"$1\"\n";}
      }
      #--- ST token
      elsif( $string =~ s/^:ST(\d+):/:/ )      { $snmp->{state} = $1; }
      #--- USR token
      elsif( $string =~ /^:USR,(r[ow]),([23]),/ ) { 
    if( $string =~ s/^:USR,(r[ow]),2,([^,]+),([^,]+),([^,]+),:/:/ ) { 
      if( $DEBUG ) { print "Found SNMPv2 user # $index\n"; }
      $snmp->{$index}{used}  = "yes";
      $snmp->{$index}{rw}    = $1;
      $snmp->{$index}{SNMPv} = 2;
      $snmp->{$index}{IPv}   = $2;
      $snmp->{$index}{comm}  = $3;
      $snmp->{$index}{ip}    = $4;
      # This is the place to do some checking...
      # (IP format or password strength)
      if( $DEBUG ) { 
        print "Parsed from string:\n";
        print "used  : $snmp->{$index}{used}\n";
        print "rw    : $snmp->{$index}{rw}\n";
        print "SNMPv : $snmp->{$index}{SNMPv}\n";
        print "IPv   : $snmp->{$index}{IPv}\n";
        print "comm  : $snmp->{$index}{comm}\n";
        print "ip    : $snmp->{$index}{ip}\n";
      }
      $index++;
    }
    # UPDATED REGEX: Now expects 6 extra fields instead of 5
    elsif( $string =~ s/^:USR,(r[ow]),3,([^,]+),([^,]+),([^,]+),([^,]+),([^,]+),:/:/ ) {    # Aricent PR 1362733 fix 
      if( $DEBUG ) { print "Found SNMPv3 user # $index\n"; }
      $snmp->{$index}{used}      = "yes";
      $snmp->{$index}{rw}        = $1;
      $snmp->{$index}{SNMPv}     = 3;
      $snmp->{$index}{user}      = $2;
      $snmp->{$index}{auth_pass} = $3;
      $snmp->{$index}{priv_pass} = $4;
          # Aricent PR 1362733 fix - Start
          $snmp->{$index}{IPv}   = $5;
          $snmp->{$index}{ip}    = $6;
          # Aricent PR 1362733 fix - End
      if( $DEBUG ) { 
        print "Parsed from string:\n";
        print "used      : $snmp->{$index}{used}\n";
        print "rw        : $snmp->{$index}{rw}\n";
        print "SNMPv     : $snmp->{$index}{SNMPv}\n";
        print "user      : $snmp->{$index}{user}\n";
        print "auth_pass : $snmp->{$index}{auth_pass}\n";
        print "priv_pass : $snmp->{$index}{priv_pass}\n";
        print "IPv       : $snmp->{$index}{IPv}\n";
        print "ip        : $snmp->{$index}{ip}\n";    # Aricent PR 1362733 fix
      }
      $index++;
    } else { $p_err++; print "Couldn't parse USR token\n"; }
      }
      # Aricent PR 1255040 fix - Start
      #--- SNMPv3 Engine ID Token
      elsif( $string =~ s/^:SNMPv3_EID,([^:]+):/:/ )  {
        $engine_id = $1;
       # Aricent PR 1323213 fix - Start
        if ( $engine_id !~ /^[\w\.]+$/ ) {
                print "Only alphanumerics or \"_\" or \".\" allowed in engineId!!\n";
                exit(-1);
           }
        # Aricent PR 1323213 fix - End
        if ( $tmp =~ /0/ ) {
          `echo "engineID $engine_id" >> $SNMPDCONF`;
        } else {
          `$SED -i '/^[ ]*engineID/ cengineID $engine_id' $SNMPDCONF`;
        }
        $snmp_usm = 1;
      }
      # Aricent PR 1255040 fix - End
      #--- default token
      else { $p_err++; print "rw or SNMPv fields not right\n"; }
    }
    #if ( $p_err ) { snmpdconf_useage(); }
    if ( $p_err ) { exit(-1); }
  }
}

sub snmpdconf_stop_start
{
  my $fn = (caller(0))[3]; fen($fn);
  my ( $snmp ) = @_;
  my $rtn;
  my ($stop_request, $start_request);
  if($DEBUG){print "snmpdconf_stop_start: Function Enter\n";}

  my $curr_state = `$SELF -r -u daemon -o snmpd`; chomp($curr_state);
  $curr_state =~ /ST(\d+)/; $curr_state = $1;   # extract number

  if( $DEBUG ) { print "curr_state $curr_state\n"; }
  if( $DEBUG ) { print "new state $snmp->{state}\n"; }

  if ( ($curr_state == 1) && ($snmp->{state} == 1) ) {
    # We have reconfigured, want a restart to pickup cfg changes.
    if( $DEBUG ) { print "Got restart request!\n"; }
    $stop_request = 1; $start_request = 1;
  } elsif ( ($curr_state == 0) && ($snmp->{state} == 1) ) {
    if( $DEBUG ) { print "Daemon start request\n"; }
    $stop_request = 0; $start_request = 1;
  } elsif ( ($curr_state == 1) && ($snmp->{state} == 0) ) {
    if( $DEBUG ) { print "Daemon stop request\n"; }
    $stop_request = 1; $start_request = 0;
  } else {
    if( $DEBUG ) { print "Request to leave deamon not running\n"; }
    $stop_request = 0; $start_request = 0;
  }

  if( $stop_request ) {
    $rtn = daemon_cfg( "0", "snmpd", "ST0" );
    if( "$rtn" ne "$OK" ) {
      if( $DEBUG ) { print "Problem stopping daemon.\n"; }
      return $rtn;
    }
  }
  # Aricent PR 1255040 fix - Start
  if( $snmp_usm ) {
    if ( !-f $VAR_SNMPDCONF ) { #Aricent PR 1604917 fix
       system("/etc/init.d/snmpd start");
     } 
    `$SED -i -e '/^[ ]*usmUser/d' $VAR_SNMPDCONF`;
    $snmp_usm = 0;
    #Aricent PR 1604917 fix
  }
  # Aricent PR 1255040 fix - End
  # Aricent PR 1362733 fix - Start
  for(my $index=1;$index<=$MAX_SNMP_USERS;$index++) {
    if( ($snmp->{$index}{used} eq "yes") && ($snmp->{$index}{SNMPv} == 3) ) {
      if ( -f $VAR_SNMPDCONF ){#Aricent PR 1604917 fix
    # UPDATED LINE: Uses auth_pass for SHA and priv_pass for AES
    `/bin/echo "createUser $snmp->{$index}{user} SHA \\"$snmp->{$index}{auth_pass}\\" AES \\"$snmp->{$index}{priv_pass}\\"" >> $VAR_SNMPDCONF`;      
      }#Aricent PR 1604917 fix    
    } 
  }
  # Aricent PR 1362733 fix - End
  if( $start_request ) {
    $rtn = daemon_cfg( "0", "snmpd", "ST1" );
    if( "$rtn" ne "$OK" ) {
      if( $DEBUG ) { print "Problem setting snmp state.\n"; }
      return $rtn;
    }
  }
  `echo 1 > /acorn/tmp/snmp_cfg`;
  system("/acorn/perl/scripts/trap_clock.pl set 2>/dev/null"); #PR-1846896 
  return $OK;
}

