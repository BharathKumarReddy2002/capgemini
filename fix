    PRTS(GEN,Got Trap Priv Pass,Ctp.Snmp.TrapPrivPass[num_user-1]);
  } while( (strcmp(Ctp.Snmp.TrapUser[num_user-1],"none") != 0) && (num_user <= CTP_MAX_TRAP_HOSTS) );
  // Aricent PR 1362733 fix - End

  if( (strcmp(&Ctp.Snmp.TrapComm[0],"none") != 0 ) &&
      (strcmp(&Ctp.Snmp.TrapHost[0][0],"none") != 0 ) ) {
    Ctp.Snmp.TrapAble = 1;
    PRT(EVE,SNMP traps enabled);
    // Aricent PR 1362733 fix - Start
    if(strcmp(&Ctp.Snmp.TrapUser[0][0],"none") != 0 ) {
      Ctp.Snmp.TrapType = 3;
    } else {
      Ctp.Snmp.TrapType = 0;
    }
    // Aricent PR 1362733 fix - End
  } else {
    Ctp.Snmp.TrapAble = 0;
    PRT(EVE,SNMP traps disabled);
    Ctp.Snmp.TrapType = 0;    // Aricent PR 1362733 fix
  }
  return(RetStat);
}
