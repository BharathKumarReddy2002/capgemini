sub snmptrap_useage
{
  my $fn = (caller(0))[3]; fen($fn);
  print "\n";
  print "Usage: syscfg -s -u snmptrap [-o interactive] [-v \':<token>:[<token>:][<token>:]\']\n";
  print "  -o interactive option will ask the user for input (menu mode)\n";
  print "  -v strings begin and end with a \":\", and have one or more tokens\n";
  print "  Valid tokens are:\n";
  print "  STx    x = Enable or disable SNMP traps (1=enable,0=disable).\n";
  print "  TRx    x = SNMP trap community string (for SNMPv2c).\n";
  print "             community string may use character set in the range 0x21(!) to 0x7e(~)).\n";
  print "             Characters not allowed are: backtick(\`),single quote('),comma(,),colon(:) and double quote(\").\n"; #PR-1846890
  print "  IP,x,  x = trap host IP (IPv4 or IPv6 format)\n";
  print "\n  Notes:\n";
  print "\t- Leaving out TR token will set it to \"none\".\n";
  print "\t- Configured IP hosts will receive both SNMPv2c and encrypted SNMPv3 traps.\n"; # Added for clarity
  print "\n";
  print "Usage: syscfg -r -u snmptrap \n";
  print "\tDumps current SNMP trap config in above -v format\n";
  exit $E_UNKNOWN;
}

